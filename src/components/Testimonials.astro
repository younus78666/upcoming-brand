---
const testimonials = [
  {
    featured: true,
    stars: 5,
    quote: "We'd tried two other agencies before Upcoming Brand. Both disappeared after launch and left us with a site that took 12 seconds to load. Upcoming Brand delivered in 7 weeks, hit 91 on PageSpeed, and we've been ranking page one for three of our practice areas ever since.",
    initials: "MR",
    name: "Maya Rodriguez",
    title: "Managing Partner",
    company: "Meridian Law",
    city: "Baltimore",
  },
  {
    featured: false,
    stars: 5,
    quote: "The fixed-scope proposal was the first thing that impressed me — I knew exactly what I was getting and for how much. The site launched on time and new patient bookings from the website went from 4 a month to 19 a month within 90 days.",
    initials: "DC",
    name: "Dr. Chen",
    title: "Owner",
    company: "Chesapeake Dental",
    city: "Annapolis",
  },
  {
    featured: false,
    stars: 5,
    quote: "I was paying $350/month to another company for 'SEO' and ranking nowhere. Upcoming Brand rebuilt the site in 5 weeks, set up proper schema, and I started getting Google Local Pack calls within 6 weeks. Worth every dollar.",
    initials: "JW",
    name: "James Whitfield",
    title: "Owner",
    company: "Whitfield HVAC",
    city: "Frederick",
  },
];
---
<section class="testi-section section-pad" id="testimonials">
  <div class="container">
    <div class="testi-intro">
      <p class="eyebrow">What clients say</p>
      <h2 class="h2-section">Real feedback from Maryland business owners</h2>
    </div>

    <div class="testi-grid">
      {testimonials.map((t) => (
        <blockquote class={`testi-card ${t.featured ? 'testi-card-featured' : ''}`}>
          {t.featured && <span class="testi-big-quote" aria-hidden="true">&ldquo;</span>}
          <div class="testi-stars" aria-label={`${t.stars} out of 5 stars`} role="img">
            &#9733;&#9733;&#9733;&#9733;&#9733;
          </div>
          <p class="testi-quote">{t.quote}</p>
          <footer class="testi-footer">
            <div class="testi-avatar" aria-hidden="true">
              {t.initials}
            </div>
            <div class="testi-author">
              <cite class="testi-name">{t.name}</cite>
              <span class="testi-role mono-xs">{t.title} &middot; {t.company}, {t.city}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testi-section {
    background: var(--cream-soft);
  }

  .testi-intro {
    margin-bottom: 40px;
  }

  .testi-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 20px;
    align-items: stretch;
  }

  .testi-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 32px;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }

  .testi-card:hover {
    box-shadow: var(--shadow-md);
  }

  .testi-card-featured {
    background: var(--ink);
    color: var(--cream);
    border-color: rgba(244,239,230,0.1);
  }

  .testi-big-quote {
    position: absolute;
    top: 20px;
    left: 28px;
    font-family: var(--f-display);
    font-size: 80px;
    line-height: 1;
    color: var(--amber);
    opacity: 0.6;
    font-weight: 300;
    pointer-events: none;
    user-select: none;
  }

  .testi-card-featured {
    position: relative;
  }

  .testi-stars {
    color: var(--amber);
    font-size: 16px;
    letter-spacing: 2px;
  }

  .testi-quote {
    font-size: clamp(14px, 1.4vw, 17px);
    line-height: 1.65;
    flex: 1;
    font-style: italic;
  }

  .testi-card-featured .testi-quote {
    color: rgba(244,239,230,0.85);
  }

  .testi-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    margin-top: auto;
  }

  .testi-card-featured .testi-footer {
    border-color: rgba(244,239,230,0.1);
  }

  .testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--f-display);
    font-size: 14px;
    font-weight: 400;
    flex-shrink: 0;
  }

  .testi-card-featured .testi-avatar {
    background: rgba(212,147,46,0.2);
    color: var(--amber);
  }

  .testi-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testi-name {
    font-style: normal;
    font-weight: 600;
    font-size: 14px;
  }

  .testi-role {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
    font-size: 11px;
  }

  .testi-card-featured .testi-role {
    color: rgba(244,239,230,0.45);
  }

  @media (max-width: 1000px) {
    .testi-grid {
      grid-template-columns: 1fr 1fr;
    }

    .testi-card-featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .testi-grid {
      grid-template-columns: 1fr;
    }

    .testi-card-featured {
      grid-column: span 1;
    }
  }
</style>
