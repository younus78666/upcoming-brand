---
<section class="industries-section section-pad" id="industries">
  <div class="container">

    <div class="industries-intro">
      <p class="eyebrow ind-eyebrow">Who we build for</p>
      <h2 class="h2-section">WordPress web design for Maryland's most competitive service industries</h2>
      <p class="lead">
        Every industry has different conversion patterns, compliance requirements, and trust signals. We've built enough sites in each vertical to know the pitfalls before you hit them.
      </p>
    </div>

    <div class="ind-grid" role="list">
      {industries.map((ind) => (
        <a href={ind.href} class="ind-card" role="listitem">
          <div class="ind-card-top">
            <div class="ind-icon" aria-hidden="true" set:html={ind.icon} />
            <span class="ind-num mono-xs">{ind.num}</span>
          </div>
          <h3 class="ind-name">{ind.name}</h3>
          <p class="ind-note mono-xs">{ind.note}</p>
          <div class="ind-tags" aria-hidden="true">
            {ind.tags.map((t) => (
              <span class="ind-tag">{t}</span>
            ))}
          </div>
          <span class="ind-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .industries-section {
    background: var(--paper);
  }

  /* ── INTRO ── */
  .industries-intro {
    max-width: 640px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .ind-eyebrow {
    justify-content: center;
  }

  /* ── GRID ── */
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  /* ── CARD ── */
  .ind-card {
    background: var(--cream-soft);
    border: 1.5px solid rgba(15,20,25,0.07);
    border-top: 3px solid transparent;
    border-radius: var(--radius-md);
    padding: 28px 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 10px rgba(15,20,25,0.05);
    transition: transform var(--transition), box-shadow var(--transition), border-top-color var(--transition), background var(--transition);
    position: relative;
  }

  .ind-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15,20,25,0.11);
    border-top-color: var(--amber);
    background: var(--paper);
  }

  /* ── TOP ROW ── */
  .ind-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  /* ── ICON ── */
  .ind-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: rgba(212,147,46,0.1);
    border: 1px solid rgba(212,147,46,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber);
    flex-shrink: 0;
  }

  /* ── NUMBER ── */
  .ind-num {
    color: var(--amber);
    font-size: 10px;
    letter-spacing: 0.1em;
    opacity: 0.65;
    padding-top: 2px;
  }

  /* ── NAME ── */
  .ind-name {
    font-family: var(--f-display);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
    transition: color var(--transition);
  }

  .ind-card:hover .ind-name {
    color: var(--amber-deep);
  }

  /* ── NOTE ── */
  .ind-note {
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  /* ── TAGS ── */
  .ind-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
    flex: 1;
    align-content: flex-start;
  }

  .ind-tag {
    font-family: var(--f-mono);
    font-size: 10px;
    padding: 3px 8px;
    background: rgba(15,20,25,0.05);
    border: 1px solid rgba(15,20,25,0.08);
    border-radius: var(--radius-pill);
    color: var(--ink-muted);
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .ind-card:hover .ind-tag {
    background: rgba(212,147,46,0.07);
    border-color: rgba(212,147,46,0.2);
    color: var(--amber-deep);
  }

  /* ── ARROW ── */
  .ind-arrow {
    display: flex;
    align-items: center;
    color: var(--amber);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition), transform var(--transition);
    margin-top: 6px;
  }

  .ind-card:hover .ind-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .ind-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .ind-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .ind-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
