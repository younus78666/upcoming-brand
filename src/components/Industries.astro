    note: "Multi-location · patient portals",
    tags: ["Patient portal", "HIPAA forms", "Provider bios"],
    href: "/industries/medical-website-design/",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
    </svg>`,
  },
  {
    num: "04",
    name: "Real Estate Brokerages",
    note: "IDX integration · agent rosters",
    tags: ["IDX / MLS sync", "Agent profiles", "Neighborhood pages"],
    href: "/industries/real-estate-website-design/",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
      <path d="M9 22V12h6v10"/>
    </svg>`,
  },
  {
    num: "05",
    name: "Nonprofits & Churches",
    note: "Donations · events · volunteers",
    tags: ["Donation forms", "Event calendar", "Volunteer signup"],
    href: "/industries/nonprofit-website-design/",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
    </svg>`,
