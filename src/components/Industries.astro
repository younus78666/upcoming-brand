---
const industries = [
  { num: "01", name: "Law Firms & Attorneys",      note: "Baltimore · Annapolis · DC metro",   href: "/industries/law-firm-website-design/" },
  { num: "02", name: "Dental Practices",            note: "HIPAA-aware · online booking",       href: "/industries/dental-website-design/" },
  { num: "03", name: "Medical Clinics",             note: "Multi-location · patient portals",   href: "/industries/medical-website-design/" },
  { num: "04", name: "Real Estate Brokerages",      note: "IDX integration · agent rosters",    href: "/industries/real-estate-website-design/" },
  { num: "05", name: "Nonprofits & Churches",       note: "Donations · events · volunteers",    href: "/industries/nonprofit-website-design/" },
  { num: "06", name: "Contractors & Trades",        note: "HVAC · plumbing · roofing",          href: "/industries/contractor-website-design/" },
  { num: "07", name: "Restaurants & Hospitality",   note: "Menus · reservations · POS",         href: "/industries/restaurant-website-design/" },
  { num: "08", name: "Small Business & Startups",   note: "From MVP to scale-ready",            href: "/industries/small-business-website-design/" },
];
---
<section class="industries-section section-pad" id="industries">
  <div class="container">
    <div class="industries-intro">
      <p class="eyebrow">Industries we specialize in</p>
      <h2 class="h2-section">Which Maryland industries do you build WordPress websites for?</h2>
      <p class="lead">
        We build WordPress websites for 10 Maryland industries — law firms, dental practices, medical clinics, real estate, nonprofits, contractors, restaurants, and small businesses.
      </p>
      <p class="ind-sub">We've built enough sites in each vertical to know the pitfalls before you hit them — the HIPAA gotchas, the IDX quirks, the donation plugin that breaks every 3 months.</p>
    </div>

    <div class="ind-list" role="list">
      {industries.map((ind) => (
        <a href={ind.href} class="ind-row" role="listitem">
          <span class="ind-num">{ind.num}</span>
          <span class="ind-name">{ind.name}</span>
          <span class="ind-note">{ind.note}</span>
          <span class="ind-arrow" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .industries-section {
    background: var(--cream-soft);
  }

  .industries-intro {
    max-width: 640px;
    margin-bottom: 56px;
  }

  .ind-sub {
    font-size: 15px;
    color: var(--ink-muted);
    margin-top: 16px;
    line-height: 1.6;
  }

  .ind-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line-strong);
  }

  .ind-row {
    display: grid;
    grid-template-columns: 56px 1fr auto auto;
    align-items: center;
    gap: 0;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    border-left: 3px solid transparent;
    padding-left: 16px;
    margin-left: -16px;
    transition: background var(--transition), border-left-color var(--transition);
  }

  .ind-row:hover {
    background: rgba(212, 147, 46, 0.04);
    border-left-color: var(--amber);
  }

  .ind-num {
    font-family: var(--f-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--amber-deep);
    font-weight: 500;
  }

  .ind-name {
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    transition: color var(--transition);
  }

  .ind-row:hover .ind-name {
    color: var(--amber-deep);
  }

  .ind-note {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-align: right;
    padding-right: 24px;
  }

  .ind-arrow {
    font-size: 16px;
    color: transparent;
    transition: color var(--transition), transform var(--transition);
    flex-shrink: 0;
  }

  .ind-row:hover .ind-arrow {
    color: var(--amber-deep);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .ind-row {
      grid-template-columns: 44px 1fr auto;
    }
    .ind-note { display: none; }
  }

  @media (max-width: 480px) {
    .ind-name { font-size: 16px; }
  }
</style>
