    note: "Baltimore · Annapolis · DC metro",
    tags: ["Intake forms", "Practice area pages", "Local SEO"],
    href: "/industries/law-firm-website-design/",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3v18M8 7l-4 9h8L8 7zM16 7l-4 9h8L16 7z"/>
      <path d="M4 20h16"/>
    </svg>`,
  },
  {
    num: "02",
    name: "Dental Practices",
    note: "HIPAA-aware · online booking",
    tags: ["Appointment booking", "Insurance info", "Multi-location"],
    href: "/industries/dental-website-design/",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2C9 2 6 4.5 6 7.5c0 1.5.5 3 1 4.5L8 18c.5 2 1.5 4 4 4s3.5-2 4-4l1-6c.5-1.5 1-3 1-4.5C18 4.5 15 2 12 2z"/>
