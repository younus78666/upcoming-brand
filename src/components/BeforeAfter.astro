---
const proofStats = [
  { before: "34", after: "94", label: "Mobile PageSpeed" },
  { before: "Pg 3", after: "Pg 1", label: "Google Rankings" },
  { before: "2/mo", after: "18/mo", label: "Leads from web" },
];

const before = [
  "PageSpeed score: 34 on mobile — Core Web Vitals all failing in Search Console",
  "Google ranking: page 3 for the brand name; nowhere for service keywords",
  "Contact form: broken on iOS Safari — no one noticed for 6 months",
  "Last plugin update: 14 months ago; security vulnerabilities unpatched",
  "Agency went silent after launch — support tickets sit unanswered for 10 days",
  "Schema markup missing or installed incorrectly on every page",
  "No topical architecture — Google can't figure out what the site is about",
  "Mobile layout breaks on iPhone 14; nobody tested it before launch",
];

const after = [
  "PageSpeed score: 94 on mobile — LCP under 2s, all three Core Web Vitals green",
  "Page 1 rankings for 11 target keywords within 6 months of launch",
  "Contact form: works on every device and browser — tested at every breakpoint",
  "Weekly WordPress core and plugin updates; zero unpatched vulnerabilities",
  "4-hour response SLA on care plan — direct access to the founder, not a ticket queue",
  "JSON-LD schema for every page type: Organization, Service, FAQ, BreadcrumbList",
  "30-page topical map — 20–40 targeted keywords reaching top-10 within 9 months",
  "Mobile-first build tested across iPhone, Android, and tablet before launch day",
];
---

<section class="ba-section section-pad" id="why-us">


  <div class="container">

    <div class="ba-intro">
      <p class="eyebrow">The difference a proper build makes</p>
      <h2 class="h2-section">Same industry. Same city. Completely different results.</h2>
      <p class="lead">
        Every Maryland business deserves a website that actually works — one that loads fast, ranks for the searches that matter, and turns visitors into booked appointments or signed contracts. Here's what that looks like in practice.
      </p>
    </div>

    <div class="ba-grid">

      <!-- Before Panel -->
      <div class="ba-panel ba-before">
        <div class="ba-panel-header">
          <span class="ba-badge ba-badge-before mono-xs">Before &middot; Template shop</span>
          <h3 class="ba-panel-title">The symptoms we keep being called to fix</h3>
        </div>
        <ul class="ba-list" role="list">
          {before.map((item) => (
            <li class="ba-item ba-item-before" role="listitem">
              <span class="ba-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity="0.3"/>
                  <path d="M5.5 5.5L10.5 10.5M10.5 5.5L5.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- VS Separator -->
      <div class="ba-vs" aria-hidden="true">
        <div class="ba-vs-inner">
          <div class="ba-vs-line"></div>
          <span class="ba-vs-circle">VS</span>
          <div class="ba-vs-line"></div>
        </div>
      </div>

      <!-- After Panel -->
      <div class="ba-panel ba-after">
        <div class="ba-panel-header">
          <span class="ba-badge ba-badge-after mono-xs">After &middot; Upcoming Brand</span>
          <h3 class="ba-panel-title">What the site actually feels like with us</h3>
        </div>
        <ul class="ba-list" role="list">
          {after.map((item) => (
            <li class="ba-item ba-item-after" role="listitem">
              <span class="ba-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity="0.3"/>
                  <path d="M5 8.5L7 10.5L11 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Proof stats strip -->
    <div class="ba-proof" role="list" aria-label="Transformation results">
      {proofStats.map((s) => (
        <div class="ba-proof-item" role="listitem">
          <div class="ba-proof-nums">
            <span class="ba-proof-before">{s.before}</span>
            <svg class="ba-proof-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M3 10h14M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="ba-proof-after">{s.after}</span>
          </div>
          <p class="ba-proof-label mono-xs">{s.label}</p>
        </div>
      ))}
      <p class="ba-proof-note mono-xs">Baltimore-area law firm client &middot; 6 months post-launch</p>
    </div>

  </div>
</section>

<style>
  .ba-section {
    background: var(--cream-soft);
  }

  .ba-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  /* ── GRID ── */
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: start;
  }

  /* ── VS ── */
  .ba-vs {
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding-top: 48px;
  }

  .ba-vs-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .ba-vs-line {
    width: 1px;
    flex: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, transparent, var(--amber), transparent);
    opacity: 0.4;
  }

  .ba-vs-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ink);
    border: 2px solid var(--amber);
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px var(--amber-glow);
  }

  /* ── PANELS ── */
  .ba-panel {
    border-radius: var(--radius-md);
    padding: clamp(24px, 3vw, 40px);
    box-shadow: var(--shadow-sm);
  }

  .ba-before {
    background: rgba(176, 74, 62, 0.04);
    border: 1px solid rgba(176, 74, 62, 0.18);
    border-left: 3px solid var(--red);
  }

  .ba-after {
    background: rgba(92, 128, 64, 0.05);
    border: 1px solid rgba(92, 128, 64, 0.2);
    border-left: 3px solid var(--green);
  }

  .ba-panel-header {
    margin-bottom: 24px;
  }

  .ba-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 10px;
  }

  .ba-badge-before {
    background: rgba(176, 74, 62, 0.1);
    color: var(--red);
    border: 1px solid rgba(176, 74, 62, 0.2);
  }

  .ba-badge-after {
    background: rgba(92, 128, 64, 0.12);
    color: #5C8040;
    border: 1px solid rgba(92, 128, 64, 0.25);
  }

  .ba-panel-title {
    font-family: var(--f-display);
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .ba-list {
    display: flex;
    flex-direction: column;
  }

  .ba-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
    line-height: 1.55;
  }

  .ba-item-after {
    border-color: rgba(92, 128, 64, 0.12);
  }

  .ba-item:last-child { border-bottom: none; padding-bottom: 0; }
  .ba-item:first-child { padding-top: 0; }

  .ba-icon { flex-shrink: 0; margin-top: 2px; }
  .ba-item-before .ba-icon { color: var(--red); }
  .ba-item-after .ba-icon { color: var(--green); }

  /* ── PROOF STRIP ── */
  .ba-proof {
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 40px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    flex-wrap: wrap;
  }

  .ba-proof-item {
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 24px 20px;
    border-right: 1px solid var(--line);
    text-align: center;
  }

  .ba-proof-note {
    flex: 2;
    min-width: 200px;
    padding: 24px 20px;
    color: var(--ink-muted);
    text-align: center;
    letter-spacing: 0.06em;
    font-size: 11px;
    border-right: none;
  }

  .ba-proof-nums {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ba-proof-before {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--red);
    opacity: 0.8;
    line-height: 1;
  }

  .ba-proof-arrow {
    color: var(--amber);
    flex-shrink: 0;
  }

  .ba-proof-after {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--green);
    line-height: 1;
  }

  .ba-proof-label {
    color: var(--ink-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 10px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .ba-grid {
      grid-template-columns: 1fr;
    }

    .ba-vs {
      padding-top: 0;
      padding-block: 8px;
    }

    .ba-vs-inner {
      flex-direction: row;
    }

    .ba-vs-line {
      flex: 1;
      width: auto;
      height: 1px;
      min-height: unset;
      background: linear-gradient(to right, transparent, var(--amber), transparent);
    }

    .ba-proof { flex-direction: column; }
    .ba-proof-item { border-right: none; border-bottom: 1px solid var(--line); width: 100%; }
    .ba-proof-note { border-top: none; }
  }
</style>
