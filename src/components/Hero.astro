---
---
<section class="hero" id="hero">
  <div class="container hero-wrap">

    <!-- ── LEFT COLUMN ── -->
    <div class="hero-left">

      <div class="hero-tags">
        <span class="hero-pill">
          <span class="hero-dot" aria-hidden="true"></span>
          WordPress Agency &middot; Maryland
        </span>
        <span class="hero-sep" aria-hidden="true">&mdash;</span>
        <span class="hero-eyebrow">A studio, not a factory</span>
      </div>

      <h1 class="hero-h1">
        <span class="h1-line">WordPress web design</span>
        <span class="h1-line h1-accent-line"><em class="h1-accent">agency services that rank,</em></span>
        <span class="h1-line h1-italic">convert &amp; keep working.</span>
      </h1>

      <p class="hero-lede">
        Upcoming Brand is a <a href="/wordpress-agency/" class="hero-lede-link"><strong>WordPress web design agency</strong></a> based in Maryland — searching for "web design near me"? We design and build custom WordPress websites for <strong>law firms, dental practices, real estate brokerages,</strong> and small businesses across Baltimore, Annapolis, Frederick, Bethesda, and the broader DMV metro. Sites that rank in Google, win Local Pack placement, and keep working long after launch.
      </p>

      <div class="hero-ctas">
        <a href="#contact" class="hero-btn-primary">
          Book a discovery call
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#work" class="hero-btn-ghost">
          See the work
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="hero-trust">
        <span class="trust-item">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Top Rated · Upwork
        </span>
        <span class="trust-dot" aria-hidden="true"></span>
        <span class="trust-item">400+ projects · 12 countries</span>
        <span class="trust-dot" aria-hidden="true"></span>
        <span class="trust-item">RankMath · Elementor · WooCommerce</span>
      </div>

    </div>

    <!-- ── RIGHT COLUMN — FORM ── -->
    <div class="hero-right">
      <div class="hero-form-card">
        <div class="form-header">
          <p class="form-eyebrow">Free discovery call</p>
          <h2 class="form-title">Tell us about your project</h2>
          <p class="form-sub">We reply within 4 business hours. No sales pitch — just an honest conversation about what you need.</p>
        </div>

        <form class="hero-form" id="hero-inquiry-form" name="hero-inquiry"-honeypot="bot-field" data-uc-form="hero-inquiry" method="POST" novalidate>
          <input type="hidden" name="form-name" value="hero-inquiry" />
          <!-- Honeypot: bots fill this, humans don't see it -->
          <div class="hp-field" aria-hidden="true">
            <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </div>
          <!-- Time trap: form submitted before 3s = bot -->
          <input type="hidden" name="_timestamp" id="form-timestamp" value="" />
          <!-- reCAPTCHA v3 token -->
          <input type="hidden" name="g-recaptcha-response" id="recaptcha-token" />

          <div class="form-row">
            <label class="form-label" for="hero-name">Your name</label>
            <input class="form-input" type="text" id="hero-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
          </div>

          <div class="form-row">
            <label class="form-label" for="hero-email">Email address</label>
            <input class="form-input" type="email" id="hero-email" name="email" placeholder="jane@company.com" required autocomplete="email" />
          </div>

          <!-- Custom themed dropdown: Business type -->
          <div class="form-row">
            <span class="form-label" id="lbl-biz">Business type</span>
            <div class="cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-biz" data-name="business_type">
              <button type="button" class="cs-trigger" aria-haspopup="listbox">
                <span class="cs-val">Select your industry</span>
                <svg class="cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </button>
              <ul class="cs-list" role="listbox" aria-label="Business type">
                <li class="cs-opt" role="option" data-value="Law Firm / Attorney">Law Firm / Attorney</li>
                <li class="cs-opt" role="option" data-value="Dental Practice">Dental Practice</li>
                <li class="cs-opt" role="option" data-value="Medical Clinic">Medical Clinic</li>
                <li class="cs-opt" role="option" data-value="Real Estate">Real Estate</li>
                <li class="cs-opt" role="option" data-value="Nonprofit / Church">Nonprofit / Church</li>
                <li class="cs-opt" role="option" data-value="Contractor / Trades">Contractor / Trades</li>
                <li class="cs-opt" role="option" data-value="Restaurant / Hospitality">Restaurant / Hospitality</li>
                <li class="cs-opt" role="option" data-value="Ecommerce / Retail">Ecommerce / Retail</li>
                <li class="cs-opt" role="option" data-value="Small Business / Startup">Small Business / Startup</li>
                <li class="cs-opt" role="option" data-value="Other">Other</li>
              </ul>
              <input type="hidden" name="business_type" class="cs-hidden" />
            </div>
          </div>

          <!-- Custom themed dropdown: Budget -->
          <div class="form-row">
            <span class="form-label" id="lbl-budget">Estimated budget</span>
            <div class="cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-budget" data-name="budget">
              <button type="button" class="cs-trigger" aria-haspopup="listbox">
                <span class="cs-val">Select a range</span>
                <svg class="cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </button>
              <ul class="cs-list" role="listbox" aria-label="Budget">
                <li class="cs-opt" role="option" data-value="$1,500 – $3,500">$1,500 – $3,500 &nbsp;<span class="cs-badge">Starter</span></li>
                <li class="cs-opt" role="option" data-value="$3,500 – $6,000">$3,500 – $6,000 &nbsp;<span class="cs-badge">Standard</span></li>
                <li class="cs-opt" role="option" data-value="$6,000 – $10,000">$6,000 – $10,000 &nbsp;<span class="cs-badge">Custom</span></li>
                <li class="cs-opt" role="option" data-value="Not sure yet">Not sure yet</li>
              </ul>
              <input type="hidden" name="budget" class="cs-hidden" />
            </div>
          </div>

          <button type="submit" class="form-submit" id="form-submit-btn">
            Get a free quote
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <p class="form-note">No commitment required &middot; Fixed-scope quotes only</p>
        </form>
      </div>
    </div>

  </div>

  <!-- ── STATS STRIP (full width) ── -->
  <div class="container">
    <div class="hero-stats" role="list" aria-label="Key statistics">
      <div class="hero-stat" role="listitem">
        <div class="stat-num">400<span class="amb">+</span></div>
        <div class="stat-lbl">WordPress projects<br>delivered</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="stat-num">99<span class="amb">%</span></div>
        <div class="stat-lbl">Upwork job<br>success score</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="stat-num">7<span class="amb">yrs</span></div>
        <div class="stat-lbl">Full-time<br>WordPress</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="stat-num">4<span class="amb">hr</span></div>
        <div class="stat-lbl">Average<br>response time</div>
      </div>
    </div>
  </div>

</section>

<style>
  /* ── SECTION ── */
  .hero {
    padding-top: clamp(28px, 4vh, 80px);
    padding-bottom: 0;
    overflow: hidden;
  }

  /* ── TWO-COLUMN LAYOUT ── */
  .hero-wrap {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: clamp(24px, 4vw, 64px);
    align-items: center;
    padding-bottom: clamp(28px, 4vh, 64px);
  }

  /* ── LEFT ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2.5vh, 28px);
  }

  .hero-tags {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  .hero-sep {
    color: var(--line-strong);
    font-size: 13px;
  }

  .hero-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* ── H1 ── */
  .hero-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, min(4.5vw, 6vh), 64px);
    line-height: 1.0;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
  }

  .h1-line { display: block; color: var(--ink); }

  .h1-accent-line { display: block; }

  .h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
  }
  .h1-accent::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.05em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }

  .h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  /* ── LEDE ── */
  .hero-lede {
    font-size: clamp(14px, min(1.2vw, 2vh), 17px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0;
  }
  .hero-lede strong { font-weight: 600; color: var(--ink); }
  .hero-lede-link {
    text-decoration: underline;
    text-decoration-color: var(--amber);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease, color 0.2s ease;
  }
  .hero-lede-link:hover {
    text-decoration-color: var(--amber-deep);
  }
  .hero-lede-link strong { color: var(--amber-deep); }
  .hero-lede-link:hover strong { color: var(--ink); }

  /* ── CTAs ── */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-btn-primary,
  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .hero-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .hero-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .hero-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .hero-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .hero-btn-primary svg,
  .hero-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .hero-btn-primary:hover svg { transform: translateX(3px); }
  .hero-btn-ghost:hover svg  { transform: translate(2px, -2px); }

  /* ── TRUST BAR ── */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .trust-item svg { color: var(--amber); flex-shrink: 0; }
  .trust-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--line-strong);
    flex-shrink: 0;
  }

  /* ── RIGHT — FORM CARD ── */
  .hero-right { align-self: start; }

  .hero-form-card {
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--radius-lg);
    padding: clamp(20px, 2.5vh, 32px) clamp(20px, 2.5vw, 32px);
    box-shadow: var(--shadow-lg);
  }

  .form-header { margin-bottom: clamp(14px, 2vh, 22px); }

  .form-eyebrow {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 8px;
  }

  .form-title {
    font-family: var(--f-display);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 8px;
    color: var(--cream);
  }

  .form-sub {
    font-size: 13px;
    line-height: 1.55;
    color: rgba(244,239,230,0.5);
  }

  /* ── FORM FIELDS ── */
  .hero-form {
    display: flex;
    flex-direction: column;
    gap: clamp(10px, 1.5vh, 14px);
  }

  /* honeypot — invisible to humans */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    tabindex: -1;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 5px;
    position: relative;
  }

  .form-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.45);
  }

  .form-input {
    background: rgba(244,239,230,0.07);
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    padding: clamp(8px, 1.2vh, 11px) 14px;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--cream);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .form-input::placeholder { color: rgba(244,239,230,0.28); }
  .form-input:focus { border-color: var(--amber); }

  /* ── CUSTOM DROPDOWN ── */
  .cs-wrap {
    position: relative;
  }

  .cs-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: rgba(244,239,230,0.07);
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    padding: clamp(8px, 1.2vh, 11px) 14px;
    font-family: var(--f-body);
    font-size: 14px;
    color: rgba(244,239,230,0.4);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s;
  }
  .cs-trigger:focus { outline: none; border-color: var(--amber); }
  .cs-wrap[aria-expanded="true"] .cs-trigger { border-color: var(--amber); color: var(--cream); }
  .cs-wrap.has-value .cs-trigger { color: var(--cream); }

  .cs-chevron {
    flex-shrink: 0;
    color: rgba(244,239,230,0.35);
    transition: transform 0.2s;
  }
  .cs-wrap[aria-expanded="true"] .cs-chevron { transform: rotate(180deg); }

  .cs-list {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: #1C232B;
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    z-index: 100;
    list-style: none;
    margin: 0;
    padding: 4px;
    max-height: 220px;
    overflow-y: auto;
  }
  .cs-wrap[aria-expanded="true"] .cs-list { display: block; }

  .cs-opt {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    font-size: 14px;
    color: rgba(244,239,230,0.7);
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .cs-opt:hover,
  .cs-opt:focus { background: rgba(212,147,46,0.15); color: var(--cream); outline: none; }
  .cs-opt.selected { background: rgba(212,147,46,0.2); color: var(--amber); }

  .cs-badge {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    opacity: 0.7;
    margin-left: auto;
  }

  .cs-hidden { display: none; }

  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    width: 100%;
    background: var(--amber);
    color: var(--ink);
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 600;
    padding: clamp(11px, 1.5vh, 15px) 24px;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 0.22s, transform 0.22s;
    margin-top: 2px;
  }
  .form-submit:hover {
    background: var(--amber-deep);
    color: var(--cream);
    transform: translateY(-2px);
  }
  .form-submit svg { transition: transform 0.22s; flex-shrink: 0; }
  .form-submit:hover svg { transform: translateX(3px); }

  .form-note {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(244,239,230,0.3);
    text-align: center;
    margin-top: -4px;
  }

  /* ── STATS STRIP (full width below grid) ── */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    padding-block: 28px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding-inline: clamp(12px, 2vw, 32px);
    border-right: 1px solid var(--line);
    text-align: center;
  }
  .hero-stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--f-display);
    font-size: clamp(26px, 2.5vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
  }
  .stat-num .amb {
    color: var(--amber-deep);
    font-style: italic;
    font-weight: 300;
  }
  .stat-lbl {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  /* ── SMALL LAPTOP (1100px) — tighten columns ── */
  @media (max-width: 1100px) {
    .hero-wrap {
      grid-template-columns: 1fr 360px;
      gap: 32px;
    }
    .form-sub { display: none; }
  }

  /* ── SMALL LAPTOP SHORT VIEWPORT — landscape-style ── */
  @media (max-height: 780px) and (min-width: 769px) {
    .hero {
      padding-top: clamp(16px, 2vh, 32px);
    }
    .hero-wrap {
      padding-bottom: clamp(16px, 2vh, 32px);
    }
    .hero-h1 {
      font-size: clamp(24px, min(3.5vw, 5vh), 52px);
    }
    .hero-lede {
      font-size: 13px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .hero-trust { display: none; }
    .hero-stats { padding-block: 16px; }
    .stat-num   { font-size: clamp(22px, 2vh, 32px); }
    .form-title { font-size: 17px; }
  }

  /* ── MOBILE (768px and below) — stack vertically ── */
  @media (max-width: 768px) {
    .hero {
      padding-top: clamp(24px, 5vw, 48px);
    }

    .hero-wrap {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-bottom: 32px;
    }

    .hero-h1 {
      font-size: clamp(30px, 8vw, 48px);
    }

    .hero-sep { display: none; }

    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
      padding-block: 20px;
    }

    .hero-stat:nth-child(2) { border-right: none; }
    .hero-stat:nth-child(3) {
      border-right: 1px solid var(--line);
      border-top: 1px solid var(--line);
      padding-top: 20px;
    }
    .hero-stat:nth-child(4) {
      border-top: 1px solid var(--line);
      padding-top: 20px;
    }

    .hero-trust { gap: 8px; }
    .trust-dot  { display: none; }
    .trust-item { display: block; }
  }

  /* ── SMALL MOBILE (480px) ── */
  @media (max-width: 480px) {
    .hero-ctas {
      flex-direction: column;
      width: 100%;
    }
    .hero-btn-primary,
    .hero-btn-ghost {
      justify-content: center;
      width: 100%;
    }
  }
</style>

<script>
  // ── CUSTOM DROPDOWNS ──────────────────────────────────────────
  function initCustomSelects() {
    document.querySelectorAll('.cs-wrap').forEach((wrap) => {
      const trigger  = wrap.querySelector('.cs-trigger');
      const list     = wrap.querySelector('.cs-list');
      const valSpan  = wrap.querySelector('.cs-val');
      const hidden   = wrap.querySelector('.cs-hidden');
      const opts     = wrap.querySelectorAll('.cs-opt');

      const open  = () => { wrap.setAttribute('aria-expanded', 'true');  };
      const close = () => { wrap.setAttribute('aria-expanded', 'false'); };
      const isOpen = () => wrap.getAttribute('aria-expanded') === 'true';

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen() ? close() : open();
      });

      opts.forEach((opt) => {
        opt.addEventListener('click', () => {
          const val = opt.dataset.value;
          // update display — strip badge text
          valSpan.textContent = opt.querySelector('.cs-badge')
            ? opt.childNodes[0].textContent.trim()
            : opt.textContent.trim();
          hidden.value = val;
          opts.forEach(o => o.classList.remove('selected'));
          opt.classList.add('selected');
          wrap.classList.add('has-value');
          close();
          trigger.focus();
        });
        // keyboard
        opt.setAttribute('tabindex', '0');
        opt.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); }
        });
      });

      // close on outside click
      document.addEventListener('click', (e) => {
        if (!wrap.contains(e.target)) close();
      });

      // close on Escape
      wrap.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { close(); trigger.focus(); }
      });
    });
  }

  // ── SPAM PROTECTION ───────────────────────────────────────────
  function initSpamProtection() {
    const ts = document.getElementById('form-timestamp');
    if (ts) ts.value = Date.now().toString();

    const form = document.getElementById('hero-inquiry-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      // Time-trap: reject if submitted in under 2 seconds
      const elapsed = Date.now() - parseInt(ts?.value || '0', 10);
      if (elapsed < 2000) {
        e.preventDefault();
        return;
      }
      // Honeypot check
      const bot = form.querySelector('[name="bot-field"]');
      if (bot && bot.value !== '') {
        e.preventDefault();
        return;
      }
    });
  }

  // ── reCAPTCHA v3 ──────────────────────────────────────────────
  // Replace YOUR_RECAPTCHA_SITE_KEY with your actual key from
  // https://www.google.com/recaptcha/admin (select v3, add your domain)
  function initRecaptcha() {
    const SITE_KEY = 'YOUR_RECAPTCHA_SITE_KEY';
    if (SITE_KEY === 'YOUR_RECAPTCHA_SITE_KEY') return; // skip until key is set

    const form = document.getElementById('hero-inquiry-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof grecaptcha === 'undefined') { form.submit(); return; }

      grecaptcha.ready(function () {
        grecaptcha.execute(SITE_KEY, { action: 'hero_form' }).then(function (token) {
          const tokenInput = document.getElementById('recaptcha-token');
          if (tokenInput) tokenInput.value = token;
          form.submit();
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCustomSelects();
    initSpamProtection();
    initRecaptcha();
  });
</script>
