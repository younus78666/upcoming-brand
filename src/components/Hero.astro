---
---
<section class="hero" id="hero">

  <!-- Corner decorator -->
  <div class="hero-decorator" aria-hidden="true">
    <span class="num">01</span>
    Est. Maryland<br>WordPress Studio
  </div>

  <div class="hero-grid container">

    <!-- Top tags -->
    <div class="hero-meta">
      <span class="hero-tag"><span class="dot" aria-hidden="true"></span>WordPress Specialists &middot; Maryland</span>
      <span class="eyebrow">A studio, not a factory</span>
    </div>

    <!-- H1 -->
    <h1 class="hero-title">
      <span>Websites that</span>
      <span class="line-2"><span class="underline-amber">rank, convert,</span></span>
      <span class="line-3">&amp; don't break.</span>
    </h1>

    <!-- Bottom row: lede + CTAs + credentials -->
    <div class="hero-bottom">
      <p class="hero-lede">
        We design and build WordPress sites for Maryland businesses that take the web seriously.
        <strong>Baltimore to Bethesda,</strong> from law firms to dental practices &mdash; we replace templates with craft, and PageSpeed scores in the 40s with scores in the 90s.
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="btn-primary">
          Book a discovery call
          <span class="arrow">&rarr;</span>
        </a>
        <a href="#work" class="btn-secondary">
          See the work
          <span class="arrow">&#8599;</span>
        </a>
      </div>
      <div class="hero-credentials">
        <span>Top Rated &mdash; Upwork</span>
        <span>400+ projects &middot; 12 countries</span>
        <span>RankMath &middot; Elementor &middot; WooCommerce</span>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="hero-stats" role="list" aria-label="Key statistics">
      <div class="hero-stat-item" role="listitem">
        <div class="hero-stat-val">400<span class="amb">+</span></div>
        <div class="hero-stat-lbl">WordPress projects<br>delivered</div>
      </div>
      <div class="hero-stat-item" role="listitem">
        <div class="hero-stat-val">99<span class="amb">%</span></div>
        <div class="hero-stat-lbl">Upwork job<br>success score</div>
      </div>
      <div class="hero-stat-item" role="listitem">
        <div class="hero-stat-val">7<span class="amb">yrs</span></div>
        <div class="hero-stat-lbl">Full-time<br>WordPress</div>
      </div>
      <div class="hero-stat-item" role="listitem">
        <div class="hero-stat-val">4<span class="amb">hr</span></div>
        <div class="hero-stat-lbl">Average<br>response time</div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding: 80px var(--pad) 60px;
    position: relative;
    overflow: hidden;
    min-height: calc(90vh - 106px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hero-tag .dot {
    width: 6px; height: 6px;
    background: var(--amber);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(52px, 8.5vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero-title .line-2 { display: block; padding-left: 6vw; }
  .hero-title .line-3 {
    display: block;
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
    padding-left: 12vw;
  }
  .underline-amber {
    position: relative;
    white-space: nowrap;
  }
  .underline-amber::after {
    content: "";
    position: absolute;
    bottom: 0.05em; left: 0; right: 0;
    height: 0.12em;
    background: var(--amber);
    opacity: 0.5;
    z-index: -1;
    border-radius: 2px;
  }

  .hero-bottom {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-top: 40px;
    border-top: 1px solid var(--line);
  }
  @media (min-width: 900px) {
    .hero-bottom {
      grid-template-columns: 1.2fr 1fr auto;
      align-items: end;
      gap: 48px;
    }
  }

  .hero-lede {
    font-family: var(--f-body);
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 520px;
  }
  .hero-lede strong { font-weight: 600; color: var(--ink); }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .btn-primary,
  .btn-secondary {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 15px;
    padding: 16px 28px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.25s;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .btn-secondary {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .btn-secondary:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }
  .btn-primary .arrow,
  .btn-secondary .arrow { transition: transform 0.3s; }
  .btn-primary:hover .arrow,
  .btn-secondary:hover .arrow { transform: translateX(4px); }

  .hero-credentials {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: right;
    white-space: nowrap;
  }

  .hero-decorator {
    position: absolute;
    top: 80px;
    right: var(--pad);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    text-align: right;
    line-height: 1.6;
    pointer-events: none;
    z-index: 0;
  }
  .hero-decorator .num {
    font-family: var(--f-display);
    font-size: 72px;
    font-weight: 300;
    color: var(--amber-deep);
    opacity: 0.15;
    line-height: 0.9;
    display: block;
    margin-bottom: 8px;
  }
  @media (max-width: 1000px) { .hero-decorator { display: none; } }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding: 28px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .hero-stat-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 clamp(16px, 2.5vw, 32px);
    border-right: 1px solid var(--line);
  }
  .hero-stat-item:first-child { padding-left: 0; }
  .hero-stat-item:last-child { padding-right: 0; border-right: none; }

  .hero-stat-val {
    font-family: var(--f-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
  }
  .hero-stat-val .amb {
    color: var(--amber-deep);
    font-style: italic;
    font-weight: 300;
  }
  .hero-stat-lbl {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .hero { padding: 48px var(--pad) 40px; min-height: auto; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
    .hero-stat-item { border-right: none; padding: 16px 0; }
    .hero-stat-item:nth-child(odd) { border-right: 1px solid var(--line); padding-right: 20px; }
    .hero-credentials { text-align: left; }
    .hero-title { font-size: clamp(42px, 11vw, 72px); }
    .hero-title .line-2 { padding-left: 20px; }
    .hero-title .line-3 { padding-left: 40px; }
  }
</style>
