---
---
<section class="hero section-pad" id="hero">
  <div class="container hero-inner">

    <!-- Tag row -->
    <div class="hero-tags">
      <span class="hero-pill">
        <span class="hero-dot" aria-hidden="true"></span>
        WordPress Specialists &middot; Maryland
      </span>
      <span class="hero-sep" aria-hidden="true">&mdash;</span>
      <span class="hero-eyebrow">A studio, not a factory</span>
    </div>

    <!-- H1 -->
    <h1 class="hero-h1">
      <span class="h1-top">Websites that</span>
      <span class="h1-mid"><em class="h1-accent">rank, convert,</em></span>
      <span class="h1-bot">&amp; don't break.</span>
    </h1>

    <!-- Lede -->
    <p class="hero-lede">
      Upcoming Brand is a WordPress web design studio based in Maryland. We've built our
      WordPress web design services around one principle: the website you ship today
      should still be working, ranking, and converting three years from now.
      We design and develop custom WordPress websites for <strong>law firms, dental
      practices, real estate brokerages,</strong> and small businesses across Baltimore,
      Annapolis, Frederick, Bethesda, and the broader DMV metro.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href="#contact" class="hero-btn-primary">
        Book a discovery call
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#work" class="hero-btn-ghost">
        See the work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Stats strip -->
    <div class="hero-stats" role="list" aria-label="Key statistics">
      <div class="hero-stat" role="listitem">
        <div class="hero-stat-num">400<span class="amb">+</span></div>
        <div class="hero-stat-lbl">WordPress projects<br>delivered</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="hero-stat-num">99<span class="amb">%</span></div>
        <div class="hero-stat-lbl">Upwork job<br>success score</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="hero-stat-num">7<span class="amb">yrs</span></div>
        <div class="hero-stat-lbl">Full-time<br>WordPress</div>
      </div>
      <div class="hero-stat" role="listitem">
        <div class="hero-stat-num">4<span class="amb">hr</span></div>
        <div class="hero-stat-lbl">Average<br>response time</div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 100%;
  }

  /* Tags row */
  .hero-tags {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 16px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  .hero-sep {
    color: var(--line-strong);
    font-size: 14px;
  }

  .hero-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* H1 */
  .hero-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(48px, 8vw, 112px);
    line-height: 0.93;
    letter-spacing: -0.04em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin: 0;
  }

  .h1-top,
  .h1-mid,
  .h1-bot {
    display: block;
  }

  .h1-top {
    color: var(--ink);
  }

  .h1-mid {
    color: var(--ink);
  }

  .h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
  }

  .h1-accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.06em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.55;
    border-radius: 2px;
  }

  .h1-bot {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  /* Lede */
  .hero-lede {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
  }

  .hero-lede strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .hero-btn-primary,
  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 15px 28px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }

  .hero-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }

  .hero-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }

  .hero-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }

  .hero-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }

  .hero-btn-primary svg,
  .hero-btn-ghost svg {
    transition: transform 0.22s ease;
    flex-shrink: 0;
  }

  .hero-btn-primary:hover svg { transform: translateX(3px); }
  .hero-btn-ghost:hover svg { transform: translate(2px, -2px); }

  /* Stats strip */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    width: 100%;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 28px;
    margin-top: 8px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding-inline: clamp(16px, 2vw, 32px);
    border-right: 1px solid var(--line);
    text-align: center;
  }

  .hero-stat:last-child {
    border-right: none;
  }

  .hero-stat-num {
    font-family: var(--f-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
  }

  .hero-stat-num .amb {
    color: var(--amber-deep);
    font-style: italic;
    font-weight: 300;
  }

  .hero-stat-lbl {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-h1 { font-size: clamp(40px, 11vw, 72px); }
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
    .hero-stat:nth-child(2) { border-right: none; }
    .hero-stat:nth-child(3) { border-right: 1px solid var(--line); border-top: 1px solid var(--line); padding-top: 20px; margin-top: 0; }
    .hero-stat:nth-child(4) { border-top: 1px solid var(--line); padding-top: 20px; margin-top: 0; }
    .hero-sep { display: none; }
    .hero-lede { font-size: 15px; }
  }

  @media (max-width: 480px) {
    .hero-inner { gap: 28px; }
    .hero-ctas { flex-direction: column; width: 100%; }
    .hero-btn-primary,
    .hero-btn-ghost { justify-content: center; }
  }
</style>
