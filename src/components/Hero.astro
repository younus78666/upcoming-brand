---
---
<section class="hero" id="hero">

  <!-- Background grid lines -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-line"></div>
    <div class="hero-bg-line"></div>
    <div class="hero-bg-line"></div>
    <div class="hero-bg-line"></div>
  </div>

  <div class="container hero-inner">

    <!-- Left column: badge + headline + lede -->
    <div class="hero-left">
      <div class="hero-tags">
        <span class="hero-pill"><span class="hero-dot" aria-hidden="true"></span>WordPress Specialists · Maryland</span>
        <span class="hero-eyebrow">A studio, not a factory</span>
      </div>

      <h1 class="hero-h1">
        <span class="h1-line h1-top">Websites that</span>
        <span class="h1-line h1-mid"><em class="h1-em">rank, convert,</em></span>
        <span class="h1-line h1-bot">&amp; don't break.</span>
      </h1>

      <p class="hero-lede">
        We design and build WordPress sites for Maryland businesses that take
        the web seriously. <strong>Baltimore to Bethesda,</strong> from law
        firms to dental practices&mdash;we replace templates with craft, and
        PageSpeed scores in the 40s with scores in the 90s.
      </p>

      <div class="hero-actions">
        <a href="#contact" class="hero-btn-primary">
          Book a discovery call
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#work" class="hero-btn-ghost">
          See the work
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <!-- Right column: stats card + credentials -->
    <div class="hero-right">

      <div class="hero-card">
        <div class="hero-card-label">By the numbers</div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-num">400<span class="amb">+</span></div>
            <div class="hero-stat-txt">WordPress projects<br>delivered</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">99<span class="amb">%</span></div>
            <div class="hero-stat-txt">Upwork job<br>success score</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">7<span class="amb">yrs</span></div>
            <div class="hero-stat-txt">Full-time<br>WordPress</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">4<span class="amb">hr</span></div>
            <div class="hero-stat-txt">Average<br>response time</div>
          </div>
        </div>
        <div class="hero-card-footer">
          <span class="hero-trust-badge">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.4"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Top Rated · Upwork
          </span>
          <span class="hero-trust-badge">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.4"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            400+ projects · 12 countries
          </span>
          <span class="hero-trust-badge">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.4"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            RankMath · Elementor · WooCommerce
          </span>
        </div>
      </div>

      <!-- Decorative index marker -->
      <div class="hero-index" aria-hidden="true">
        <span class="hero-index-num">01</span>
        <span class="hero-index-label">Est. Maryland<br>WordPress Studio</span>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(90vh - 106px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(64px, 8vw, 120px);
  }

  /* Subtle vertical grid lines */
  .hero-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    pointer-events: none;
    z-index: 0;
  }
  .hero-bg-line {
    border-right: 1px solid var(--line);
  }
  .hero-bg-line:last-child { border-right: none; }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: clamp(48px, 6vw, 100px);
    align-items: center;
  }

  /* ---- LEFT ---- */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .hero-tags {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hero-dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* Headline */
  .hero-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.04em;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .h1-line {
    display: block;
    font-size: clamp(44px, 6.5vw, 96px);
    color: var(--ink);
  }
  .h1-mid {
    padding-left: 0.18em;
  }
  .h1-bot {
    padding-left: 0.36em;
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }
  .h1-em {
    font-style: inherit;
    position: relative;
  }
  .h1-em::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.06em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }

  /* Lede */
  .hero-lede {
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 52ch;
  }
  .hero-lede strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* CTAs */
  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-btn-primary,
  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 15px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .hero-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .hero-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .hero-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .hero-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .hero-btn-primary svg,
  .hero-btn-ghost svg {
    transition: transform 0.22s ease;
    flex-shrink: 0;
  }
  .hero-btn-primary:hover svg { transform: translateX(3px); }
  .hero-btn-ghost:hover svg { transform: translate(2px, -2px); }

  /* ---- RIGHT ---- */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
  }

  .hero-card {
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    box-shadow: var(--shadow-lg);
  }

  .hero-card-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.4);
    margin-bottom: 28px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .hero-stat {
    padding: 20px 0;
    border-bottom: 1px solid rgba(244,239,230,0.1);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hero-stat:nth-child(odd) {
    padding-right: 20px;
    border-right: 1px solid rgba(244,239,230,0.1);
  }
  .hero-stat:nth-child(even) {
    padding-left: 20px;
  }
  .hero-stat:nth-child(3),
  .hero-stat:nth-child(4) {
    border-bottom: none;
  }

  .hero-stat-num {
    font-family: var(--f-display);
    font-size: clamp(28px, 2.5vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--cream);
  }
  .hero-stat-num .amb {
    color: var(--amber);
    font-style: italic;
    font-weight: 300;
    font-size: 0.75em;
  }
  .hero-stat-txt {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.45);
    line-height: 1.4;
  }

  .hero-card-footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(244,239,230,0.1);
  }
  .hero-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: rgba(244,239,230,0.45);
  }
  .hero-trust-badge svg { flex-shrink: 0; color: var(--amber); }

  /* Decorative index marker */
  .hero-index {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    padding-left: 4px;
  }
  .hero-index-num {
    font-family: var(--f-display);
    font-size: 64px;
    font-weight: 300;
    line-height: 0.85;
    color: var(--amber-deep);
    opacity: 0.12;
  }
  .hero-index-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    line-height: 1.5;
    padding-bottom: 4px;
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 1100px) {
    .hero-inner {
      grid-template-columns: 1fr 380px;
    }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-right {
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
    }
    .hero-card { flex: 1; min-width: 280px; }
    .hero-index { display: none; }
    .h1-line { font-size: clamp(38px, 8vw, 68px); }
  }

  @media (max-width: 600px) {
    .hero {
      min-height: auto;
      padding-block: 48px;
    }
    .hero-right { flex-direction: column; }
    .hero-card { min-width: 0; }
    .h1-mid { padding-left: 0.12em; }
    .h1-bot { padding-left: 0.24em; }
    .hero-lede { font-size: 15px; }
  }
</style>
