---
const cases = [
  {
    num: "01",
    tag: "Law Firm",
    city: "Baltimore",
    year: "2026",
    client: "Meridian Law Group",
    desc: "48-page rebuild for a 40-year firm with six practice areas. Full intake routing, location schema, and a topical map targeting 22 Baltimore attorney keywords.",
    stats: [
      { val: "+312%", label: "Organic leads" },
      { val: "94", label: "PageSpeed mobile" },
      { val: "Pg 1", label: "11 keywords" },
    ],
    gradient: "linear-gradient(145deg, #111820 0%, #1C3A50 60%, #0F2035 100%)",
    accentColor: "rgba(212,147,46,0.7)",
    navColor: "rgba(255,255,255,0.12)",
    heroColor: "rgba(212,147,46,0.18)",
    screenshotSrc: "/work/meridian-law-group.png",
  },
  {
    num: "02",
    tag: "Dental Practice",
    city: "Annapolis",
    year: "2025",
    client: "Chesapeake Dental",
    desc: "3-location dental group unified under one WordPress install. Integrated online booking, insurance verification widget, and per-location SEO landing pages.",
    stats: [
      { val: "+218%", label: "Online bookings" },
      { val: "92", label: "PageSpeed mobile" },
      { val: "3", label: "Locations unified" },
    ],
    gradient: "linear-gradient(145deg, #0D1F1A 0%, #183828 60%, #0A1510 100%)",
    accentColor: "rgba(92,128,64,0.7)",
    navColor: "rgba(255,255,255,0.1)",
    heroColor: "rgba(92,128,64,0.2)",
    screenshotSrc: "/work/chesapeake-dental.png",
  },
  {
    num: "03",
    tag: "Real Estate",
    city: "Bethesda",
    year: "2025",
    client: "Tidewater Realty",
    desc: "IDX-powered brokerage site with 80+ agent profiles, MLS data sync, and neighborhood pages targeting Bethesda, Chevy Chase, and Rockville buyers.",
    stats: [
      { val: "80+", label: "Agent profiles" },
      { val: "2.4s", label: "LCP time" },
      { val: "+156%", label: "Qualified leads" },
    ],
    gradient: "linear-gradient(145deg, #1A1008 0%, #2E1C0A 60%, #3A2410 100%)",
    accentColor: "rgba(180,120,40,0.7)",
    navColor: "rgba(255,255,255,0.1)",
    heroColor: "rgba(180,120,40,0.18)",
  },
  {
    num: "04",
    tag: "E-commerce",
    city: "Rockville",
    year: "2025",
    client: "Arden Interiors",
    desc: "340-SKU WooCommerce store with a custom product configurator, fabric sample request flow, and Stripe checkout — shipping Maryland, Virginia, and DC.",
    stats: [
      { val: "3.8%", label: "Conversion rate" },
      { val: "340", label: "Products live" },
      { val: "+89%", label: "Avg order value" },
    ],
    gradient: "linear-gradient(145deg, #1A0F1E 0%, #2E183A 60%, #1C0E24 100%)",
    accentColor: "rgba(160,100,200,0.5)",
    navColor: "rgba(255,255,255,0.1)",
    heroColor: "rgba(160,100,200,0.15)",
  },
];
---
<section class="work-section section-pad" id="work">
  <div class="container">

    <div class="work-intro">
      <p class="eyebrow">Selected work</p>
      <h2 class="h2-section">Recent WordPress web design builds from the studio</h2>
      <p class="lead">Four examples from 400+ projects. Every stat below is from a live Google Analytics or Search Console report.</p>
    </div>

    <div class="work-list">
      {cases.map((c, i) => (
        <article class={`work-row${i % 2 !== 0 ? ' work-row--reverse' : ''}`}>

          <!-- LEFT: Text content -->
          <div class="work-content">
            <div class="work-num-row">
              <span class="work-num" aria-hidden="true">{c.num}</span>
              <span class="work-tag mono-xs">{c.tag}</span>
              <span class="work-loc mono-xs">{c.city} &middot; {c.year}</span>
            </div>
            <h3 class="work-client">{c.client}</h3>
            <p class="work-desc">{c.desc}</p>
            <div class="work-stats" role="list">
              {c.stats.map((s) => (
                <div class="work-stat" role="listitem">
                  <span class="wstat-val">{s.val}</span>
                  <span class="wstat-label mono-xs">{s.label}</span>
                </div>
              ))}
            </div>
            <a href="#contact" class="work-cta">View case study <span aria-hidden="true">&rarr;</span></a>
          </div>

          <!-- RIGHT: Browser mockup or screenshot -->
          <div class="work-visual" aria-hidden="true" style={c.screenshotSrc ? '' : `background: ${c.gradient}`}>
            {c.screenshotSrc ? (
              <img
                src={c.screenshotSrc}
                alt={`${c.client} website screenshot`}
                class="work-screenshot"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <>
                <div class="wb-chrome">
                  <div class="wb-dots">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="wb-urlbar"></div>
                </div>
                <div class="wb-body">
                  <div class="wb-nav" style={`background: ${c.navColor}`}></div>
                  <div class="wb-hero" style={`background: ${c.heroColor}`}>
                    <div class="wb-hero-line" style={`background: ${c.accentColor}`}></div>
                    <div class="wb-hero-sub"></div>
                    <div class="wb-hero-btn" style={`background: ${c.accentColor}`}></div>
                  </div>
                  <div class="wb-cards">
                    <div class="wb-card"></div>
                    <div class="wb-card"></div>
                    <div class="wb-card"></div>
                  </div>
                  <div class="wb-text-block">
                    <div class="wb-line wb-line-full"></div>
                    <div class="wb-line wb-line-mid"></div>
                    <div class="wb-line wb-line-short"></div>
                  </div>
                </div>
              </>
            )}
          </div>

        </article>
      ))}
    </div>

    <div class="work-footer">
      <div class="work-footer-left">
        <p class="work-footer-num">400+</p>
        <p class="work-footer-label">projects delivered across Maryland and 12 countries</p>
      </div>
      <a href="#contact" class="cta-outline">View full portfolio &rarr;</a>
    </div>

  </div>
</section>

<style>
  .work-section {
    background: var(--paper);
  }

  /* ── INTRO ── */
  .work-intro {
    max-width: 640px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .work-intro .eyebrow {
    justify-content: center;
  }

  /* ── LIST ── */
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* ── ROW ── */
  .work-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 460px;
    border: 1.5px solid rgba(15,20,25,0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(15,20,25,0.06);
    transition: box-shadow var(--transition);
  }

  .work-row:hover {
    box-shadow: 0 8px 40px rgba(15,20,25,0.11);
  }

  /* Alternating: image left, text right */
  .work-row--reverse .work-content {
    order: 2;
    border-right: none;
    border-left: 1px solid rgba(15,20,25,0.08);
  }

  .work-row--reverse .work-visual {
    order: 1;
  }

  /* ── CONTENT ── */
  .work-content {
    padding: clamp(32px, 4vw, 52px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
    overflow: hidden;
    border-right: 1px solid rgba(15,20,25,0.08);
    background: var(--paper);
    transition: background var(--transition);
  }

  .work-row:hover .work-content {
    background: var(--cream-soft);
  }

  /* ── NUM ROW ── */
  .work-num-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .work-num {
    font-family: var(--f-display);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--amber);
    opacity: 0.7;
  }

  .work-tag {
    background: var(--amber-glow);
    color: var(--amber-deep);
    border: 1px solid rgba(212,147,46,0.22);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 10px;
  }

  .work-loc {
    color: var(--ink-muted);
    font-size: 11px;
    margin-left: auto;
  }

  /* ── CLIENT NAME ── */
  .work-client {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.5vw, 34px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
  }

  /* ── DESCRIPTION ── */
  .work-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.65;
    max-width: 46ch;
  }

  /* ── STATS ── */
  .work-stats {
    display: flex;
    gap: 0;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .work-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-right: 20px;
    border-right: 1px solid var(--line);
  }

  .work-stat:last-child {
    border-right: none;
    padding-right: 0;
    padding-left: 20px;
  }

  .work-stat:nth-child(2) {
    padding-left: 20px;
  }

  .wstat-val {
    font-family: var(--f-display);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--amber);
  }

  .wstat-label {
    color: var(--ink-muted);
    letter-spacing: 0.07em;
    font-size: 10px;
    text-transform: uppercase;
  }

  /* ── CTA LINK ── */
  .work-cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--amber);
    letter-spacing: 0.01em;
    transition: opacity var(--transition);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 4px;
  }

  .work-cta:hover {
    opacity: 0.7;
  }

  /* ── VISUAL (RIGHT) ── */
  .work-visual {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Real screenshot */
  .work-screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* Browser chrome */
  .wb-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(0,0,0,0.25);
    flex-shrink: 0;
  }

  .wb-dots {
    display: flex;
    gap: 5px;
  }

  .wb-dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
  }

  .wb-urlbar {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    max-width: 180px;
  }

  /* Browser body */
  .wb-body {
    flex: 1;
    padding: 12px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .wb-nav {
    height: 8px;
    border-radius: 3px;
    width: 70%;
  }

  .wb-hero {
    flex: 0 0 auto;
    border-radius: 6px;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-height: 90px;
  }

  .wb-hero-line {
    height: 7px;
    border-radius: 3px;
    width: 65%;
  }

  .wb-hero-sub {
    height: 5px;
    border-radius: 2px;
    background: rgba(255,255,255,0.12);
    width: 45%;
  }

  .wb-hero-btn {
    height: 14px;
    border-radius: 4px;
    width: 80px;
    margin-top: 4px;
    opacity: 0.8;
  }

  .wb-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .wb-card {
    height: 40px;
    background: rgba(255,255,255,0.06);
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .wb-text-block {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding-top: 4px;
  }

  .wb-line {
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
  }

  .wb-line-full { width: 100%; }
  .wb-line-mid { width: 75%; }
  .wb-line-short { width: 50%; }

  /* ── FOOTER ── */
  .work-footer {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 32px;
    padding: 28px 32px;
    border: 1.5px solid rgba(15,20,25,0.08);
    border-radius: var(--radius-md);
    background: var(--cream-soft);
  }

  .work-footer-left {
    flex: 1;
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .work-footer-num {
    font-family: var(--f-display);
    font-size: 40px;
    font-weight: 300;
    letter-spacing: -0.04em;
    color: var(--amber);
    line-height: 1;
  }

  .work-footer-label {
    font-size: 14px;
    color: var(--ink-muted);
    max-width: 28ch;
    line-height: 1.4;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .work-row {
      grid-template-columns: 1fr;
      height: auto;
    }

    /* Reset reversed-row order — content always first on mobile */
    .work-row--reverse .work-content {
      order: unset;
      border-left: none;
      border-bottom: 1px solid rgba(15,20,25,0.08);
    }

    .work-row--reverse .work-visual {
      order: unset;
    }

    .work-content {
      border-right: none;
      border-bottom: 1px solid rgba(15,20,25,0.08);
    }

    .work-visual {
      min-height: 240px;
    }

    .work-desc {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .work-content {
      padding: 28px 20px;
    }

    .work-footer {
      flex-direction: column;
      align-items: flex-start;
      padding: 20px;
    }

    .work-footer-left {
      flex-direction: column;
      gap: 4px;
    }

    .work-stats {
      flex-wrap: wrap;
      gap: 16px;
    }

    .work-stat {
      flex: none;
      min-width: 80px;
      padding-right: 0;
      border-right: none;
    }
  }
</style>
