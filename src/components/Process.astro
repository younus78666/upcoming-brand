---
const phases = [
  {
    num: "01",
    name: "Discovery Call",
    timing: "Week 0",
    desc: "45-min call to understand your business, goals, and current site. We figure out if we're the right fit — no sales pitch.",
  },
  {
    num: "02",
    name: "Scope & Proposal",
    timing: "Days 3–5",
    desc: "Written fixed-scope proposal: page list, feature list, timeline, and one price. You approve it or pass — no pressure.",
  },
  {
    num: "03",
    name: "Design",
    timing: "Weeks 1–2",
    desc: "Figma wireframes and full visual mockups for every page type. Two revision rounds before we touch WordPress.",
  },
  {
    num: "04",
    name: "Development",
    timing: "Weeks 2–6",
    desc: "Build on staging — Elementor Pro, Astra, RankMath Pro, weekly demo links. We don't launch until you sign off.",
  },
  {
    num: "05",
    name: "SEO & Speed",
    timing: "Weeks 5–7",
    desc: "RankMath Pro, JSON-LD schema, internal linking, WP Rocket, Cloudflare CDN. PageSpeed and Core Web Vitals tested before going live.",
  },
  {
    num: "06",
    name: "Launch & Care",
    timing: "Week 6–10",
    desc: "Zero-downtime DNS cutover, 30-day Search Console monitoring, recorded walkthrough of admin. Optional care plan from $150/mo.",
  },
];
---
<section class="process-section section-pad" id="process">
  <div class="container">
    <div class="process-intro">
      <p class="eyebrow">How we work</p>
      <h2 class="h2-section">From first call to live site in 4–10 weeks</h2>
      <p class="lead">Our process is built around one principle: no surprises. Fixed scope, fixed price, fixed timeline. You'll know what's happening at every stage — no chasing, no ambiguity.</p>
    </div>

    <div class="process-timeline" role="list" aria-label="Project phases">
      {phases.map((phase, i) => (
        <div class="phase-item" role="listitem">
          <div class="phase-marker" aria-hidden="true">
            <span class="phase-num mono-xs">{phase.num}</span>
            <div class="phase-line"></div>
          </div>
          <div class="phase-content">
            <div class="phase-header">
              <h3 class="phase-name">{phase.name}</h3>
              <span class="phase-timing mono-xs">{phase.timing}</span>
            </div>
            <p class="phase-deliverables-label">DELIVERABLES</p>
            <p class="phase-desc">{phase.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="process-cta">
      <a href="#contact" class="cta-btn">Start with a discovery call &rarr;</a>
      <p class="process-cta-note mono-xs">No sales pitch on the first call. Just a working conversation.</p>
    </div>
  </div>
</section>

<style>
  .process-section {
    background: var(--cream-soft);
  }

  .process-intro {
    max-width: 600px;
    margin-bottom: 56px;
  }

  .process-timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 48px;
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .phase-item {
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    position: relative;
    transition: background var(--transition);
  }

  .phase-item:hover {
    background: var(--cream-soft);
  }

  .phase-item:nth-child(3n) { border-right: none; }
  .phase-item:nth-child(4),
  .phase-item:nth-child(5),
  .phase-item:nth-child(6) { border-bottom: none; }

  .phase-marker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .phase-num {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 50%;
    color: var(--amber);
    font-family: var(--f-display);
    font-size: 14px;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .phase-line {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .phase-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }

  .phase-name {
    font-family: var(--f-display);
    font-size: clamp(16px, 1.8vw, 20px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .phase-timing {
    color: var(--amber);
    white-space: nowrap;
    letter-spacing: 0.06em;
    text-align: right;
  }

  .phase-deliverables-label {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 4px;
    opacity: 0.8;
  }

  .phase-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .process-cta {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .process-cta-note {
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .process-timeline {
      grid-template-columns: repeat(2, 1fr);
    }

    .phase-item:nth-child(3n) { border-right: 1px solid var(--line); }
    .phase-item:nth-child(2n) { border-right: none; }
    .phase-item:nth-child(5),
    .phase-item:nth-child(6) { border-bottom: none; }
    .phase-item:nth-child(4) { border-bottom: 1px solid var(--line); }
  }

  @media (max-width: 600px) {
    .process-timeline {
      grid-template-columns: 1fr;
    }

    .phase-item { border-right: none !important; }
    .phase-item:last-child { border-bottom: none; }
    .phase-item:nth-child(n) { border-bottom: 1px solid var(--line); }

    .process-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
