---
const stack = [
  {
    category: "Platform",
    tool: "WordPress",
    abbr: "WP",
    note: "43% of the web runs on WordPress — open source, flexible, and built to last.",
  },
  {
    category: "Page Builder",
    tool: "Elementor Pro",
    abbr: "EP",
    note: "Pixel-accurate design with a client-friendly editor and 2,500+ widget options.",
  },
  {
    category: "Theme",
    tool: "Astra Pro",
    abbr: "AP",
    note: "Lightweight, accessibility-aware parent theme — loads in under 50kb.",
  },
  {
    category: "Commerce",
    tool: "WooCommerce",
    abbr: "WC",
    note: "Native to WordPress, zero monthly transaction fees, scales to any catalog size.",
  },
  {
    category: "SEO",
    tool: "RankMath Pro",
    abbr: "RM",
    note: "Schema, sitemaps, redirects, and keyword tracking — all in one licensed plugin.",
  },
  {
    category: "Speed",
    tool: "WP Rocket",
    abbr: "WR",
    note: "Industry-standard caching, minification, and lazy load — no manual config needed.",
  },
  {
    category: "Hosting",
    tool: "Cloudways",
    abbr: "CW",
    note: "Managed WordPress hosting on DigitalOcean with published uptime SLAs.",
  },
  {
    category: "Security",
    tool: "Wordfence",
    abbr: "WF",
    note: "Web application firewall, malware scanning, and 2FA — updated daily.",
  },
  {
    category: "CDN",
    tool: "Cloudflare",
    abbr: "CF",
    note: "Global edge network serving assets from 300+ cities with free DDoS protection.",
  },
  {
    category: "Analytics",
    tool: "GA4 + GSC",
    abbr: "GA",
    note: "Real performance data in Google Analytics 4 and Search Console — not vanity metrics.",
  },
];
---
<section class="stack-section section-pad" id="stack">
  <div class="container">

    <div class="stack-intro">
      <p class="eyebrow">Built on tools that work</p>
      <h2 class="h2-section">The WordPress tech stack behind every Upcoming Brand site</h2>
      <p class="lead">
        We don't chase shiny new plugins. Every tool here was chosen because it performs reliably on live Maryland business sites — vetted across 400+ real projects. All licenses are included on active care plans.
      </p>
    </div>

    <div class="stack-grid" role="list" aria-label="Technology stack">
      {stack.map((item) => (
        <div class="stack-card" role="listitem">
          <div class="stack-card-top">
            <span class="stack-abbr" aria-hidden="true">{item.abbr}</span>
            <span class="stack-cat mono-xs">{item.category}</span>
          </div>
          <h3 class="stack-tool">{item.tool}</h3>
          <span class="stack-rule" aria-hidden="true"></span>
          <p class="stack-note">{item.note}</p>
        </div>
      ))}
    </div>

    <p class="stack-footnote mono-xs">
      All plugins and themes fully licensed &middot; Updated weekly on every active care plan &middot; No shared licenses
    </p>

  </div>
</section>

<style>
  .stack-section {
    background: var(--cream-soft);
  }

  /* ── INTRO ── */
  .stack-intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 52px;
  }

  .stack-intro .eyebrow {
    justify-content: center;
  }

  /* ── GRID ── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  /* ── CARD ── */
  .stack-card {
    background: var(--paper);
    border: 1.5px solid rgba(15,20,25,0.07);
    border-radius: var(--radius-md);
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    box-shadow: 0 2px 10px rgba(15,20,25,0.06);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    position: relative;
    overflow: hidden;
  }

  .stack-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--amber), rgba(212,147,46,0.3));
  }

  .stack-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(15,20,25,0.11);
    border-color: rgba(212,147,46,0.3);
  }

  /* ── TOP ROW ── */
  .stack-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  /* ── ABBR BADGE ── */
  .stack-abbr {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--ink);
    color: var(--amber);
    font-family: var(--f-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── CATEGORY ── */
  .stack-cat {
    color: var(--amber);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: right;
    opacity: 0.8;
    line-height: 1.3;
  }

  /* ── TOOL NAME ── */
  .stack-tool {
    font-family: var(--f-display);
    font-size: clamp(16px, 1.5vw, 19px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--ink);
  }

  /* ── AMBER RULE ── */
  .stack-rule {
    display: block;
    width: 28px;
    height: 2px;
    background: linear-gradient(to right, var(--amber), rgba(212,147,46,0.15));
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── NOTE ── */
  .stack-note {
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-muted);
    flex: 1;
  }

  /* ── FOOTNOTE ── */
  .stack-footnote {
    text-align: center;
    color: var(--ink-muted);
    margin-top: 32px;
    letter-spacing: 0.07em;
    font-size: 11px;
    opacity: 0.7;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .stack-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 800px) {
    .stack-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
