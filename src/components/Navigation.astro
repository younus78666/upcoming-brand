    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mobile-section {
    border-bottom: 1px solid rgba(244, 239, 230, 0.08);
  }

  .mobile-link {
    display: block;
    padding: 16px 4px;
    font-family: var(--f-display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--cream);
    text-decoration: none;
    transition: color 0.2s;
  }
  .mobile-link:hover, .mobile-link:active { color: var(--amber); }

  /* Accordion button */
  .mobile-acc-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 4px;
    background: transparent;
    border: none;
    font-family: var(--f-display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--cream);
    cursor: pointer;
    text-align: left;
    transition: color 0.2s;
  }
  .mobile-acc-btn:hover { color: var(--amber); }
  .mobile-acc-icon {
    color: var(--amber);
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .mobile-acc-btn[aria-expanded="true"] {
    color: var(--amber);
  }
  .mobile-acc-btn[aria-expanded="true"] .mobile-acc-icon {
    transform: rotate(180deg);
  }

  /* Accordion panel */
  .mobile-acc-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
    overflow: hidden;
  }
  .mobile-acc-btn[aria-expanded="true"] + .mobile-acc-panel {
    grid-template-rows: 1fr;
  }
  .mobile-acc-panel > * { min-height: 0; }

  .mobile-sublink {
    display: block;
    padding: 11px 16px;
    font-size: 14px;
    font-weight: 500;
    color: rgba(244, 239, 230, 0.7);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-sublink:first-child { margin-top: 4px; }
  .mobile-sublink:last-child { margin-bottom: 12px; }
  .mobile-sublink:hover, .mobile-sublink:active {
    background: rgba(244, 239, 230, 0.04);
    color: var(--amber);
  }
  .mobile-sublink-all {
    color: var(--amber);
    font-weight: 600;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .mobile-sublink-all:hover { color: var(--amber); background: rgba(212, 147, 46, 0.08); }

  /* Direct contact block in mobile drawer */
  .mobile-contact {
    margin-top: 24px;
    padding: 20px;
    background: rgba(244, 239, 230, 0.04);
    border: 1px solid rgba(244, 239, 230, 0.1);
    border-radius: var(--radius-lg);
    color: var(--cream);
    text-align: center;
  }
  .mobile-contact-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(244, 239, 230, 0.5);
    margin-bottom: 8px;
  }
  .mobile-contact-phone {
    display: block;
    font-family: var(--f-display);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--amber);
    text-decoration: none;
    margin-bottom: 14px;
    line-height: 1.1;
    transition: color 0.2s ease;
  }
  .mobile-contact-phone:hover { color: var(--cream); }
  .mobile-contact-row {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .mobile-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border: 1px solid rgba(244, 239, 230, 0.18);
    border-radius: 999px;
    background: rgba(244, 239, 230, 0.04);
    font-family: var(--f-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--cream);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .mobile-contact-link:hover, .mobile-contact-link:active {
    border-color: var(--amber);
    color: var(--amber);
  }
  .mobile-contact-wa {
    background: rgba(37, 211, 102, 0.14);
    border-color: rgba(37, 211, 102, 0.4);
    color: #25D366;
  }
  .mobile-contact-wa:hover, .mobile-contact-wa:active {
    background: #25D366;
    color: #fff;
    border-color: #25D366;
  }

  .mobile-link-cta {
    margin-top: 16px;
    padding: 16px 24px;
    background: var(--amber);
    color: var(--ink) !important;
    text-align: center;
    border-radius: 999px;
    font-family: var(--f-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }
  .mobile-link-cta:hover, .mobile-link-cta:active {
    background: var(--cream);
    color: var(--ink) !important;
  }

  /* Body scroll lock when menu open */
  :global(body.mobile-nav-open) {
    overflow: hidden;
  }

  /* ====================================================
     RESPONSIVE
     ==================================================== */
  @media (max-width: 1100px) {
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    .nav-cta { display: none; }
  }
</style>

<script>
  // Scroll shadow on nav
  const nav = document.querySelector('.site-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Mega menu — hover with delay + click for touch
  const navItems = document.querySelectorAll('.nav-item');
  navItems.forEach(item => {
    let hoverTimeout;
    item.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimeout);
      navItems.forEach(i => i.classList.remove('open'));
      item.classList.add('open');
      const btn = item.querySelector('.nav-trigger');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('mouseleave', () => {
      hoverTimeout = setTimeout(() => {
        item.classList.remove('open');
        const btn = item.querySelector('.nav-trigger');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      }, 200);
    });
    // Click to toggle on touch
    const trigger = item.querySelector('.nav-trigger');
    if (trigger) {
      trigger.addEventListener('click', (e) => {
        const isOpen = item.classList.contains('open');
        navItems.forEach(i => {
          i.classList.remove('open');
          const b = i.querySelector('.nav-trigger');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
        e.stopPropagation();
      });
    }
  });
  document.addEventListener('click', () => {
    navItems.forEach(i => {
      i.classList.remove('open');
      const b = i.querySelector('.nav-trigger');
      if (b) b.setAttribute('aria-expanded', 'false');
    });
  });

  // Hamburger + mobile drawer
  const burger = document.querySelector('.nav-burger');
  const mobileNav = document.getElementById('mobile-nav');

  function setMobileOpen(open) {
    if (!burger || !mobileNav) return;
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    mobileNav.setAttribute('aria-hidden', String(!open));
    mobileNav.classList.toggle('open', open);
    document.body.classList.toggle('mobile-nav-open', open);
  }

  if (burger && mobileNav) {
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      setMobileOpen(!open);
    });

    // Explicit close button inside drawer
    const closeBtn = mobileNav.querySelector('[data-mobile-close]');
    if (closeBtn) closeBtn.addEventListener('click', () => setMobileOpen(false));

    // Click on backdrop (the ::before overlay area) closes drawer
    mobileNav.addEventListener('click', (e) => {
      if (e.target === mobileNav) setMobileOpen(false);
    });

    // Close drawer on regular link click (but NOT accordion buttons)
    mobileNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => setMobileOpen(false));
    });

    // Accordion expand/collapse — close siblings so only one open at a time
    const accBtns = mobileNav.querySelectorAll('[data-acc]');
    accBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        accBtns.forEach(b => b.setAttribute('aria-expanded', 'false'));
        btn.setAttribute('aria-expanded', String(!expanded));
      });
    });

    // ESC key closes drawer
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setMobileOpen(false);
      }
    });

    // Resize past mobile breakpoint resets state
    window.addEventListener('resize', () => {
      if (window.innerWidth > 1100) setMobileOpen(false);
    });
  }
</script>
