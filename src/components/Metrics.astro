---
const metrics = [
  {
    num: "400+",
    label: "WordPress projects delivered",
    sub: "From 1-page lead-gen sites to 80-page WooCommerce stores across 12 countries",
  },
  {
    num: "90+",
    label: "Average PageSpeed score at launch",
    sub: "Every site ships with LCP under 2.5s and all Core Web Vitals passing in Search Console",
  },
  {
    num: "99%",
    label: "Upwork job success score",
    sub: "Across 100+ contracts — top 3% of all WordPress specialists on the platform",
  },
  {
    num: "4 hr",
    label: "Support SLA on care plans",
    sub: "Direct access to the founder — not a help-desk ticket system",
  },
  {
    num: "$0",
    label: "Hourly billing, ever",
    sub: "Every project is fixed-scope — you know the number before you sign anything",
  },
  {
    num: "7 yrs",
    label: "Full-time WordPress",
    sub: "No side hustles, no agency handoffs — this is the only thing we do",
  },
];
---
<section class="metrics-section section-pad" id="metrics">
  <div class="container">

    <div class="metrics-intro">
      <p class="eyebrow metrics-eyebrow">By the numbers</p>
      <h2 class="h2-section metrics-h2">What a 7-year WordPress practice looks like</h2>
      <p class="lead metrics-lead">
        These aren't agency-padded numbers. Real projects across Maryland, the DMV metro, and 12 countries — seven years of full-time WordPress work, zero hourly billing.
      </p>
    </div>

    <div class="metrics-grid" role="list" aria-label="Key performance metrics">
      {metrics.map((m) => (
        <div class="metric-card" role="listitem">
          <div class="metric-num-wrap">
            <span class="metric-num">{m.num}</span>
            <span class="metric-rule" aria-hidden="true"></span>
          </div>
          <span class="metric-label">{m.label}</span>
          <p class="metric-sub mono-xs">{m.sub}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .metrics-section {
    background: var(--ink);
    color: var(--cream);
    border-top: 3px solid var(--amber);
    position: relative;
    overflow: hidden;
  }

  .metrics-section::before {
    content: "Results";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--f-display);
    font-size: clamp(120px, 20vw, 280px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.04em;
    color: var(--cream);
    opacity: 0.03;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .metrics-section .container {
    position: relative;
    z-index: 2;
  }

  /* ── INTRO ── */
  .metrics-intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 56px;
  }

  .metrics-eyebrow {
    color: rgba(244,239,230,0.45);
    justify-content: center;
  }

  .metrics-eyebrow::before {
    background: rgba(244,239,230,0.25);
  }

  .metrics-h2 {
    color: var(--cream);
  }

  .metrics-lead {
    color: rgba(244,239,230,0.6);
  }

  /* ── GRID ── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── CARD ── */
  .metric-card {
    background: rgba(244,239,230,0.04);
    border: 1px solid rgba(244,239,230,0.09);
    border-top: 3px solid rgba(212,147,46,0.55);
    border-radius: var(--radius-md);
    padding: clamp(28px, 3vw, 44px);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background var(--transition), transform var(--transition), border-top-color var(--transition), box-shadow var(--transition);
  }

  .metric-card:hover {
    background: rgba(244,239,230,0.07);
    border-top-color: var(--amber);
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.25);
  }

  /* ── NUMBER + RULE ── */
  .metric-num-wrap {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .metric-num {
    font-family: var(--f-display);
    font-size: clamp(44px, 5vw, 68px);
    font-weight: 300;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--amber);
    display: block;
  }

  .metric-rule {
    display: block;
    width: 36px;
    height: 2px;
    background: linear-gradient(to right, var(--amber), rgba(212,147,46,0.2));
    border-radius: 2px;
  }

  /* ── LABEL ── */
  .metric-label {
    font-size: 15px;
    font-weight: 500;
    color: rgba(244,239,230,0.9);
    line-height: 1.35;
  }

  /* ── SUB ── */
  .metric-sub {
    color: rgba(244,239,230,0.38);
    line-height: 1.5;
    font-size: 11px;
    letter-spacing: 0.04em;
    margin-top: 2px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
