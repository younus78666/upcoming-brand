---
const metrics = [
  {
    num: "400+",
    label: "WordPress projects delivered",
    sub: "From 1-page lead-gen sites to 80-page WooCommerce stores across 12 countries",
  },
  {
    num: "90+",
    label: "Average PageSpeed score at launch",
    sub: "Every site ships with LCP under 2.5s and all Core Web Vitals passing in Search Console",
  },
  {
    num: "99%",
    label: "Upwork job success score",
    sub: "Across 100+ contracts — top 3% of all WordPress specialists on the platform",
  },
  {
    num: "4 hr",
    label: "Support SLA on care plans",
    sub: "Direct access to the founder — not a help-desk ticket system",
  },
  {
    num: "$0",
    label: "Hourly billing, ever",
    sub: "Every project is fixed-scope — you know the number before you sign anything",
  },
  {
    num: "7 yrs",
    label: "Full-time WordPress",
    sub: "No side hustles, no agency handoffs — this is the only thing we do",
  },
];
---
<section class="metrics-section section-pad" id="metrics">
  <div class="container">
    <div class="metrics-intro">
      <p class="eyebrow">By the numbers</p>
      <h2 class="h2-section">What a 7-year WordPress practice looks like</h2>
      <p class="lead">
        These aren't agency-padded numbers. They're from real WordPress projects across Maryland, the DMV metro, and 12 countries — accumulated over seven years of full-time WordPress work with a $0 hourly billing policy.
      </p>
    </div>

    <div class="metrics-grid" role="list" aria-label="Key performance metrics">
      {metrics.map((m) => (
        <div class="metric-card" role="listitem">
          <span class="metric-num">{m.num}</span>
          <span class="metric-label">{m.label}</span>
          <span class="metric-sub mono-xs">{m.sub}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metrics-section {
    background: var(--ink);
    color: var(--cream);
    border-top: 3px solid var(--amber);
    position: relative;
    overflow: hidden;
  }

  .metrics-section::before {
    content: "Results";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--f-display);
    font-size: clamp(120px, 20vw, 280px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.04em;
    color: var(--cream);
    opacity: 0.04;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .metrics-section .container {
    position: relative;
    z-index: 1;
  }

  .metrics-section .eyebrow {
    color: rgba(244,239,230,0.45);
  }

  .metrics-section .eyebrow::before {
    background: rgba(244,239,230,0.25);
  }

  .metrics-section .h2-section {
    color: var(--cream);
  }

  .metrics-section .lead {
    color: rgba(244,239,230,0.65);
    max-width: 60ch;
  }

  .metrics-intro {
    margin-bottom: 56px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid rgba(244,239,230,0.1);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: clamp(28px, 3vw, 48px);
    border-right: 1px solid rgba(244,239,230,0.1);
    border-bottom: 1px solid rgba(244,239,230,0.1);
    position: relative;
    transition: background var(--transition);
  }

  .metric-card:nth-child(3n) {
    border-right: none;
  }

  .metric-card:nth-child(4),
  .metric-card:nth-child(5),
  .metric-card:nth-child(6) {
    border-bottom: none;
  }

  .metric-card:hover {
    background: rgba(244,239,230,0.04);
  }

  .metric-num {
    font-family: var(--f-display);
    font-size: clamp(40px, 5vw, 72px);
    font-weight: 300;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--amber);
  }

  .metric-label {
    font-size: 15px;
    font-weight: 500;
    color: rgba(244,239,230,0.85);
    line-height: 1.3;
  }

  .metric-sub {
    color: rgba(244,239,230,0.4);
    line-height: 1.4;
    margin-top: 4px;
  }

  @media (max-width: 1000px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .metric-card {
      border-right: 1px solid rgba(244,239,230,0.1);
      border-bottom: 1px solid rgba(244,239,230,0.1);
    }

    .metric-card:nth-child(3n) { border-right: 1px solid rgba(244,239,230,0.1); }
    .metric-card:nth-child(2n) { border-right: none; }
    .metric-card:nth-child(5),
    .metric-card:nth-child(6) { border-bottom: none; }
  }

  @media (max-width: 600px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }

    .metric-card {
      border-right: none;
      border-bottom: 1px solid rgba(244,239,230,0.1);
    }

    .metric-card:last-child {
      border-bottom: none;
    }
  }
</style>
