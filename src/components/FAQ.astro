---
const faqs = [
  {
    q: "How much does a WordPress website cost in Maryland?",
    a: "Most Maryland small business WordPress websites fall between $1,500 and $10,000. A straightforward 8-page site for a contractor or solo practitioner starts around $1,500–$3,500. A 15–20 page site with custom design, SEO setup, and blog integration runs $3,500–$6,000. Complex builds with WooCommerce, appointment booking, or IDX integration start at $6,000. Every quote we send is fixed-scope — one price, no hourly surprises.",
  },
  {
    q: "How long does a WordPress project take from start to launch?",
    a: "Starter sites (up to 8 pages) take 4–6 weeks from signed scope to live launch. Growth sites (up to 20 pages with custom design) take 6–8 weeks. Custom builds take 8–10 weeks. Timeline depends most on how quickly you can provide feedback — our design review and revision rounds are where most delays happen.",
  },
  {
    q: "Will my site score 90+ on Google PageSpeed?",
    a: "Yes — we commit to it in writing. Every site we launch targets a PageSpeed score of 90 or above on both mobile and desktop, with LCP under 2.5 seconds, INP under 200ms, and all three Core Web Vitals passing in Google Search Console. For context: only 44% of WordPress sites on mobile pass all three Core Web Vitals. We're aiming for the other 56% to be your competition.",
  },
  {
    q: "Can you migrate my existing Wix or Squarespace site to WordPress?",
    a: "Yes — without losing your existing search rankings. We build a complete 301 redirect map before any DNS changes, run a pre-launch ranking benchmark, and check rank parity in Search Console for 30 days after launch. Most migrations see no ranking loss and often see improvement within 60 days because the WordPress build is faster and better structured.",
  },
  {
    q: "Do you work with law firms, dental practices, and regulated industries?",
    a: "Yes. Law firm, dental practice, and medical clinic websites make up a significant portion of our Maryland client base. We understand the compliance considerations (HIPAA-aware forms, attorney ethics rules for testimonials), the conversion patterns, and the schema types (LegalService, Dentist, MedicalOrganization) that help these sites rank in competitive local searches.",
  },
  {
    q: "What's included in your monthly care plans?",
    a: "Care plans start at $150/month and include weekly WordPress core and plugin updates, off-site backups to S3 or Google Drive, uptime monitoring, a 4-hour SLA for support tickets, and a monthly performance report. You communicate directly with the founder — not a help-desk system. Higher-tier plans include content updates, SEO reporting, and quarterly strategy reviews.",
  },
  {
    q: "Why WordPress instead of Webflow, Squarespace, or Wix?",
    a: "WordPress is open source: you own your data, there's no platform lock-in, and no monthly SaaS fee that scales with your revenue. 43% of all websites run on WordPress. The total cost of ownership over 5 years is consistently lower than any SaaS website platform — and you can move hosts any time.",
  },
  {
    q: "Do you guarantee specific Google rankings?",
    a: "No ethical agency can guarantee rankings — anyone who does is lying to you. We guarantee clean schema markup, Core Web Vitals in the green, proper internal linking, and a topical map built for your market. Clients on our SEO care plan typically see top-10 positions for 20–40 targeted keywords within 6–9 months.",
  },
];
---
<section class="faq-section section-pad" id="faq">
  <div class="container">
    <div class="faq-layout">
      <div class="faq-sidebar">
        <p class="eyebrow">Common questions</p>
        <h2 class="h2-section">WordPress web design questions Maryland business owners ask before hiring us</h2>
        <p class="faq-sidebar-text">
          The questions we get on almost every discovery call — answered up front so you don't have to wait for a sales call to get a straight answer.
        </p>
        <a href="#contact" class="cta-outline faq-sidebar-cta">Ask your question &rarr;</a>
      </div>

      <div class="faq-list" id="faq-accordion">
        {faqs.map((faq, i) => (
          <div class="faq-item" data-faq-item>
            <button
              class="faq-trigger"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-btn-${i}`}
            >
              <span class="faq-q">{faq.q}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path class="faq-plus-h" d="M4 10H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path class="faq-plus-v" d="M10 4V16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div
              class="faq-answer"
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              hidden
            >
              <p class="faq-a">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .faq-layout {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 64px;
    align-items: start;
  }

  .faq-sidebar {
    position: sticky;
    top: 88px;
  }

  .faq-sidebar-text {
    font-size: 15px;
    color: var(--ink-muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .faq-sidebar-cta {
    display: inline-flex;
  }

  /* Accordion */
  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--line);
    border-left: 3px solid transparent;
    transition: border-left-color var(--transition);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--line);
  }

  .faq-item:has(.faq-trigger[aria-expanded="true"]) {
    border-left-color: var(--amber);
  }

  .faq-trigger {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    width: 100%;
    padding: 20px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: color var(--transition);
  }

  .faq-trigger:hover {
    color: var(--amber-deep);
  }

  .faq-q {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--ink-muted);
    transition: color var(--transition), transform var(--transition);
    margin-top: 2px;
  }

  .faq-trigger[aria-expanded="true"] .faq-icon {
    color: var(--amber);
    transform: rotate(45deg);
  }

  .faq-answer {
    overflow: hidden;
  }

  .faq-answer:not([hidden]) {
    display: block;
    animation: faq-open 200ms ease forwards;
  }

  @keyframes faq-open {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .faq-a {
    padding-bottom: 20px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-muted);
  }

  @media (max-width: 1000px) {
    .faq-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .faq-sidebar {
      position: static;
    }
  }
</style>

<script>
  const items = document.querySelectorAll('[data-faq-item]');

  items.forEach((item) => {
    const btn = item.querySelector('.faq-trigger');
    const answer = item.querySelector('.faq-answer');

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      items.forEach((other) => {
        const otherBtn = other.querySelector('.faq-trigger');
        const otherAnswer = other.querySelector('.faq-answer');
        otherBtn.setAttribute('aria-expanded', 'false');
        otherAnswer.hidden = true;
      });

      // Open this one if it was closed
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
      }
    });
  });
</script>
