---
const currentYear = new Date().getFullYear();

const nav = [
  {
    heading: "Services",
    links: [
      { label: "WordPress Agency", href: "/wordpress-agency/" },
      { label: "Hire a WordPress Designer", href: "/hire-wordpress-designer/" },
      { label: "Custom WordPress Design", href: "/services/wordpress-web-design/" },
      { label: "WordPress Redesign", href: "/services/wordpress-redesign/" },
      { label: "WordPress Migration", href: "/services/wordpress-migration/" },
      { label: "WooCommerce Development", href: "/services/woocommerce-development/" },
      { label: "WordPress SEO Services", href: "/services/wordpress-seo-services/" },
      { label: "Local SEO Maryland", href: "/services/local-seo-maryland/" },
      { label: "SEO Audit", href: "/services/seo-audit/" },
      { label: "Speed Optimization", href: "/services/wordpress-speed-optimization/" },
      { label: "WordPress Security", href: "/services/wordpress-security/" },
      { label: "WordPress Hosting", href: "/services/wordpress-hosting/" },
      { label: "Care Plans & Maintenance", href: "/services/wordpress-care-plans/" },
      { label: "On-Demand Support", href: "/services/wordpress-support/" },
    ],
  },
  {
    heading: "Industries",
    links: [
      { label: "Law Firms & Attorneys", href: "/industries/law-firm-website-design/" },
      { label: "Dental Practices", href: "/industries/dental-website-design/" },
      { label: "Medical Clinics", href: "/industries/medical-website-design/" },
      { label: "Real Estate Brokers", href: "/industries/real-estate-website-design/" },
      { label: "Contractors & Trades", href: "/industries/contractor-website-design/" },
      { label: "Nonprofits & Churches", href: "/industries/nonprofit-website-design/" },
      { label: "Restaurants", href: "/industries/restaurant-website-design/" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "The Team", href: "/team/" },
      { label: "Our Process", href: "/process/" },
      { label: "Values & Principles", href: "/values/" },
      { label: "Pricing", href: "/pricing/" },
      { label: "Reviews", href: "/reviews/" },
      { label: "Portfolio", href: "/work/" },
      { label: "Blog", href: "/blog/" },
      { label: "Free Tools", href: "/tools/" },
      { label: "Careers", href: "/careers/" },
      { label: "Contact", href: "/contact/" },
      { label: "Book a Discovery Call", href: "/book-a-discovery-call/" },
    ],
  },
];

const locationTags = [
  { label: "Web Design Maryland",      href: "/locations/maryland-web-design/" },
  { label: "Web Design Baltimore",     href: "/locations/baltimore-web-design/" },
  { label: "Web Design Annapolis",     href: "/locations/annapolis-web-design/" },
  { label: "Web Design Frederick",     href: "/locations/frederick-web-design/" },
  { label: "Web Design Bethesda",      href: "/locations/bethesda-web-design/" },
  { label: "Web Design Rockville",     href: "/locations/rockville-web-design/" },
  { label: "Web Design Silver Spring", href: "/locations/silver-spring-web-design/" },
  { label: "Web Design Columbia",      href: "/locations/columbia-web-design/" },
  { label: "Web Design Towson",        href: "/locations/towson-web-design/" },
  { label: "Web Design Gaithersburg",  href: "/locations/gaithersburg-web-design/" },
  { label: "Web Design Germantown",    href: "/locations/germantown-web-design/" },
  { label: "Web Design Ellicott City", href: "/locations/ellicott-city-web-design/" },
  { label: "Web Design Catonsville",   href: "/locations/catonsville-web-design/" },
  { label: "Web Design Dundalk",       href: "/locations/dundalk-web-design/" },
  { label: "Web Design Hagerstown",    href: "/locations/hagerstown-web-design/" },
  { label: "Web Design Westminster",   href: "/locations/westminster-web-design/" },
  { label: "Web Design Bowie",         href: "/locations/bowie-web-design/" },
  { label: "Web Design Waldorf",       href: "/locations/waldorf-web-design/" },
  { label: "Web Design Salisbury",     href: "/locations/salisbury-web-design/" },
];

const socials = [
  { label: "LinkedIn", href: "#", icon: "in" },
  { label: "X (Twitter)", href: "#", icon: "x" },
  { label: "Instagram", href: "#", icon: "ig" },
  { label: "Dribbble", href: "#", icon: "dr" },
];
---
<footer class="footer" role="contentinfo">
  <div class="container">
    <!-- Top -->
    <div class="footer-top">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-brand-mark" aria-label="Upcoming Brand home">
          <img
            src="/02-footer-logo-dark-edited.png"
            alt="Upcoming Brand"
            class="footer-logo-img"
            width="200"
            height="52"
          />
        </a>
        <p class="footer-tagline">WordPress web design services based in Maryland — Baltimore, Annapolis, Frederick, Rockville &amp; all of Maryland.</p>
        <div class="footer-socials" role="list" aria-label="Social media links">
          {socials.map((s) => (
            <a href={s.href} class="social-link" role="listitem" aria-label={s.label}>
              <span class="social-icon mono-xs">{s.icon}</span>
            </a>
          ))}
        </div>
        <div class="footer-badge">
          <span class="footer-badge-dot" aria-hidden="true"></span>
          <span class="footer-badge-text mono-xs">Accepting May 2026 projects</span>
        </div>

        <div class="footer-contact" aria-label="Direct contact">
          <span class="footer-contact-label mono-xs">Direct line</span>
          <a href="tel:+12402092757" class="footer-contact-phone">+1 (240) 209 2757</a>
          <div class="footer-contact-row">
            <a href="https://wa.me/12402092757?text=Hi%20Upcoming%20Brand%2C%20I%27d%20like%20to%20discuss%20a%20project." target="_blank" rel="noopener" class="footer-contact-link footer-contact-link-wa" aria-label="Chat with us on WhatsApp">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17.6 6.32A8 8 0 0 0 4.3 14.97L4 19.7l4.84-1.27A8 8 0 0 0 19.7 8.42a7.94 7.94 0 0 0-2.1-2.1ZM12 18.5a6.65 6.65 0 0 1-3.4-.94l-.24-.14-2.87.75.77-2.8-.16-.25a6.66 6.66 0 1 1 5.9 3.38Zm3.65-4.99c-.2-.1-1.18-.58-1.36-.65-.18-.07-.32-.1-.45.1-.13.2-.51.65-.63.78-.12.13-.23.15-.43.05a5.46 5.46 0 0 1-1.61-1 6 6 0 0 1-1.11-1.38c-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.61-1.48-.16-.39-.32-.34-.45-.34h-.39c-.13 0-.34.05-.52.25s-.69.67-.69 1.64.71 1.91.81 2.04c.1.13 1.4 2.13 3.39 2.99.47.2.84.32 1.13.42.48.15.91.13 1.25.08.38-.06 1.18-.48 1.34-.94.17-.46.17-.86.12-.94-.05-.08-.18-.13-.38-.23Z" fill="currentColor"/></svg>
              WhatsApp
            </a>
            <a href="mailto:hello@upcomingbrand.com" class="footer-contact-link">hello@upcomingbrand.com</a>
          </div>
        </div>
      </div>

      <!-- Nav columns -->
      {nav.map((col) => (
        <nav class="footer-nav-col" aria-label={`${col.heading} links`}>
          <h3 class="footer-col-heading mono-xs">{col.heading}</h3>
          <ul role="list">
            {col.links.map((link) => (
              <li role="listitem">
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <!-- Location tags strip -->
    <div class="footer-locations" aria-label="Maryland locations served">
      <span class="footer-locations-label mono-xs">Locations</span>
      <div class="footer-location-tags" role="list">
        {locationTags.map((loc) => (
          <a href={loc.href} class="footer-loc-tag" role="listitem">{loc.label}</a>
        ))}
        <a href="/locations/" class="footer-loc-tag footer-loc-tag-all" role="listitem">All 18 cities &rarr;</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy mono-xs">
        &copy; {currentYear} Upcoming Brand &middot; WordPress Web Design Services Maryland
      </p>
      <div class="footer-legal" role="list">
        <a href="/privacy-policy/" class="footer-legal-link" role="listitem">Privacy Policy</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms-and-conditions/" class="footer-legal-link" role="listitem">Terms &amp; Conditions</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/accessibility/" class="footer-legal-link" role="listitem">Accessibility</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-soft);
    color: var(--cream);
    padding-top: clamp(56px, 7vw, 96px);
    border-top: 3px solid var(--amber);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: 40px;
    padding-bottom: 40px;
  }

  /* Brand column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-brand-mark {
    display: inline-flex;
  }

  .footer-logo-img {
    height: 44px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 14px;
    color: rgba(244,239,230,0.55);
    line-height: 1.5;
    max-width: 22ch;
  }

  .footer-socials {
    display: flex;
    gap: 8px;
  }

  .social-link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(244,239,230,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(244,239,230,0.5);
    transition: border-color var(--transition), color var(--transition), background var(--transition);
  }

  .social-link:hover {
    border-color: var(--amber);
    color: var(--amber);
    background: rgba(212,147,46,0.08);
  }

  .social-icon {
    font-size: 11px;
    letter-spacing: 0;
    font-weight: 600;
  }

  .footer-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1px solid rgba(92,128,64,0.3);
    border-radius: var(--radius-pill);
    background: rgba(92,128,64,0.08);
    width: fit-content;
  }

  .footer-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .footer-badge-text {
    color: #8ab86a;
    letter-spacing: 0.08em;
    font-size: 11px;
  }

  .footer-contact {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px dashed rgba(244,239,230,0.18);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-contact-label {
    color: rgba(244,239,230,0.5);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 10px;
    margin-bottom: 2px;
  }
  .footer-contact-phone {
    font-family: var(--f-display, Georgia, serif);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--amber, #D4932E);
    text-decoration: none;
    line-height: 1.1;
    transition: color 0.2s ease;
  }
  .footer-contact-phone:hover { color: #F4EFE6; }
  .footer-contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid rgba(244,239,230,0.2);
    border-radius: 999px;
    font-family: var(--f-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    color: rgba(244,239,230,0.85);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: all 0.2s ease;
  }
  .footer-contact-link:hover {
    border-color: var(--amber, #D4932E);
    color: var(--amber, #D4932E);
  }
  .footer-contact-link-wa {
    background: rgba(37, 211, 102, 0.12);
    border-color: rgba(37, 211, 102, 0.35);
    color: #25D366;
  }
  .footer-contact-link-wa:hover {
    background: #25D366;
    color: #FFFFFF;
    border-color: #25D366;
  }

  /* Nav columns */
  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-col-heading {
    color: rgba(244,239,230,0.35);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 10px;
    font-weight: 400;
    margin-bottom: 4px;
  }

  .footer-nav-col ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-link {
    font-size: 14px;
    color: rgba(244,239,230,0.6);
    transition: color var(--transition);
    line-height: 1.4;
  }

  .footer-link:hover {
    color: var(--amber);
  }

  /* Location tags strip */
  .footer-locations {
    padding: 20px 0 32px;
    border-top: 1px solid rgba(244,239,230,0.08);
    border-bottom: 1px solid rgba(244,239,230,0.1);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-locations-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.35);
  }

  .footer-location-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .footer-loc-tag {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(244,239,230,0.55);
    background: rgba(244,239,230,0.05);
    border: 1px solid rgba(244,239,230,0.1);
    border-radius: var(--radius-pill);
    padding: 5px 12px;
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
    white-space: nowrap;
  }

  .footer-loc-tag:hover {
    color: var(--amber);
    border-color: rgba(212,147,46,0.3);
    background: rgba(212,147,46,0.07);
  }

  .footer-loc-tag-all {
    color: var(--amber);
    border-color: rgba(212,147,46,0.25);
    background: rgba(212,147,46,0.06);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 20px;
    gap: 16px;
    border-top: 1px solid rgba(244,239,230,0.15);
  }

  .footer-copy {
    color: rgba(244,239,230,0.3);
    letter-spacing: 0.06em;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(244,239,230,0.25);
    font-family: var(--f-mono);
    font-size: 12px;
    letter-spacing: 0.05em;
  }

  .footer-legal-link {
    color: rgba(244,239,230,0.35);
    transition: color var(--transition);
  }

  .footer-legal-link:hover {
    color: var(--cream);
  }

  @media (max-width: 1100px) {
    .footer-top {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer-brand {
      grid-column: span 3;
      display: grid;
      grid-template-columns: auto 1fr 1fr;
      gap: 32px;
      align-items: start;
    }

    .footer-tagline { grid-column: 2; }
    .footer-socials { grid-column: 3; }
    .footer-badge { grid-column: 2; margin-top: -8px; }
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: span 2;
      grid-template-columns: 1fr;
    }

    .footer-tagline, .footer-socials, .footer-badge {
      grid-column: auto;
    }

    .footer-loc-tag { font-size: 10px; padding: 4px 10px; }
  }

  @media (max-width: 500px) {
    .footer-top {
      grid-template-columns: 1fr;
    }

    .footer-brand { grid-column: span 1; }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
