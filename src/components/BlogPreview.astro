---
const articles = [
  {
    tag: "Buying Guide",
    readTime: "12 min read",
    title: "How much does a WordPress website actually cost in 2026?",
    desc: "Transparent breakdown from $3,500 to $50,000 based on 400+ projects.",
    href: "#",
  },
  {
    tag: "Comparison",
    readTime: "10 min read",
    title: "WordPress vs Webflow: which one wins for Maryland businesses in 2026?",
    desc: "Honest comparison from an agency that's built on both.",
    href: "#",
  },
  {
    tag: "Guide",
    readTime: "8 min read",
    title: "12 questions to ask every web designer before you hire them",
    desc: "Questions most Maryland business owners don't think to ask.",
    href: "#",
  },
];
---
<section class="blog-section section-pad" id="blog">
  <div class="container">
    <div class="blog-intro">
      <p class="eyebrow">From the resources library</p>
      <h2 class="h2-section">Articles for Maryland business owners evaluating WordPress</h2>
      <p class="lead">Practical WordPress guides written for the business owner signing the contract, not the developer reading the code.</p>
    </div>

    <div class="blog-grid">
      {articles.map((article) => (
        <article class="blog-card card">
          <a href={article.href} class="blog-card-link" aria-label={`Read: ${article.title}`}>
            <!-- Placeholder image area -->
            <div class="blog-img" aria-hidden="true">
              <div class="blog-img-pattern"></div>
              <div class="blog-img-tag-wrap">
                <span class="blog-img-tag mono-xs">{article.tag}</span>
              </div>
            </div>

            <div class="blog-body">
              <div class="blog-meta">
                <span class="blog-tag mono-xs">{article.tag}</span>
                <span class="blog-read mono-xs">{article.readTime}</span>
              </div>
              <h3 class="blog-title">{article.title}</h3>
              <p class="blog-desc">{article.desc}</p>
              <span class="blog-cta-link">Read article &rarr;</span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-footer">
      <a href="#" class="cta-outline">Browse all articles &rarr;</a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    background: var(--cream-soft);
  }

  .blog-intro {
    max-width: 600px;
    margin-bottom: 40px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  /* Image placeholder */
  .blog-img {
    height: 180px;
    background: var(--ink-soft);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .blog-img-pattern {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 40%, rgba(212,147,46,0.08) 100%),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 12px,
        rgba(244,239,230,0.03) 12px,
        rgba(244,239,230,0.03) 13px
      );
  }

  .blog-img-tag-wrap {
    position: relative;
    padding: 16px;
  }

  .blog-img-tag {
    background: rgba(212,147,46,0.9);
    color: var(--ink);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .blog-tag {
    color: var(--amber-deep);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-read {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .blog-title {
    font-family: var(--f-display);
    font-size: clamp(17px, 1.8vw, 21px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .blog-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.5;
    flex: 1;
  }

  .blog-cta-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--amber-deep);
    margin-top: 8px;
    transition: color var(--transition);
  }

  .blog-card:hover .blog-cta-link {
    color: var(--ink);
  }

  .blog-footer {
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
