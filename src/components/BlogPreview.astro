---
const articles = [
  {
    tag: "Pricing Guide",
    readTime: "10 min read",
    title: "How Much Does a WordPress Website Cost in Maryland? (2026 Complete Pricing Guide)",
    desc: "Everything you need to know about Maryland web design costs — from a 5-page contractor site at $2,500 to a custom law firm build at $10,000. Fixed pricing explained.",
    href: "#",
    imgGradient: "linear-gradient(135deg, #1C232B 0%, #2C3E50 100%)",
  },
  {
    tag: "Platform Comparison",
    readTime: "9 min read",
    title: "WordPress vs. Squarespace for Maryland Law Firms: Which Platform Wins?",
    desc: "We run both platforms through the same 12-point test — Core Web Vitals, SEO, attorney schema markup, content management, and total 3-year cost.",
    href: "#",
    imgGradient: "linear-gradient(135deg, #0F1419 0%, #2A3A28 100%)",
  },
  {
    tag: "Performance",
    readTime: "7 min read",
    title: "Why 56% of Maryland Businesses Are Leaving PageSpeed Points on the Table",
    desc: "Only 44% of WordPress sites pass all three Core Web Vitals on mobile. Here's exactly what's failing and the fastest fixes for Maryland service businesses.",
    href: "#",
    imgGradient: "linear-gradient(135deg, #2C1810 0%, #3A2A1C 100%)",
  },
];
---
<section class="blog-section section-pad" id="blog">
  <div class="container">
    <div class="blog-intro">
      <p class="eyebrow">From the blog</p>
      <h2 class="h2-section">WordPress web design resources for Maryland business owners</h2>
      <p class="lead">Practical articles about WordPress performance, local SEO, and what actually moves the needle for Maryland service businesses.</p>
    </div>

    <div class="blog-grid">
      {articles.map((article) => (
        <article class="blog-card card">
          <a href={article.href} class="blog-card-link" aria-label={`Read: ${article.title}`}>
            <!-- Placeholder image area -->
            <div class="blog-img" aria-hidden="true" style={`background: ${article.imgGradient}`}>
              <div class="blog-img-pattern"></div>
              <div class="blog-img-tag-wrap">
                <span class="blog-img-tag mono-xs">{article.tag}</span>
              </div>
            </div>

            <div class="blog-body">
              <div class="blog-meta">
                <span class="blog-tag mono-xs">{article.tag}</span>
                <span class="blog-read mono-xs">{article.readTime}</span>
              </div>
              <h3 class="blog-title">{article.title}</h3>
              <p class="blog-desc">{article.desc}</p>
              <span class="blog-cta-link">Read article &rarr;</span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-footer">
      <a href="#" class="cta-outline">Browse all articles &rarr;</a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    background: var(--cream-soft);
  }

  .blog-intro {
    max-width: 600px;
    margin-bottom: 40px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-top: 3px solid transparent;
    transition: box-shadow var(--transition), transform var(--transition), border-top-color var(--transition);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-top-color: var(--amber);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  /* Image placeholder */
  .blog-img {
    height: 180px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .blog-img-pattern {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 40%, rgba(212,147,46,0.08) 100%),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 12px,
        rgba(244,239,230,0.03) 12px,
        rgba(244,239,230,0.03) 13px
      );
  }

  .blog-img-tag-wrap {
    position: relative;
    padding: 16px;
  }

  .blog-img-tag {
    background: rgba(212,147,46,0.9);
    color: var(--ink);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .blog-tag {
    color: var(--amber-deep);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-read {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .blog-title {
    font-family: var(--f-display);
    font-size: clamp(17px, 1.8vw, 21px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .blog-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.5;
    flex: 1;
  }

  .blog-cta-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--amber-deep);
    margin-top: 8px;
    transition: color var(--transition);
  }

  .blog-card:hover .blog-cta-link {
    color: var(--ink);
  }

  .blog-footer {
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
