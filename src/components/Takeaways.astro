---
const facts = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L12.5 7.5H18L13.5 11L15.5 17L10 13.5L4.5 17L6.5 11L2 7.5H7.5L10 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>`,
    stat: "$1,500",
    unit: "– $10,000",
    label: "Fixed-price projects",
    body: "Every quote is fixed-scope — no hourly billing, no retainer creep. You know the number before you sign anything.",
    dark: true,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"/><path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    stat: "4",
    unit: "–10 wks",
    label: "Discovery to live launch",
    body: "Starter sites ship in 4–6 weeks. Growth builds in 6–10 weeks. Timeline depends on your feedback speed, not ours.",
    dark: false,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10.5L8 14.5L16 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    stat: "90+",
    unit: "PageSpeed",
    label: "Core Web Vitals in the green",
    body: "Every site launches with LCP under 2.5s, INP under 200ms, and all three Core Web Vitals passing in Search Console.",
    dark: false,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2C6 2 3 5 3 9c0 5 7 11 7 11s7-6 7-11c0-4-3-7-7-7z" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="9" r="2.5" stroke="currentColor" stroke-width="1.4"/></svg>`,
    stat: "20+",
    unit: "cities",
    label: "Across Maryland",
    body: "Baltimore, Annapolis, Frederick, Bethesda, Rockville, Silver Spring — and everywhere in between. On-site meetings within 90 min of DC.",
    dark: false,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 10a7 7 0 1014 0A7 7 0 003 10z" stroke="currentColor" stroke-width="1.4"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    stat: "4 hr",
    unit: "SLA",
    label: "Monthly care plans from $150",
    body: "Updates, backups, security monitoring, and a 4-hour support SLA. Direct access to the founder — not a help-desk ticket.",
    dark: false,
  },
];
---

<section class="tk-section section-pad-sm" id="takeaways">
  <div class="container">

    <div class="tk-header">
      <p class="eyebrow">Quick facts</p>
      <h2 class="h2-section tk-h2">What you get from a WordPress project with us</h2>
      <p class="tk-sub lead">Five things every Maryland client should know before we start talking numbers.</p>
    </div>

    <div class="tk-grid">
      {facts.map((f) => (
        <div class={`tk-card${f.dark ? ' tk-card--dark' : ''}`}>
          <div class="tk-card-top">
            <span class="tk-icon" aria-hidden="true" set:html={f.icon} />
            <div class="tk-stat">
              <span class="tk-num">{f.stat}</span><span class="tk-unit">{f.unit}</span>
            </div>
          </div>
          <div class="tk-label">{f.label}</div>
          <p class="tk-body">{f.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .tk-section {
    background: var(--cream-soft);
  }

  .tk-header {
    max-width: 600px;
    margin-bottom: 48px;
  }

  .tk-h2 { margin-bottom: 12px; }

  .tk-sub {
    color: var(--ink-muted);
    max-width: 52ch;
  }

  /* 5-card grid: 3 + 2 */
  .tk-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* last 2 cards span to fill the row evenly */
  .tk-card:nth-child(4) { grid-column: 1 / span 1; }
  .tk-card:nth-child(5) { grid-column: 2 / span 1; }

  @media (min-width: 901px) {
    .tk-grid {
      /* 5 cards: row 1 = 3 cards, row 2 = 2 cards centred */
      grid-template-columns: repeat(6, 1fr);
    }
    .tk-card { grid-column: span 2; }
    /* last two cards: start at col 2 and col 4 to center them */
    .tk-card:nth-child(4) { grid-column: 2 / span 2; }
    .tk-card:nth-child(5) { grid-column: 4 / span 2; }
  }

  /* ── CARD BASE ── */
  .tk-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: clamp(24px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
  }

  .tk-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: rgba(15,20,25,0.18);
  }

  /* ── DARK CARD (pricing) ── */
  .tk-card--dark {
    background: var(--ink);
    border-color: transparent;
    color: var(--cream);
  }

  .tk-card--dark:hover {
    border-color: var(--amber);
  }

  /* ── CARD INTERNALS ── */
  .tk-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .tk-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--amber-glow);
    border-radius: var(--radius-sm);
    color: var(--amber-deep);
    flex-shrink: 0;
  }

  .tk-card--dark .tk-icon {
    background: rgba(212,147,46,0.15);
    color: var(--amber);
  }

  .tk-stat {
    text-align: right;
  }

  .tk-num {
    font-family: var(--f-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--amber-deep);
  }

  .tk-card--dark .tk-num { color: var(--amber); }

  .tk-unit {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    display: block;
    text-align: right;
    margin-top: 2px;
  }

  .tk-card--dark .tk-unit { color: rgba(244,239,230,0.4); }

  .tk-label {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }

  .tk-card--dark .tk-label { color: var(--cream); }

  .tk-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-muted);
    margin: 0;
  }

  .tk-card--dark .tk-body { color: rgba(244,239,230,0.5); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .tk-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .tk-card { grid-column: span 1 !important; }
    .tk-card:nth-child(5) { grid-column: 1 / -1 !important; }
  }

  @media (max-width: 560px) {
    .tk-grid {
      grid-template-columns: 1fr;
    }
    .tk-card { grid-column: span 1 !important; }
  }
</style>
