---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import BottomFormCTA from '../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/values/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Values & Principles | Upcoming Brand",
      "description": "The nine principles Upcoming Brand operates by. How we build, how we collaborate, and what we ship — written down so clients know exactly what to expect before they sign.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".page-lead", ".values-manifesto-text"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",   "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "About",  "item": "https://upcomingbrand.com/about/" },
          { "@type": "ListItem", "position": 3, "name": "Values", "item": canonical }
        ]
      }
    }
  ]
});

const groups = [
  {
    eyebrow: "How we build",
    title: "The work",
    summary: "The technical decisions we make on every project, regardless of vertical or budget tier.",
    color: "amber",
    principles: [
      {
        num: "01",
        title: "Schema is the first artifact",
        body: "Before a single block is designed, we map your schema graph. LocalBusiness, FAQ, Service, vertical-specific types like LegalService or Dentist. Schema isn't a launch-day add-on — it's the architecture that determines what Google can do with your site for the next ten years.",
        tag: "Architecture",
      },
      {
        num: "02",
        title: "Performance is a contractual deliverable",
        body: "90+ Lighthouse on every page, every device, on launch day. Not 'something we'll look at after launch' — it's in the contract. If the site doesn't ship green, we don't invoice the final milestone. Core Web Vitals tracking continues for 30 days post-launch.",
        tag: "Engineering",
      },
      {
        num: "03",
        title: "Custom blocks beat page builders",
        body: "Page builders look fast in a demo and become a maintenance tax for ten years. We build custom Gutenberg blocks for the content patterns you actually use, then hand you a site you (or any other developer) can edit without negotiating with a $400/year plugin license.",
        tag: "Tooling",
      },
    ],
  },
  {
    eyebrow: "How we collaborate",
    title: "The relationship",
    summary: "How we work with you day-to-day. Designed for clients who'd rather see the build than hear a status update about it.",
    color: "ink",
    principles: [
      {
        num: "04",
        title: "Async by default, sync only when it matters",
        body: "Discovery is sync. Launch coordination is sync. Everything in between happens in writing on a private staging URL with comment threads. Faster decisions, written record, no calendar Tetris. We respond within 4 business hours during business days.",
        tag: "Communication",
      },
      {
        num: "05",
        title: "One channel of accountability",
        body: "The person you book the discovery call with is the same person who writes your schema, builds your blocks, runs your Lighthouse audits, and ships your launch. No account managers. No project coordinators. One person responsible for the whole project landing in the green.",
        tag: "Ownership",
      },
      {
        num: "06",
        title: "Fixed-scope or we don't take it",
        body: "Hourly billing punishes clients for asking questions and lets scope creep silently bill the project. Every Upcoming Brand engagement is fixed-scope: one number agreed before code is written, with every milestone, deliverable, and dependency documented in a PDF you sign.",
        tag: "Pricing",
      },
    ],
  },
  {
    eyebrow: "What we ship",
    title: "The standard",
    summary: "The bar every project clears before we'll let it go live. If it can't, we don't ship.",
    color: "amber",
    principles: [
      {
        num: "07",
        title: "Specialists over generalists",
        body: "When a project needs a dedicated visual designer or a senior front-end engineer, we bring in a vetted specialist who's built that exact thing 20+ times. A small studio with a tight network outperforms a 50-person agency on every metric we care about.",
        tag: "Network",
      },
      {
        num: "08",
        title: "We say no to the wrong work",
        body: "We turn down about one in four inquiries — usually because the timeline is unrealistic, the brief asks us to skip schema or skip performance, or the project is the wrong fit. Saying no early protects every other client we said yes to.",
        tag: "Boundaries",
      },
      {
        num: "09",
        title: "Long-term over churn",
        body: "We'd rather work with a client for ten years than turn over twenty in one. Care plans renew month-to-month, never annually. We'll point out when you don't need us anymore. Repeat work and referrals are how the studio grows — not paid acquisition.",
        tag: "Approach",
      },
    ],
  },
];

const decisionRules = [
  {
    when: "When a brief asks us to skip schema",
    we: "We politely decline the project.",
    why: "Schema isn't optional — it's the foundation that determines what Google does with your site for the next decade.",
  },
  {
    when: "When a client requests page builders or pre-built themes",
    we: "We explain the maintenance cost and recommend custom blocks.",
    why: "Page builders look fast in demos and turn into a 10-year maintenance tax. Custom blocks ship once and stay editable forever.",
  },
  {
    when: "When scope creeps mid-project",
    we: "We pause, scope the change, send a fixed-price change order, and resume.",
    why: "Quietly absorbing scope changes leads to a 'we ran over' surprise at the end. Visibility protects both sides.",
  },
  {
    when: "When the timeline is unrealistic",
    we: "We turn down the project or propose a phased version.",
    why: "Compressed timelines force the wrong shortcuts — usually skipping schema, performance, or QA. We'd rather not start than ship something that won't perform.",
  },
  {
    when: "When a launch hits a Lighthouse score below 90",
    we: "We don't invoice the final milestone until it's green.",
    why: "It's in the contract. Performance is a deliverable, not a courtesy.",
  },
  {
    when: "When you don't need us anymore",
    we: "We tell you.",
    why: "If your site is healthy and rankings are stable, the most valuable thing we can say is 'you don't need a care plan upgrade right now.' Repeat clients are how the studio grows.",
  },
];
---
<BaseLayout
  title="Values & Principles | Upcoming Brand WordPress Studio"
  description="The nine principles Upcoming Brand operates by. How we build, how we collaborate, and what we ship — written down so clients know exactly what to expect before they sign."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">Values &amp; principles</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">Nine principles.</span>
          <span class="page-h1-line"><em class="page-h1-accent">Written down on purpose.</em></span>
          <span class="page-h1-line page-h1-italic">Non-negotiable on every project.</span>
        </h1>

        <p class="page-lead">
          These aren't marketing positions or values posters. They're the constraints we set on every project before kickoff — <strong>how we build, how we collaborate, and what we ship</strong>. If a brief asks us to violate one, we politely decline the project.
        </p>

        <div class="page-hero-ctas">
          <a href="#principles" class="lp-btn-primary">
            Read the principles
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v12M2 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/contact/" class="lp-btn-ghost">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <span class="values-tally">3</span> on how we build
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">
            <span class="values-tally">3</span> on how we collaborate
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">
            <span class="values-tally">3</span> on what we ship
          </span>
        </div>
      </div>
    </section>

    <!-- ====== MANIFESTO ====== -->
    <section class="values-manifesto">
      <div class="container">
        <div class="values-manifesto-inner">
          <span class="values-manifesto-mark" aria-hidden="true">&ldquo;</span>
          <p class="values-manifesto-text">
            We don't ship sites that look beautiful and rank for nothing. We don't bill hourly. We don't hand you off to an account manager. We don't skip schema. We don't ignore Core Web Vitals. We don't take projects that ask us to break any of these rules — <em>even when the timeline is tight or the budget is large.</em>
          </p>
          <span class="values-manifesto-attr">
            <span class="values-manifesto-attr-line" aria-hidden="true"></span>
            The Upcoming Brand operating contract
          </span>
        </div>
      </div>
    </section>

    <!-- ====== PRINCIPLES (3 grouped sections) ====== -->
    <div id="principles">
      {groups.map((group, gIdx) => (
        <section class={`values-group values-group-${group.color}`}>
          <div class="container">
            <div class="values-group-head">
              <div class="values-group-num-bar" aria-hidden="true">
                <span class="values-group-num-line"></span>
                <span class="values-group-num">{String(gIdx + 1).padStart(2, '0')}</span>
                <span class="values-group-num-of">/ 03</span>
                <span class="values-group-num-line"></span>
              </div>
              <p class="values-group-eyebrow">{group.eyebrow}</p>
              <h2 class="page-h2 values-group-h2">
                {group.title}
              </h2>
              <p class="values-group-summary">{group.summary}</p>
            </div>

            <div class="values-principles-grid">
              {group.principles.map((p) => (
                <article class="values-principle">
                  <div class="values-principle-head">
                    <span class="values-principle-num">{p.num}</span>
                    <span class="values-principle-tag">{p.tag}</span>
                  </div>
                  <h3 class="values-principle-title">{p.title}</h3>
                  <p class="values-principle-body">{p.body}</p>
                  <div class="values-principle-mark" aria-hidden="true"></div>
                </article>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- ====== DECISION FRAMEWORK ====== -->
    <section class="values-decisions">
      <div class="container">
        <div class="values-decisions-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">In practice</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 values-decisions-h2">
            Six real situations <em>and how we resolve them.</em>
          </h2>
          <p class="page-section-lead values-decisions-lead">Principles only matter if they hold up when reality pushes back. These are the recurring scenarios where the rules get tested — and what we do about them.</p>
        </div>

        <div class="values-decisions-grid">
          {decisionRules.map((d, i) => (
            <div class="values-decision">
              <span class="values-decision-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="values-decision-content">
                <div class="values-decision-when">
                  <span class="values-decision-label values-decision-label-when">When</span>
                  <p class="values-decision-text">{d.when}</p>
                </div>
                <div class="values-decision-arrow" aria-hidden="true">
                  <svg width="16" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7h17M13 1l5 6-5 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="values-decision-we">
                  <span class="values-decision-label values-decision-label-we">We</span>
                  <p class="values-decision-text values-decision-text-we">{d.we}</p>
                </div>
                <div class="values-decision-why">
                  <span class="values-decision-label values-decision-label-why">Because</span>
                  <p class="values-decision-text values-decision-text-why">{d.why}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== PLEDGE (dark) ====== -->
    <section class="values-pledge">
      <div class="container">
        <div class="values-pledge-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">The pledge</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>

          <p class="values-pledge-text">
            If you book a discovery call, sign a quote, or hire us for an audit, <em>these nine principles travel with the project.</em> They're not customised, watered down, or quietly dropped when a deadline gets tight. They're the reason clients refer us. They're the reason we still have all our hair.
          </p>

          <div class="values-pledge-sig">
            <div class="values-pledge-sig-line"></div>
            <span class="values-pledge-sig-name">Younus</span>
            <span class="values-pledge-sig-role">Founder, Upcoming Brand</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Ready to start</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            Hire a studio whose principles<br>
            <em>survive contact with reality.</em>
          </h2>
          <p class="page-cta-lead">A free 45-minute discovery call. We map your competitive set, identify the schema and Local Pack gaps, and send a fixed quote within 48 hours.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">
              Book a discovery call
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/process/" class="page-cta-ghost-light">
              See our process
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <BottomFormCTA formName="values-cta" />

  <Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(56px, 8vh, 96px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }

  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .page-eyebrow-line-light { background: rgba(212,147,46,0.5); }
  .page-eyebrow-line-amber { background: var(--amber); }

  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }

  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }

  .page-h1-line { display: block; color: var(--ink); }

  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }

  .page-h1-accent::after { display: none; }

  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }

  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .lp-btn-primary,
  .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lp-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg,
  .lp-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateY(3px); }
  .lp-btn-ghost:hover svg { transform: translate(2px, -2px); }

  .page-hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .page-trust-line {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .values-tally {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--amber);
    color: var(--ink);
    font-family: var(--f-display);
    font-size: 11px;
    font-weight: 500;
    font-style: italic;
  }

  .page-trust-dot {
    width: 3px; height: 3px;
    background: var(--ink-muted);
    border-radius: 50%;
    opacity: 0.4;
  }

  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 16px 0 0;
  }

  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-section-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 16px 0 0;
  }

  /* ===========================================
     MANIFESTO BAND
     =========================================== */
  .values-manifesto {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(72px, 10vh, 128px) 0;
    position: relative;
    overflow: hidden;
  }

  .values-manifesto::before {
    content: "";
    position: absolute;
    top: 0; left: 50%;
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,147,46,0.5), transparent);
    transform: translateX(-50%);
  }

  .values-manifesto::after {
    content: "";
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 1000px; height: 1000px;
    background: radial-gradient(circle, rgba(212,147,46,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .values-manifesto-inner {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .values-manifesto-mark {
    font-family: var(--f-display);
    font-size: 96px;
    line-height: 0.6;
    color: var(--amber);
    font-weight: 400;
    margin-bottom: 16px;
    opacity: 0.6;
  }

  .values-manifesto-text {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(22px, 3vw, 36px);
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--cream);
    margin: 0 0 32px;
  }

  .values-manifesto-text em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber);
  }

  .values-manifesto-attr {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.55);
  }

  .values-manifesto-attr-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: rgba(244,239,230,0.3);
  }

  /* ===========================================
     PRINCIPLES GROUPS
     =========================================== */
  .values-group {
    padding: clamp(64px, 9vh, 112px) 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .values-group-amber {
