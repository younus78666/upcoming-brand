---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import FinalCTA from '../../components/FinalCTA.astro';
const canonical = "https://upcomingbrand.com/about/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "About Upcoming Brand | Maryland WordPress Web Design Studio",
      "description": "Upcoming Brand is a Maryland-based WordPress web design studio. Schema-first builds, fixed-scope pricing, 90+ PageSpeed, and a remote-only process built for serious businesses.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".about-lead"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": canonical }
        ]
      }
    }
  ]
});

const beliefs = [
  {
    num: "01",
    title: "Schema is non-negotiable",
    body: "Generic agencies skip structured data because they don't understand it. We start every project with the schema map — LocalBusiness, LegalService, Dentist, FAQPage — because that's what actually helps Google classify your business correctly.",
  },
  {
    num: "02",
    title: "Fixed-scope or it doesn't ship",
    body: "Hourly billing punishes clients for asking questions. Every Upcoming Brand project ships on a fixed price agreed before code is written. Discovery, design rounds, build, launch, post-launch monitoring — one number.",
  },
  {
    num: "03",
    title: "Remote-only, async by design",
    body: "We don't do site visits, in-office meetings, or coffee shop discoveries. Zoom for the discovery call, async staging links for design rounds, weekly written status updates. Faster decisions, lower cost, no travel time.",
  },
  {
    num: "04",
    title: "Core Web Vitals are a deliverable",
    body: "Most agencies treat PageSpeed as 'something we'll look at after launch.' We treat 90+ Lighthouse scores as a contractual deliverable. If your site doesn't ship green, we don't invoice the final milestone.",
  },
];

const numbers = [
  { num: "400+", label: "Projects shipped" },
  { num: "12",   label: "Countries served" },
  { num: "18+",  label: "MD cities covered" },
  { num: "90+",  label: "Avg PageSpeed score" },
  { num: "100%", label: "Remote / async" },
  { num: "0",    label: "Hourly billing" },
];

const antiPatterns = [
  {
    wrong: "Hourly billing",
    wrongWhy: "Punishes you for asking questions and lets scope creep silently bill the project.",
    right: "Fixed-scope quotes",
    rightWhy: "One number agreed before code is written. Discovery, design, build, launch, monitoring."
  },
  {
    wrong: "Generic Bootstrap themes",
    wrongWhy: "Looks like 10,000 other sites and doesn't ship LocalBusiness or industry schema.",
    right: "Custom WordPress design",
    rightWhy: "Designed around your schema map, conversion architecture, and Local Pack strategy."
  },
  {
    wrong: "$99/month maintenance",
    wrongWhy: "A bot updates plugins. No backups, no monitoring, no Search Console eyes on rankings.",
    right: "$150 - $400 care plans",
    rightWhy: "Weekly backups, uptime monitoring, ranking watch, security patching, monthly report."
  },
  {
    wrong: "In-person meetings",
    wrongWhy: "Two hours of travel and a coffee shop discovery for 30 minutes of useful conversation.",
    right: "Zoom + async staging",
    rightWhy: "45-min discovery call, then async design rounds via private staging URL with comments."
  },
  {
    wrong: "Skipping schema",
    wrongWhy: "Generic agencies don't understand structured data, so they leave it off the project entirely.",
    right: "Schema-first architecture",
    rightWhy: "The schema map is the FIRST artifact in discovery. LocalBusiness, FAQ, Service, Industry types."
  },
  {
    wrong: "Hiding behind designers",
    wrongWhy: "Account managers relay messages between you and a designer who has never opened your stack.",
    right: "You talk to the builder",
    rightWhy: "The person who ran your discovery call writes your schema and ships your code. One channel."
  },
];
---
<BaseLayout
  title="About Upcoming Brand | Maryland WordPress Web Design Studio"
  description="Upcoming Brand is a Maryland-based WordPress web design studio. Schema-first builds, fixed-scope pricing, 90+ PageSpeed, and a remote-only process built for serious businesses."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO (centered, with strip) ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">About Upcoming Brand</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">A WordPress studio</span>
          <span class="page-h1-line"><em class="page-h1-accent">built for the way Google</em></span>
          <span class="page-h1-line page-h1-italic">actually ranks businesses now.</span>
        </h1>

        <p class="page-lead about-lead">
          Upcoming Brand is a remote-first WordPress web design studio based in Maryland. We work with <strong>law firms, medical practices, contractors, and ecommerce brands</strong> who care more about ranking and converting than about pretty hero images. Schema-first. Fixed-scope. Core Web Vitals as a deliverable.
        </p>

        <div class="page-hero-ctas">
          <a href="/contact/" class="lp-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/work/" class="lp-btn-ghost">
            See our work
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Top Rated &middot; Upwork
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">400+ projects &middot; 12 countries</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">Remote-first &middot; Zoom &middot; Async</span>
        </div>
      </div>
    </section>

    <!-- ====== ORIGIN STORY ====== -->
    <section class="about-story">
      <div class="container">
        <div class="about-story-grid">
          <div class="about-story-meta">
            <p class="page-section-eyebrow">
              <span class="page-section-eyebrow-line"></span>
              The story
            </p>
            <div class="about-story-meta-card">
              <p class="about-story-meta-label">Founded</p>
              <p class="about-story-meta-val">2024</p>
              <div class="about-story-meta-divider"></div>
              <p class="about-story-meta-label">HQ</p>
              <p class="about-story-meta-val">Maryland, USA</p>
              <div class="about-story-meta-divider"></div>
              <p class="about-story-meta-label">Model</p>
              <p class="about-story-meta-val">Remote-first studio</p>
              <div class="about-story-meta-divider"></div>
              <p class="about-story-meta-label">Pricing</p>
              <p class="about-story-meta-val">Fixed-scope only</p>
            </div>
          </div>

          <div class="about-story-content">
            <h2 class="page-h2">
              We started Upcoming Brand because <em>most agencies were optimising for the wrong thing.</em>
            </h2>
            <div class="about-story-body">
              <p>
                After 400+ WordPress projects across 12 countries, the same pattern kept showing up: clients had spent five figures with previous agencies and still couldn't crack page one. Beautiful sites. Empty Local Pack slots. Schema either missing or generic. Lighthouse scores in the 40s.
              </p>
              <p>
                The agencies hadn't done bad work — they'd done the wrong work. Hero animations instead of LocalBusiness schema. Stock photos instead of Core Web Vitals. Six rounds of logo revisions for a site that took twelve seconds to load on 4G.
              </p>
              <p>
                Upcoming Brand is the studio we wished existed when we started: schema-first, fixed-scope, remote-only, and unwilling to ship a site that doesn't earn its rankings. We work with serious businesses — law firms, medical practices, contractors, ecommerce — that need a site that ranks, converts, and keeps working long after launch.
              </p>
            </div>

            <div class="about-story-quote">
              <span class="about-story-quote-mark" aria-hidden="true">&ldquo;</span>
              <p>If schema, performance, and conversion architecture aren't on the agenda at the discovery call, you're paying an agency to build the wrong site.</p>
              <span class="about-story-quote-attr mono-tag">Founding principle</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== WHAT WE BELIEVE ====== -->
    <section class="about-beliefs">
      <div class="container">
        <div class="about-beliefs-head">
          <div class="page-eyebrow-strip page-eyebrow-strip-left">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">What we believe</span>
          </div>
          <h2 class="page-h2">
            Four principles <em>we won't bend on</em>
          </h2>
          <p class="page-section-lead">
            These aren't marketing positions. They're the constraints we set on every project before kickoff. If a brief asks us to violate one of these, we politely decline.
          </p>
        </div>

        <div class="about-beliefs-grid">
          {beliefs.map((b) => (
            <article class="about-belief-card">
              <span class="about-belief-num">{b.num}</span>
              <h3 class="about-belief-title">{b.title}</h3>
              <p class="about-belief-body">{b.body}</p>
              <div class="about-belief-line" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== BY THE NUMBERS ====== -->
    <section class="about-numbers">
      <div class="container">
        <div class="about-numbers-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">By the numbers</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 about-numbers-h2">
            Where we are <em>five years in.</em>
          </h2>
        </div>

        <div class="about-numbers-grid">
          {numbers.map((n) => (
            <div class="about-number">
              <span class="about-number-num">{n.num}</span>
              <span class="about-number-label">{n.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== WHAT WE DON'T DO (split-panel comparison) ====== -->
    <section class="about-anti">
      <div class="container">
        <div class="about-anti-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">What we don't do</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 about-anti-h2">
            Six shortcuts <em>we say no to.</em>
          </h2>
          <p class="page-section-lead about-anti-lead">
            Every other agency in our price range will say yes to all six. We don't. They're the same six things that quietly lock you into a site that ranks for nothing and converts at half the rate it should.
          </p>
        </div>

        <!-- Comparison panel -->
        <div class="anti-panel">
          <!-- Header row -->
          <div class="anti-panel-headers">
            <div class="anti-col-head anti-col-head-wrong">
              <span class="anti-col-tag">Industry standard</span>
              <h3 class="anti-col-title">Most agencies say <em>yes</em></h3>
              <p class="anti-col-sub">Six practices that quietly damage your project before launch.</p>
            </div>
            <div class="anti-col-divider" aria-hidden="true">
              <span class="anti-col-divider-label">VS</span>
            </div>
            <div class="anti-col-head anti-col-head-right">
              <span class="anti-col-tag anti-col-tag-amber">Upcoming Brand</span>
              <h3 class="anti-col-title">We say <em>no</em></h3>
              <p class="anti-col-sub">And here's exactly what we do instead, on every project.</p>
            </div>
          </div>

          <!-- Rows -->
          <div class="anti-rows">
            {antiPatterns.map((a, i) => (
              <div class="anti-row">
                <span class="anti-row-num">{String(i + 1).padStart(2, '0')}</span>

                <div class="anti-side anti-side-wrong">
                  <div class="anti-side-headline">
                    <span class="anti-side-icon anti-side-icon-no" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </span>
                    <span class="anti-side-text">{a.wrong}</span>
                  </div>
                  <p class="anti-side-why">{a.wrongWhy}</p>
                </div>

                <div class="anti-row-arrow" aria-hidden="true">
                  <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7h17M13 1l5 6-5 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>

                <div class="anti-side anti-side-right">
                  <div class="anti-side-headline">
                    <span class="anti-side-icon anti-side-icon-yes" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    <span class="anti-side-text">{a.right}</span>
                  </div>
                  <p class="anti-side-why">{a.rightWhy}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Footer -->
          <div class="anti-panel-footer">
            <div class="anti-footer-left">
              <span class="anti-footer-label">Bottom line</span>
              <p class="anti-footer-text">
                If a brief asks us to break one of these six rules, we politely decline the project. <strong>It's saved more launches than any feature ever has.</strong>
              </p>
            </div>
            <a href="/contact/" class="anti-footer-cta">
              Start a project that respects these rules
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== HOW WE WORK ====== -->
    <section class="about-how">
      <div class="container">
        <div class="about-how-grid">
          <div class="about-how-text">
            <p class="page-section-eyebrow">
              <span class="page-section-eyebrow-line"></span>
              How we work
            </p>
            <h2 class="page-h2">
              You talk to <em>the person building it.</em>
            </h2>
            <p class="about-how-body">
              No account managers. No project coordinators relaying messages. The person you discovery-called is the person who writes your schema, builds your custom blocks, runs your Core Web Vitals audits, and ships your site. One channel, one chain of accountability.
            </p>
            <p class="about-how-body">
              Discovery happens over a 45-minute Zoom call. Designs happen on a private staging URL with comment threads. Status updates happen weekly via written brief — no surprise check-ins, no "quick chats" that derail your week. Built for clients who'd rather see the build than hear about it.
            </p>
            <a href="/contact/" class="lp-btn-primary about-how-cta">
              Book a discovery call
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div class="about-how-panel">
            <div class="about-how-panel-head">
              <span class="about-how-panel-label">Our process</span>
              <span class="about-how-panel-pulse"></span>
            </div>
            <ol class="about-how-steps">
              <li class="about-how-step">
                <span class="about-how-step-num">01</span>
                <div>
                  <span class="about-how-step-title">Discovery</span>
                  <span class="about-how-step-meta">45 min &middot; Zoom &middot; Free</span>
                </div>
              </li>
              <li class="about-how-step">
                <span class="about-how-step-num">02</span>
                <div>
                  <span class="about-how-step-title">Fixed quote</span>
                  <span class="about-how-step-meta">48 hrs &middot; PDF &middot; No surprises</span>
                </div>
              </li>
              <li class="about-how-step">
                <span class="about-how-step-num">03</span>
                <div>
                  <span class="about-how-step-title">Design rounds</span>
                  <span class="about-how-step-meta">Async &middot; Staging URL &middot; 2 rounds</span>
                </div>
              </li>
              <li class="about-how-step">
                <span class="about-how-step-num">04</span>
                <div>
                  <span class="about-how-step-title">Build &amp; schema</span>
                  <span class="about-how-step-meta">Custom blocks &middot; LocalBusiness schema</span>
                </div>
              </li>
              <li class="about-how-step">
                <span class="about-how-step-num">05</span>
                <div>
                  <span class="about-how-step-title">Launch</span>
                  <span class="about-how-step-meta">90+ Lighthouse &middot; 30-day Search Console watch</span>
                </div>
              </li>
            </ol>
            <a href="/process/" class="about-how-link">
              See the full process
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
</main>

<FinalCTA />
<Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM (reused across content pages)
     =========================================== */

  /* Mono tag */
  .mono-tag {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 400;
  }

  /* Page hero (centered) */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(56px, 8vh, 96px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  /* Eyebrow strip — centered with horizontal lines */
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }

  .page-eyebrow-strip-left {
    justify-content: flex-start;
  }

  .page-eyebrow-line {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .page-eyebrow-line-light {
    background: rgba(212,147,46,0.5);
  }

  .page-eyebrow-line-amber {
    background: var(--amber);
  }

  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }

  .page-eyebrow-text-light {
    color: rgba(244,239,230,0.7);
  }

  /* Page H1 */
  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }

  .page-h1-line {
    display: block;
    color: var(--ink);
  }

  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }

  .page-h1-accent::after { display: none; }

  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  /* Page lead */
  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }

  .page-lead strong {
    font-weight: 600;
    color: var(--ink);
  }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  /* Reuse city-page button system */
  .lp-btn-primary,
  .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lp-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg,
  .lp-btn-ghost  svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }
  .lp-btn-ghost:hover   svg { transform: translate(2px, -2px); }

  .page-hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .page-trust-line {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .page-trust-dot {
    width: 3px;
    height: 3px;
    background: var(--ink-muted);
    border-radius: 50%;
    opacity: 0.4;
  }

  /* Section eyebrow (left-aligned variant) */
  .page-section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber-deep);
    margin: 0;
    font-weight: 500;
  }

  .page-section-eyebrow-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--amber);
  }

  /* Page H2 */
  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 16px 0 0;
  }

  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-section-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 16px 0 0;
  }

  /* ===========================================
     ABOUT-PAGE-SPECIFIC SECTIONS
     =========================================== */

  /* Story */
  .about-story {
    background: var(--paper);
    padding: clamp(56px, 8vh, 96px) 0;
    border-bottom: 1px solid var(--line);
  }

  .about-story-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: flex-start;
  }

  .about-story-meta {
    position: sticky;
    top: 24px;
  }

  .about-story-meta-card {
    margin-top: 24px;
    padding: 24px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .about-story-meta-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 4px;
  }

  .about-story-meta-val {
    font-family: var(--f-display);
    font-size: 18px;
    color: var(--ink);
    margin: 0;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .about-story-meta-divider {
    height: 1px;
    background: var(--line);
    margin: 16px 0;
    border-top: 1px dashed var(--line);
    background: transparent;
  }

  .about-story-body {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .about-story-body p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0;
  }

  .about-story-quote {
    margin-top: 36px;
    padding: 28px 32px;
    background: var(--cream);
    border-left: 3px solid var(--amber);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    position: relative;
  }

  .about-story-quote-mark {
    position: absolute;
    top: 0;
    left: 18px;
    font-family: var(--f-display);
    font-size: 64px;
    color: var(--amber);
    opacity: 0.25;
    line-height: 1;
  }

  .about-story-quote p {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 14px;
    position: relative;
    z-index: 1;
  }

  .about-story-quote-attr {
    color: var(--amber-deep);
  }

  /* Beliefs */
  .about-beliefs {
    background: var(--cream);
    padding: clamp(56px, 8vh, 96px) 0;
    border-bottom: 1px solid var(--line);
  }

  .about-beliefs-head {
    max-width: 720px;
    margin-bottom: 48px;
  }

  .about-beliefs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .about-belief-card {
    padding: 32px 28px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .about-belief-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--amber);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.4s ease;
  }

  .about-belief-card:hover {
    border-color: var(--amber);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(212,147,46,0.12);
  }

  .about-belief-card:hover::before {
    transform: scaleY(1);
  }

  .about-belief-num {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--amber-deep);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .about-belief-title {
    font-family: var(--f-display);
    font-size: 22px;
    line-height: 1.2;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 14px 0 12px;
  }

  .about-belief-body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  .about-belief-line {
    position: absolute;
    bottom: 0;
    right: 24px;
    width: 32px;
    height: 1px;
    background: var(--amber);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .about-belief-card:hover .about-belief-line {
    opacity: 1;
  }

  /* Numbers (dark band) */
  .about-numbers {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(56px, 8vh, 96px) 0;
    position: relative;
    overflow: hidden;
  }

  .about-numbers::before {
    content: "";
    position: absolute;
    top: 0; left: 50%;
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,147,46,0.5), transparent);
    transform: translateX(-50%);
  }

  .about-numbers::after {
    content: "";
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .about-numbers-head {
    text-align: center;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .about-numbers-h2 {
    color: var(--cream);
  }

  .about-numbers-h2 em {
    color: var(--amber);
  }

  .about-numbers-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    position: relative;
    z-index: 1;
    border-top: 1px dashed rgba(244,239,230,0.15);
    border-bottom: 1px dashed rgba(244,239,230,0.15);
  }

  .about-number {
    padding: 36px 20px;
    text-align: center;
    border-right: 1px dashed rgba(244,239,230,0.15);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .about-number:last-child {
    border-right: none;
  }

  .about-number-num {
    font-family: var(--f-display);
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    color: var(--amber);
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  .about-number-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.55);
  }

  /* ===========================================
     ANTI-PATTERNS — split-panel comparison
     =========================================== */
  .about-anti {
    background: var(--paper);
    padding: clamp(56px, 8vh, 96px) 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .about-anti::before {
    content: "";
    position: absolute;
    top: 30%; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse, rgba(212,147,46,0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .about-anti-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto clamp(40px, 6vh, 64px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .about-anti-h2 {
    text-align: center;
  }

  .about-anti-lead {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  /* Panel */
  .anti-panel {
    max-width: 1100px;
    margin: 0 auto;
    background: var(--cream);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    position: relative;
    z-index: 1;
  }

  .anti-panel::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, rgba(176,74,62,0.4) 0%, var(--amber) 50%, rgba(92,128,64,0.5) 100%);
  }

  /* Header row */
  .anti-panel-headers {
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    gap: 0;
    padding: 32px 36px 28px;
    border-bottom: 1px dashed var(--line);
    background: linear-gradient(180deg, var(--paper) 0%, transparent 100%);
  }

  .anti-col-head {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .anti-col-head-wrong {
    padding-right: 20px;
  }

  .anti-col-head-right {
    padding-left: 20px;
  }

  .anti-col-tag {
    display: inline-flex;
    align-self: flex-start;
    padding: 4px 12px;
    background: rgba(15,20,25,0.06);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
  }

  .anti-col-tag-amber {
    background: rgba(212,147,46,0.12);
    color: var(--amber-deep);
  }

  .anti-col-title {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.5vw, 30px);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .anti-col-title em {
    font-style: italic;
    font-weight: 300;
  }

  .anti-col-head-wrong .anti-col-title em {
    color: var(--red);
    opacity: 0.85;
  }

  .anti-col-head-right .anti-col-title em {
    color: var(--amber-deep);
  }

  .anti-col-sub {
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-muted);
    margin: 4px 0 0;
  }

  .anti-col-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .anti-col-divider::before {
    content: "";
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--line), transparent);
    transform: translateX(-50%);
  }

  .anti-col-divider-label {
    position: relative;
    z-index: 1;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--cream);
    border: 1.5px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
  }

  /* Rows */
  .anti-rows {
    display: flex;
    flex-direction: column;
  }

  .anti-row {
    display: grid;
    grid-template-columns: 36px 1fr 60px 1fr;
    gap: 0;
    padding: 22px 24px;
    border-bottom: 1px dashed var(--line);
    align-items: stretch;
    position: relative;
    transition: background 0.2s ease;
  }

  .anti-row:last-child {
    border-bottom: none;
  }

  .anti-row:hover {
    background: var(--paper);
  }

  .anti-row::before {
    content: "";
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--line);
    transform: translateX(-50%);
    opacity: 0.5;
  }

  .anti-row-num {
    font-family: var(--f-display);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-muted);
    opacity: 0.5;
    align-self: center;
    text-align: center;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .anti-row:hover .anti-row-num {
    color: var(--amber-deep);
    opacity: 1;
  }

  .anti-side {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 20px;
  }

  .anti-side-headline {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
  }

  .anti-side-wrong .anti-side-headline {
    color: var(--ink-muted);
  }

  .anti-side-wrong .anti-side-text {
    text-decoration: line-through;
    text-decoration-color: rgba(176,74,62,0.45);
    text-decoration-thickness: 1.5px;
  }

  .anti-side-right .anti-side-headline {
    color: var(--ink);
  }

  .anti-side-icon {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .anti-side-icon-no {
    background: rgba(176,74,62,0.1);
    color: var(--red);
  }

  .anti-side-icon-yes {
    background: rgba(92,128,64,0.12);
    color: var(--green);
  }

  .anti-side-why {
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 0;
    padding-left: 32px;
  }

  .anti-side-right .anti-side-why {
    color: var(--ink-soft);
  }

  .anti-row-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber);
    opacity: 0.45;
    transition: all 0.3s ease;
  }

  .anti-row:hover .anti-row-arrow {
    opacity: 1;
    color: var(--amber-deep);
    transform: translateX(2px);
  }

  /* Panel footer */
  .anti-panel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: 28px 36px;
    background: linear-gradient(180deg, transparent 0%, var(--paper) 100%);
    border-top: 1px dashed var(--line);
  }

  .anti-footer-left {
    flex: 1;
    max-width: 560px;
  }

  .anti-footer-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    display: block;
    margin-bottom: 6px;
  }

  .anti-footer-text {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  .anti-footer-text strong {
    font-weight: 600;
    color: var(--ink);
  }

  .anti-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber-deep);
    text-decoration: none;
    padding: 12px 18px;
    background: rgba(212,147,46,0.08);
    border: 1px solid rgba(212,147,46,0.25);
    border-radius: var(--radius-pill);
    transition: all var(--transition);
    flex-shrink: 0;
    font-weight: 500;
  }

  .anti-footer-cta:hover {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--ink);
    transform: translateY(-2px);
  }

  .anti-footer-cta svg {
    transition: transform 0.22s ease;
  }

  .anti-footer-cta:hover svg {
    transform: translateX(3px);
  }

  /* How we work */
  .about-how {
    background: var(--cream);
    padding: clamp(56px, 8vh, 96px) 0;
  }

  .about-how-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: center;
  }

  .about-how-text {
    max-width: 540px;
  }

  .about-how-body {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-top: 20px;
  }

  .about-how-cta {
    margin-top: 28px;
  }

  .about-how-panel {
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .about-how-panel::before {
    content: "";
    position: absolute;
    top: -1px; left: 24px; right: 24px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    opacity: 0.6;
  }

  .about-how-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    border-bottom: 1px dashed var(--line);
    margin-bottom: 18px;
  }

  .about-how-panel-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .about-how-panel-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: page-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 0 4px rgba(92,128,64,0.15);
  }

  @keyframes page-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .about-how-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .about-how-step {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 14px;
    align-items: center;
    padding-bottom: 14px;
    border-bottom: 1px dashed var(--line);
  }

  .about-how-step:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about-how-step-num {
    font-family: var(--f-display);
    font-size: 22px;
    color: var(--amber);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
  }

  .about-how-step-title {
    display: block;
    font-size: 15px;
    color: var(--ink);
    font-weight: 600;
  }

  .about-how-step-meta {
    display: block;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    margin-top: 2px;
    text-transform: uppercase;
  }

  .about-how-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 20px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber-deep);
    text-decoration: none;
    transition: gap 0.3s ease, color var(--transition);
  }

  .about-how-link:hover {
    gap: 10px;
    color: var(--ink);
  }

  /* ===========================================
     PAGE FINAL CTA (shared)
     =========================================== */
  .page-cta {
    background: var(--ink);
    padding: clamp(72px, 10vh, 112px) 0;
    position: relative;
    overflow: hidden;
  }

  .page-cta::before {
    content: "";
    position: absolute;
    top: -300px; left: -200px;
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-cta::after {
    content: "";
    position: absolute;
    bottom: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,147,46,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-cta-inner {
    max-width: 720px;
    text-align: center;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .page-cta-h2 {
    color: var(--cream);
    margin-top: 8px;
  }

  .page-cta-h2 em {
    color: var(--amber);
  }

  .page-cta-lead {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(244,239,230,0.65);
    max-width: 56ch;
    margin: 0 auto;
  }

  .page-cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  .page-cta-primary {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--ink);
  }

  .page-cta-primary:hover {
    background: var(--cream);
    border-color: var(--cream);
    color: var(--ink);
  }

  .page-cta-ghost-light {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1.5px solid rgba(244,239,230,0.2);
    color: var(--cream);
    background: transparent;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
