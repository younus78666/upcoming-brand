---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import BottomFormCTA from '../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/pricing/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Website Cost & Design Packages | Upcoming Brand",
      "description": "Fixed-scope WordPress website cost. Three packages from $1,500 (Starter, 8 pages) to $6,000+ (Custom WooCommerce / IDX). One number, agreed before code is written. No hourly billing.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-02",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".tier-price"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",    "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Pricing", "item": canonical }
        ]
      }
    },
    {
      "@type": "Product",
      "@id": `${canonical}#starter`,
      "name": "Starter WordPress Website",
      "description": "8-page custom WordPress build with LocalBusiness schema, custom design, and Core Web Vitals green on delivery. Fixed scope, 4-6 week delivery.",
      "brand": { "@id": "https://upcomingbrand.com/#organization" },
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      }
    },
    {
      "@type": "Product",
      "@id": `${canonical}#growth`,
      "name": "Growth WordPress Website",
      "description": "15-20 page WordPress site with custom design, city landing pages, and full Local Pack optimization. Fixed scope, 6-8 week delivery.",
      "brand": { "@id": "https://upcomingbrand.com/#organization" },
      "offers": {
        "@type": "Offer",
        "price": "3500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      }
    },
    {
      "@type": "Product",
      "@id": `${canonical}#custom`,
      "name": "Custom WordPress Build",
      "description": "WooCommerce, IDX integration, multi-location schema, or complex booking systems. Custom-scoped projects starting from $6,000.",
      "brand": { "@id": "https://upcomingbrand.com/#organization" },
      "offers": {
        "@type": "Offer",
        "price": "6000",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      }
    }
  ]
});

const costFactors = [
  {
    num: "01",
    factor: "Number of pages",
    detail: "Starter is 8 pages. Growth is 15-20. Custom can hit 50+ pages with city, service, and portfolio combinations.",
    impact: "+$1,500 to +$3,000 between tiers",
  },
  {
    num: "02",
    factor: "Custom design vs template",
    detail: "Custom design in Figma with bespoke Gutenberg blocks costs more than template-based work. We don't do templates.",
    impact: "Always custom; baked into base price",
  },
  {
    num: "03",
    factor: "Schema + SEO scope",
    detail: "Basic LocalBusiness vs vertical-specific (LegalService, Dentist, IDX, multi-location) drives complexity and price.",
    impact: "+$500 to +$2,000 for advanced schema",
  },
  {
    num: "04",
    factor: "WooCommerce or integrations",
    detail: "Adding WooCommerce, IDX feeds, booking systems, or custom plugin development pushes pricing into the Custom tier.",
    impact: "From $4,500 (basic Woo) to $15,000+ (custom)",
  },
  {
    num: "05",
    factor: "Migration vs new build",
    detail: "Migrating from Wix, Squarespace, or GoDaddy adds redirect mapping and content extraction work. Net new builds are simpler.",
    impact: "+$750 to +$1,500 for migration",
  },
  {
    num: "06",
    factor: "Content production",
    detail: "We write copy on every project. Photography or video production from outside specialists is scoped separately when needed.",
    impact: "Copy included; media variable",
  },
];

const tiers = [
  {
    id: "starter",
    badge: "Solo + small business",
    name: "Starter",
    price: "$1,500",
    priceFrom: false,
    note: "Fixed scope · 4-6 weeks",
    summary: "A custom 8-page WordPress site for solo practitioners and small businesses ready to graduate from Wix or Squarespace.",
    highlight: false,
    cta: "Start with Starter",
    includes: [
      "8 custom-designed pages",
      "Custom WordPress theme (no page builders)",
      "LocalBusiness + FAQPage schema",
      "Mobile-first responsive design",
      "Contact form with spam protection",
      "Google Analytics 4 setup",
      "90+ Lighthouse on every page",
      "30-day post-launch monitoring",
      "Two structured design rounds",
      "1 year of training + support included",
    ],
    notIncluded: [
      "WooCommerce / e-commerce",
      "Custom integrations (CRM, IDX, booking)",
      "City / service landing page set",
    ],
  },
  {
    id: "growth",
    badge: "Most chosen",
    name: "Growth",
    price: "$3,500",
    priceFrom: false,
    note: "Fixed scope · 6-8 weeks",
    summary: "The full local-business build: city landing pages, vertical-specific schema, and the Local Pack optimization stack we use on every project.",
    highlight: true,
    cta: "Choose Growth",
    includes: [
      "Everything in Starter, plus:",
      "15-20 custom-designed pages",
      "Vertical-specific schema (LegalService, Dentist, etc.)",
      "Up to 5 city / service landing pages",
      "Internal linking strategy + execution",
      "Advanced contact + intake forms",
      "Conversion-focused design system",
      "Three structured design rounds",
      "Search Console + Bing Webmaster setup",
      "60-day post-launch monitoring",
    ],
    notIncluded: [
      "WooCommerce / IDX / multi-location",
      "Custom plugin development",
    ],
  },
  {
    id: "custom",
    badge: "WooCommerce / IDX / Enterprise",
    name: "Custom",
    price: "$6,000+",
    priceFrom: true,
    note: "Custom scope · 8-10 weeks",
    summary: "WooCommerce, real estate IDX, multi-location schema, booking systems, or anything outside the Starter / Growth scope. Custom-quoted after discovery.",
    highlight: false,
    cta: "Scope a Custom build",
    includes: [
      "Everything in Growth, plus:",
      "WooCommerce, IDX, or booking integration",
      "Multi-location LocalBusiness schema",
      "Custom plugin or block development",
      "Subscription / membership systems",
      "Payment gateway integration (Stripe / Auth.net)",
      "Custom intake / qualification flows",
      "Multi-language or multi-region setup",
      "Four structured design rounds",
      "90-day post-launch monitoring",
    ],
    notIncluded: [],
  },
];

const baseline = [
  { area: "Schema architecture",  detail: "LocalBusiness, FAQ, Service, and vertical types mapped before design begins" },
  { area: "Custom WordPress",      detail: "No page builders, no $400/year plugin licences. Editable forever." },
  { area: "Core Web Vitals",       detail: "90+ Lighthouse on every page on launch day. Contractually." },
  { area: "Mobile-first design",   detail: "Designed for phones first, scaled up to desktop. 70%+ of your traffic is mobile." },
  { area: "Async-first build",     detail: "Private staging URL, comment-thread feedback, weekly written status updates." },
  { area: "Direct founder access", detail: "The person on your discovery call writes your schema and ships your site." },
  { area: "Fixed-scope quote",     detail: "One number, agreed before code is written. No hourly billing, ever." },
  { area: "Post-launch monitoring", detail: "30-90 days of Search Console + Core Web Vitals watch on every project." },
];

const addons = [
  {
    name: "Care plan",
    price: "From $150/mo",
    description: "WordPress core + plugin updates, off-site backups, uptime monitoring, security patching, 4-hour SLA. Month-to-month.",
    icon: "shield",
  },
  {
    name: "SEO audit",
    price: "$1,500",
    description: "Schema, performance, Core Web Vitals, Local Pack, and content gap audit with a prioritised action list. Credited toward a build.",
    icon: "search",
  },
  {
    name: "City landing pages",
    price: "$200 / page",
    description: "Add additional city or service pages after launch. Includes content, schema, and internal linking. Bulk discounts at 10+.",
    icon: "pin",
  },
  {
    name: "Speed sprint",
    price: "$2,500",
    description: "Two-week Core Web Vitals optimization on an existing site. Targets 90+ Lighthouse without a full redesign.",
    icon: "zap",
  },
  {
    name: "Schema retrofit",
    price: "$1,000",
    description: "Add LocalBusiness, FAQ, and vertical schema to an existing site. Includes structured data testing and Search Console verification.",
    icon: "code",
  },
  {
    name: "Migration",
    price: "From $750",
    description: "Wix, Squarespace, GoDaddy, or outdated WordPress to custom WordPress. Includes 301 redirect map and zero-downtime cutover.",
    icon: "transfer",
  },
];

const faqs = [
  {
    q: "Why fixed-scope and not hourly?",
    a: "Hourly billing punishes clients for asking questions and lets scope creep silently bill the project. With fixed-scope, you know the number before code is written. We document every milestone, deliverable, and dependency in a PDF you sign. If the scope changes, we send a written change order with a new fixed price you approve before work resumes.",
  },
  {
    q: "What does 'WordPress website cost' actually include?",
    a: "Every Upcoming Brand build includes design, custom WordPress development, schema architecture, mobile responsive design, contact forms, GA4 setup, Core Web Vitals optimization, two design rounds, and 30+ days of post-launch monitoring. Hosting, domain registration, premium plugin licenses, and stock photography are paid by you and itemised in the quote.",
  },
  {
    q: "Are there cheaper WordPress packages out there?",
    a: "Yes, and they exist for a reason. $400 builds skip schema, ship without Core Web Vitals optimization, use generic Bootstrap themes, and often render in $99/month maintenance hostage situations. We're not the cheapest option in the market. We're the best fit for businesses that need their site to actually rank, convert, and stay maintainable for the next ten years.",
  },
  {
    q: "Can I pay in installments?",
    a: "Yes. The standard milestone schedule is 40% deposit, 30% on design approval, 30% on launch. For projects over $10,000 we accept ACH and wire transfer. Credit card fees are absorbed by us. We don't offer financing or payment plans beyond the milestone schedule, but we'll work with you on milestone timing if cash flow is a concern.",
  },
  {
    q: "What if I need ongoing changes after launch?",
    a: "Care plans cover small content updates as part of the monthly fee. Larger ongoing work (new landing pages, feature additions, major redesigns) is quoted as a separate fixed-scope project. We don't bill hourly for post-launch work either. Every change has a fixed price agreed before work begins.",
  },
  {
    q: "Do prices include hosting and domain?",
    a: "No, but we recommend specific hosts at three price points (budget, mid-tier, enterprise) and handle the entire setup, migration, and DNS cutover as part of every project. You own the hosting account so you keep control. Care plans cover server-level monitoring and backups regardless of which host you choose.",
  },
];
---
<BaseLayout
  title="How Much Does a WordPress Website Cost? | Pricing & Packages | Upcoming Brand"
  description="How much does a WordPress website cost? Fixed-scope WordPress pricing from $1,500 (Starter, 8 pages) to $6,000+ (Custom). Small business website design packages, transparent pricing, no hourly billing."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">WordPress website cost &amp; pricing</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">WordPress website cost,</span>
          <span class="page-h1-line"><em class="page-h1-accent">written down up front.</em></span>
          <span class="page-h1-line page-h1-italic">Three fixed-scope packages.</span>
        </h1>

        <p class="page-lead">
          Three tiers (Starter, Growth, Custom) ranging <strong>$1,500 to $6,000+</strong>. Wondering <strong>how much a WordPress website costs</strong>? Fixed-scope means one price agreed before code is written. No hourly billing. No surprise invoices. No quote that doubles between discovery and launch.
        </p>

        <div class="page-hero-ctas">
          <a href="#tiers" class="lp-btn-primary">
            See the packages
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v12M2 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/contact/" class="lp-btn-ghost">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">Fixed-scope only</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">90+ PageSpeed guaranteed</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">6-10 week delivery</span>
        </div>
      </div>
    </section>

    <!-- ====== DEFINITION (Know intent + AI Overview citation) ====== -->
    <section class="pricing-define">
      <div class="container">
        <div class="pricing-define-card">
          <div class="pricing-define-head">
            <span class="pricing-define-pulse" aria-hidden="true"></span>
            <span class="pricing-define-label">The straight answer</span>
          </div>
          <h2 class="page-h2 pricing-define-h2">
            How much does a WordPress website cost?
          </h2>
          <p class="pricing-define-answer">
            <strong>A custom WordPress website costs $1,500 to $15,000 for most small-to-mid business projects in 2026, with enterprise builds reaching $20,000-$80,000+.</strong> The price depends on number of pages, design complexity, schema scope, integrations (WooCommerce, IDX, multi-location), and whether the engagement is a new build or migration. Hourly WordPress designer rates run $80-$200/hr; the higher-quality firms have moved to fixed-scope pricing instead.
          </p>

          <div class="pricing-define-ranges">
            <div class="pricing-define-range">
              <span class="pricing-define-range-label">DIY / freelance marketplace</span>
              <span class="pricing-define-range-price">$200 - $2,000</span>
              <span class="pricing-define-range-note">Theme-based, no schema, no performance guarantees</span>
            </div>
            <div class="pricing-define-range pricing-define-range-amber">
              <span class="pricing-define-range-label">Mid-tier custom (Starter / Growth)</span>
              <span class="pricing-define-range-price">$1,500 - $6,000</span>
              <span class="pricing-define-range-note">Custom design, schema, 90+ Lighthouse, fixed-scope</span>
            </div>
            <div class="pricing-define-range">
              <span class="pricing-define-range-label">Custom / enterprise</span>
              <span class="pricing-define-range-price">$6,000 - $80,000+</span>
              <span class="pricing-define-range-note">WooCommerce, IDX, multi-location, custom plugins</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== COST FACTORS (Component frame) ====== -->
    <section class="pricing-factors">
      <div class="container">
        <div class="pricing-factors-head">
          <p class="pricing-section-eyebrow">
            <span class="pricing-section-eyebrow-line"></span>
            What drives the price
          </p>
          <h2 class="page-h2">
            Six factors <em>that move the WordPress website cost.</em>
          </h2>
          <p class="page-section-lead">A WordPress website cost calculator is rarely accurate because every project's mix is different. These six factors explain the actual variance between a $1,500 Starter and a $15,000 Custom build.</p>
        </div>

        <div class="pricing-factors-grid">
          {costFactors.map((c) => (
            <article class="pricing-factor-card">
              <span class="pricing-factor-num">{c.num}</span>
              <h3 class="pricing-factor-title">{c.factor}</h3>
              <p class="pricing-factor-detail">{c.detail}</p>
              <span class="pricing-factor-impact">{c.impact}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="pricing-tiers" id="tiers">
      <div class="container">
        <div class="pricing-tiers-head">
          <p class="pricing-section-eyebrow">
            <span class="pricing-section-eyebrow-line"></span>
            Three packages
          </p>
          <h2 class="page-h2">
            One price. <em>Agreed before code is written.</em>
          </h2>
          <p class="page-section-lead">Every quote is fixed-scope, documented in a PDF, and held at the stated price for 30 days. The Growth tier is what most clients choose.</p>
        </div>

        <div class="pricing-tiers-grid">
          {tiers.map((t) => (
            <article class={`pricing-tier ${t.highlight ? 'pricing-tier-highlight' : ''}`} id={t.id}>
              {t.highlight && (
                <span class="pricing-tier-flag">
                  <span class="pricing-tier-flag-dot" aria-hidden="true"></span>
                  Most chosen
                </span>
              )}

              <div class="pricing-tier-head">
                <span class="pricing-tier-badge">{t.badge}</span>
                <h3 class="pricing-tier-name">{t.name}</h3>
                <p class="pricing-tier-summary">{t.summary}</p>
              </div>

              <div class="pricing-tier-price-block">
                {t.priceFrom && <span class="pricing-tier-price-from">From</span>}
                <span class="tier-price pricing-tier-price">{t.price}</span>
                <span class="pricing-tier-price-note">{t.note}</span>
              </div>

              <a href="/contact/" class={`pricing-tier-cta ${t.highlight ? 'pricing-tier-cta-amber' : ''}`}>
                {t.cta}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>

              <div class="pricing-tier-divider">
                <span class="pricing-tier-divider-label">What's included</span>
              </div>

              <ul class="pricing-tier-includes">
                {t.includes.map((item) => (
                  <li>
                    <span class="pricing-tier-check" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>

              {t.notIncluded.length > 0 && (
                <ul class="pricing-tier-excludes">
                  {t.notIncluded.map((item) => (
                    <li>
                      <span class="pricing-tier-x" aria-hidden="true">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>

        <div class="pricing-tiers-foot">
          <span class="pricing-tiers-foot-label">All tiers include:</span>
          <span class="pricing-tiers-foot-pills">
            <span class="pricing-foot-pill">Schema-first</span>
            <span class="pricing-foot-pill">90+ Lighthouse</span>
            <span class="pricing-foot-pill">Mobile-first</span>
            <span class="pricing-foot-pill">Direct founder</span>
            <span class="pricing-foot-pill">Async build</span>
            <span class="pricing-foot-pill">Post-launch monitoring</span>
          </span>
        </div>
      </div>
    </section>

    <!-- ====== BASELINE ====== -->
    <section class="pricing-baseline">
      <div class="container">
        <div class="pricing-baseline-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">In every project</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 pricing-baseline-h2">
            Eight things every project<br>
            <em>ships with.</em>
          </h2>
          <p class="pricing-baseline-lead">Tier-independent. The Starter package gets the same engineering bar as a Custom build. Only scope and complexity change.</p>
        </div>

        <div class="pricing-baseline-grid">
          {baseline.map((b, i) => (
            <article class="pricing-baseline-card">
              <span class="pricing-baseline-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="pricing-baseline-area">{b.area}</h3>
              <p class="pricing-baseline-detail">{b.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== ADD-ONS ====== -->
    <section class="pricing-addons">
      <div class="container">
        <div class="pricing-addons-head">
          <p class="pricing-section-eyebrow">
            <span class="pricing-section-eyebrow-line"></span>
            Add-ons &amp; standalone services
          </p>
          <h2 class="page-h2">
            Audits, sprints, <em>and ongoing care.</em>
          </h2>
          <p class="page-section-lead">Standalone engagements for clients who don't need a full rebuild. Each one is a fixed-scope quote, same as our project work.</p>
        </div>

        <div class="pricing-addons-grid">
          {addons.map((a) => (
            <article class="pricing-addon">
              <div class="pricing-addon-head">
                <span class="pricing-addon-icon" aria-hidden="true">
                  {a.icon === "shield" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  )}
                  {a.icon === "search" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  )}
                  {a.icon === "pin" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  )}
                  {a.icon === "zap" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  )}
                  {a.icon === "code" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  )}
                  {a.icon === "transfer" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                  )}
                </span>
                <span class="pricing-addon-price">{a.price}</span>
              </div>
              <h3 class="pricing-addon-name">{a.name}</h3>
              <p class="pricing-addon-desc">{a.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="pricing-faq">
      <div class="container">
        <div class="pricing-faq-head">
