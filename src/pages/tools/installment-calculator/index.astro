<script is:inline>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      const projectsEl = document.getElementById('ic-projects');
      const catTabsEl = document.getElementById('ic-cat-tabs');
      const customAmountEl = document.getElementById('ic-custom-amount');
      const customApplyEl = document.getElementById('ic-custom-apply');
      const depositSlider = document.getElementById('ic-deposit');
      const depositVal = document.getElementById('ic-deposit-val');
      const termTabs = document.querySelectorAll('.ic-term-tab');
      const termVal = document.getElementById('ic-term-val');
      const trafficEl = document.getElementById('ic-traffic');
      const aovEl = document.getElementById('ic-aov');

      const resultCard = document.querySelector('.ic-result-card');
      const resultName = document.getElementById('ic-result-name');
      const resultDeposit = document.getElementById('ic-result-deposit');
      const resultMonthly = document.getElementById('ic-result-monthly');
      const resultMonthlyMeta = document.getElementById('ic-result-monthly-meta');
      const resultLaunch = document.getElementById('ic-result-launch');
      const resultLaunchNote = document.getElementById('ic-result-launch-note');
      const resultTotal = document.getElementById('ic-result-total');
      const resultDeposit2 = document.getElementById('ic-result-deposit-2');
      const resultRemaining = document.getElementById('ic-result-remaining');
      const resultTerm2 = document.getElementById('ic-result-term-2');
      const resultInterest = document.getElementById('ic-result-interest');
      const cashflowSvg = document.getElementById('ic-cashflow-svg');
      const roiBlock = document.getElementById('ic-roi');
      const roiVal = document.getElementById('ic-roi-val');
      const roiNote = document.getElementById('ic-roi-note');

      const formProject = document.getElementById('ic-form-project');
      const formTotal = document.getElementById('ic-form-total');
      const formDepositInput = document.getElementById('ic-form-deposit');
      const formMonthly = document.getElementById('ic-form-monthly');
      const formTerm = document.getElementById('ic-form-term');
      const formLaunch = document.getElementById('ic-form-launch');

      const state = {
        project: null,
        depositPct: 25,
        term: 6,
        traffic: 0,
        aov: 0,
      };

      // Category tabs
      catTabsEl.querySelectorAll('.ic-cat-tab').forEach((b) => {
        b.addEventListener('click', () => {
          const cat = b.dataset.cat;
          catTabsEl.querySelectorAll('.ic-cat-tab').forEach((x) => x.classList.remove('ic-cat-tab-active'));
          b.classList.add('ic-cat-tab-active');
          projectsEl.querySelectorAll('.ic-project').forEach((p) => {
            p.style.display = (cat === 'all' || p.dataset.cat === cat) ? '' : 'none';
          });
        });
      });

      // Project selection
      projectsEl.querySelectorAll('.ic-project').forEach((b) => {
        b.addEventListener('click', () => {
          projectsEl.querySelectorAll('.ic-project').forEach((x) => { x.classList.remove('ic-project-active'); x.setAttribute('aria-checked','false'); });
          b.classList.add('ic-project-active');
          b.setAttribute('aria-checked','true');
          state.project = {
            id: b.dataset.id,
            name: b.dataset.name,
            price: Number(b.dataset.price),
            weeks: Number(b.dataset.weeks),
            leadLift: Number(b.dataset.leadlift),
            closeRate: Number(b.dataset.closerate),
          };
          customAmountEl.value = '';
          render();
        });
      });

      // Custom amount
      customApplyEl.addEventListener('click', () => {
        const v = Number(customAmountEl.value);
        if (!v || v < 500) return;
        projectsEl.querySelectorAll('.ic-project').forEach((x) => { x.classList.remove('ic-project-active'); x.setAttribute('aria-checked','false'); });
        state.project = {
          id: 'custom',
          name: 'Custom project bundle',
          price: v,
          weeks: Math.max(2, Math.round(v / 1000)),
          leadLift: 0.5,
          closeRate: 0.04,
        };
        render();
      });

      // Deposit slider
      depositSlider.addEventListener('input', (e) => {
        state.depositPct = Number(e.target.value);
        depositVal.textContent = state.depositPct + '%';
        render();
      });

      // Term tabs
      termTabs.forEach((b) => {
        b.addEventListener('click', () => {
          termTabs.forEach((x) => { x.classList.remove('ic-term-tab-active'); x.setAttribute('aria-checked','false'); });
          b.classList.add('ic-term-tab-active');
          b.setAttribute('aria-checked','true');
          state.term = Number(b.dataset.term);
          termVal.textContent = state.term + ' months';
          render();
        });
      });

      // ROI inputs
      trafficEl.addEventListener('input', () => { state.traffic = Number(trafficEl.value) || 0; render(); });
      aovEl.addEventListener('input', () => { state.aov = Number(aovEl.value) || 0; render(); });

      function fmt(n) {
        return '$' + Math.round(n).toLocaleString();
      }

      function render() {
        if (!state.project) {
          resultCard.dataset.empty = 'true';
          return;
        }
        delete resultCard.dataset.empty;

        const total = state.project.price;
        const deposit = total * (state.depositPct / 100);
        const remaining = total - deposit;
        const monthsToPay = state.depositPct >= 100 ? 0 : state.term;
        const monthly = monthsToPay > 0 ? remaining / monthsToPay : 0;

        resultName.textContent = state.project.name;
        resultDeposit.textContent = fmt(deposit);
        resultDeposit2.textContent = fmt(deposit);
        resultMonthly.textContent = monthly === 0 ? 'Paid in full' : fmt(monthly);
        resultMonthlyMeta.textContent = monthly === 0 ? 'No installments' : `for ${monthsToPay} months`;
        resultTotal.textContent = fmt(total);
        resultRemaining.textContent = fmt(remaining);
        resultTerm2.textContent = monthsToPay === 0 ? 'one payment' : monthsToPay + ' months';
        resultInterest.textContent = '$0 (zero interest)';

        // Launch timeline
        const launchWeek = state.project.weeks;
        const launchMonth = Math.ceil(launchWeek / 4.33);
        const installmentDuration = monthsToPay;
        if (launchMonth >= installmentDuration) {
          resultLaunch.textContent = `Week ${launchWeek} (final installment same month or before)`;
          resultLaunchNote.textContent = 'Site launches before installments end. You own and operate the site for the duration of the remaining payments.';
        } else if (state.depositPct >= 100) {
          resultLaunch.textContent = `Week ${launchWeek}`;
          resultLaunchNote.textContent = 'Paid upfront. Site launches per the standard delivery timeline.';
        } else {
          resultLaunch.textContent = `Week ${launchWeek} (mid-term, before final installment)`;
          resultLaunchNote.textContent = `Site goes live in week ${launchWeek}. You take full ownership at launch. Remaining installments continue for ${installmentDuration - launchMonth} more months after launch.`;
        }

        // Cashflow visualization
        renderCashflow(deposit, monthly, monthsToPay, launchMonth);

        // ROI projection
        renderRoi(deposit, monthly, monthsToPay, launchMonth);

        // Update form hidden fields
        formProject.value = state.project.name;
        formTotal.value = String(total);
        formDepositInput.value = String(Math.round(deposit));
        formMonthly.value = String(Math.round(monthly));
        formTerm.value = String(monthsToPay);
        formLaunch.value = `Week ${launchWeek}`;
      }

      function renderCashflow(deposit, monthly, months, launchMonth) {
        const svg = cashflowSvg;
        svg.innerHTML = '';
        const totalPeriods = Math.max(months + 1, 6);
        const w = 340;
        const h = 120;
        const pad = 8;
        const barW = (w - pad * 2) / totalPeriods - 4;

        // Find max for scaling
        const maxOut = Math.max(deposit, monthly);
        // Projected revenue starts at launchMonth and ramps
        const newLeads = (state.traffic > 0 && state.aov > 0 && state.project.leadLift > 0)
          ? state.traffic * state.project.leadLift * state.project.closeRate
          : 0;
        const monthlyRevenue = newLeads * state.aov;
        const maxIn = monthlyRevenue;
        const maxBoth = Math.max(maxOut, maxIn, 1);

        for (let m = 0; m < totalPeriods; m++) {
          // Out bar
          let outAmt = 0;
          if (m === 0) outAmt = deposit;
          else if (m <= months) outAmt = monthly;

          if (outAmt > 0) {
            const bh = (outAmt / maxBoth) * (h - 30);
            const bx = pad + m * ((w - pad * 2) / totalPeriods);
            const by = h - 18 - bh;
            const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            rect.setAttribute('x', String(bx));
            rect.setAttribute('y', String(by));
            rect.setAttribute('width', String(barW));
            rect.setAttribute('height', String(bh));
            rect.setAttribute('rx', '2');
            rect.setAttribute('fill', '#d4932e');
            rect.setAttribute('opacity', '0.9');
            svg.appendChild(rect);
          }

          // In bar (revenue, starts at launch)
          if (monthlyRevenue > 0 && m >= launchMonth) {
            const ramp = Math.min(1, (m - launchMonth + 1) / 3); // ramps over 3 months
            const inAmt = monthlyRevenue * ramp;
            const bh = (inAmt / maxBoth) * (h - 30);
            const bx = pad + m * ((w - pad * 2) / totalPeriods) + barW / 2;
            const by = h - 18 - bh;
            const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            rect.setAttribute('x', String(bx));
            rect.setAttribute('y', String(by));
            rect.setAttribute('width', String(barW * 0.8));
            rect.setAttribute('height', String(bh));
            rect.setAttribute('rx', '2');
            rect.setAttribute('fill', '#5c8040');
            rect.setAttribute('opacity', '0.85');
            svg.appendChild(rect);
          }

          // Month label
          const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          text.setAttribute('x', String(pad + m * ((w - pad * 2) / totalPeriods) + barW / 2));
          text.setAttribute('y', String(h - 4));
          text.setAttribute('text-anchor', 'middle');
          text.setAttribute('font-family', 'monospace');
          text.setAttribute('font-size', '8');
          text.setAttribute('fill', '#9a8e80');
          text.textContent = m === 0 ? 'Now' : 'M' + m;
          svg.appendChild(text);
        }

        // Launch marker
        const lx = pad + launchMonth * ((w - pad * 2) / totalPeriods);
        const launchLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        launchLine.setAttribute('x1', String(lx));
        launchLine.setAttribute('y1', '8');
        launchLine.setAttribute('x2', String(lx));
        launchLine.setAttribute('y2', String(h - 18));
        launchLine.setAttribute('stroke', '#0f1419');
        launchLine.setAttribute('stroke-width', '1');
        launchLine.setAttribute('stroke-dasharray', '3 3');
        svg.appendChild(launchLine);
        const launchText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        launchText.setAttribute('x', String(lx + 3));
        launchText.setAttribute('y', '14');
        launchText.setAttribute('font-family', 'monospace');
        launchText.setAttribute('font-size', '8');
        launchText.setAttribute('fill', '#0f1419');
        launchText.textContent = 'LAUNCH';
        svg.appendChild(launchText);
      }

      function renderRoi(deposit, monthly, months, launchMonth) {
        if (state.traffic === 0 || state.aov === 0) {
          roiBlock.dataset.shown = 'false';
          roiVal.textContent = 'Add visitors + revenue to project';
          roiNote.textContent = 'Based on industry-typical lead lift after this engagement type.';
          return;
        }
        roiBlock.dataset.shown = 'true';

        const newMonthlyLeads = state.traffic * state.project.leadLift * state.project.closeRate;
        const newMonthlyRevenue = newMonthlyLeads * state.aov;

        if (newMonthlyRevenue === 0) {
          roiVal.textContent = 'No direct ROI projection for this project type';
          roiNote.textContent = 'This project category does not have a direct lead-lift model. Indirect ROI from improved performance, search visibility, and brand trust still applies.';
          return;
        }

        // When does cumulative revenue exceed cumulative cost?
        let cumCost = deposit;
        let cumRev = 0;
        let breakEvenMonth = -1;
        for (let m = 1; m <= 24; m++) {
          if (m <= months) cumCost += monthly;
          if (m >= launchMonth) {
            const ramp = Math.min(1, (m - launchMonth + 1) / 3);
            cumRev += newMonthlyRevenue * ramp;
          }
          if (cumRev >= cumCost && breakEvenMonth === -1) {
            breakEvenMonth = m;
            break;
          }
        }

        if (breakEvenMonth === -1) {
          roiVal.textContent = 'Break-even beyond 24 months';
          roiNote.textContent = `Projected new monthly revenue (${'$' + Math.round(newMonthlyRevenue).toLocaleString()}) is below project cost. Consider a smaller tier or higher-impact engagement.`;
        } else {
          roiVal.textContent = `Month ${breakEvenMonth} break-even`;
          const newLeadsRounded = Math.round(newMonthlyLeads * 10) / 10;
          roiNote.textContent = `Projected ${newLeadsRounded.toFixed(1)} new monthly leads × ${'$' + state.aov.toLocaleString()} avg revenue = ${'$' + Math.round(newMonthlyRevenue).toLocaleString()}/mo. Cumulative revenue exceeds cumulative cost by month ${breakEvenMonth}.`;
        }
      }

      // Init
      render();
    });
  })();
</script>

