---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import FinalCTA from '../../../components/FinalCTA.astro';

const canonical = "https://upcomingbrand.com/tools/installment-calculator/";

// Project catalog drawn from real Upcoming Brand offerings
const projectCatalog = [
  // Audits + small ($750 tier)
  { id: 'seo-audit',         name: 'SEO Audit',                    price: 1500, weeks: 1,  category: 'audit',     desc: 'Take-it-anywhere prioritised fix list', leadLift: 0.0,  closeRate: 0.0  },
  { id: 'speed-audit',       name: 'WordPress Speed Audit',        price: 750,  weeks: 1,  category: 'audit',     desc: 'Lighthouse + CWV report with fixes',     leadLift: 0.0,  closeRate: 0.0  },
  { id: 'security-audit',    name: 'Security Audit',               price: 750,  weeks: 1,  category: 'audit',     desc: 'Vulnerability scan + hardening checklist', leadLift: 0.0, closeRate: 0.0 },
  { id: 'hosting-setup',     name: 'WordPress Hosting Setup',      price: 750,  weeks: 1,  category: 'audit',     desc: 'Account setup + performance baseline',   leadLift: 0.05, closeRate: 0.0  },

  // Mid tier ($1,500-$3,000)
  { id: 'web-design-starter', name: 'WordPress Web Design (Starter)', price: 1500, weeks: 6,  category: 'build',     desc: '8-page custom build, schema-first',           leadLift: 0.40, closeRate: 0.04 },
  { id: 'wp-seo',             name: 'WordPress SEO Services',         price: 1500, weeks: 5,  category: 'optimize',   desc: 'Schema, RankMath, on-page, internal linking', leadLift: 0.65, closeRate: 0.0  },
  { id: 'speed-optimization', name: 'Speed Optimization (Standard)',  price: 1500, weeks: 1,  category: 'optimize',   desc: 'Audit + full implementation, 90+ Lighthouse', leadLift: 0.18, closeRate: 0.06 },
  { id: 'security-hardening', name: 'Security Hardening (Standard)',  price: 1500, weeks: 1,  category: 'optimize',   desc: 'Hardening + monitoring + 30-day support',     leadLift: 0.0,  closeRate: 0.0  },
  { id: 'local-seo',          name: 'Local SEO (Standard)',           price: 1500, weeks: 4,  category: 'optimize',   desc: 'GBP + citations + schema + Local Pack push',  leadLift: 0.85, closeRate: 0.0  },
  { id: 'wp-migration',       name: 'WordPress Migration',            price: 1500, weeks: 3,  category: 'migrate',    desc: 'Wix/Squarespace/GoDaddy → WordPress',         leadLift: 0.35, closeRate: 0.0  },
  { id: 'wp-redesign-refresh',name: 'WP Redesign (Refresh tier)',     price: 2500, weeks: 4,  category: 'build',      desc: 'Visual refresh, URLs preserved',              leadLift: 0.20, closeRate: 0.04 },
  { id: 'multi-local-seo',    name: 'Multi-location Local SEO',       price: 3000, weeks: 6,  category: 'optimize',   desc: '2-20 locations, per-city pages',              leadLift: 1.20, closeRate: 0.0  },

  // Higher tier ($4,500-$10,000)
  { id: 'woo-setup',          name: 'WooCommerce Setup',              price: 4500, weeks: 6,  category: 'build',      desc: 'Up to 50 products, Stripe, schema',           leadLift: 0.50, closeRate: 0.025 },
  { id: 'speed-custom',       name: 'Speed Optimization (Custom)',    price: 4500, weeks: 3,  category: 'optimize',   desc: 'WooCommerce / multilingual / JS-heavy',        leadLift: 0.25, closeRate: 0.06 },
  { id: 'wp-redesign-std',    name: 'WP Redesign (Standard)',         price: 5000, weeks: 7,  category: 'build',      desc: 'Full new design system + schema',             leadLift: 0.45, closeRate: 0.05 },
  { id: 'web-design-growth',  name: 'WordPress Web Design (Growth)',  price: 6000, weeks: 8,  category: 'build',      desc: '15-20 pages, city + service pages, full SEO', leadLift: 0.85, closeRate: 0.04 },
  { id: 'woo-custom',         name: 'WooCommerce (Custom)',           price: 8500, weeks: 9,  category: 'build',      desc: 'Subscriptions / configurators / multi-vendor', leadLift: 0.70, closeRate: 0.025 },
  { id: 'wp-redesign-custom', name: 'WP Redesign (Custom)',           price: 10000,weeks: 11, category: 'build',      desc: 'Architecture changes, content restructure',   leadLift: 0.65, closeRate: 0.05 },

  // Enterprise ($15,000+)
  { id: 'woo-enterprise',     name: 'WooCommerce (Enterprise)',       price: 15000,weeks: 13, category: 'build',      desc: '500+ products, ERP/CRM, multi-currency',      leadLift: 0.80, closeRate: 0.03 },
  { id: 'web-design-custom',  name: 'WordPress Web Design (Custom)',  price: 12000,weeks: 12, category: 'build',      desc: '40+ pages, complex IA, multi-vertical',       leadLift: 1.10, closeRate: 0.04 },
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": `${canonical}#tool`,
      "name": "Upcoming Brand Installment Calculator",
      "description": "Free installment calculator for Upcoming Brand fixed-price WordPress projects. Pick your project, choose deposit and term, see exact monthly payment, launch timeline, and projected ROI break-even.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "browserRequirements": "Requires JavaScript",
      "url": canonical,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Installment Calculator | Start Today, Pay Later | Upcoming Brand",
      "description": "Calculate your monthly payment, launch date, and ROI break-even on any Upcoming Brand fixed-price project. Pay 25% today, the rest over 3-12 months.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                  "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Tools",                 "item": "https://upcomingbrand.com/tools/" },
          { "@type": "ListItem", "position": 3, "name": "Installment Calculator","item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title="Installment Payment Calculator | Upcoming Brand"
  description="Calculate monthly payments for any Upcoming Brand project. Pay 25% today, rest over 3–12 months. See your launch date and ROI break-even. Free."
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLd} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- HERO -->
    <section class="ic-hero">
      <div class="container">
        <div class="ic-hero-inner">
          <a href="/tools/" class="ic-back">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            All tools
          </a>
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">New tool</span><span class="page-eyebrow-line"></span></div>
          <h1 class="ic-h1">
            Start your project today.<br>
            <em>Pay over 3 to 12 months.</em>
          </h1>
          <p class="ic-lead">
            Pick any Upcoming Brand fixed-price project below. Choose your deposit and term. See your <strong>exact monthly payment, launch timeline, and projected ROI break-even</strong> in real time. Zero interest. No credit checks. Approval based on a 15-minute call.
          </p>
          <div class="ic-trust">
            <span class="ic-trust-item">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.4"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Zero interest, ever
            </span>
            <span class="ic-trust-dot" aria-hidden="true"></span>
            <span class="ic-trust-item">25% deposit minimum</span>
            <span class="ic-trust-dot" aria-hidden="true"></span>
            <span class="ic-trust-item">Site launches mid-term</span>
            <span class="ic-trust-dot" aria-hidden="true"></span>
            <span class="ic-trust-item" id="ic-availability">3 of 4 Q2 spots remain</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CALCULATOR -->
    <section class="ic-calc">
      <div class="container ic-calc-grid">

        <!-- LEFT: Inputs -->
        <div class="ic-inputs">

          <!-- STEP 1: Project picker -->
          <div class="ic-step">
            <div class="ic-step-head">
              <span class="ic-step-num">01</span>
              <div>
                <h2 class="ic-step-title">Pick your project</h2>
                <p class="ic-step-sub">Or enter a custom amount if you have a multi-service bundle.</p>
              </div>
            </div>

            <div class="ic-cat-tabs" id="ic-cat-tabs">
              <button class="ic-cat-tab ic-cat-tab-active" data-cat="all" type="button">All projects</button>
              <button class="ic-cat-tab" data-cat="build" type="button">Builds</button>
              <button class="ic-cat-tab" data-cat="optimize" type="button">Optimization</button>
              <button class="ic-cat-tab" data-cat="migrate" type="button">Migration</button>
              <button class="ic-cat-tab" data-cat="audit" type="button">Audits</button>
            </div>

            <div class="ic-projects" id="ic-projects" role="radiogroup" aria-label="Choose a project">
              {projectCatalog.map((p) => (
                <button class="ic-project" type="button" role="radio" aria-checked="false" data-id={p.id} data-price={p.price} data-weeks={p.weeks} data-cat={p.category} data-leadlift={p.leadLift} data-closerate={p.closeRate} data-name={p.name}>
                  <span class="ic-project-name">{p.name}</span>
                  <span class="ic-project-price">${p.price.toLocaleString()}</span>
                  <span class="ic-project-desc">{p.desc}</span>
                  <span class="ic-project-weeks">{p.weeks} week{p.weeks === 1 ? '' : 's'} delivery</span>
                </button>
              ))}
            </div>

            <div class="ic-custom">
              <span class="ic-custom-label">Or enter a custom amount</span>
              <div class="ic-custom-input-wrap">
                <span class="ic-custom-prefix">$</span>
                <input type="number" id="ic-custom-amount" class="ic-custom-input" placeholder="e.g. 7500" min="500" max="100000" step="100" />
                <button type="button" class="ic-custom-apply" id="ic-custom-apply">Apply</button>
              </div>
            </div>
          </div>

          <!-- STEP 2: Deposit + term -->
          <div class="ic-step">
            <div class="ic-step-head">
              <span class="ic-step-num">02</span>
              <div>
                <h2 class="ic-step-title">Deposit + term</h2>
                <p class="ic-step-sub">Higher deposit shortens timeline. Longer term lowers monthly payment.</p>
              </div>
            </div>

            <div class="ic-control">
              <div class="ic-control-head">
                <label for="ic-deposit" class="ic-control-label">Deposit</label>
                <span class="ic-control-val" id="ic-deposit-val">25%</span>
              </div>
              <input type="range" id="ic-deposit" class="ic-slider" min="20" max="100" step="5" value="25" />
              <div class="ic-slider-marks">
                <span>20% min</span>
                <span>50%</span>
                <span>100% upfront</span>
              </div>
            </div>

            <div class="ic-control">
              <div class="ic-control-head">
                <label class="ic-control-label">Term length</label>
                <span class="ic-control-val" id="ic-term-val">6 months</span>
              </div>
              <div class="ic-term-tabs" role="radiogroup" aria-label="Term length">
                <button class="ic-term-tab" data-term="3" type="button" role="radio" aria-checked="false">3 mo</button>
                <button class="ic-term-tab ic-term-tab-active" data-term="6" type="button" role="radio" aria-checked="true">6 mo</button>
                <button class="ic-term-tab" data-term="9" type="button" role="radio" aria-checked="false">9 mo</button>
                <button class="ic-term-tab" data-term="12" type="button" role="radio" aria-checked="false">12 mo</button>
              </div>
            </div>
          </div>

          <!-- STEP 3: ROI inputs (optional) -->
          <div class="ic-step ic-step-optional">
            <div class="ic-step-head">
              <span class="ic-step-num">03</span>
              <div>
                <h2 class="ic-step-title">ROI projection <span class="ic-optional">optional</span></h2>
                <p class="ic-step-sub">Add your current numbers to see when the project pays for itself.</p>
              </div>
            </div>

            <div class="ic-roi-grid">
              <div class="ic-control">
                <label for="ic-traffic" class="ic-control-label">Current monthly visitors</label>
                <input type="number" id="ic-traffic" class="ic-input" placeholder="e.g. 2,000" min="0" step="100" />
              </div>
              <div class="ic-control">
                <label for="ic-aov" class="ic-control-label">Avg revenue per closed lead</label>
                <div class="ic-input-prefixed">
                  <span class="ic-input-prefix">$</span>
                  <input type="number" id="ic-aov" class="ic-input" placeholder="e.g. 2,500" min="0" step="100" />
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Live result panel (sticky) -->
        <aside class="ic-result">
          <div class="ic-result-card" data-empty="true">

            <div class="ic-result-empty">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <rect x="6" y="10" width="36" height="28" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 18h36M14 26h6M14 30h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <h3 class="ic-result-empty-title">Pick a project to see your plan.</h3>
              <p class="ic-result-empty-sub">Your live monthly payment, launch timeline, and ROI projection will appear here.</p>
            </div>

            <div class="ic-result-filled">
              <div class="ic-result-stripe" aria-hidden="true"></div>

              <span class="ic-result-eyebrow">Your installment plan</span>
              <h3 class="ic-result-name" id="ic-result-name">—</h3>

              <div class="ic-result-headline">
                <div class="ic-result-headline-block">
                  <span class="ic-result-headline-label">Today</span>
                  <span class="ic-result-headline-val" id="ic-result-deposit">$0</span>
                </div>
                <span class="ic-result-headline-plus" aria-hidden="true">+</span>
                <div class="ic-result-headline-block">
                  <span class="ic-result-headline-label">Per month</span>
                  <span class="ic-result-headline-val" id="ic-result-monthly">$0</span>
                  <span class="ic-result-headline-meta" id="ic-result-monthly-meta">for 6 months</span>
                </div>
              </div>

              <!-- Site launch timeline -->
              <div class="ic-launch">
                <div class="ic-launch-head">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L7 7M7 7l5-5M7 7l5 5M7 7L2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  <span class="ic-launch-label">Site launches</span>
                </div>
                <span class="ic-launch-val" id="ic-result-launch">—</span>
                <span class="ic-launch-note" id="ic-result-launch-note">We start work immediately on deposit. You take possession on launch even if installments continue after.</span>
              </div>

              <!-- Cashflow chart -->
              <div class="ic-cashflow">
                <span class="ic-cashflow-label">Cashflow over your term</span>
                <svg class="ic-cashflow-svg" id="ic-cashflow-svg" viewBox="0 0 340 120" preserveAspectRatio="none" aria-hidden="true">
                  <!-- Bars rendered by JS -->
                </svg>
                <div class="ic-cashflow-legend">
                  <span class="ic-cashflow-legend-item"><span class="ic-cashflow-legend-dot ic-cashflow-out"></span>Payment out</span>
                  <span class="ic-cashflow-legend-item"><span class="ic-cashflow-legend-dot ic-cashflow-in"></span>Projected revenue (post-launch)</span>
                </div>
              </div>

              <!-- ROI break-even -->
              <div class="ic-roi" id="ic-roi" data-shown="false">
                <div class="ic-roi-head">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12 L6 8 L9 10 L12 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span class="ic-roi-label">ROI break-even</span>
                </div>
                <span class="ic-roi-val" id="ic-roi-val">Add traffic + revenue to project</span>
                <span class="ic-roi-note" id="ic-roi-note">Based on industry-typical lead lift after this engagement.</span>
              </div>

              <!-- Total breakdown -->
              <dl class="ic-breakdown">
                <div class="ic-breakdown-row">
                  <dt>Total project</dt>
                  <dd id="ic-result-total">$0</dd>
                </div>
                <div class="ic-breakdown-row">
                  <dt>Deposit today</dt>
                  <dd id="ic-result-deposit-2">$0</dd>
                </div>
                <div class="ic-breakdown-row">
                  <dt>Remaining over <span id="ic-result-term-2">6 months</span></dt>
                  <dd id="ic-result-remaining">$0</dd>
                </div>
                <div class="ic-breakdown-row ic-breakdown-row-savings">
                  <dt>Interest paid</dt>
                  <dd id="ic-result-interest">$0 (zero interest)</dd>
                </div>
              </dl>

              <!-- Email + book CTA -->
              <form class="ic-result-cta" name="installment-plan" method="POST"-honeypot="bot-field" data-uc-form="installment-plan" novalidate>
                <input type="hidden" name="form-name" value="installment-plan" />
                <input type="hidden" name="project_name" id="ic-form-project" />
                <input type="hidden" name="total_price" id="ic-form-total" />
                <input type="hidden" name="deposit_amount" id="ic-form-deposit" />
                <input type="hidden" name="monthly_payment" id="ic-form-monthly" />
                <input type="hidden" name="term_months" id="ic-form-term" />
                <input type="hidden" name="launch_week" id="ic-form-launch" />
                <div class="ic-hp" aria-hidden="true"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
                <input type="email" name="email" class="ic-email-input" placeholder="your@email.com" required autocomplete="email" aria-label="Email address" />
                <button type="submit" class="ic-email-submit">
                  Email this plan + book call
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <p class="ic-result-note">We will send the plan + a link to schedule a 15-minute call to confirm scope. Approval is human, not credit-pulled.</p>
              </form>
            </div>
          </div>
        </aside>

      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="ic-how">
      <div class="container">
        <div class="ic-how-head">
          <p class="ic-section-eyebrow"><span class="ic-section-eyebrow-line"></span>How it works</p>
          <h2 class="ic-h2">Five steps from <em>quote to launch.</em></h2>
        </div>
        <div class="ic-how-grid">
          <article class="ic-how-step">
            <span class="ic-how-num">01</span>
            <h3 class="ic-how-title">Pick the plan above</h3>
            <p class="ic-how-text">Use the calculator to find a payment that fits. Email yourself the plan when ready.</p>
          </article>
          <article class="ic-how-step">
            <span class="ic-how-num">02</span>
            <h3 class="ic-how-title">15-minute approval call</h3>
            <p class="ic-how-text">We confirm scope, project fit, and payment plan. No credit pull. Decision in 24 hours.</p>
          </article>
          <article class="ic-how-step">
            <span class="ic-how-num">03</span>
            <h3 class="ic-how-title">Pay deposit, work starts</h3>
            <p class="ic-how-text">Sign SOW, deposit clears via Stripe, project kickoff scheduled within 5 business days.</p>
          </article>
          <article class="ic-how-step">
            <span class="ic-how-num">04</span>
            <h3 class="ic-how-title">Site launches mid-term</h3>
            <p class="ic-how-text">You take ownership the day the site goes live, even if installments continue after.</p>
          </article>
          <article class="ic-how-step">
            <span class="ic-how-num">05</span>
            <h3 class="ic-how-title">Auto-charge runs to completion</h3>
            <p class="ic-how-text">Monthly Stripe charge against card on file. Zero interest, full transparency, cancel-anytime if scope changes.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="ic-faq">
      <div class="container">
        <div class="ic-faq-head">
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">Plan FAQ</span><span class="page-eyebrow-line"></span></div>
          <h2 class="ic-h2 ic-faq-h2">Six questions <em>before you book.</em></h2>
        </div>
        <div class="ic-faq-list">
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">01</span><span class="ic-faq-q-text">Is there a credit check or interest?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">No credit check. No interest. We carry the risk because most defaults come from scope mismatch, not credit risk. The 15-minute approval call is qualitative and looks at scope-fit and operating history.</p></details>
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">02</span><span class="ic-faq-q-text">When does my site launch?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">The site launches based on the project's normal delivery timeline (3-13 weeks depending on tier), regardless of the installment term. You take ownership on launch day. Remaining installments simply continue afterward.</p></details>
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">03</span><span class="ic-faq-q-text">What happens if I miss a payment?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">Stripe auto-retries 3 times over 7 days. If all attempts fail, we pause work (if pre-launch) or schedule a call to restructure terms. We have not had to invoke this clause yet because we screen for fit upfront.</p></details>
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">04</span><span class="ic-faq-q-text">Can I pay off the balance early?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">Yes, anytime. No prepayment penalty. Email accounting@upcomingbrand.com with "pay off remaining balance" and we charge the card on file for the remainder.</p></details>
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">05</span><span class="ic-faq-q-text">How is this calculator different from typical financing tools?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">Three things: it shows when your site actually launches in the timeline (not just payment dates), it projects ROI break-even based on industry-typical lead-lift data for your project type, and it visualizes cashflow with projected revenue overlay so you see when the project starts paying for itself.</p></details>
          <details class="ic-faq-item"><summary class="ic-faq-q"><span class="ic-faq-num">06</span><span class="ic-faq-q-text">Why only 4 installment slots per quarter?</span><span class="ic-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></summary><p class="ic-faq-a">Because we self-fund installment risk and our cash reserve supports a finite number of in-flight installment plans without compromising delivery timelines on full-pay clients. Slots reset every quarter.</p></details>
        </div>
      </div>
    </section>

  </main>
