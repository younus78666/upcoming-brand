    function render(){
      var graph = buildGraph();
      var json = JSON.stringify(graph, null, 2);
      var entityCount = graph['@graph'].length;
      var refMatches = json.match(/"@id":/g) || [];
      var refs = Math.max(0, refMatches.length - entityCount);
      var bytes = new Blob([json]).size;
      outputCode.textContent = json;
      statEntities.textContent = String(entityCount);
      statRefs.textContent = String(refs);
      statBytes.textContent = String(bytes);
    }

