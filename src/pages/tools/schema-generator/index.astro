---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import FinalCTA from '../../../components/FinalCTA.astro';

const canonical = "https://upcomingbrand.com/tools/schema-generator/";

const jsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": canonical + "#tool",
      "name": "Schema Markup Generator",
      "description": "Free schema markup generator producing multi-entity JSON-LD with cross-references. Industry presets bundle correct schemas automatically.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "url": canonical,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "WebPage",
      "@id": canonical + "#webpage",
      "url": canonical,
      "name": "Schema Markup Generator | Multi-Entity JSON-LD | Upcoming Brand",
      "description": "Generate connected JSON-LD schemas with cross-references. Industry presets for law firms, dentists, restaurants, real estate. Free, no signup.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",              "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Tools",             "item": "https://upcomingbrand.com/tools/" },
          { "@type": "ListItem", "position": 3, "name": "Schema Generator", "item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title="Schema Markup Generator | JSON-LD Builder | Upcoming Brand"
  description="Generate connected JSON-LD schemas with cross-references. Industry presets bundle the right combinations for your vertical. Free, no signup."
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLdString} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <section class="sg-hero">
      <div class="container">
        <div class="sg-hero-inner">
          <a href="/tools/" class="sg-back">All tools</a>
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">Free tool</span><span class="page-eyebrow-line"></span></div>
          <h1 class="sg-h1">Schema markup generator that <em>links your entities.</em></h1>
          <p class="sg-lead">
            Most generators output one schema. Ours produces a complete graph with proper cross-references between Organization, WebSite, LocalBusiness, Service, and FAQ. Industry presets load the right combination automatically.
          </p>
        </div>
      </div>
    </section>

    <section class="sg-tool">
      <div class="container">

        <div class="sg-presets-wrap">
          <span class="sg-section-eyebrow">Industry presets</span>
          <p class="sg-presets-help">Click to load a multi-entity graph with sample data.</p>
          <div class="sg-presets" id="sg-presets">
            <button class="sg-preset" type="button" data-preset="law"><span class="sg-preset-name">Law Firm</span><span class="sg-preset-meta">LegalService + LocalBusiness + FAQ</span></button>
            <button class="sg-preset" type="button" data-preset="dental"><span class="sg-preset-name">Dental Practice</span><span class="sg-preset-meta">Dentist + MedicalProcedure + Review</span></button>
            <button class="sg-preset" type="button" data-preset="medical"><span class="sg-preset-name">Medical Clinic</span><span class="sg-preset-meta">MedicalClinic + Physician</span></button>
            <button class="sg-preset" type="button" data-preset="real-estate"><span class="sg-preset-name">Real Estate</span><span class="sg-preset-meta">RealEstateAgent + Service</span></button>
            <button class="sg-preset" type="button" data-preset="restaurant"><span class="sg-preset-name">Restaurant</span><span class="sg-preset-meta">Restaurant + Menu + Offer</span></button>
            <button class="sg-preset" type="button" data-preset="contractor"><span class="sg-preset-name">Contractor</span><span class="sg-preset-meta">HomeAndConstructionBusiness + Service</span></button>
            <button class="sg-preset" type="button" data-preset="ecommerce"><span class="sg-preset-name">Ecommerce</span><span class="sg-preset-meta">Store + Product + AggregateRating</span></button>
            <button class="sg-preset" type="button" data-preset="church"><span class="sg-preset-name">Church / Faith</span><span class="sg-preset-meta">Church + Event</span></button>
            <button class="sg-preset" type="button" data-preset="nonprofit"><span class="sg-preset-name">Nonprofit</span><span class="sg-preset-meta">NGO + DonateAction + Event</span></button>
          </div>
        </div>

        <div class="sg-grid">

          <div class="sg-form-wrap">
            <div class="sg-form-section">
              <h2 class="sg-form-section-title">Identity</h2>
              <p class="sg-form-section-sub">These fields seed every entity in the graph.</p>
              <div class="sg-form-grid">
                <div class="sg-field"><label for="sg-name" class="sg-label">Business name</label><input type="text" id="sg-name" class="sg-input" placeholder="e.g. Coleman and Reyes Law" /></div>
                <div class="sg-field"><label for="sg-url" class="sg-label">Website URL</label><input type="url" id="sg-url" class="sg-input" placeholder="https://example.com" /></div>
                <div class="sg-field sg-field-full"><label for="sg-description" class="sg-label">Short description</label><textarea id="sg-description" class="sg-input sg-textarea" rows="2" placeholder="One sentence about the business."></textarea></div>
                <div class="sg-field"><label for="sg-phone" class="sg-label">Phone</label><input type="text" id="sg-phone" class="sg-input" placeholder="+1-555-555-5555" /></div>
                <div class="sg-field"><label for="sg-email" class="sg-label">Email</label><input type="email" id="sg-email" class="sg-input" placeholder="hello@example.com" /></div>
                <div class="sg-field"><label for="sg-street" class="sg-label">Street</label><input type="text" id="sg-street" class="sg-input" placeholder="123 Main St" /></div>
                <div class="sg-field"><label for="sg-city" class="sg-label">City</label><input type="text" id="sg-city" class="sg-input" placeholder="Baltimore" /></div>
                <div class="sg-field"><label for="sg-region" class="sg-label">State</label><input type="text" id="sg-region" class="sg-input" placeholder="MD" /></div>
                <div class="sg-field"><label for="sg-postal" class="sg-label">Postal code</label><input type="text" id="sg-postal" class="sg-input" placeholder="21201" /></div>
                <div class="sg-field"><label for="sg-lat" class="sg-label">Latitude (optional)</label><input type="text" id="sg-lat" class="sg-input" placeholder="39.2904" /></div>
                <div class="sg-field"><label for="sg-lng" class="sg-label">Longitude (optional)</label><input type="text" id="sg-lng" class="sg-input" placeholder="-76.6122" /></div>
                <div class="sg-field sg-field-full">
                  <button type="button" id="sg-geocode-btn" class="sg-add-row" style="margin-top:0;">Look up coordinates from address (Nominatim)</button>
                  <span class="sg-field-help" id="sg-geocode-status" style="display:none; margin-top:6px;"></span>
                </div>
                <div class="sg-field"><label class="sg-label">Business type</label>
                  <select id="sg-business-type" class="sg-input sg-select">
                    <option value="LocalBusiness">LocalBusiness (generic)</option>
                    <option value="ProfessionalService">ProfessionalService (generic)</option>
                    <optgroup label="Legal">
                      <option value="LegalService">LegalService (Law Firm)</option>
                      <option value="Attorney">Attorney</option>
                      <option value="Notary">Notary</option>
                    </optgroup>
                    <optgroup label="Medical + Dental">
                      <option value="MedicalBusiness">MedicalBusiness (generic)</option>
                      <option value="MedicalClinic">MedicalClinic</option>
                      <option value="Hospital">Hospital</option>
                      <option value="Physician">Physician</option>
                      <option value="Dentist">Dentist</option>
                      <option value="Optician">Optician / Optometrist</option>
                      <option value="Pharmacy">Pharmacy</option>
                      <option value="VeterinaryCare">VeterinaryCare</option>
                      <option value="ChildCare">ChildCare</option>
                    </optgroup>
                    <optgroup label="Real Estate + Hospitality">
                      <option value="RealEstateAgent">RealEstateAgent</option>
                      <option value="LodgingBusiness">LodgingBusiness</option>
                      <option value="Hotel">Hotel</option>
                      <option value="BedAndBreakfast">BedAndBreakfast</option>
                      <option value="Resort">Resort</option>
                      <option value="EventVenue">EventVenue</option>
                    </optgroup>
                    <optgroup label="Food + Beverage">
                      <option value="Restaurant">Restaurant</option>
                      <option value="FastFoodRestaurant">FastFoodRestaurant</option>
                      <option value="CafeOrCoffeeShop">Cafe / Coffee Shop</option>
                      <option value="Bakery">Bakery</option>
                      <option value="BarOrPub">Bar / Pub</option>
                      <option value="Brewery">Brewery</option>
                      <option value="Winery">Winery</option>
                      <option value="IceCreamShop">IceCreamShop</option>
                    </optgroup>
                    <optgroup label="Trades + Construction">
                      <option value="HomeAndConstructionBusiness">HomeAndConstructionBusiness</option>
                      <option value="GeneralContractor">GeneralContractor</option>
                      <option value="RoofingContractor">RoofingContractor</option>
                      <option value="Plumber">Plumber</option>
                      <option value="Electrician">Electrician</option>
                      <option value="HVACBusiness">HVAC Business</option>
                      <option value="HousePainter">HousePainter</option>
                      <option value="Locksmith">Locksmith</option>
                      <option value="MovingCompany">MovingCompany</option>
                    </optgroup>
                    <optgroup label="Retail">
                      <option value="Store">Store (generic)</option>
                      <option value="ClothingStore">ClothingStore</option>
                      <option value="ElectronicsStore">ElectronicsStore</option>
                      <option value="JewelryStore">JewelryStore</option>
                      <option value="ShoeStore">ShoeStore</option>
                      <option value="HardwareStore">HardwareStore</option>
                      <option value="HobbyShop">HobbyShop</option>
                      <option value="Florist">Florist</option>
                      <option value="GroceryStore">GroceryStore</option>
                      <option value="PetStore">PetStore</option>
                      <option value="Bookstore">Bookstore</option>
                    </optgroup>
                    <optgroup label="Beauty + Wellness">
                      <option value="HealthAndBeautyBusiness">HealthAndBeautyBusiness</option>
                      <option value="HairSalon">HairSalon</option>
                      <option value="BeautySalon">BeautySalon</option>
                      <option value="DaySpa">DaySpa</option>
                      <option value="NailSalon">NailSalon</option>
                      <option value="TattooParlor">TattooParlor</option>
                    </optgroup>
                    <optgroup label="Fitness">
                      <option value="HealthClub">HealthClub / Gym</option>
                      <option value="SportsActivityLocation">SportsActivityLocation</option>
                      <option value="ExerciseGym">ExerciseGym</option>
                      <option value="YogaStudio">YogaStudio (use SportsActivityLocation)</option>
                    </optgroup>
                    <optgroup label="Automotive">
                      <option value="AutoDealer">AutoDealer</option>
                      <option value="AutoRepair">AutoRepair</option>
                      <option value="AutoBodyShop">AutoBodyShop</option>
                      <option value="GasStation">GasStation</option>
                      <option value="MotorcycleDealer">MotorcycleDealer</option>
                    </optgroup>
                    <optgroup label="Financial + Professional">
                      <option value="AccountingService">AccountingService</option>
                      <option value="FinancialService">FinancialService</option>
                      <option value="InsuranceAgency">InsuranceAgency</option>
                      <option value="BankOrCreditUnion">BankOrCreditUnion</option>
                      <option value="EmploymentAgency">EmploymentAgency</option>
                      <option value="TravelAgency">TravelAgency</option>
                      <option value="ChildCare">ChildCare</option>
                    </optgroup>
                    <optgroup label="Faith + Community">
                      <option value="Church">Church</option>
                      <option value="HinduTemple">HinduTemple</option>
                      <option value="Mosque">Mosque</option>
                      <option value="Synagogue">Synagogue</option>
                      <option value="BuddhistTemple">BuddhistTemple</option>
                      <option value="NGO">NGO</option>
                      <option value="GovernmentOffice">GovernmentOffice</option>
                      <option value="Library">Library</option>
                      <option value="Museum">Museum</option>
                    </optgroup>
                    <optgroup label="Other">
                      <option value="DryCleaningOrLaundry">DryCleaningOrLaundry</option>
                      <option value="ChildCare">ChildCare</option>
                      <option value="EmploymentAgency">EmploymentAgency</option>
                      <option value="EntertainmentBusiness">EntertainmentBusiness</option>
                    </optgroup>
                  </select>
                </div>
              </div>
            </div>

            <div class="sg-form-section">
              <h2 class="sg-form-section-title">Entities to include</h2>
              <p class="sg-form-section-sub">Toggle the entity types to add to the graph. All reference Organization via cross-reference.</p>
              <div class="sg-toggles">
                <label class="sg-toggle"><input type="checkbox" id="sg-include-organization" checked /><span class="sg-toggle-name">Organization</span><span class="sg-toggle-desc">Brand identity layer (recommended)</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-website" checked /><span class="sg-toggle-name">WebSite</span><span class="sg-toggle-desc">Site-level entity with SearchAction</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-localbusiness" checked /><span class="sg-toggle-name">LocalBusiness</span><span class="sg-toggle-desc">Local SEO layer with address</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-rating" /><span class="sg-toggle-name">AggregateRating</span><span class="sg-toggle-desc">Star rating block</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-service" /><span class="sg-toggle-name">Service / Offer</span><span class="sg-toggle-desc">Up to 5 services</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-faq" /><span class="sg-toggle-name">FAQPage</span><span class="sg-toggle-desc">Up to 6 questions</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-authority" /><span class="sg-toggle-name">Authority signals</span><span class="sg-toggle-desc">knowsAbout + social URLs (sameAs)</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-hours" /><span class="sg-toggle-name">Opening hours</span><span class="sg-toggle-desc">Business hours per day</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-speakable" /><span class="sg-toggle-name">Speakable</span><span class="sg-toggle-desc">Voice search optimization</span></label>
              </div>
            </div>

            <div class="sg-form-section" id="sg-rating-section" data-shown="false">
              <h2 class="sg-form-section-title">Aggregate rating</h2>
              <div class="sg-form-grid">
                <div class="sg-field"><label for="sg-rating-value" class="sg-label">Rating value</label><input type="number" id="sg-rating-value" class="sg-input" step="0.1" min="1" max="5" value="5.0" /></div>
                <div class="sg-field"><label for="sg-rating-count" class="sg-label">Review count</label><input type="number" id="sg-rating-count" class="sg-input" min="1" value="12" /></div>
              </div>
            </div>

            <div class="sg-form-section" id="sg-service-section" data-shown="false">
              <h2 class="sg-form-section-title">Services offered</h2>
              <p class="sg-form-section-sub">Each becomes a Service entity, linked to Organization as provider.</p>
              <div class="sg-services" id="sg-services-list"></div>
              <button type="button" class="sg-add-row" id="sg-add-service">Add service</button>
            </div>

            <div class="sg-form-section" id="sg-faq-section" data-shown="false">
              <h2 class="sg-form-section-title">FAQ items</h2>
              <p class="sg-form-section-sub">Outputs FAQPage with Question and Answer entities.</p>
              <div class="sg-faqs" id="sg-faqs-list"></div>
              <button type="button" class="sg-add-row" id="sg-add-faq">Add Q and A</button>
            </div>

            <div class="sg-form-section" id="sg-authority-section" data-shown="false">
              <h2 class="sg-form-section-title">Authority signals</h2>
              <p class="sg-form-section-sub">Tells Google what topics you are expert on (knowsAbout) and which social profiles belong to this entity (sameAs). Both signals strengthen entity matching in the knowledge graph and improve AI Overview citation odds.</p>
              <div class="sg-form-grid">
                <div class="sg-field sg-field-full">
                  <label for="sg-knows-about" class="sg-label">knowsAbout (one topic per line, up to 12)</label>
                  <textarea id="sg-knows-about" class="sg-input sg-textarea" rows="5" placeholder="Estate planning&#10;Probate administration&#10;Trust formation&#10;Business succession&#10;Tax optimization"></textarea>
                  <span class="sg-field-help">Use specific topics, not generic categories. "Estate planning" beats "Legal services". 5 to 12 topics is the sweet spot.</span>
                </div>
                <div class="sg-field sg-field-full">
                  <label class="sg-label">sameAs URLs (social profiles + verified pages)</label>
                  <span class="sg-field-help" style="margin-bottom: 8px;">Links your business entity to verified social profiles. Google uses these to disambiguate your entity from similarly-named businesses.</span>
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-linkedin" class="sg-label-mini">LinkedIn</label>
                  <input type="url" id="sg-same-linkedin" class="sg-input" placeholder="https://www.linkedin.com/company/your-company" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-facebook" class="sg-label-mini">Facebook</label>
                  <input type="url" id="sg-same-facebook" class="sg-input" placeholder="https://www.facebook.com/your-page" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-instagram" class="sg-label-mini">Instagram</label>
                  <input type="url" id="sg-same-instagram" class="sg-input" placeholder="https://www.instagram.com/your-handle" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-twitter" class="sg-label-mini">X / Twitter</label>
                  <input type="url" id="sg-same-twitter" class="sg-input" placeholder="https://x.com/your-handle" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-youtube" class="sg-label-mini">YouTube</label>
                  <input type="url" id="sg-same-youtube" class="sg-input" placeholder="https://www.youtube.com/@your-channel" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-same-wikipedia" class="sg-label-mini">Wikipedia / Wikidata (if listed)</label>
                  <input type="url" id="sg-same-wikipedia" class="sg-input" placeholder="https://en.wikipedia.org/wiki/Your_Business" />
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-knows-language" class="sg-label">knowsLanguage (comma-separated)</label>
                  <input type="text" id="sg-knows-language" class="sg-input" placeholder="en, es, ko" />
                  <span class="sg-field-help">Languages your business operates in. Useful for multilingual / international businesses.</span>
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-founding-date" class="sg-label">foundingDate (optional)</label>
                  <input type="date" id="sg-founding-date" class="sg-input" />
                  <span class="sg-field-help">When the business was founded. Adds longevity signal.</span>
                </div>
                <div class="sg-field sg-field-full">
                  <label for="sg-price-range" class="sg-label">priceRange (optional)</label>
                  <input type="text" id="sg-price-range" class="sg-input" placeholder="$$ or $1,500 to $15,000" />
                  <span class="sg-field-help">Either dollar signs ($, $$, $$$, $$$$) or a literal range. Shows in some local rich results.</span>
                </div>
              </div>
            </div>

            <div class="sg-form-section" id="sg-hours-section" data-shown="false">
              <h2 class="sg-form-section-title">Opening hours</h2>
              <p class="sg-form-section-sub">Per-day hours show in Google Maps and search results. Use 24-hour format (HH:MM). Leave empty days as Closed.</p>
              <div class="sg-hours-grid">
                <div class="sg-hours-row" data-day="Monday"><span class="sg-hours-day">Monday</span><input type="time" class="sg-input sg-hours-open" data-day="Monday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Monday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Monday" /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Tuesday"><span class="sg-hours-day">Tuesday</span><input type="time" class="sg-input sg-hours-open" data-day="Tuesday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Tuesday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Tuesday" /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Wednesday"><span class="sg-hours-day">Wednesday</span><input type="time" class="sg-input sg-hours-open" data-day="Wednesday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Wednesday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Wednesday" /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Thursday"><span class="sg-hours-day">Thursday</span><input type="time" class="sg-input sg-hours-open" data-day="Thursday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Thursday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Thursday" /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Friday"><span class="sg-hours-day">Friday</span><input type="time" class="sg-input sg-hours-open" data-day="Friday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Friday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Friday" /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Saturday"><span class="sg-hours-day">Saturday</span><input type="time" class="sg-input sg-hours-open" data-day="Saturday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Saturday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Saturday" checked /><span>Closed</span></label></div>
                <div class="sg-hours-row" data-day="Sunday"><span class="sg-hours-day">Sunday</span><input type="time" class="sg-input sg-hours-open" data-day="Sunday" /><span class="sg-hours-sep">to</span><input type="time" class="sg-input sg-hours-close" data-day="Sunday" /><label class="sg-hours-closed-label"><input type="checkbox" class="sg-hours-closed" data-day="Sunday" checked /><span>Closed</span></label></div>
              </div>
            </div>

            <div class="sg-form-section">
              <h2 class="sg-form-section-title">Where will you install this?</h2>
              <p class="sg-form-section-sub">We tailor the install guide based on your platform. Some WP plugins block custom schema; we tell you which ones and how to work around them.</p>
              <div class="sg-platform-grid">
                <button type="button" class="sg-platform-btn sg-platform-btn-active" data-platform="wp-rankmath">
                  <span class="sg-platform-name">WordPress + RankMath Pro</span>
                  <span class="sg-platform-meta">Custom schema supported</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="wp-yoast">
                  <span class="sg-platform-name">WordPress + Yoast</span>
                  <span class="sg-platform-meta">Workaround required</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="wp-aioseo">
                  <span class="sg-platform-name">WordPress + AIOSEO</span>
                  <span class="sg-platform-meta">Custom schema supported</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="wp-seopress">
                  <span class="sg-platform-name">WordPress + SEOPress</span>
                  <span class="sg-platform-meta">Custom schema supported</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="wp-manual">
                  <span class="sg-platform-name">WordPress (no SEO plugin)</span>
                  <span class="sg-platform-meta">Header/footer code required</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="webflow">
                  <span class="sg-platform-name">Webflow</span>
                  <span class="sg-platform-meta">Project Settings &rarr; Custom Code</span>
                </button>
                <button type="button" class="sg-platform-btn" data-platform="shopify">
                  <span class="sg-platform-name">Shopify</span>
