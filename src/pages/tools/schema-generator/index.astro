  .sg-grid { display: grid; grid-template-columns: 1fr 440px; gap: clamp(24px, 4vw, 56px); align-items: start; max-width: 1200px; margin: 0 auto; }

  .sg-form-wrap { display: flex; flex-direction: column; gap: 18px; min-width: 0; }
