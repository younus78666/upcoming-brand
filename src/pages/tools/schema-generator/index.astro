<script is:inline>
(function(){
  // Visible debug panel — shows checkpoints + JS errors directly on page (no DevTools needed)
  var __sgDebug = { steps: [], errors: [] };
  function __sgLog(step){ __sgDebug.steps.push(step); __sgRender(); }
  function __sgErr(msg){ __sgDebug.errors.push(String(msg)); __sgRender(); }
  function __sgRender(){
    var p = document.getElementById('sg-debug-panel');
    if(!p){
      p = document.createElement('div');
      p.id = 'sg-debug-panel';
      p.style.cssText = 'position:fixed;bottom:10px;right:10px;max-width:380px;max-height:50vh;overflow:auto;background:#111;color:#0f0;font:11px/1.4 monospace;padding:10px 12px;border-radius:8px;z-index:99999;box-shadow:0 8px 30px rgba(0,0,0,0.4);border:1px solid #333;';
      var btn = document.createElement('button');
      btn.textContent = 'x';
      btn.style.cssText = 'position:absolute;top:4px;right:6px;background:transparent;color:#888;border:0;cursor:pointer;font-size:14px;';
      btn.onclick = function(){ p.style.display = 'none'; };
      p.appendChild(btn);
      var body = document.createElement('div');
      body.id = 'sg-debug-body';
      p.appendChild(body);
      (document.body || document.documentElement).appendChild(p);
    }
    var body = document.getElementById('sg-debug-body');
    if(!body) return;
    var html = '<strong style="color:#fff;">SG debug</strong><br>';
    html += '<span style="color:#0f0;">' + __sgDebug.steps.length + ' checkpoints OK</span><br>';
    __sgDebug.steps.forEach(function(s){ html += '&#x2713; ' + s + '<br>'; });
    if(__sgDebug.errors.length){
      html += '<br><strong style="color:#f55;">ERRORS:</strong><br>';
      __sgDebug.errors.forEach(function(e){ html += '<span style="color:#f99;">' + e.replace(/</g,'&lt;') + '</span><br>'; });
    }
    body.innerHTML = html;
  }
  window.addEventListener('error', function(e){ __sgErr((e.message || 'error') + ' @ ' + (e.filename || '').split('/').pop() + ':' + (e.lineno || '?')); });
  __sgLog('script loaded');

  document.addEventListener('DOMContentLoaded', function(){
    try { __sgLog('DOMContentLoaded'); } catch(e){}
    var state = {
      name:'', url:'', description:'', phone:'', email:'',
      street:'', city:'', region:'', postal:'', country:'US',
      businessType:'LocalBusiness',
      includeOrganization:true, includeWebsite:true, includeLocalBusiness:true,
      includeRating:false, ratingValue:'5.0', ratingCount:'12',
      includeService:false, services:[{name:'',description:'',price:''}],
      includeFaq:false, faqs:[{q:'',a:''}],
      includeAuthority:false, knowsAbout:[], sameAs:{linkedin:'',facebook:'',instagram:'',twitter:'',youtube:'',wikipedia:''},
      knowsLanguage:'', foundingDate:'', priceRange:'',
      includeHours:false, hours:{Monday:{open:'',close:'',closed:false},Tuesday:{open:'',close:'',closed:false},Wednesday:{open:'',close:'',closed:false},Thursday:{open:'',close:'',closed:false},Friday:{open:'',close:'',closed:false},Saturday:{open:'',close:'',closed:true},Sunday:{open:'',close:'',closed:true}},
      includeSpeakable:false, speakableSelectors:[],
      latitude:'', longitude:'',
      platform:'wp-rankmath',
      aiProvider:'', aiKey:'', aiModel:''
    };

    function bind(id, key){
      var el = document.getElementById(id);
      if(!el) return;
      state[key] = el.value;
      el.addEventListener('input', function(){ state[key] = el.value; render(); });
    }
    bind('sg-name','name'); bind('sg-url','url'); bind('sg-description','description');
    bind('sg-phone','phone'); bind('sg-email','email'); bind('sg-street','street');
    bind('sg-city','city'); bind('sg-region','region'); bind('sg-postal','postal');
    bind('sg-rating-value','ratingValue'); bind('sg-rating-count','ratingCount');
    bind('sg-knows-language','knowsLanguage'); bind('sg-founding-date','foundingDate'); bind('sg-price-range','priceRange');
    bind('sg-lat','latitude'); bind('sg-lng','longitude');

    // knowsAbout textarea (split by lines)
    var knowsAboutEl = document.getElementById('sg-knows-about');
    if(knowsAboutEl){
      knowsAboutEl.addEventListener('input', function(){
        state.knowsAbout = knowsAboutEl.value.split('\n').map(function(s){return s.trim();}).filter(Boolean).slice(0, 12);
        render();
      });
    }

    // sameAs URL inputs
    var sameAsMap = { 'sg-same-linkedin':'linkedin', 'sg-same-facebook':'facebook', 'sg-same-instagram':'instagram', 'sg-same-twitter':'twitter', 'sg-same-youtube':'youtube', 'sg-same-wikipedia':'wikipedia' };
    Object.keys(sameAsMap).forEach(function(id){
      var el = document.getElementById(id);
      if(!el) return;
      el.addEventListener('input', function(){ state.sameAs[sameAsMap[id]] = el.value; render(); });
    });

    // Hours inputs
    document.querySelectorAll('.sg-hours-open, .sg-hours-close, .sg-hours-closed').forEach(function(el){
      el.addEventListener('change', function(){
        var day = el.dataset.day;
        if(!state.hours[day]) return;
        if(el.classList.contains('sg-hours-closed')){
          state.hours[day].closed = el.checked;
        } else if(el.classList.contains('sg-hours-open')){
          state.hours[day].open = el.value;
        } else {
          state.hours[day].close = el.value;
        }
        render();
      });
    });

    document.getElementById('sg-business-type').addEventListener('change', function(e){
      state.businessType = e.target.value; render();
    });

    var toggles = [
      ['sg-include-organization','includeOrganization', null],
      ['sg-include-website','includeWebsite', null],
      ['sg-include-localbusiness','includeLocalBusiness', null],
      ['sg-include-rating','includeRating', 'sg-rating-section'],
      ['sg-include-service','includeService', 'sg-service-section'],
      ['sg-include-faq','includeFaq', 'sg-faq-section'],
      ['sg-include-authority','includeAuthority', 'sg-authority-section'],
      ['sg-include-hours','includeHours', 'sg-hours-section'],
      ['sg-include-speakable','includeSpeakable', 'sg-speakable-section']
    ];
    toggles.forEach(function(t){
      var id = t[0], key = t[1], sectionId = t[2];
      var el = document.getElementById(id);
      if(!el) return;
      var label = el.closest('.sg-toggle');
      function syncLabel(){ if(label) label.classList.toggle('sg-toggle-active', el.checked); }
      syncLabel();
      el.addEventListener('change', function(){
        state[key] = el.checked;
        syncLabel();
        if(sectionId){
          var sec = document.getElementById(sectionId);
          if(sec) sec.dataset.shown = el.checked ? 'true' : 'false';
        }
        render();
      });
    });

    var speakableEl = document.getElementById('sg-speakable-selectors');
    if(speakableEl){
      speakableEl.addEventListener('input', function(){
        state.speakableSelectors = speakableEl.value.split('\n').map(function(s){return s.trim();}).filter(Boolean);
        render();
      });
    }

    var speakablePresets = {
      'default': ['h1','h2','.lead'],
      'article': ['h1','article h2','.article-summary','article p:first-of-type'],
      'service': ['h1','.service-headline','.service-summary','section.intro p'],
      'faq': ['h1','.faq-question','.faq-answer'],
      'recipe': ['h1','.recipe-summary','.recipe-ingredients','.recipe-instructions'],
      'product': ['h1','.product-name','.product-description','.product-price'],
      'news': ['h1','.article-headline','.article-byline','article p:first-of-type']
    };
    document.querySelectorAll('[data-speakable-preset]').forEach(function(b){
      b.addEventListener('click', function(){
        var key = b.dataset.speakablePreset;
        var preset = speakablePresets[key] || speakablePresets['default'];
        state.speakableSelectors = preset.slice();
        if(speakableEl) speakableEl.value = preset.join('\n');
        // Auto-enable speakable section if not already
        if(!state.includeSpeakable){
          var t = document.getElementById('sg-include-speakable');
          if(t){ t.checked = true; t.dispatchEvent(new Event('change')); }
        }
        render();
      });
    });

    var servicesList = document.getElementById('sg-services-list');
    function renderServices(){
      servicesList.innerHTML = '';
      state.services.forEach(function(s, idx){
        var card = document.createElement('div');
        card.className = 'sg-row-card';

        var head = document.createElement('div');
        head.className = 'sg-row-head';
        var label = document.createElement('span');
        label.className = 'sg-row-label';
        label.textContent = 'Service ' + String(idx + 1).padStart(2, '0');
        var rmB = document.createElement('button');
        rmB.type='button'; rmB.className='sg-row-remove'; rmB.textContent='Remove';
        rmB.addEventListener('click', function(){
          state.services.splice(idx,1);
          if(state.services.length===0) state.services.push({name:'',description:'',price:''});
          renderServices(); render();
        });
        head.appendChild(label); head.appendChild(rmB);

        var grid = document.createElement('div');
        grid.className = 'sg-row-grid';

        // Name field with AI button
        var nameField = document.createElement('div');
        nameField.className = 'sg-field sg-field-full sg-field-with-ai';
        var nameLabel = document.createElement('label');
        nameLabel.className = 'sg-label';
        nameLabel.textContent = 'Service name';
        var nameI = document.createElement('input');
        nameI.type='text'; nameI.className='sg-input'; nameI.placeholder='e.g. Estate Planning'; nameI.value=s.name;
        nameI.addEventListener('input', function(){ state.services[idx].name = nameI.value; render(); });
        nameField.appendChild(nameLabel); nameField.appendChild(nameI);
        try {
          if(typeof makeAiButton === 'function'){
            var nameAi = makeAiButton({
              label: 'Suggest service name',
              tooltip: 'Suggest a service name fitting this business type',
              getCurrentValue: function(){ return state.services[idx].name; },
              buildPrompt: function(current){
                var ctx = typeof bizContextString === 'function' ? bizContextString() : (state.name || 'this business');
                if(current){
                  return 'Rewrite this service name to be clearer and more specific (2-4 words max). Output ONLY the name:\n\n' + current;
                }
                var existing = state.services.map(function(x){return x.name;}).filter(Boolean).join(', ');
                return 'Suggest one specific service name for ' + ctx + (existing ? ' (already have: ' + existing + ' — suggest a different one)' : '') + '. 2-4 words max. Output ONLY the service name, no quotes, no period.';
              },
              applyResult: function(text){
                state.services[idx].name = text.replace(/^["']|["']$/g, '');
                nameI.value = state.services[idx].name;
                render();
              }
            });
            if(typeof registerAi === 'function') registerAi(nameAi);
            nameField.appendChild(nameAi);
          }
        } catch(e){ if(window.console) console.error('Service name AI failed:', e); }

        // Description field with AI button
        var descField = document.createElement('div');
        descField.className = 'sg-field sg-field-full sg-field-with-ai';
        var descLabel = document.createElement('label');
        descLabel.className = 'sg-label';
        descLabel.textContent = 'Short description (optional)';
        var descI = document.createElement('textarea');
        descI.className='sg-input sg-textarea'; descI.rows=2; descI.placeholder='What this service includes, in one sentence.'; descI.value=s.description || '';
        descI.addEventListener('input', function(){ state.services[idx].description = descI.value; render(); });
        descField.appendChild(descLabel); descField.appendChild(descI);

        // AI button for service description (polish or generate from name + biz context)
        try {
          if(typeof makeAiButton === 'function'){
            var serviceAi = makeAiButton({
              label: 'Polish / Generate description',
              tooltip: 'Polish this description, or generate one from the service name',
              getCurrentValue: function(){ return state.services[idx].description; },
              buildPrompt: function(current){
                var sname = state.services[idx].name || 'this service';
                if(current){
                  return 'Rewrite this service description in 1 sentence. Factual, no em-dashes, no marketing puffery. Output ONLY the rewritten text:\n\n' + current;
                }
                return 'Write a 1-sentence factual description of "' + sname + '" as offered by ' + (typeof bizContextString === 'function' ? bizContextString() : (state.name || 'this business')) + '. No em-dashes, no marketing fluff. Output ONLY the description.';
              },
              applyResult: function(text){
                state.services[idx].description = text;
                descI.value = text;
                render();
              }
            });
            if(typeof registerAi === 'function') registerAi(serviceAi);
            descField.appendChild(serviceAi);
          }
        } catch(e){ if(window.console) console.error('Service AI button failed:', e); }

        // Price field with AI button
        var priceField = document.createElement('div');
        priceField.className = 'sg-field sg-field-full sg-field-with-ai';
        var priceLabel = document.createElement('label');
        priceLabel.className = 'sg-label';
        priceLabel.textContent = 'Price or starting from';
        var priceI = document.createElement('input');
        priceI.type='text'; priceI.className='sg-input'; priceI.placeholder='From $1,500'; priceI.value=s.price;
        priceI.addEventListener('input', function(){ state.services[idx].price = priceI.value; render(); });
        priceField.appendChild(priceLabel); priceField.appendChild(priceI);
        try {
          if(typeof makeAiButton === 'function'){
            var priceAi = makeAiButton({
              label: 'Suggest typical price',
              tooltip: 'Suggest a realistic price range for this service in this market',
              getCurrentValue: function(){ return state.services[idx].price; },
              buildPrompt: function(current){
                var sname = state.services[idx].name || 'this service';
                var ctx = typeof bizContextString === 'function' ? bizContextString() : (state.name || 'this business');
                if(current){
                  return 'Reformat this price for schema markup readability. Keep currency and value, just improve format. Output ONLY the formatted price (e.g. "From $1,500" or "$150"):\n\n' + current;
                }
                return 'Suggest a realistic typical starting price for "' + sname + '" offered by ' + ctx + '. Use US dollars. Format: "From $X" or "$X" only. No explanation, no range, just one short price string.';
              },
              applyResult: function(text){
                state.services[idx].price = text.replace(/^["']|["']$/g, '');
                priceI.value = state.services[idx].price;
                render();
              }
            });
            if(typeof registerAi === 'function') registerAi(priceAi);
            priceField.appendChild(priceAi);
          }
        } catch(e){ if(window.console) console.error('Service price AI failed:', e); }

        grid.appendChild(nameField); grid.appendChild(descField); grid.appendChild(priceField);
        card.appendChild(head); card.appendChild(grid);
        servicesList.appendChild(card);
      });
    }
    document.getElementById('sg-add-service').addEventListener('click', function(){
      if(state.services.length >= 5) return;
      state.services.push({name:'',description:'',price:''}); renderServices(); render();
    });

    var faqsList = document.getElementById('sg-faqs-list');
    function renderFaqs(){
      faqsList.innerHTML = '';
      state.faqs.forEach(function(f, idx){
