    // ===== AI POLISH (BYO API key) =====
    var aiProviderEl = document.getElementById('sg-ai-provider');
    var aiKeyEl = document.getElementById('sg-ai-key');
    var aiModelEl = document.getElementById('sg-ai-model');
    var aiStatusEl = document.getElementById('sg-ai-status');
    var aiDefaultModelEl = document.getElementById('sg-ai-default-model');

    // ===== BULLETPROOF STATUS UPDATER (runs independent of state machinery) =====
    // This is wired BEFORE updateAiStatus so it always reflects DOM truth even if
    // anything else throws downstream.
    function bulletproofStatus(){
      try {
        if(!aiStatusEl) return;
        var k = aiKeyEl ? (aiKeyEl.value || '').trim() : '';
        var p = aiProviderEl ? (aiProviderEl.value || '').trim() : '';
        var hasK = !!k, hasP = !!p;
        var msg, cls;
        if(hasK && hasP){ msg = 'Ready: ' + p; cls = 'sg-ai-status sg-ai-status-ready'; }
        else if(hasK && !hasP){ msg = 'Pick a provider (key saved)'; cls = 'sg-ai-status sg-ai-status-partial'; }
        else if(!hasK && hasP){ msg = 'Paste API key (' + p + ' selected)'; cls = 'sg-ai-status sg-ai-status-partial'; }
        else { msg = 'Pick provider + add key'; cls = 'sg-ai-status'; }
        aiStatusEl.textContent = msg;
        aiStatusEl.className = cls;
        // Also enable/disable big buttons + sparkles
        var ready = hasK && hasP;
        document.querySelectorAll('.sg-ai-btn, .sg-ai-spark').forEach(function(b){
          if(!b.classList.contains('sg-ai-spark-loading') && !b.dataset.loading){
            b.disabled = !ready;
          }
        });
        if(aiKeyEl) aiKeyEl.classList.toggle('sg-input-filled', hasK);
        if(aiProviderEl) aiProviderEl.classList.toggle('sg-input-filled', hasP);
      } catch(e){ if(window.console) console.error('bulletproofStatus failed:', e); }
    }
    if(aiKeyEl){
      ['input','change','keyup','paste','blur'].forEach(function(ev){ aiKeyEl.addEventListener(ev, function(){ setTimeout(bulletproofStatus, 0); }); });
    }
    if(aiProviderEl){
      ['change','input','blur'].forEach(function(ev){ aiProviderEl.addEventListener(ev, bulletproofStatus); });
    }
    // Fire once on load
    bulletproofStatus();

    // Restore saved key + provider + model
    try {
      var savedKey = localStorage.getItem('sg-ai-key');
      var savedProvider = localStorage.getItem('sg-ai-provider');
      var savedModel = localStorage.getItem('sg-ai-model');
      if(savedKey) { aiKeyEl.value = savedKey; state.aiKey = savedKey; }
      if(savedProvider) { aiProviderEl.value = savedProvider; state.aiProvider = savedProvider; }
      if(savedModel) { aiModelEl.value = savedModel; state.aiModel = savedModel; }
    } catch(e){}

    function updateAiStatus(){
      // Read directly from DOM as the source of truth, not state
      // (state can race or be stale)
      var keyValue = aiKeyEl ? (aiKeyEl.value || '') : '';
      var providerValue = aiProviderEl ? (aiProviderEl.value || '') : '';
      // Sync state from DOM
      state.aiKey = keyValue;
      state.aiProvider = providerValue;
      var hasKey = !!(keyValue && keyValue.trim());
      var hasProvider = !!(providerValue && providerValue.trim());
      var ready = hasKey && hasProvider;
      var modelName = getModel();
      var statusText, tooltip;
      if(ready){
        statusText = 'Ready: ' + state.aiProvider + (modelName ? ' (' + modelName + ')' : '');
        tooltip = '';
      } else if(!hasProvider && !hasKey){
        statusText = 'Pick provider + add key';
        tooltip = 'Choose a provider from the dropdown and paste your API key';
      } else if(!hasProvider){
        statusText = 'Pick a provider (key saved)';
        tooltip = 'Key is saved. Now choose a provider from the dropdown above';
      } else if(!hasKey){
        statusText = 'Paste API key (' + state.aiProvider + ' selected)';
        tooltip = 'Provider is set. Now paste your API key above';
      }
      aiStatusEl.textContent = statusText;
      aiStatusEl.className = ready ? 'sg-ai-status sg-ai-status-ready' : (hasKey || hasProvider ? 'sg-ai-status sg-ai-status-partial' : 'sg-ai-status');
      aiStatusEl.title = tooltip;
      if(aiDefaultModelEl){
        aiDefaultModelEl.textContent = state.aiProvider ? (defaultModels[state.aiProvider] || 'unknown') : 'choose a provider above';
      }
      // Mark inputs visually based on filled state
      if(aiKeyEl) aiKeyEl.classList.toggle('sg-input-filled', hasKey);
      if(aiProviderEl) aiProviderEl.classList.toggle('sg-input-filled', hasProvider);
      document.querySelectorAll('.sg-ai-btn').forEach(function(b){
        b.disabled = !ready;
        b.title = ready ? '' : tooltip;
      });
    }
    updateAiStatus();

    aiProviderEl.addEventListener('change', function(){
      state.aiProvider = aiProviderEl.value;
      try { localStorage.setItem('sg-ai-provider', state.aiProvider); } catch(e){}
      updateAiStatus();
      refreshAiButtons();
    });
    function saveKey(){
      state.aiKey = aiKeyEl.value;
      try { localStorage.setItem('sg-ai-key', state.aiKey); } catch(e){}
      updateAiStatus();
      refreshAiButtons();
    }
    aiKeyEl.addEventListener('input', saveKey);
    aiKeyEl.addEventListener('change', saveKey);
    aiKeyEl.addEventListener('blur', saveKey);
    function saveModel(){
      state.aiModel = aiModelEl.value;
      try { localStorage.setItem('sg-ai-model', state.aiModel); } catch(e){}
      updateAiStatus();
    }
    aiModelEl.addEventListener('input', saveModel);
    aiModelEl.addEventListener('change', saveModel);
    document.getElementById('sg-ai-clear-key').addEventListener('click', function(){
      state.aiKey = ''; state.aiProvider = ''; state.aiModel = '';
      aiKeyEl.value = ''; aiProviderEl.value = ''; aiModelEl.value = '';
      try { localStorage.removeItem('sg-ai-key'); localStorage.removeItem('sg-ai-provider'); localStorage.removeItem('sg-ai-model'); } catch(e){}
      updateAiStatus();
    });

    // Default model IDs per provider — updated 2026-05.
    // User can override via the "Model" input below if a specific version is needed.
    var defaultModels = {
      anthropic: 'claude-haiku-4-5-20251001',
      openai:    'gpt-4o-mini',
      google:    'gemini-2.0-flash',
      groq:      'llama-3.3-70b-versatile',
      kimi:      'moonshot-v1-8k'
    };

    function getModel(){
      var override = state.aiModel && state.aiModel.trim();
      return override || defaultModels[state.aiProvider] || '';
    }

    function callAi(prompt, callback){
      if(!state.aiKey || !state.aiProvider) { callback(null, 'No API key set'); return; }
      var model = getModel();
      var endpoint, headers, body;
      if(state.aiProvider === 'anthropic'){
        endpoint = 'https://api.anthropic.com/v1/messages';
        headers = { 'x-api-key': state.aiKey, 'anthropic-version': '2023-06-01', 'content-type': 'application/json', 'anthropic-dangerous-direct-browser-access': 'true' };
        body = JSON.stringify({ model: model, max_tokens: 600, messages: [{ role: 'user', content: prompt }] });
      } else if(state.aiProvider === 'openai'){
        endpoint = 'https://api.openai.com/v1/chat/completions';
        headers = { 'Authorization': 'Bearer ' + state.aiKey, 'content-type': 'application/json' };
        body = JSON.stringify({ model: model, max_tokens: 600, messages: [{ role: 'user', content: prompt }] });
      } else if(state.aiProvider === 'google'){
        endpoint = 'https://generativelanguage.googleapis.com/v1beta/models/' + encodeURIComponent(model) + ':generateContent?key=' + encodeURIComponent(state.aiKey);
        headers = { 'content-type': 'application/json' };
        body = JSON.stringify({ contents: [{ parts: [{ text: prompt }] }], generationConfig: { maxOutputTokens: 600 } });
      } else if(state.aiProvider === 'groq'){
        endpoint = 'https://api.groq.com/openai/v1/chat/completions';
        headers = { 'Authorization': 'Bearer ' + state.aiKey, 'content-type': 'application/json' };
        body = JSON.stringify({ model: model, max_tokens: 600, messages: [{ role: 'user', content: prompt }] });
      } else if(state.aiProvider === 'kimi'){
        endpoint = 'https://api.moonshot.ai/v1/chat/completions';
        headers = { 'Authorization': 'Bearer ' + state.aiKey, 'content-type': 'application/json' };
        body = JSON.stringify({ model: model, max_tokens: 600, messages: [{ role: 'user', content: prompt }] });
      } else { callback(null, 'Unsupported provider'); return; }

      fetch(endpoint, { method: 'POST', headers: headers, body: body })
        .then(function(r){ return r.json().then(function(data){ return { status: r.status, data: data }; }); })
        .then(function(res){
          var data = res.data;
          // Extract error message if any
          if(res.status >= 400){
            var msg = '';
            if(data && data.error){
              if(typeof data.error === 'string') msg = data.error;
              else msg = data.error.message || data.error.type || JSON.stringify(data.error);
            } else { msg = 'HTTP ' + res.status; }
            callback(null, msg);
            return;
          }
          var text = '';
          if(state.aiProvider === 'anthropic') text = (data.content && data.content[0] && data.content[0].text) || '';
          else if(state.aiProvider === 'google') text = (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts && data.candidates[0].content.parts[0].text) || '';
          else text = (data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) || '';
          if(text) callback(text.trim());
          else callback(null, 'Empty response from provider');
        })
        .catch(function(e){ callback(null, e.message || 'Network error'); });
    }

    // ===== Per-field AI sparkle buttons =====
    // Generic helper: attach a small ✨ button next to any input/textarea
    // action: 'polish' | 'generate' | 'auto' (auto = polish if value, generate if empty)
    // contextFn: () => string  (returns prompt context, like business name + type)
    // applyFn: (text) => void  (applies the AI result to the form + state)
    function makeAiButton(opts){
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'sg-ai-spark';
      btn.setAttribute('aria-label', opts.label || 'AI polish or generate');
      var defaultText = opts.label || 'AI polish / generate';
      function renderIdle(){
        btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="margin-right:5px;flex-shrink:0;"><path d="M7 1.5l1.2 3.3L11.5 6 8.2 7.2 7 10.5 5.8 7.2 2.5 6l3.3-1.2L7 1.5zM11 9l.5 1.5L13 11l-1.5.5L11 13l-.5-1.5L9 11l1.5-.5L11 9z" fill="currentColor"/></svg><span>' + defaultText + '</span>';
      }
      renderIdle();
      var hasKey = state.aiKey && state.aiProvider;
      btn.disabled = !hasKey;
      btn.title = hasKey ? (opts.tooltip || 'Polish if filled, generate if empty') : 'Add provider + API key in the AI section to enable';
      btn.addEventListener('click', function(e){
        e.preventDefault();
        if(btn.disabled) return;
        var currentValue = opts.getCurrentValue ? opts.getCurrentValue() : '';
        var prompt = opts.buildPrompt(currentValue);
        btn.innerHTML = '<span class="sg-ai-spinner" aria-hidden="true"></span><span style="margin-left:6px;">Working...</span>';
        btn.disabled = true;
        btn.classList.add('sg-ai-spark-loading');
        callAi(prompt, function(text, err){
          renderIdle();
          btn.disabled = !(state.aiKey && state.aiProvider);
          btn.classList.remove('sg-ai-spark-loading');
          if(text){
            opts.applyResult(text);
          } else {
            alert('AI failed: ' + (err || 'unknown error'));
          }
        });
      });
      return btn;
    }
    try { __sgLog('makeAiButton defined'); } catch(e){}

    // Track all rendered AI buttons so we can re-enable/disable when key changes
    var aiButtonRegistry = [];
    function registerAi(btn){ aiButtonRegistry.push(btn); }
    function refreshAiButtons(){
      var keyValue = aiKeyEl ? (aiKeyEl.value || '') : '';
      var providerValue = aiProviderEl ? (aiProviderEl.value || '') : '';
      var hasKey = !!(keyValue && keyValue.trim());
      var hasProvider = !!(providerValue && providerValue.trim());
      var ready = hasKey && hasProvider;
      var disabledTip;
      if(!hasProvider && !hasKey) disabledTip = 'Add provider + API key in the AI section above';
      else if(!hasProvider) disabledTip = 'Pick a provider from the dropdown above';
      else disabledTip = 'Paste your API key in the AI section above';
      aiButtonRegistry.forEach(function(b){
        if(!b.classList.contains('sg-ai-spark-loading')){
          b.disabled = !ready;
          b.title = ready ? 'Polish if filled, generate if empty' : disabledTip;
        }
      });
      document.querySelectorAll('.sg-ai-btn').forEach(function(b){
        if(!b.dataset.loading){
          b.disabled = !ready;
          b.title = ready ? '' : disabledTip;
        }
      });
    }

    function bizContextString(){
      return (state.name || 'this business') + ' (' + state.businessType + ')' +
        (state.description ? '. ' + state.description : '') +
        (state.city ? ' in ' + state.city + (state.region ? ', ' + state.region : '') : '');
    }

    // Wire AI button next to Description field
    try {
      var descEl = document.getElementById('sg-description');
      if(descEl){
        var descAiBtn = makeAiButton({
          label: 'Polish / Generate description',
          tooltip: 'Polish if filled, generate from business context if empty',
          getCurrentValue: function(){ return state.description; },
          buildPrompt: function(current){
            if(current){
              return 'Rewrite this business description in 1-2 sharp factual sentences. No em-dashes, no marketing puffery. Output ONLY the rewritten text:\n\n' + current;
            }
            return 'Write a 1-2 sentence factual business description for: ' + state.name + ' (' + state.businessType + ')' + (state.city ? ' in ' + state.city + (state.region ? ', ' + state.region : '') : '') + '. No em-dashes, no marketing puffery. Output ONLY the description.';
          },
          applyResult: function(text){
            state.description = text;
            descEl.value = text;
            render();
          }
        });
        registerAi(descAiBtn);
        descEl.parentNode.classList.add('sg-field-with-ai');
        descEl.parentNode.appendChild(descAiBtn);
        try { __sgLog('description sparkle attached'); } catch(e){}
      } else {
        try { __sgErr('sg-description element not found'); } catch(e){}
      }
    } catch(e){ try { __sgErr('description AI button failed: ' + (e.message||e)); } catch(_){} }

    // Wire AI button next to knowsAbout textarea
    try {
      var knowsTa = document.getElementById('sg-knows-about');
      if(knowsTa){
        var knowsAiBtn = makeAiButton({
          label: 'Generate / Refresh topics',
          tooltip: 'Generate 8-10 specific topics this business is expert on',
          getCurrentValue: function(){ return state.knowsAbout.join('\n'); },
          buildPrompt: function(){
            return 'Based on this business: "' + bizContextString() + '"\n\nGenerate 8-10 specific topics this business is expert on, for schema.org knowsAbout. Use specific topics ("Estate planning" not "Legal services"). Output as a plain newline-separated list, no numbering, no bullets, no other text.';
          },
          applyResult: function(text){
            state.knowsAbout = text.split('\n').map(function(s){return s.replace(/^[-*\d.\s]+/, '').trim();}).filter(Boolean).slice(0, 12);
            knowsTa.value = state.knowsAbout.join('\n');
            render();
          }
        });
        registerAi(knowsAiBtn);
        knowsTa.parentNode.classList.add('sg-field-with-ai');
        knowsTa.parentNode.appendChild(knowsAiBtn);
        try { __sgLog('knowsAbout sparkle attached'); } catch(e){}
      } else {
        try { __sgErr('sg-knows-about element not found'); } catch(e){}
      }
    } catch(e){ try { __sgErr('knowsAbout AI button failed: ' + (e.message||e)); } catch(_){} }

    // The big buttons at the top of AI section now do master auto-fill + key clear
    document.getElementById('sg-ai-polish-desc').addEventListener('click', function(){
      var btn = this;
      var pitch = prompt('Paste a 1-3 sentence pitch about your business. AI will fill the entire form (description, services, FAQs, knowsAbout) for you to refine:');
      if(!pitch || !pitch.trim()) return;
      btn.querySelector('span').textContent = 'Auto-filling...';
      btn.disabled = true;
      btn.dataset.loading = 'true';
      var systemPrompt = 'You are filling a schema.org markup generator. Given this business pitch:\n\n"' + pitch + '"\n\nReturn a strict JSON object (no markdown, no commentary) with these keys:\n{\n  "name": "business name",\n  "description": "1-2 factual sentences, no em-dashes",\n  "services": [{"name":"...","description":"1 sentence","price":"From $X"}, ...] (3-5 services),\n  "faqs": [{"q":"...","a":"1-3 sentences"}, ...] (3-5 Q&As),\n  "knowsAbout": ["topic 1","topic 2"] (8-10 specific topics)\n}\n\nReturn ONLY the JSON object. No preamble, no code fence.';
      callAi(systemPrompt, function(text, err){
        btn.querySelector('span').textContent = 'Auto-fill from a pitch';
        btn.disabled = !(state.aiKey && state.aiProvider);
        delete btn.dataset.loading;
        if(!text){ alert('Auto-fill failed: ' + (err || 'unknown error')); return; }
        try {
          var cleaned = text.replace(/^```(?:json)?\s*/i, '').replace(/```\s*$/, '').trim();
          var data = JSON.parse(cleaned);
          if(data.name){ state.name = data.name; document.getElementById('sg-name').value = data.name; }
          if(data.description){ state.description = data.description; document.getElementById('sg-description').value = data.description; }
          if(data.services && data.services.length){
            state.services = data.services.slice(0, 5).map(function(s){ return { name: s.name||'', description: s.description||'', price: s.price||'' }; });
            renderServices();
            if(!state.includeService){ var t = document.getElementById('sg-include-service'); if(t){ t.checked = true; t.dispatchEvent(new Event('change')); } }
          }
          if(data.faqs && data.faqs.length){
            state.faqs = data.faqs.slice(0, 6).map(function(f){ return { q: f.q||'', a: f.a||'' }; });
            renderFaqs();
            if(!state.includeFaq){ var t2 = document.getElementById('sg-include-faq'); if(t2){ t2.checked = true; t2.dispatchEvent(new Event('change')); } }
          }
          if(data.knowsAbout && data.knowsAbout.length){
            state.knowsAbout = data.knowsAbout.slice(0, 12);
            var ka = document.getElementById('sg-knows-about'); if(ka) ka.value = state.knowsAbout.join('\n');
            if(!state.includeAuthority){ var t3 = document.getElementById('sg-include-authority'); if(t3){ t3.checked = true; t3.dispatchEvent(new Event('change')); } }
          }
          render();
        } catch(e){
          alert('Could not parse AI response as JSON. Try a clearer pitch. Raw response (first 200 chars):\n\n' + text.slice(0, 200));
        }
      });
    });

    document.getElementById('sg-ai-gen-knows').addEventListener('click', function(){
      var btn = this;
      var biz = bizContextString();
      btn.querySelector('span').textContent = 'Generating...';
      btn.disabled = true;
      btn.dataset.loading = 'true';
      var prompt = 'Based on this business: "' + biz + '"\n\nGenerate 8-10 specific topics this business is expert on, for schema.org knowsAbout. Use specific topics ("Estate planning" not "Legal services"). Output as a plain newline-separated list, no numbering, no bullets.';
      callAi(prompt, function(text, err){
        btn.querySelector('span').textContent = 'Generate knowsAbout (full list)';
        btn.disabled = !(state.aiKey && state.aiProvider);
        delete btn.dataset.loading;
        if(text){
          state.knowsAbout = text.split('\n').map(function(s){return s.replace(/^[-*\d.\s]+/, '').trim();}).filter(Boolean).slice(0, 12);
          var ta = document.getElementById('sg-knows-about');
          if(ta) ta.value = state.knowsAbout.join('\n');
          if(!state.includeAuthority){ var t = document.getElementById('sg-include-authority'); if(t){ t.checked = true; t.dispatchEvent(new Event('change')); } }
          render();
        } else {
          alert('AI generation failed: ' + (err || 'unknown error'));
        }
      });
    });

    renderServices(); renderFaqs(); render();
  });
})();
</script>

