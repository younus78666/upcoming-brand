        qLabel.className = 'sg-label';
        qLabel.textContent = 'Question';
        var qI = document.createElement('input');
        qI.type='text'; qI.className='sg-input'; qI.placeholder='e.g. How much does this cost?'; qI.value=f.q;
        qI.addEventListener('input', function(){ state.faqs[idx].q = qI.value; render(); });
        qField.appendChild(qLabel); qField.appendChild(qI);
        try {
          if(typeof makeAiButton === 'function'){
            var qAi = makeAiButton({
              label: 'Suggest a question',
              tooltip: 'Suggest a frequently-asked question for this business',
              getCurrentValue: function(){ return state.faqs[idx].q; },
              buildPrompt: function(current){
                var ctx = typeof bizContextString === 'function' ? bizContextString() : (state.name || 'this business');
