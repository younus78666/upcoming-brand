---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/tools/schema-generator/";

const jsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": canonical + "#tool",
      "name": "Schema Markup Generator",
      "description": "Free schema markup generator producing multi-entity JSON-LD with cross-references. Industry presets bundle correct schemas automatically.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "url": canonical,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "WebPage",
      "@id": canonical + "#webpage",
      "url": canonical,
      "name": "Schema Markup Generator | Multi-Entity JSON-LD | Upcoming Brand",
      "description": "Generate connected JSON-LD schemas with cross-references. Industry presets for law firms, dentists, restaurants, real estate. Free, no signup.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",              "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Tools",             "item": "https://upcomingbrand.com/tools/" },
          { "@type": "ListItem", "position": 3, "name": "Schema Generator", "item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title="Schema Markup Generator | Multi-Entity JSON-LD | Upcoming Brand"
  description="Generate connected JSON-LD schemas with cross-references. Industry presets bundle the right combinations for your vertical. Free, no signup."
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLdString} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <section class="sg-hero">
      <div class="container">
        <div class="sg-hero-inner">
          <a href="/tools/" class="sg-back">All tools</a>
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">Free tool</span><span class="page-eyebrow-line"></span></div>
          <h1 class="sg-h1">Schema markup generator that <em>links your entities.</em></h1>
          <p class="sg-lead">
            Most generators output one schema. Ours produces a complete graph with proper cross-references between Organization, WebSite, LocalBusiness, Service, and FAQ. Industry presets load the right combination automatically.
          </p>
        </div>
      </div>
    </section>

    <section class="sg-tool">
      <div class="container">

        <div class="sg-presets-wrap">
          <span class="sg-section-eyebrow">Industry presets</span>
          <p class="sg-presets-help">Click to load a multi-entity graph with sample data.</p>
          <div class="sg-presets" id="sg-presets">
            <button class="sg-preset" type="button" data-preset="law"><span class="sg-preset-name">Law Firm</span><span class="sg-preset-meta">LegalService + LocalBusiness + FAQ</span></button>
            <button class="sg-preset" type="button" data-preset="dental"><span class="sg-preset-name">Dental Practice</span><span class="sg-preset-meta">Dentist + MedicalProcedure + Review</span></button>
            <button class="sg-preset" type="button" data-preset="medical"><span class="sg-preset-name">Medical Clinic</span><span class="sg-preset-meta">MedicalClinic + Physician</span></button>
            <button class="sg-preset" type="button" data-preset="real-estate"><span class="sg-preset-name">Real Estate</span><span class="sg-preset-meta">RealEstateAgent + Service</span></button>
            <button class="sg-preset" type="button" data-preset="restaurant"><span class="sg-preset-name">Restaurant</span><span class="sg-preset-meta">Restaurant + Menu + Offer</span></button>
            <button class="sg-preset" type="button" data-preset="contractor"><span class="sg-preset-name">Contractor</span><span class="sg-preset-meta">HomeAndConstructionBusiness + Service</span></button>
            <button class="sg-preset" type="button" data-preset="ecommerce"><span class="sg-preset-name">Ecommerce</span><span class="sg-preset-meta">Store + Product + AggregateRating</span></button>
            <button class="sg-preset" type="button" data-preset="church"><span class="sg-preset-name">Church / Faith</span><span class="sg-preset-meta">Church + Event</span></button>
            <button class="sg-preset" type="button" data-preset="nonprofit"><span class="sg-preset-name">Nonprofit</span><span class="sg-preset-meta">NGO + DonateAction + Event</span></button>
          </div>
        </div>

        <div class="sg-grid">

          <div class="sg-form-wrap">
            <div class="sg-form-section">
              <h2 class="sg-form-section-title">Identity</h2>
              <p class="sg-form-section-sub">These fields seed every entity in the graph.</p>
              <div class="sg-form-grid">
                <div class="sg-field"><label for="sg-name" class="sg-label">Business name</label><input type="text" id="sg-name" class="sg-input" placeholder="e.g. Coleman and Reyes Law" /></div>
                <div class="sg-field"><label for="sg-url" class="sg-label">Website URL</label><input type="url" id="sg-url" class="sg-input" placeholder="https://example.com" /></div>
                <div class="sg-field sg-field-full"><label for="sg-description" class="sg-label">Short description</label><textarea id="sg-description" class="sg-input sg-textarea" rows="2" placeholder="One sentence about the business."></textarea></div>
                <div class="sg-field"><label for="sg-phone" class="sg-label">Phone</label><input type="text" id="sg-phone" class="sg-input" placeholder="+1-555-555-5555" /></div>
                <div class="sg-field"><label for="sg-email" class="sg-label">Email</label><input type="email" id="sg-email" class="sg-input" placeholder="hello@example.com" /></div>
                <div class="sg-field"><label for="sg-street" class="sg-label">Street</label><input type="text" id="sg-street" class="sg-input" placeholder="123 Main St" /></div>
                <div class="sg-field"><label for="sg-city" class="sg-label">City</label><input type="text" id="sg-city" class="sg-input" placeholder="Baltimore" /></div>
                <div class="sg-field"><label for="sg-region" class="sg-label">State</label><input type="text" id="sg-region" class="sg-input" placeholder="MD" /></div>
                <div class="sg-field"><label for="sg-postal" class="sg-label">Postal code</label><input type="text" id="sg-postal" class="sg-input" placeholder="21201" /></div>
                <div class="sg-field"><label class="sg-label">Business type</label>
                  <select id="sg-business-type" class="sg-input sg-select">
                    <option value="LocalBusiness">LocalBusiness</option>
                    <option value="LegalService">LegalService</option>
                    <option value="Attorney">Attorney</option>
                    <option value="MedicalBusiness">MedicalBusiness</option>
                    <option value="Dentist">Dentist</option>
                    <option value="MedicalClinic">MedicalClinic</option>
                    <option value="Physician">Physician</option>
                    <option value="RealEstateAgent">RealEstateAgent</option>
                    <option value="Restaurant">Restaurant</option>
                    <option value="HomeAndConstructionBusiness">HomeAndConstructionBusiness</option>
                    <option value="Store">Store</option>
                    <option value="Church">Church</option>
                    <option value="NGO">NGO</option>
                    <option value="AccountingService">AccountingService</option>
                    <option value="ProfessionalService">ProfessionalService</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="sg-form-section">
              <h2 class="sg-form-section-title">Entities to include</h2>
              <p class="sg-form-section-sub">Toggle the entity types to add to the graph. All reference Organization via cross-reference.</p>
              <div class="sg-toggles">
                <label class="sg-toggle"><input type="checkbox" id="sg-include-organization" checked /><span class="sg-toggle-name">Organization</span><span class="sg-toggle-desc">Brand identity layer (recommended)</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-website" checked /><span class="sg-toggle-name">WebSite</span><span class="sg-toggle-desc">Site-level entity with SearchAction</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-localbusiness" checked /><span class="sg-toggle-name">LocalBusiness</span><span class="sg-toggle-desc">Local SEO layer with address</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-rating" /><span class="sg-toggle-name">AggregateRating</span><span class="sg-toggle-desc">Star rating block</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-service" /><span class="sg-toggle-name">Service / Offer</span><span class="sg-toggle-desc">Up to 5 services</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-faq" /><span class="sg-toggle-name">FAQPage</span><span class="sg-toggle-desc">Up to 6 questions</span></label>
                <label class="sg-toggle"><input type="checkbox" id="sg-include-speakable" /><span class="sg-toggle-name">Speakable</span><span class="sg-toggle-desc">Voice search optimization</span></label>
              </div>
            </div>

            <div class="sg-form-section" id="sg-rating-section" data-shown="false">
              <h2 class="sg-form-section-title">Aggregate rating</h2>
              <div class="sg-form-grid">
                <div class="sg-field"><label for="sg-rating-value" class="sg-label">Rating value</label><input type="number" id="sg-rating-value" class="sg-input" step="0.1" min="1" max="5" value="5.0" /></div>
                <div class="sg-field"><label for="sg-rating-count" class="sg-label">Review count</label><input type="number" id="sg-rating-count" class="sg-input" min="1" value="12" /></div>
              </div>
            </div>

            <div class="sg-form-section" id="sg-service-section" data-shown="false">
              <h2 class="sg-form-section-title">Services offered</h2>
              <p class="sg-form-section-sub">Each becomes a Service entity, linked to Organization as provider.</p>
              <div class="sg-services" id="sg-services-list"></div>
              <button type="button" class="sg-add-row" id="sg-add-service">Add service</button>
            </div>

            <div class="sg-form-section" id="sg-faq-section" data-shown="false">
              <h2 class="sg-form-section-title">FAQ items</h2>
              <p class="sg-form-section-sub">Outputs FAQPage with Question and Answer entities.</p>
              <div class="sg-faqs" id="sg-faqs-list"></div>
              <button type="button" class="sg-add-row" id="sg-add-faq">Add Q and A</button>
            </div>

            <div class="sg-form-section" id="sg-speakable-section" data-shown="false">
              <h2 class="sg-form-section-title">Speakable selectors</h2>
              <p class="sg-form-section-sub">CSS selectors that Google Assistant can read aloud. One per line.</p>
              <div class="sg-form-grid">
                <div class="sg-field sg-field-full"><textarea id="sg-speakable-selectors" class="sg-input sg-textarea" rows="3" placeholder="h1, h2, .lead"></textarea></div>
              </div>
            </div>

          </div>

          <aside class="sg-output">
            <div class="sg-output-card">
              <div class="sg-output-stripe" aria-hidden="true"></div>
              <div class="sg-output-head">
                <span class="sg-output-eyebrow">Live JSON-LD</span>
                <div class="sg-output-actions">
                  <button type="button" class="sg-action" id="sg-copy"><span id="sg-copy-text">Copy</span></button>
                  <button type="button" class="sg-action" id="sg-download">Download</button>
                </div>
              </div>
              <pre class="sg-output-pre"><code id="sg-output-code">Fill in the identity fields above to generate JSON-LD.</code></pre>
              <div class="sg-output-stats">
                <span class="sg-output-stat"><span class="sg-output-stat-num" id="sg-stat-entities">0</span> entities</span>
                <span class="sg-output-stat"><span class="sg-output-stat-num" id="sg-stat-refs">0</span> cross-refs</span>
                <span class="sg-output-stat"><span class="sg-output-stat-num" id="sg-stat-bytes">0</span> bytes</span>
              </div>
              <a href="https://search.google.com/test/rich-results" target="_blank" rel="noopener" class="sg-validate-link">Test in Google Rich Results &rarr;</a>
            </div>
          </aside>

        </div>
      </div>
    </section>

    <section class="sg-why">
      <div class="container">
        <div class="sg-why-head">
          <span class="sg-section-eyebrow">Why multi-entity</span>
          <h2 class="sg-h2">Most generators output one schema. <em>We output a graph.</em></h2>
        </div>
        <div class="sg-why-grid">
          <article class="sg-why-card"><span class="sg-why-num">01</span><h3 class="sg-why-title">Entity disambiguation</h3><p class="sg-why-text">Service entities reference the organization by id instead of repeating fields. Google links them in its knowledge graph.</p></article>
          <article class="sg-why-card"><span class="sg-why-num">02</span><h3 class="sg-why-title">Single source of truth</h3><p class="sg-why-text">Update Organization once and every linked entity inherits the change. No duplicate maintenance.</p></article>
          <article class="sg-why-card"><span class="sg-why-num">03</span><h3 class="sg-why-title">More rich result types</h3><p class="sg-why-text">Connected schemas qualify for review snippets plus service rich result plus FAQ stack plus sitelinks search.</p></article>
          <article class="sg-why-card"><span class="sg-why-num">04</span><h3 class="sg-why-title">Cleaner audit trail</h3><p class="sg-why-text">Search Console traces issues by id. A clean graph makes diagnosing schema problems materially faster.</p></article>
        </div>
      </div>
    </section>

  </main>
  <BottomFormCTA formName="schema-generator-cta" heading="Need a senior to set this up properly?" sub="Schema is one of five layers we cover. Book a free 15-minute call to audit your full structured data setup." />
  <Footer />
</BaseLayout>

<script is:inline>
(function(){
  document.addEventListener('DOMContentLoaded', function(){
    var state = {
      name:'', url:'', description:'', phone:'', email:'',
      street:'', city:'', region:'', postal:'', country:'US',
      businessType:'LocalBusiness',
      includeOrganization:true, includeWebsite:true, includeLocalBusiness:true,
      includeRating:false, ratingValue:'5.0', ratingCount:'12',
      includeService:false, services:[{name:'',price:''}],
      includeFaq:false, faqs:[{q:'',a:''}],
      includeSpeakable:false, speakableSelectors:[]
    };

    function bind(id, key){
      var el = document.getElementById(id);
      if(!el) return;
      state[key] = el.value;
      el.addEventListener('input', function(){ state[key] = el.value; render(); });
    }
    bind('sg-name','name'); bind('sg-url','url'); bind('sg-description','description');
    bind('sg-phone','phone'); bind('sg-email','email'); bind('sg-street','street');
    bind('sg-city','city'); bind('sg-region','region'); bind('sg-postal','postal');
    bind('sg-rating-value','ratingValue'); bind('sg-rating-count','ratingCount');

    document.getElementById('sg-business-type').addEventListener('change', function(e){
      state.businessType = e.target.value; render();
    });

    var toggles = [
      ['sg-include-organization','includeOrganization', null],
      ['sg-include-website','includeWebsite', null],
      ['sg-include-localbusiness','includeLocalBusiness', null],
      ['sg-include-rating','includeRating', 'sg-rating-section'],
      ['sg-include-service','includeService', 'sg-service-section'],
      ['sg-include-faq','includeFaq', 'sg-faq-section'],
      ['sg-include-speakable','includeSpeakable', 'sg-speakable-section']
    ];
    toggles.forEach(function(t){
      var id = t[0], key = t[1], sectionId = t[2];
      var el = document.getElementById(id);
      if(!el) return;
      var label = el.closest('.sg-toggle');
      function syncLabel(){ if(label) label.classList.toggle('sg-toggle-active', el.checked); }
      syncLabel();
      el.addEventListener('change', function(){
        state[key] = el.checked;
        syncLabel();
        if(sectionId){
          var sec = document.getElementById(sectionId);
          if(sec) sec.dataset.shown = el.checked ? 'true' : 'false';
        }
        render();
      });
    });

    var speakableEl = document.getElementById('sg-speakable-selectors');
    if(speakableEl){
      speakableEl.addEventListener('input', function(){
        state.speakableSelectors = speakableEl.value.split('\n').map(function(s){return s.trim();}).filter(Boolean);
        render();
      });
    }

    var servicesList = document.getElementById('sg-services-list');
    function renderServices(){
      servicesList.innerHTML = '';
      state.services.forEach(function(s, idx){
        var row = document.createElement('div');
        row.className = 'sg-service-row';
        var nameI = document.createElement('input');
        nameI.type='text'; nameI.className='sg-input'; nameI.placeholder='Service name'; nameI.value=s.name;
        var priceI = document.createElement('input');
        priceI.type='text'; priceI.className='sg-input'; priceI.placeholder='From $1,500'; priceI.value=s.price;
        var rmB = document.createElement('button');
        rmB.type='button'; rmB.className='sg-row-remove'; rmB.textContent='Remove';
        nameI.addEventListener('input', function(){ state.services[idx].name = nameI.value; render(); });
        priceI.addEventListener('input', function(){ state.services[idx].price = priceI.value; render(); });
        rmB.addEventListener('click', function(){
          state.services.splice(idx,1);
          if(state.services.length===0) state.services.push({name:'',price:''});
          renderServices(); render();
        });
        row.appendChild(nameI); row.appendChild(priceI); row.appendChild(rmB);
        servicesList.appendChild(row);
      });
    }
    document.getElementById('sg-add-service').addEventListener('click', function(){
      if(state.services.length >= 5) return;
      state.services.push({name:'', price:''}); renderServices(); render();
    });

    var faqsList = document.getElementById('sg-faqs-list');
    function renderFaqs(){
      faqsList.innerHTML = '';
      state.faqs.forEach(function(f, idx){
        var row = document.createElement('div');
        row.className = 'sg-faq-row';
        var qI = document.createElement('input');
        qI.type='text'; qI.className='sg-input'; qI.placeholder='Question'; qI.value=f.q;
        var aI = document.createElement('textarea');
        aI.className='sg-input sg-textarea'; aI.rows=2; aI.placeholder='Answer'; aI.value=f.a;
        var rmB = document.createElement('button');
        rmB.type='button'; rmB.className='sg-row-remove'; rmB.textContent='Remove';
        qI.addEventListener('input', function(){ state.faqs[idx].q = qI.value; render(); });
        aI.addEventListener('input', function(){ state.faqs[idx].a = aI.value; render(); });
        rmB.addEventListener('click', function(){
          state.faqs.splice(idx,1);
          if(state.faqs.length===0) state.faqs.push({q:'',a:''});
          renderFaqs(); render();
        });
        row.appendChild(qI); row.appendChild(aI); row.appendChild(rmB);
        faqsList.appendChild(row);
      });
    }
    document.getElementById('sg-add-faq').addEventListener('click', function(){
      if(state.faqs.length >= 6) return;
      state.faqs.push({q:'', a:''}); renderFaqs(); render();
    });

    // Industry presets
    var presets = {
      'law': { name:'Coleman and Reyes Law', url:'https://example-law.com', description:'Maryland estate planning and business law firm.', businessType:'LegalService', street:'1100 N Charles St', city:'Baltimore', region:'MD', postal:'21201', phone:'+1-410-555-0100', email:'hello@example-law.com', includeRating:true, includeService:true, includeFaq:true, services:[{name:'Estate Planning',price:'From $2,500'},{name:'Business Formation',price:'From $1,500'}], faqs:[{q:'How much does estate planning cost?',a:'Estate planning starts at $2,500 for basic packages.'}] },
      'dental': { name:'Hartford Family Dentistry', url:'https://example-dental.com', description:'Family and cosmetic dental practice.', businessType:'Dentist', street:'500 York Rd', city:'Towson', region:'MD', postal:'21204', phone:'+1-410-555-0200', email:'hello@example-dental.com', includeRating:true, includeService:true, services:[{name:'Dental Cleaning',price:'$150'},{name:'Teeth Whitening',price:'From $400'}] },
      'medical': { name:'Park Family Practice', url:'https://example-medical.com', description:'Primary care medical practice.', businessType:'MedicalClinic', street:'6710 Oak Hall Ln', city:'Columbia', region:'MD', postal:'21045', phone:'+1-410-555-0300', email:'hello@example-medical.com', includeRating:true },
      'real-estate': { name:'Donnelly Bay Properties', url:'https://example-realty.com', description:'Annapolis real estate brokerage specializing in waterfront homes.', businessType:'RealEstateAgent', street:'110 Main St', city:'Annapolis', region:'MD', postal:'21401', phone:'+1-410-555-0400', email:'hello@example-realty.com', includeRating:true, includeService:true, services:[{name:'Buyer Representation',price:'Standard commission'},{name:'Seller Representation',price:'Standard commission'}] },
      'restaurant': { name:'Russo Italian Kitchen', url:'https://example-restaurant.com', description:'Modern Italian restaurant in Baltimore.', businessType:'Restaurant', street:'200 W Pratt St', city:'Baltimore', region:'MD', postal:'21201', phone:'+1-410-555-0500', email:'reservations@example-restaurant.com', includeRating:true },
      'contractor': { name:'Mendoza Roofing', url:'https://example-contractor.com', description:'Maryland-based roofing contractor.', businessType:'HomeAndConstructionBusiness', street:'450 W Patrick St', city:'Frederick', region:'MD', postal:'21701', phone:'+1-301-555-0600', email:'quotes@example-contractor.com', includeRating:true, includeService:true, services:[{name:'Roof Replacement',price:'From $8,500'},{name:'Roof Repair',price:'From $450'}] },
      'ecommerce': { name:'Brennan Outdoor Co.', url:'https://example-shop.com', description:'Outdoor and camping gear retailer.', businessType:'Store', street:'8200 Snowden River Pkwy', city:'Columbia', region:'MD', postal:'21045', phone:'+1-410-555-0700', email:'support@example-shop.com', includeRating:true },
      'church': { name:'Greater Faith Fellowship', url:'https://example-church.org', description:'Multi-campus church serving Baltimore.', businessType:'Church', street:'300 N Charles St', city:'Baltimore', region:'MD', postal:'21201', phone:'+1-410-555-0800', email:'office@example-church.org', includeFaq:true, faqs:[{q:'When are services?',a:'Sundays at 9 AM and 11 AM.'}] },
      'nonprofit': { name:'Maryland Community Foundation', url:'https://example-nonprofit.org', description:'Statewide community foundation supporting Maryland.', businessType:'NGO', street:'600 N Howard St', city:'Baltimore', region:'MD', postal:'21201', phone:'+1-410-555-0900', email:'info@example-nonprofit.org' }
    };

    document.querySelectorAll('.sg-preset').forEach(function(b){
      b.addEventListener('click', function(){
        var p = presets[b.dataset.preset];
        if(!p) return;
        Object.keys(p).forEach(function(k){ state[k] = p[k]; });
        if(!p.services) state.services = [{name:'',price:''}];
        if(!p.faqs) state.faqs = [{q:'',a:''}];
        // Sync DOM
        document.getElementById('sg-name').value = state.name;
        document.getElementById('sg-url').value = state.url;
        document.getElementById('sg-description').value = state.description;
        document.getElementById('sg-phone').value = state.phone || '';
        document.getElementById('sg-email').value = state.email || '';
        document.getElementById('sg-street').value = state.street || '';
        document.getElementById('sg-city').value = state.city || '';
        document.getElementById('sg-region').value = state.region || '';
        document.getElementById('sg-postal').value = state.postal || '';
        document.getElementById('sg-business-type').value = state.businessType;
        document.getElementById('sg-include-rating').checked = !!state.includeRating;
        document.getElementById('sg-include-service').checked = !!state.includeService;
        document.getElementById('sg-include-faq').checked = !!state.includeFaq;
        document.getElementById('sg-rating-section').dataset.shown = state.includeRating ? 'true' : 'false';
        document.getElementById('sg-service-section').dataset.shown = state.includeService ? 'true' : 'false';
        document.getElementById('sg-faq-section').dataset.shown = state.includeFaq ? 'true' : 'false';
        // Sync toggle visual
        document.querySelectorAll('.sg-toggle').forEach(function(l){
          var i = l.querySelector('input');
          if(i) l.classList.toggle('sg-toggle-active', i.checked);
        });
        renderServices(); renderFaqs(); render();
        document.querySelector('.sg-grid').scrollIntoView({behavior:'smooth', block:'start'});
      });
    });

    function buildGraph(){
      var baseUrl = (state.url || 'https://example.com').replace(/\/$/, '');
      var orgId = baseUrl + '#organization';
      var websiteId = baseUrl + '#website';
      var businessId = baseUrl + '#business';
      var ratingId = baseUrl + '#rating';
      var graph = [];

      if(state.includeOrganization){
        var org = { '@type':'Organization', '@id':orgId, name:(state.name||'[Business name]'), url:baseUrl };
        if(state.description) org.description = state.description;
        if(state.email) org.email = state.email;
        if(state.phone) org.telephone = state.phone;
        graph.push(org);
      }

      if(state.includeWebsite){
        var site = { '@type':'WebSite', '@id':websiteId, url:baseUrl, name:(state.name||'[Business name]') };
        if(state.includeOrganization) site.publisher = { '@id': orgId };
        site.potentialAction = { '@type':'SearchAction', target:{ '@type':'EntryPoint', urlTemplate:(baseUrl + '/?s=SEARCHTERM') }, 'query-input':'required name=SEARCHTERM' };
        graph.push(site);
      }

      if(state.includeLocalBusiness){
        var biz = { '@type':state.businessType, '@id':businessId, name:(state.name||'[Business name]'), url:baseUrl };
        if(state.description) biz.description = state.description;
        if(state.phone) biz.telephone = state.phone;
        if(state.email) biz.email = state.email;
        if(state.street || state.city || state.region){
          biz.address = { '@type':'PostalAddress' };
          if(state.street) biz.address.streetAddress = state.street;
          if(state.city) biz.address.addressLocality = state.city;
          if(state.region) biz.address.addressRegion = state.region;
          if(state.postal) biz.address.postalCode = state.postal;
          if(state.country) biz.address.addressCountry = state.country;
        }
        if(state.includeOrganization) biz.parentOrganization = { '@id': orgId };
        if(state.includeRating) biz.aggregateRating = { '@id': ratingId };
        graph.push(biz);
      }

      if(state.includeRating){
        graph.push({ '@type':'AggregateRating', '@id':ratingId, ratingValue:(state.ratingValue||'5.0'), reviewCount:(state.ratingCount||'12'), bestRating:'5', worstRating:'1', itemReviewed: state.includeLocalBusiness ? { '@id': businessId } : undefined });
      }

      if(state.includeService){
        state.services.forEach(function(s, i){
          if(!s.name) return;
          var svc = { '@type':'Service', '@id':(baseUrl + '#service-' + (i+1)), name:s.name, serviceType:s.name };
          if(state.includeOrganization) svc.provider = { '@id': orgId };
          if(s.price){
            svc.offers = { '@type':'Offer', price:(s.price.replace(/[^\d.]/g,'') || '0'), priceCurrency:'USD', description:s.price };
          }
          graph.push(svc);
        });
      }

      if(state.includeFaq){
        var validFaqs = state.faqs.filter(function(f){return f.q && f.a;});
        if(validFaqs.length > 0){
          graph.push({ '@type':'FAQPage', '@id':(baseUrl + '#faqpage'), mainEntity: validFaqs.map(function(f){
            return { '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } };
          }) });
        }
      }

      if(state.includeSpeakable && state.speakableSelectors.length > 0){
        graph.push({ '@type':'SpeakableSpecification', '@id':(baseUrl + '#speakable'), cssSelector: state.speakableSelectors });
      }

      // Strip undefined values
      function clean(o){
        if(o === null || typeof o !== 'object') return o;
        if(Array.isArray(o)) return o.map(clean);
        var out = {};
        Object.keys(o).forEach(function(k){
          if(o[k] !== undefined) out[k] = clean(o[k]);
        });
        return out;
      }
      return { '@context':'https://schema.org', '@graph': graph.map(clean) };
    }

    var outputCode = document.getElementById('sg-output-code');
    var statEntities = document.getElementById('sg-stat-entities');
    var statRefs = document.getElementById('sg-stat-refs');
    var statBytes = document.getElementById('sg-stat-bytes');

    function render(){
      var graph = buildGraph();
      var json = JSON.stringify(graph, null, 2);
      var entityCount = graph['@graph'].length;
      var refMatches = json.match(/"@id":/g) || [];
      var refs = Math.max(0, refMatches.length - entityCount);
      var bytes = new Blob([json]).size;
      outputCode.textContent = json;
      statEntities.textContent = String(entityCount);
      statRefs.textContent = String(refs);
      statBytes.textContent = String(bytes);
    }

    document.getElementById('sg-copy').addEventListener('click', function(){
      navigator.clipboard.writeText(outputCode.textContent).then(function(){
        var t = document.getElementById('sg-copy-text');
        t.textContent = 'Copied!';
        setTimeout(function(){ t.textContent = 'Copy'; }, 2000);
      });
    });

    document.getElementById('sg-download').addEventListener('click', function(){
      var blob = new Blob([outputCode.textContent], { type:'application/ld+json' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = 'schema.json'; a.click();
      URL.revokeObjectURL(url);
    });

    renderServices(); renderFaqs(); render();
  });
})();
</script>

