---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { articles, categories, articleUrl, type BlogArticle } from '../../data/blog-articles';

export async function getStaticPaths() {
  return articles
    .filter((a) => a.status !== 'published')
    .map((a) => ({
      params: { slug: a.slug },
      props: { article: a },
    }));
}

interface Props { article: BlogArticle; }
const { article } = Astro.props;
const category = categories[article.category];
const canonical = `https://upcomingbrand.com/blog/${article.slug}/`;

const inCategory = articles.filter((a) => a.category === article.category && a.slug !== article.slug).slice(0, 6);
const otherCategories = articles.filter((a) => a.category !== article.category).slice(0, 4);

// Dynamic CTAs derived from article relations
const relatedServices = article.relatedServices ?? [];
const relatedIndustries = article.relatedIndustries ?? [];

// Searchable index for sidebar search (title + description + slug)
const searchIndex = articles.map((a) => ({ slug: a.slug, url: a.route ?? `/blog/${a.slug}/`, title: a.title, category: categories[a.category].label }));

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": `${article.title} | Upcoming Brand`,
      "description": article.description,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://upcomingbrand.com/blog/" },
          { "@type": "ListItem", "position": 3, "name": article.title, "item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title={`${article.title} | Coming Soon | Upcoming Brand`}
  description={article.description}
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
    <meta name="robots" content="noindex" />
  </Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- HERO (full width) -->
    <section class="art-hero">
      <div class="container">
        <div class="art-hero-inner">
          <a href="/blog/" class="art-back-link">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            All insights
          </a>
          <div class="art-meta">
            <span class="art-cat-pill">{category.label}</span>
            <span class="art-status-pill">
              <span class="art-status-dot" aria-hidden="true"></span>
              In production · {article.estPublishMonth ?? 'Coming soon'}
            </span>
          </div>
          <h1 class="art-h1">{article.title}</h1>
          <p class="art-lead">{article.description}</p>
        </div>
      </div>
    </section>

    <!-- BODY: 2-col with sticky sidebar -->
    <section class="art-body">
      <div class="container art-body-grid">

        <!-- ===== SIDEBAR (left) ===== -->
        <aside class="art-sidebar">

          <!-- Search -->
          <div class="art-side-card">
            <span class="art-side-eyebrow">Search insights</span>
            <div class="art-side-search">
              <svg class="art-side-search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9.5 9.5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <input type="search" id="art-side-search-input" class="art-side-search-input" placeholder="Search articles..." aria-label="Search articles" />
            </div>
            <ul class="art-side-search-results" id="art-side-search-results" data-empty="">
              <li class="art-side-search-empty">Start typing to search {articles.length} articles</li>
            </ul>
          </div>

          <!-- Dynamic CTAs (services/industries) -->
          {(relatedServices.length || relatedIndustries.length) && (
            <div class="art-side-card art-side-cta-card">
              <span class="art-side-eyebrow art-side-eyebrow-amber">Live and ready</span>
              <h3 class="art-side-title">Want answers now?</h3>
              <p class="art-side-sub">These pages cover adjacent ground while the article ships.</p>
              <div class="art-side-cta-list">
                {relatedServices.map((href) => (
                  <a href={href} class="art-side-cta-item">
                    <span class="art-side-cta-tag">Service</span>
                    <span class="art-side-cta-name">{href.replace(/^\/services\//, '').replace(/^\//, '').replace(/\/$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                    <svg class="art-side-cta-arrow" width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
                {relatedIndustries.map((href) => (
                  <a href={href} class="art-side-cta-item">
                    <span class="art-side-cta-tag">Industry</span>
                    <span class="art-side-cta-name">{href.replace(/^\/industries\//, '').replace(/^\//, '').replace(/\/$/, '').replace(/-website-design$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                    <svg class="art-side-cta-arrow" width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
              </div>
              <a href="/contact/" class="art-side-discovery">
                Book free 15-min call
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          )}

          <!-- Related posts in same category -->
          {inCategory.length > 0 && (
            <div class="art-side-card">
              <span class="art-side-eyebrow">More in {category.label}</span>
              <ul class="art-side-list">
                {inCategory.map((a) => (
                  <li>
                    <a href={articleUrl(a)} class="art-side-link">
                      <span class="art-side-link-title">{a.title}</span>
                      <span class="art-side-link-meta">{a.estPublishMonth ?? 'Coming soon'}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Browse all categories -->
          <div class="art-side-card">
            <span class="art-side-eyebrow">All categories</span>
            <ul class="art-side-cat-list">
              {Object.entries(categories).map(([id, c]) => (
                <li>
                  <a href={`/blog/#${id}`} class={`art-side-cat-link ${id === article.category ? 'art-side-cat-link-active' : ''}`}>
                    {c.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </aside>

        <!-- ===== MAIN COLUMN (right) ===== -->
        <div class="art-main">

          <!-- Coming soon notice -->
          <div class="art-notice">
            <div class="art-notice-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6m0 4v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div class="art-notice-body">
              <h2 class="art-notice-h2">This article is in production.</h2>
              <p class="art-notice-text">Subscribe below to get notified when it ships. If you need answers on this topic <strong>now</strong>, the sidebar lists related services and an option to book a free 15-minute call.</p>
            </div>
          </div>

          <!-- Subscribe -->
          <form class="art-subscribe" name={`blog-${article.slug}`} method="POST"-honeypot="bot-field" name="generic-form" data-uc-form="generic-form" data-uc-recaptcha-defer="true" novalidate>
            <input type="hidden" name="form-name" value={`blog-${article.slug}`} />
            <input type="hidden" name="article_slug" value={article.slug} />
            <div class="art-hp" aria-hidden="true"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
            <input class="art-subscribe-input" type="email" name="email" placeholder="your@email.com" required autocomplete="email" aria-label="Email address" />
            <button type="submit" class="art-subscribe-btn">
              Notify me <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>

          <!-- Cross-category articles teaser -->
          {otherCategories.length > 0 && (
            <div class="art-other-cats">
              <p class="art-other-eyebrow">Or explore other topics</p>
              <div class="art-other-grid">
                {otherCategories.map((a) => (
                  <a href={articleUrl(a)} class="art-other-card">
                    <span class="art-other-cat">{categories[a.category].label}</span>
                    <span class="art-other-title">{a.title}</span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

      </div>
    </section>

  </main>
<FinalCTA />
<Footer />
</BaseLayout>

<script is:inline define:vars={{ searchIndex }}>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('art-side-search-input');
    const results = document.getElementById('art-side-search-results');
    if (!input || !results) return;

    function render(items, empty) {
      results.innerHTML = '';
      if (empty) {
        results.dataset.empty = '';
        const li = document.createElement('li');
        li.className = 'art-side-search-empty';
        li.textContent = `Start typing to search ${searchIndex.length} articles`;
        results.appendChild(li);
        return;
      }
      delete results.dataset.empty;
      if (items.length === 0) {
        const li = document.createElement('li');
        li.className = 'art-side-search-empty';
        li.textContent = 'No articles match your search.';
        results.appendChild(li);
        return;
      }
      items.slice(0, 6).forEach((a) => {
        const li = document.createElement('li');
        const anchor = document.createElement('a');
        anchor.className = 'art-side-search-result';
        anchor.href = a.url;
        const titleSpan = document.createElement('span');
        titleSpan.className = 'art-side-search-title';
        titleSpan.textContent = a.title;
        const catSpan = document.createElement('span');
        catSpan.className = 'art-side-search-cat';
        catSpan.textContent = a.category;
        anchor.appendChild(titleSpan);
        anchor.appendChild(catSpan);
        li.appendChild(anchor);
        results.appendChild(li);
      });
    }

    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      if (!q) { render([], true); return; }
      const matches = searchIndex.filter((a) =>
        a.title.toLowerCase().includes(q) ||
        a.slug.toLowerCase().includes(q) ||
        a.category.toLowerCase().includes(q)
      );
      render(matches, false);
    });
  });
</script>

<style>
  /* HERO */
  .art-hero { background: var(--cream); padding: clamp(40px, 6vh, 72px) 0 clamp(36px, 5vh, 64px); border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
  .art-hero::before { content: ""; position: absolute; top: -200px; right: -150px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(212,147,46,0.1) 0%, transparent 55%); pointer-events: none; }
  .art-hero::after { content: ""; position: absolute; bottom: -100px; left: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(212,147,46,0.06) 0%, transparent 60%); pointer-events: none; }
  .art-hero-inner { position: relative; z-index: 1; max-width: 880px; display: flex; flex-direction: column; gap: 14px; }
  .art-h1 { font-family: var(--f-display); font-weight: 500; font-size: clamp(32px, 5vw, 52px); line-height: 1.05; letter-spacing: -0.03em; color: var(--ink); margin: 6px 0 0; }
  .art-back-link { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); text-decoration: none; transition: color 0.2s ease; align-self: flex-start; }
  .art-back-link:hover { color: var(--amber-deep); }
  .art-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .art-cat-pill { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); padding: 4px 12px; background: rgba(212,147,46,0.1); border-radius: var(--radius-pill); font-weight: 600; }
  .art-status-pill { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); padding: 4px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-pill); }
  .art-status-dot { width: 6px; height: 6px; background: var(--amber); border-radius: 50%; animation: art-pulse 2.4s ease-in-out infinite; }
  @keyframes art-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .art-lead { font-size: clamp(15px, 1.2vw, 18px); line-height: 1.65; color: var(--ink-soft); margin: 0; max-width: 70ch; }

  /* BODY 2-COL */
  .art-body { background: var(--cream); padding: clamp(40px, 6vh, 72px) 0 clamp(56px, 8vh, 96px); border-bottom: 1px solid var(--line); }
  .art-body-grid { display: grid; grid-template-columns: 320px 1fr; gap: clamp(24px, 4vw, 56px); align-items: start; }

  /* SIDEBAR */
  .art-sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 24px; align-self: start; }
  .art-side-card { background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-lg); padding: 20px 22px; }
  .art-side-eyebrow { display: block; font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); font-weight: 600; margin-bottom: 12px; }
  .art-side-eyebrow-amber { color: var(--amber-deep); }
  .art-side-title { font-family: var(--f-display); font-size: 18px; line-height: 1.2; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 4px; font-weight: 500; }
  .art-side-sub { font-size: 12.5px; line-height: 1.5; color: var(--ink-soft); margin: 0 0 12px; }

  /* SEARCH */
  .art-side-search { position: relative; display: flex; align-items: center; }
  .art-side-search-icon { position: absolute; left: 12px; color: var(--ink-muted); pointer-events: none; }
  .art-side-search-input { width: 100%; padding: 10px 12px 10px 34px; background: var(--cream); border: 1px solid var(--line); border-radius: var(--radius-md); font-family: var(--f-body); font-size: 13px; color: var(--ink); outline: none; transition: border-color 0.2s ease, box-shadow 0.2s ease; }
  .art-side-search-input::placeholder { color: var(--ink-muted); }
  .art-side-search-input:focus { border-color: var(--amber); box-shadow: 0 0 0 3px rgba(212,147,46,0.16); }
  .art-side-search-results { list-style: none; padding: 0; margin: 10px 0 0; display: flex; flex-direction: column; gap: 4px; max-height: 240px; overflow-y: auto; }
  .art-side-search-results[data-empty] { max-height: none; }
  .art-side-search-empty { font-family: var(--f-mono); font-size: 10px; color: var(--ink-muted); padding: 6px 0; letter-spacing: 0.04em; }
  .art-side-search-result { display: flex; flex-direction: column; gap: 2px; padding: 8px 10px; border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: background 0.15s ease; }
  .art-side-search-result:hover { background: var(--cream); }
  .art-side-search-title { font-family: var(--f-display); font-size: 13px; line-height: 1.25; color: var(--ink); font-weight: 500; }
  .art-side-search-cat { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--amber-deep); }

  /* CTA CARD (dark, dynamic) */
  .art-side-cta-card { background: var(--ink); color: var(--cream); border-color: var(--amber); }
  .art-side-cta-card .art-side-title { color: var(--cream); }
  .art-side-cta-card .art-side-sub { color: rgba(244,239,230,0.65); }
  .art-side-cta-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
  .art-side-cta-item { display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items: center; padding: 10px 12px; background: rgba(244,239,230,0.05); border: 1px solid rgba(244,239,230,0.12); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: all 0.2s ease; }
  .art-side-cta-item:hover { background: rgba(244,239,230,0.08); border-color: var(--amber); }
  .art-side-cta-tag { grid-column: 1; font-family: var(--f-mono); font-size: 8px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber); font-weight: 600; }
  .art-side-cta-name { grid-column: 1; font-family: var(--f-display); font-size: 14px; line-height: 1.2; color: var(--cream); font-weight: 500; }
  .art-side-cta-arrow { grid-column: 2; grid-row: 1 / span 2; color: rgba(244,239,230,0.5); }
  .art-side-cta-item:hover .art-side-cta-arrow { color: var(--amber); }
  .art-side-discovery { display: inline-flex; align-items: center; justify-content: center; gap: 6px; width: 100%; padding: 10px 14px; background: var(--amber); color: var(--ink); border-radius: var(--radius-md); text-decoration: none; font-family: var(--f-body); font-size: 12.5px; font-weight: 600; transition: background 0.2s ease; }
  .art-side-discovery:hover { background: var(--amber-deep); color: var(--ink); }

  /* RELATED LIST */
  .art-side-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .art-side-link { display: flex; flex-direction: column; gap: 3px; padding: 10px 12px; background: var(--cream); border: 1px solid var(--line); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: all 0.2s ease; }
  .art-side-link:hover { border-color: var(--amber); transform: translateX(2px); }
  .art-side-link-title { font-family: var(--f-display); font-size: 13.5px; line-height: 1.3; color: var(--ink); font-weight: 500; }
  .art-side-link-meta { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); }

  /* CATEGORIES */
  .art-side-cat-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .art-side-cat-link { display: block; padding: 8px 12px; font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-soft); text-decoration: none; border-radius: var(--radius-md); transition: all 0.15s ease; }
  .art-side-cat-link:hover { background: var(--cream); color: var(--ink); }
  .art-side-cat-link-active { background: var(--ink); color: var(--cream); }
  .art-side-cat-link-active:hover { background: var(--ink); color: var(--cream); }

  /* MAIN */
  .art-main { display: flex; flex-direction: column; gap: 18px; min-width: 0; }

  .art-notice { display: grid; grid-template-columns: 32px 1fr; gap: 14px; padding: 22px 24px; background: var(--paper); border: 1.5px solid rgba(212,147,46,0.3); border-radius: var(--radius-lg); position: relative; overflow: hidden; }
  .art-notice::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--amber); }
  .art-notice-icon { color: var(--amber-deep); display: flex; align-items: flex-start; padding-top: 2px; }
  .art-notice-h2 { font-family: var(--f-display); font-size: 18px; line-height: 1.3; color: var(--ink); font-weight: 600; margin: 0 0 4px; }
  .art-notice-text { font-size: 14px; line-height: 1.6; color: var(--ink-soft); margin: 0; }
  .art-notice-text strong { font-weight: 600; color: var(--ink); }

  .art-subscribe { display: flex; gap: 8px; padding: 8px; background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-pill); position: relative; }
  .art-subscribe-input { flex: 1; padding: 10px 16px; background: transparent; border: none; font-family: var(--f-body); font-size: 14px; color: var(--ink); outline: none; }
  .art-subscribe-input::placeholder { color: var(--ink-muted); }
  .art-subscribe-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: var(--ink); color: var(--cream); border: none; border-radius: var(--radius-pill); font-family: var(--f-body); font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; white-space: nowrap; }
  .art-subscribe-btn:hover { background: var(--amber-deep); }
  .art-hp { position: absolute; left: -10000px; }

  .art-other-cats { margin-top: 24px; padding: 24px 24px 4px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .art-other-eyebrow { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; margin: 0 0 14px; }
  .art-other-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding-bottom: 20px; }
  .art-other-card { display: flex; flex-direction: column; gap: 6px; padding: 14px 16px; background: var(--cream); border: 1px solid var(--line); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: all 0.25s ease; }
  .art-other-card:hover { border-color: var(--amber); transform: translateY(-2px); }
  .art-other-cat { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; }
  .art-other-title { font-family: var(--f-display); font-size: 14px; line-height: 1.3; color: var(--ink); font-weight: 500; }

  @media (max-width: 1024px) {
    .art-body-grid { grid-template-columns: 1fr; }
    .art-sidebar { position: static; order: 2; }
    .art-main { order: 1; }
    .art-other-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .art-subscribe { flex-direction: column; border-radius: var(--radius-lg); }
  }
</style>
