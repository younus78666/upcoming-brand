---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import BottomFormCTA from '../../components/BottomFormCTA.astro';
import { articles, categories, type BlogArticle } from '../../data/blog-articles';

export async function getStaticPaths() {
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

interface Props { article: BlogArticle; }
const { article } = Astro.props;
const category = categories[article.category];
const canonical = `https://upcomingbrand.com/blog/${article.slug}/`;

const related = articles
  .filter((a) => a.category === article.category && a.slug !== article.slug)
  .slice(0, 4);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": `${article.title} | Upcoming Brand`,
      "description": article.description,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://upcomingbrand.com/blog/" },
          { "@type": "ListItem", "position": 3, "name": article.title, "item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title={`${article.title} | Coming Soon | Upcoming Brand`}
  description={article.description}
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
    <meta name="robots" content="noindex" />
  </Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <section class="art-hero">
      <div class="container">
        <div class="art-hero-inner">
          <a href="/blog/" class="art-back-link">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            All insights
          </a>

          <div class="art-meta">
            <span class="art-cat-pill">{category.label}</span>
            <span class="art-status-pill">
              <span class="art-status-dot" aria-hidden="true"></span>
              In production · {article.estPublishMonth ?? 'Coming soon'}
            </span>
          </div>

          <h1 class="art-h1">{article.title}</h1>
          <p class="art-lead">{article.description}</p>

          <div class="art-notice">
            <div class="art-notice-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6m0 4v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div class="art-notice-body">
              <h2 class="art-notice-h2">This article is in production.</h2>
              <p class="art-notice-text">Subscribe below to get notified when it ships. If you need answers on this topic <strong>now</strong>, book a free 15-minute call and we will share what we know.</p>
            </div>
          </div>

          <form class="art-subscribe" name={`blog-${article.slug}`} method="POST" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value={`blog-${article.slug}`} />
            <input type="hidden" name="article_slug" value={article.slug} />
            <div class="art-hp" aria-hidden="true"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
            <input class="art-subscribe-input" type="email" name="email" placeholder="your@email.com" required autocomplete="email" aria-label="Email address" />
            <button type="submit" class="art-subscribe-btn">
              Notify me <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
        </div>
      </div>
    </section>

    {(article.relatedServices?.length || article.relatedIndustries?.length) && (
      <section class="art-related-pages">
        <div class="container">
          <div class="art-related-head">
            <h2 class="art-related-h2">While you wait, see related work.</h2>
            <p class="art-related-sub">These pages are live and cover adjacent ground for this topic.</p>
          </div>
          <div class="art-related-grid">
            {article.relatedServices?.map((href) => (
              <a href={href} class="art-related-card art-related-card-service">
                <span class="art-related-tag">Service</span>
                <span class="art-related-name">{href.replace('/services/', '').replace(/\/$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                <span class="art-related-arrow"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </a>
            ))}
            {article.relatedIndustries?.map((href) => (
              <a href={href} class="art-related-card art-related-card-industry">
                <span class="art-related-tag">Industry</span>
                <span class="art-related-name">{href.replace('/industries/', '').replace(/\/$/, '').replace(/-website-design/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                <span class="art-related-arrow"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="art-related-articles">
        <div class="container">
          <div class="art-related-head">
            <h2 class="art-related-h2">Other articles in {category.label}</h2>
            <p class="art-related-sub">Subscribe once and you will be notified when any of these ship.</p>
          </div>
          <div class="art-grid">
            {related.map((a) => (
              <a href={`/blog/${a.slug}/`} class="art-card">
                <div class="art-card-meta">
                  <span class="art-card-cat">{category.label}</span>
                  <span class="art-card-status">{a.estPublishMonth ?? 'Coming soon'}</span>
                </div>
                <h3 class="art-card-title">{a.title}</h3>
                <p class="art-card-desc">{a.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
  <BottomFormCTA formName={`blog-cta-${article.slug}`} heading="Need this answered today?" sub="If this topic is blocking a decision, book a free 15-minute call. We will share our thinking even though the article is not ready." />
  <Footer />
</BaseLayout>

<style>
  .art-hero { background: var(--cream); padding: clamp(48px, 7vh, 88px) 0 clamp(40px, 6vh, 72px); border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
  .art-hero::before { content: ""; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%); pointer-events: none; }
  .art-hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }

  .art-back-link { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); text-decoration: none; transition: color 0.2s ease; align-self: flex-start; }
  .art-back-link:hover { color: var(--amber-deep); }

  .art-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .art-cat-pill { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); padding: 4px 12px; background: rgba(212,147,46,0.1); border-radius: var(--radius-pill); font-weight: 600; }
  .art-status-pill { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); padding: 4px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-pill); }
  .art-status-dot { width: 6px; height: 6px; background: var(--amber); border-radius: 50%; animation: art-pulse 2.4s ease-in-out infinite; }
  @keyframes art-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .art-h1 { font-family: var(--f-display); font-weight: 500; font-size: clamp(28px, 4.5vw, 44px); line-height: 1.1; letter-spacing: -0.025em; color: var(--ink); margin: 4px 0 0; }
  .art-lead { font-size: clamp(15px, 1.2vw, 17px); line-height: 1.6; color: var(--ink-soft); margin: 0; }

  .art-notice { display: grid; grid-template-columns: 32px 1fr; gap: 14px; padding: 20px 22px; background: var(--paper); border: 1.5px solid rgba(212,147,46,0.3); border-radius: var(--radius-lg); margin-top: 4px; position: relative; overflow: hidden; }
  .art-notice::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--amber); }
  .art-notice-icon { color: var(--amber-deep); display: flex; align-items: flex-start; padding-top: 2px; }
  .art-notice-h2 { font-family: var(--f-display); font-size: 17px; line-height: 1.3; color: var(--ink); font-weight: 600; margin: 0 0 4px; }
  .art-notice-text { font-size: 13.5px; line-height: 1.55; color: var(--ink-soft); margin: 0; }
  .art-notice-text strong { font-weight: 600; color: var(--ink); }

  .art-subscribe { display: flex; gap: 8px; padding: 8px; background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-pill); position: relative; }
  .art-subscribe-input { flex: 1; padding: 10px 16px; background: transparent; border: none; font-family: var(--f-body); font-size: 14px; color: var(--ink); outline: none; }
  .art-subscribe-input::placeholder { color: var(--ink-muted); }
  .art-subscribe-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: var(--ink); color: var(--cream); border: none; border-radius: var(--radius-pill); font-family: var(--f-body); font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; white-space: nowrap; }
  .art-subscribe-btn:hover { background: var(--amber-deep); }
  .art-hp { position: absolute; left: -10000px; }

  .art-related-pages, .art-related-articles { background: var(--cream); padding: clamp(48px, 6vh, 72px) 0; border-bottom: 1px solid var(--line); }
  .art-related-articles { background: var(--paper); }
  .art-related-head { max-width: 760px; margin: 0 auto 28px; text-align: center; display: flex; flex-direction: column; gap: 6px; align-items: center; }
  .art-related-h2 { font-family: var(--f-display); font-size: clamp(22px, 2.8vw, 30px); line-height: 1.2; color: var(--ink); font-weight: 500; letter-spacing: -0.02em; margin: 0; }
  .art-related-sub { font-size: 14px; line-height: 1.55; color: var(--ink-soft); margin: 0; }

  .art-related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; max-width: 1000px; margin: 0 auto; }
  .art-related-card { display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items: center; padding: 18px 22px; background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: all 0.25s ease; }
  .art-related-card:hover { border-color: var(--amber); transform: translateY(-2px); }
  .art-related-tag { grid-column: 1; font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; }
  .art-related-name { grid-column: 1; font-family: var(--f-display); font-size: 16px; line-height: 1.2; color: var(--ink); font-weight: 500; }
  .art-related-arrow { grid-column: 2; grid-row: 1 / span 2; color: var(--ink-muted); }
  .art-related-card:hover .art-related-arrow { color: var(--amber-deep); }

  .art-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 1000px; margin: 0 auto; }
  .art-card { display: flex; flex-direction: column; gap: 8px; padding: 22px 24px; background: var(--cream); border: 1.5px solid var(--line); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: all 0.3s ease; }
  .art-card:hover { border-color: var(--amber); transform: translateY(-2px); }
  .art-card-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .art-card-cat { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; }
  .art-card-status { font-family: var(--f-mono); font-size: 10px; color: var(--ink-muted); padding: 2px 8px; background: rgba(15,20,25,0.05); border-radius: var(--radius-pill); }
  .art-card-title { font-family: var(--f-display); font-size: 17px; line-height: 1.25; color: var(--ink); font-weight: 600; margin: 0; }
  .art-card-desc { font-size: 13px; line-height: 1.55; color: var(--ink-soft); margin: 0; }

  @media (max-width: 768px) { .art-grid { grid-template-columns: 1fr; } .art-subscribe { flex-direction: column; border-radius: var(--radius-lg); } }
</style>
