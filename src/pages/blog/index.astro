---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { articles, categories, articleUrl } from '../../data/blog-articles';

const canonical = "https://upcomingbrand.com/blog/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": `${canonical}#blog`,
      "url": canonical,
      "name": "Upcoming Brand Insights",
      "description": "WordPress, SEO, and conversion insights from a senior agency. Buying guides, technical deep-dives, and vertical-specific playbooks.",
      "inLanguage": "en-US",
      "publisher": { "@id": "https://upcomingbrand.com/#organization" },
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Insights | WordPress + SEO Guides | Upcoming Brand",
      "description": "WordPress, SEO, hosting, and Local Pack guides. Honest comparisons, vertical playbooks, and technical deep-dives.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",   "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Insights", "item": canonical }
        ]
      }
    }
  ]
});

const filterChips = [
  { id: 'all', label: 'All articles' },
  ...Object.entries(categories).map(([id, c]) => ({ id, label: c.label })),
];

const stats = [
  { num: String(articles.length), label: 'Articles in production' },
  { num: '6',                      label: 'Topic categories' },
  { num: 'Tue',                    label: 'Weekly publish day' },
  { num: '2026',                   label: 'Editorial year' },
];
---
<BaseLayout
  title="Insights | WordPress + SEO Guides | Upcoming Brand"
  description="WordPress, SEO, hosting, and Local Pack guides from a senior agency. Honest comparisons, vertical playbooks, and technical deep-dives. New posts every Tuesday."
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLd} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- HERO -->
    <section class="blg-hero">
      <div class="container">
        <div class="blg-hero-inner">
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">Insights</span><span class="page-eyebrow-line"></span></div>
          <h1 class="blg-h1">
            <span class="blg-h1-line">WordPress + SEO insights</span>
            <span class="blg-h1-line blg-h1-accent"><em>that move rankings.</em></span>
          </h1>
          <p class="blg-lead">
            Buying guides, technical deep-dives, and vertical-specific playbooks for businesses serious about WordPress. New posts <strong>every Tuesday</strong>. The catalog below shows what is in production; subscribe to be notified when each ships.
          </p>

          <form class="blg-subscribe" name="blog-subscribe" method="POST"-honeypot="bot-field" data-uc-form="blog-subscribe" data-uc-recaptcha-defer="true" novalidate>
            <input type="hidden" name="form-name" value="blog-subscribe" />
            <div class="blg-hp" aria-hidden="true"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
            <input class="blg-subscribe-input" type="email" name="email" placeholder="your@email.com" required autocomplete="email" aria-label="Email address" />
            <button type="submit" class="blg-subscribe-btn">
              Subscribe <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>

          <div class="blg-stats">
            {stats.map((s) => (
              <div class="blg-stat">
                <div class="blg-stat-num">{s.num}</div>
                <div class="blg-stat-label">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CATEGORY FILTER -->
    <section class="blg-filters">
      <div class="container">
        <div class="blg-filters-inner" id="blg-filters">
          {filterChips.map((c) => (
            <button class="blg-filter-btn" data-filter={c.id} type="button">{c.label}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- CATEGORIES + ARTICLES -->
    {Object.entries(categories).map(([catId, cat]) => {
      const catArticles = articles.filter((a) => a.category === catId);
      return (
        <section class="blg-cat-section" data-cat-section={catId}>
          <div class="container">
            <div class="blg-cat-head">
              <h2 class="blg-cat-h2">{cat.label}</h2>
              <p class="blg-cat-desc">{cat.desc}</p>
              <span class="blg-cat-count">{catArticles.length} article{catArticles.length === 1 ? '' : 's'}</span>
            </div>
            <div class="blg-grid">
              {catArticles.map((a) => (
                <a href={articleUrl(a)} class={`blg-card${a.image ? ' blg-card-has-img' : ''}`} data-cat={catId}>
                  {a.image && (
                    <div class="blg-card-img">
                      <img src={a.image} alt={a.imageAlt ?? a.title} width="800" height="450" loading="lazy" decoding="async" />
                    </div>
                  )}
                  <div class="blg-card-body">
                    <div class="blg-card-meta">
                      <span class="blg-card-cat">{cat.label}</span>
                      <span class="blg-card-status">{a.status === 'published' ? 'Published' : (a.estPublishMonth ?? 'Coming soon')}</span>
                    </div>
                    <h3 class="blg-card-title">{a.title}</h3>
                    <p class="blg-card-desc">{a.description}</p>
                    <span class="blg-card-cta">
                      {a.status === 'published' ? 'Read article' : 'Get notified'}
                      <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      );
    })}

  </main>
<FinalCTA />
<Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBar = document.getElementById('blg-filters');
    if (!filterBar) return;

    const buttons = filterBar.querySelectorAll('.blg-filter-btn');
    const sections = document.querySelectorAll('[data-cat-section]');

    function applyFilter(id) {
      buttons.forEach((b) => {
        b.classList.toggle('blg-filter-btn-active', b.dataset.filter === id);
      });
      sections.forEach((s) => {
        const cat = s.dataset.catSection;
        s.style.display = (id === 'all' || cat === id) ? '' : 'none';
      });
    }

    buttons.forEach((b) => {
      b.addEventListener('click', () => applyFilter(b.dataset.filter));
    });

    applyFilter('all');
  });
</script>

<style>
  .page-eyebrow-strip { display: inline-flex; align-items: center; gap: 14px; flex-wrap: nowrap; justify-content: center; }
  .page-eyebrow-line { display: inline-block; width: 48px; height: 1px; background: var(--amber); flex-shrink: 0; }
  .page-eyebrow-text { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; white-space: nowrap; }

  .blg-hero { background: var(--cream); border-bottom: 1px solid var(--line); padding: clamp(56px, 8vh, 96px) 0 clamp(40px, 6vh, 72px); position: relative; overflow: hidden; text-align: center; }
  .blg-hero::before { content: ""; position: absolute; top: -300px; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%); pointer-events: none; }
  .blg-hero-inner { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .blg-h1 { font-family: var(--f-display); font-weight: 400; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.035em; display: flex; flex-direction: column; gap: 4px; margin: 8px 0 0; text-align: center; }
  .blg-h1-line { display: block; color: var(--ink); }
  .blg-h1-accent em { font-style: italic; font-weight: 300; color: var(--amber-deep); }
  .blg-lead { font-size: clamp(15px, 1.2vw, 17px); line-height: 1.6; color: var(--ink-soft); max-width: 64ch; margin: 4px auto 0; }
  .blg-lead strong { font-weight: 600; color: var(--ink); }

  .blg-subscribe { display: flex; gap: 8px; max-width: 480px; width: 100%; margin: 8px auto 0; padding: 8px; background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-pill); }
  .blg-subscribe-input { flex: 1; padding: 10px 16px; background: transparent; border: none; font-family: var(--f-body); font-size: 14px; color: var(--ink); outline: none; }
  .blg-subscribe-input::placeholder { color: var(--ink-muted); }
  .blg-subscribe-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: var(--ink); color: var(--cream); border: none; border-radius: var(--radius-pill); font-family: var(--f-body); font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; white-space: nowrap; }
  .blg-subscribe-btn:hover { background: var(--amber-deep); }
  .blg-hp { position: absolute; left: -10000px; }

  .blg-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; max-width: 720px; margin: 12px auto 0; width: 100%; }
  .blg-stat { text-align: center; padding: 14px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-md); }
  .blg-stat-num { font-family: var(--f-display); font-size: 24px; font-weight: 600; color: var(--amber-deep); letter-spacing: -0.02em; }
  .blg-stat-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); margin-top: 4px; }

  .blg-filters { background: var(--paper); border-bottom: 1px solid var(--line); padding: 16px 0; position: sticky; top: 0; z-index: 5; }
  .blg-filters-inner { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .blg-filter-btn { padding: 8px 16px; background: transparent; border: 1px solid var(--line-strong); border-radius: var(--radius-pill); font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-soft); cursor: pointer; transition: all 0.2s ease; font-weight: 500; }
  .blg-filter-btn:hover { border-color: var(--amber); color: var(--ink); }
  .blg-filter-btn-active { background: var(--ink); color: var(--cream); border-color: var(--ink); }

  .blg-cat-section { background: var(--cream); padding: clamp(48px, 6vh, 72px) 0; border-bottom: 1px solid var(--line); }
  .blg-cat-section:nth-of-type(even) { background: var(--paper); }
  .blg-cat-head { max-width: 880px; margin: 0 auto 32px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .blg-cat-h2 { font-family: var(--f-display); font-weight: 500; font-size: clamp(24px, 3vw, 36px); line-height: 1.15; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
  .blg-cat-desc { font-size: 15px; line-height: 1.6; color: var(--ink-soft); max-width: 60ch; margin: 0; }
  .blg-cat-count { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); padding: 4px 10px; background: rgba(212,147,46,0.1); border-radius: var(--radius-pill); font-weight: 600; }

  .blg-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 1100px; margin: 0 auto; }
  .blg-card { display: flex; flex-direction: column; gap: 0; background: var(--cream); border: 1.5px solid var(--line); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: all 0.3s ease; position: relative; overflow: hidden; }
  .blg-card-body { display: flex; flex-direction: column; gap: 10px; padding: 24px 26px; flex: 1; }
  .blg-card-img { width: 100%; aspect-ratio: 16/9; overflow: hidden; flex-shrink: 0; }
  .blg-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .blg-card:hover .blg-card-img img { transform: scale(1.03); }
  .blg-cat-section:nth-of-type(even) .blg-card { background: var(--cream); }
  .blg-card:hover { border-color: var(--amber); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(212,147,46,0.1); }
  .blg-card-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .blg-card-cat { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; }
  .blg-card-status { font-family: var(--f-mono); font-size: 10px; color: var(--ink-muted); letter-spacing: 0.06em; padding: 3px 8px; background: rgba(15,20,25,0.05); border-radius: var(--radius-pill); }
  .blg-card-title { font-family: var(--f-display); font-size: 19px; line-height: 1.25; color: var(--ink); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .blg-card-desc { font-size: 13.5px; line-height: 1.6; color: var(--ink-soft); margin: 0; flex: 1; }
  .blg-card-cta { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; margin-top: 6px; padding-top: 12px; border-top: 1px dashed var(--line); }

  @media (max-width: 1024px) { .blg-stats { grid-template-columns: repeat(2, 1fr); } .blg-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .page-eyebrow-line { width: 24px; } .blg-subscribe { flex-direction: column; border-radius: var(--radius-lg); } }
</style>
