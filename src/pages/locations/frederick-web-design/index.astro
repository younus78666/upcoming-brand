        "WordPress web design Frederick",
        "Custom WordPress development",
        "WooCommerce Frederick",
        "Local SEO Frederick MD",
        "LocalBusiness schema",
        "Core Web Vitals optimization",
        "Google Local Pack ranking"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Web Design Services Frederick",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Starter WordPress Website", "serviceType": "WordPress Web Design" },
            "name": "Starter - Frederick Web Design",
            "description": "8-page custom WordPress build for Frederick small businesses. LocalBusiness schema, Core Web Vitals green on delivery.",
            "price": "1500",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Growth WordPress Website", "serviceType": "WordPress + Local SEO" },
            "name": "Growth - Frederick Web Design",
            "description": "15-20 page site with Frederick landing pages, custom design, and full Local Pack optimization.",
            "price": "3500",
            "priceCurrency": "USD"
          },
