      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a WordPress website cost in Frederick, MD?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most Frederick small business WordPress websites fall between $1,500 and $10,000. A simple 8-page site starts at $1,500-$3,500. A 15-20 page site with custom design and SEO runs $3,500-$6,000. Complex WooCommerce or IDX builds start at $6,000. Every quote is fixed-scope - one price, no hourly surprises." }
        },
        {
          "@type": "Question",
          "name": "How do you work with Frederick clients remotely?",
          "acceptedAnswer": { "@type": "Answer", "text": "Entirely remote, by design. Discovery calls and design reviews run over Zoom or Google Meet. The build phase is async - you get weekly staging links, leave feedback directly on the site, and we iterate on your schedule. Frederick clients across Frederick County get the same process with no loss of quality." }
        },
        {
          "@type": "Question",
          "name": "How long does a Frederick website project take?",
          "acceptedAnswer": { "@type": "Answer", "text": "Starter sites (up to 8 pages) take 4-6 weeks. Growth sites (15-20 pages with custom design) take 6-8 weeks. Custom WooCommerce or membership builds take 8-10 weeks. The biggest timeline variable is how quickly you review and approve design rounds." }
        },
        {
          "@type": "Question",
          "name": "Do you work with Frederick law firms and biotech companies?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Frederick County law firms, Fort Detrick-area biotech companies, and Frederick Health-affiliated medical practices are a significant part of our client base. We know the schema types - LegalService, MedicalOrganization, Physician - and the compliance requirements that help these sites rank for competitive local searches." }
        },
        {
          "@type": "Question",
          "name": "Will my Frederick website rank in Google's Local Pack?",
          "acceptedAnswer": { "@type": "Answer", "text": "Local Pack rankings depend on your Google Business Profile, review velocity, and local citations - not just your website. We handle the website side: LocalBusiness schema with correct Frederick NAP, city-specific service pages, internal linking, and Core Web Vitals in the green. That's the foundation every Local Pack ranking is built on." }
        },
        {
          "@type": "Question",
          "name": "Can you redesign my existing Frederick business website?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many Frederick businesses built their sites on Wix or GoDaddy between 2015 and 2019, before Core Web Vitals and local schema requirements tightened. We migrate to a custom WordPress build without losing your Google rankings - complete 301 redirect map, pre-launch ranking benchmark, and 30 days of Search Console monitoring post-launch." }
        }
      ]
    }
  ]
});

const industries = [
