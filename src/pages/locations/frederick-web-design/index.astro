const faqs = [
  { num: "01", category: "Pricing",    q: "How much does a WordPress website cost in Frederick, MD?",         a: "Most Frederick small business WordPress websites fall between $1,500 and $10,000. A simple 8-page site starts at $1,500-$3,500. A 15-20 page site with custom design and SEO runs $3,500-$6,000. Complex WooCommerce or IDX builds start at $6,000. Every quote is fixed-scope - one price, no hourly surprises." },
  { num: "02", category: "Location",   q: "How do you work with Frederick clients remotely?",                a: "Entirely remote, by design. Discovery calls and design reviews run over Zoom or Google Meet. The build phase is async - you get weekly staging links, leave feedback directly on the site, and we iterate on your schedule. Frederick clients across Frederick County get the same process with no loss of quality." },
