---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
const city      = "Frederick";
const stateAbbr = "MD";
const slug      = "frederick-web-design";
const canonical = `https://upcomingbrand.com/locations/${slug}/`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://upcomingbrand.com/locations/frederick-web-design/#webpage",
      "url": "https://upcomingbrand.com/locations/frederick-web-design/",
      "name": `Web Design ${city} MD | WordPress & SEO | Upcoming Brand`,
      "description": `Web design ${city} businesses trust for real Google rankings. Custom WordPress builds, 90+ PageSpeed, fixed pricing. Serving Frederick City, Urbana, Middletown, and Frederick County.`,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/locations/frederick-web-design/#localbusiness" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".lp-hero-headline", ".lp-hero-sub"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://upcomingbrand.com/locations/" },
          { "@type": "ListItem", "position": 3, "name": "Frederick Web Design", "item": "https://upcomingbrand.com/locations/frederick-web-design/" }
        ]
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://upcomingbrand.com/locations/frederick-web-design/#localbusiness",
      "name": "Upcoming Brand - Web Design Frederick MD",
      "url": "https://upcomingbrand.com/locations/frederick-web-design/",
      "description": "WordPress web design for Frederick businesses. Fixed-scope pricing, 90+ PageSpeed, 6-10 week delivery.",
      "image": { "@id": "https://upcomingbrand.com/#logo" },
      "logo": { "@id": "https://upcomingbrand.com/#logo" },
      "priceRange": "$1,500-$15,000",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Credit Card, Bank Transfer",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Frederick",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 39.4143,
        "longitude": -77.4105
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5",
        "worstRating": "1"
      },
      "areaServed": [
        { "@type": "City", "name": "Frederick", "sameAs": "https://en.wikipedia.org/wiki/Frederick,_Maryland" },
        { "@type": "City", "name": "Gaithersburg" },
        { "@type": "City", "name": "Germantown" },
        { "@type": "City", "name": "Hagerstown" },
        { "@type": "City", "name": "Westminster" },
        { "@type": "State", "name": "Maryland", "sameAs": "https://en.wikipedia.org/wiki/Maryland" }
