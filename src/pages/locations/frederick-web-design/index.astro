            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Custom WordPress Build", "serviceType": "WordPress + WooCommerce" },
            "name": "Custom - Frederick Web Design",
            "description": "WooCommerce, booking systems, IDX, or multi-location schema for established Frederick businesses.",
