const phases = [
  { num: "01", name: "Discovery Call",   timing: "Week 0",     desc: "45-min call to understand your Frederick business, goals, and current site. We figure out if we're the right fit with no sales pitch." },
  { num: "02", name: "Scope & Proposal", timing: "Days 3-5",   desc: "Written fixed-scope proposal: page list, feature list, timeline, and one price. You approve it or walk away with no pressure." },
  { num: "03", name: "Design",           timing: "Weeks 1-2",  desc: "AI-assisted custom layouts built and refined to your brand, deployed to a staging URL for real-time client review. No static mockups." },
  { num: "04", name: "Development",      timing: "Weeks 2-6",  desc: "Full build on staging - Elementor Pro, Astra, RankMath Pro, weekly demo links. We don't launch until you sign off on every page." },
  { num: "05", name: "SEO & Speed",      timing: "Weeks 5-7",  desc: "RankMath Pro, JSON-LD schema, internal linking, WP Rocket, Cloudflare CDN. PageSpeed and Core Web Vitals tested before going live." },
  { num: "06", name: "Launch & Care",    timing: "Weeks 6-10", desc: "Zero-downtime DNS cutover, 30-day Search Console monitoring, recorded admin walkthrough. Optional care plan from $150/mo." },
