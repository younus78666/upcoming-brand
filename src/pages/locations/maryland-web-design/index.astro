const catColors: Record<string, { bg: string; text: string; border: string }> = {
  "Pricing":    { bg: "rgba(212,147,46,0.1)",  text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)"  },
  "Location":   { bg: "rgba(66,133,244,0.08)", text: "#2a6fc4",           border: "rgba(66,133,244,0.18)"  },
  "Timeline":   { bg: "rgba(92,128,64,0.09)",  text: "#4a7a28",           border: "rgba(92,128,64,0.2)"    },
  "Process":    { bg: "rgba(176,74,62,0.08)",  text: "#b04a3e",           border: "rgba(176,74,62,0.18)"   },
  "SEO":        { bg: "rgba(92,128,64,0.09)",  text: "#4a7a28",           border: "rgba(92,128,64,0.2)"    },
