---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const city      = "Maryland";
const stateAbbr = "MD";
const slug      = "maryland-web-design";
const canonical = `https://upcomingbrand.com/locations/${slug}/`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "name": "Web Design Maryland | WordPress & SEO | Upcoming Brand",
      "url": canonical,
      "description": "Web design Maryland businesses trust for real Google rankings. Custom WordPress builds, 90+ PageSpeed, fixed pricing. Serving all 18 cities across Maryland's DC Metro, Baltimore, and Eastern Shore regions.",
      "inLanguage": "en-US",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://upcomingbrand.com/locations/" },
          { "@type": "ListItem", "position": 3, "name": "Maryland Web Design", "item": canonical }
        ]
      }
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://upcomingbrand.com/#localbusiness",
      "name": "Upcoming Brand",
      "description": "WordPress web design studio serving all of Maryland. Fixed-scope pricing, 90+ PageSpeed, 6-10 week delivery.",
      "url": "https://upcomingbrand.com/",
      "priceRange": "$$-$$$",
      "areaServed": [
        { "@type": "State",  "name": "Maryland" },
        { "@type": "City",   "name": "Baltimore" },
        { "@type": "City",   "name": "Annapolis" },
        { "@type": "City",   "name": "Frederick" },
        { "@type": "City",   "name": "Bethesda" },
        { "@type": "City",   "name": "Rockville" },
        { "@type": "City",   "name": "Silver Spring" },
        { "@type": "City",   "name": "Columbia" },
        { "@type": "City",   "name": "Towson" },
        { "@type": "City",   "name": "Gaithersburg" },
        { "@type": "City",   "name": "Germantown" },
        { "@type": "City",   "name": "Ellicott City" },
        { "@type": "City",   "name": "Catonsville" },
        { "@type": "City",   "name": "Dundalk" },
        { "@type": "City",   "name": "Hagerstown" },
        { "@type": "City",   "name": "Westminster" },
        { "@type": "City",   "name": "Bowie" },
        { "@type": "City",   "name": "Waldorf" },
        { "@type": "City",   "name": "Salisbury" }
      ],
      "serviceType": ["WordPress Web Design", "WooCommerce Development", "SEO", "Web Maintenance"],
      "currenciesAccepted": "USD",
      "paymentAccepted": "Credit Card, Bank Transfer"
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faqpage`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a WordPress website cost in Maryland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Maryland WordPress websites range from $1,500 to $10,000+ depending on scope. An 8-page starter site runs $1,500-$3,500. A 15-20 page site with custom design and local SEO runs $3,500-$6,000. Complex builds for law firms, medical practices, or contractors with WooCommerce start at $6,000. Every project is fixed-scope - one price, no hourly billing." }
        },
        {
          "@type": "Question",
          "name": "Do you serve businesses across all of Maryland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. We work with businesses across all 24 Maryland counties and Baltimore City - from the DC Metro corridor (Bethesda, Rockville, Silver Spring, Gaithersburg, Germantown) to the Baltimore region (Baltimore, Towson, Catonsville, Dundalk) to Howard County (Columbia, Ellicott City), Western Maryland (Frederick, Hagerstown, Westminster), the Annapolis area, and the Eastern Shore (Salisbury). Every project runs entirely remote over Zoom, Google Meet, and async staging reviews." }
        },
        {
          "@type": "Question",
          "name": "How long does a Maryland WordPress project take?",
          "acceptedAnswer": { "@type": "Answer", "text": "Starter sites (up to 8 pages) take 4-6 weeks. Growth sites (15-20 pages with custom design) take 6-8 weeks. Custom WooCommerce, IDX real estate, or medical practice builds take 8-10 weeks. Timeline depends most on how quickly you review and approve design rounds - we keep the build moving on our end." }
        },
        {
          "@type": "Question",
          "name": "How do you work with Maryland clients remotely?",
          "acceptedAnswer": { "@type": "Answer", "text": "Entirely remote, by design. Discovery calls and design reviews run over Zoom or Google Meet. The build phase is async - you get weekly staging links, leave feedback directly on the site, and we iterate on your schedule. A Frederick contractor reviewing designs between job sites gets the same process as a Bethesda law firm reviewing from a conference room. No commutes, no lost time." }
        },
        {
          "@type": "Question",
          "name": "Will my Maryland website rank in Google's Local Pack?",
          "acceptedAnswer": { "@type": "Answer", "text": "Local Pack rankings need your Google Business Profile, review velocity, and local citations working together with your website. We handle the website side: LocalBusiness schema with correct NAP data for your specific city, service area pages covering your county and neighboring cities, internal linking, and Core Web Vitals in the green. That combination is the technical foundation every Local Pack ranking in Maryland is built on." }
        },
        {
          "@type": "Question",
          "name": "Can you redesign my existing Maryland business website?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many Maryland businesses have been on the same Wix, GoDaddy, or outdated WordPress theme for years - built before Core Web Vitals or local schema requirements created a real ranking gap. We benchmark every page before touching anything, build a complete 301 redirect map, run a zero-downtime DNS cutover, and monitor Search Console for 30 days after launch to catch any slippage early." }
        }
      ]
    }
  ]
});

const industries = [
  {
    num: "01",
    name: "Medical & Dental",
    stat: "+284% appointment inquiries",
    hook: "Maryland's healthcare market runs from Johns Hopkins and the University of Maryland Medical System in Baltimore to NIH-adjacent practices in Montgomery County and TidalHealth on the Eastern Shore. Patients across the state research specialist and dental practices online before booking any appointment. We build HIPAA-aware contact forms, Physician and Dentist schema, and appointment pages that rank for condition-specific and location-specific searches - whether you're competing in a dense Baltimore corridor or serving a regional patient base in Western Maryland.",
    schema: "MedicalOrganization",
    tags: ["HIPAA-aware forms", "Physician schema", "Maryland medical SEO"],
    href: "/industries/medical-website-design/",
  },
  {
    num: "02",
    name: "Law Firms",
    stat: "+312% organic intake leads",
    hook: "Maryland's legal market spans the US District Court in Baltimore, Montgomery County Circuit Court in Rockville, Anne Arundel Circuit Court in Annapolis, and county courts from Hagerstown to Salisbury. Attorneys across the state compete for clients who search on mobile before calling any office. We build multi-step intake forms, LegalService schema, attorney profile pages, and practice area pages that rank for the competitive legal searches Maryland clients use when they need representation.",
    schema: "LegalService",
    tags: ["Multi-step intake forms", "LegalService schema", "Maryland legal SEO"],
    href: "/industries/law-firm-website-design/",
  },
  {
    num: "03",
    name: "Contractors & Trades",
    stat: "7s average contractor site load",
    hook: "Maryland's contractor market spans Bethesda's luxury renovation corridor, Baltimore's aging row house inventory, Columbia's planned community housing stock, and Western Maryland's rural trade service areas. Homeowners compare contractors online before calling - in every market from Montgomery County to Carroll County. A fast portfolio site with HomeAndConstructionBusiness schema, a quote request form that works, and service area pages covering your county puts you ahead of every competitor still running a Wix page from 2020.",
    schema: "HomeAndConstructionBusiness",
    tags: ["Quote request forms", "HomeAndConstruction schema", "Maryland contractor SEO"],
    href: "/industries/contractor-website-design/",
  },
  {
    num: "04",
    name: "Restaurants & Small Business",
    stat: "89% research online first",
    hook: "Maryland's restaurant market covers the Inner Harbor and Federal Hill in Baltimore, the DC suburb dining corridors in Bethesda and Silver Spring, Annapolis waterfront dining, Ocean City's tourist dining season, and the independent restaurant towns from Frederick to Salisbury. Diners search before they visit everywhere in the state. The restaurant with a slow site or a PDF menu loses the reservation to whoever loads first - regardless of whether they're in a tourist town or a suburban strip.",
    schema: "Restaurant",
    tags: ["Menu SEO", "Restaurant schema", "Maryland dining SEO"],
    href: "/industries/restaurant-website-design/",
  },
  {
    num: "05",
    name: "Real Estate",
    stat: "93% of buyers start on Google",
    hook: "Maryland's real estate market is one of the most diverse in the mid-Atlantic - luxury suburbs in Montgomery County, competitive waterfront markets in Annapolis and the Eastern Shore, Baltimore City neighborhood buyers, Howard County family buyers, and rural land markets in Western Maryland. Buyers search specific neighborhood and city names with purchase intent before contacting any agent. We build IDX-integrated sites with neighborhood landing pages, RealEstateAgent schema, and community content that ranks for the specific searches Maryland buyers use.",
    schema: "RealEstateAgent",
    tags: ["IDX integration", "Neighborhood landing pages", "RealEstateAgent schema"],
    href: "/industries/real-estate-website-design/",
  },
  {
    num: "06",
    name: "Nonprofits & Churches",
    stat: "3x donor engagement lift",
    hook: "Maryland's nonprofit sector spans national organizations headquartered in the DC Metro corridor, Baltimore-anchored human services organizations, faith communities across 24 counties, and cause-focused nonprofits throughout the state. Donors, volunteers, and community members research organizations online before giving or getting involved. We build donation flows, volunteer forms, event pages, and Organization schema that rank for cause-specific and geographic searches across Maryland's diverse philanthropic landscape.",
    schema: "NonprofitOrganization",
    tags: ["Donation flows", "Organization schema", "Maryland nonprofit SEO"],
    href: "/industries/nonprofit-website-design/",
  },
];

const phases = [
  { num: "01", name: "Discovery Call",   timing: "Week 0",     desc: "45-min call to understand your Maryland business, goals, and current site. We figure out if we're the right fit - no sales pitch, just a working conversation." },
  { num: "02", name: "Scope & Proposal", timing: "Days 3-5",   desc: "Written fixed-scope proposal: page list, feature list, timeline, and one price. You approve it or walk away with no pressure." },
  { num: "03", name: "Design",           timing: "Weeks 1-2",  desc: "AI-assisted custom layouts built to your brand, deployed to a staging URL for real-time review. No static mockups - you see real device behavior from day one." },
  { num: "04", name: "Development",      timing: "Weeks 2-6",  desc: "Full build on staging - Elementor Pro, Astra, RankMath Pro, weekly demo links. We don't launch until you've signed off on every page." },
  { num: "05", name: "SEO & Speed",      timing: "Weeks 5-7",  desc: "RankMath Pro, JSON-LD schema matched to your business type and Maryland city, WP Rocket, Cloudflare CDN. PageSpeed and Core Web Vitals tested before going live." },
  { num: "06", name: "Launch & Care",    timing: "Weeks 6-10", desc: "Zero-downtime DNS cutover, 30-day Search Console monitoring, recorded admin walkthrough. Optional care plan from $150/mo." },
];

const regions = [
  {
    name: "Baltimore Area",
    cities: [
      { name: "Baltimore",    county: "Baltimore City",   hook: "Law, medical, nonprofits, Inner Harbor business",    href: "/locations/baltimore-web-design/" },
      { name: "Towson",       county: "Baltimore County", hook: "Baltimore County seat, GBMC, law firms, contractors",  href: "/locations/towson-web-design/" },
      { name: "Catonsville",  county: "Baltimore County", hook: "UMBC corridor, medical, contractors, restaurants",     href: "/locations/catonsville-web-design/" },
      { name: "Dundalk",      county: "Baltimore County", hook: "Trade contractors, manufacturing, small business",     href: "/locations/dundalk-web-design/" },
    ],
  },
  {
    name: "DC Metro Corridor",
    cities: [
      { name: "Bethesda",      county: "Montgomery County", hook: "Luxury medical, law firms, NIH-adjacent practices",  href: "/locations/bethesda-web-design/" },
      { name: "Rockville",     county: "Montgomery County", hook: "Circuit Court, biotech, medical practices",          href: "/locations/rockville-web-design/" },
      { name: "Silver Spring", county: "Montgomery County", hook: "Diverse small business, restaurants, nonprofits",    href: "/locations/silver-spring-web-design/" },
      { name: "Gaithersburg",  county: "Montgomery County", hook: "Tech corridor, medical, contractors, retail",        href: "/locations/gaithersburg-web-design/" },
      { name: "Germantown",    county: "Montgomery County", hook: "Growing suburban market, contractors, small biz",    href: "/locations/germantown-web-design/" },
      { name: "Bowie",         county: "Prince George's",   hook: "30 min DC, growing residential, real estate",       href: "/locations/bowie-web-design/" },
      { name: "Waldorf",       county: "Charles County",    hook: "Military corridor, growing South MD market",         href: "/locations/waldorf-web-design/" },
    ],
  },
  {
    name: "Howard County & Annapolis",
    cities: [
      { name: "Columbia",      county: "Howard County",     hook: "Planned community, medical, nonprofits, corporate", href: "/locations/columbia-web-design/" },
      { name: "Ellicott City", county: "Howard County",     hook: "High-income residential, contractors, real estate", href: "/locations/ellicott-city-web-design/" },
      { name: "Annapolis",     county: "Anne Arundel",      hook: "State capital, maritime, law, tourism, dining",     href: "/locations/annapolis-web-design/" },
    ],
  },
  {
    name: "Western Maryland",
    cities: [
      { name: "Frederick",    county: "Frederick County", hook: "Fastest-growing MD city, medical, contractors, tech", href: "/locations/frederick-web-design/" },
      { name: "Hagerstown",   county: "Washington County", hook: "Regional hub, I-81 corridor, trades, healthcare",    href: "/locations/hagerstown-web-design/" },
      { name: "Westminster",  county: "Carroll County",   hook: "Rural-suburban market, contractors, small business",  href: "/locations/westminster-web-design/" },
    ],
  },
  {
    name: "Eastern Shore",
    cities: [
      { name: "Salisbury",    county: "Wicomico County",  hook: "Regional hub for Delmarva, TidalHealth, SU, dining",  href: "/locations/salisbury-web-design/" },
    ],
  },
];

const faqs = [
  { num: "01", category: "Pricing",    q: "How much does a WordPress website cost in Maryland?",           a: "Maryland WordPress websites range from $1,500 to $10,000+ depending on scope. An 8-page starter site runs $1,500-$3,500. A 15-20 page site with custom design and local SEO runs $3,500-$6,000. Complex builds for law firms, medical practices, or contractors with WooCommerce start at $6,000. Every project is fixed-scope - one price, no hourly billing." },
  { num: "02", category: "Location",   q: "Do you serve businesses across all of Maryland?",               a: "Yes. We work with businesses across all 24 Maryland counties and Baltimore City - from the DC Metro corridor to the Baltimore region, Howard County, Western Maryland, the Annapolis area, and the Eastern Shore. Every project runs entirely remote over Zoom, Google Meet, and async staging reviews." },
  { num: "03", category: "Timeline",   q: "How long does a Maryland WordPress project take?",               a: "Starter sites (up to 8 pages) take 4-6 weeks. Growth sites (15-20 pages with custom design) take 6-8 weeks. Custom WooCommerce, IDX real estate, or medical practice builds take 8-10 weeks. Timeline depends most on how quickly you review and approve design rounds - we keep the build moving on our end." },
  { num: "04", category: "Process",    q: "How do you work with Maryland clients remotely?",                a: "Entirely remote, by design. Discovery calls and design reviews run over Zoom or Google Meet. The build phase is async - you get weekly staging links, leave feedback directly on the site, and we iterate on your schedule. A Frederick contractor reviewing designs between job sites gets the same process as a Bethesda law firm reviewing from a conference room. No commutes, no lost time." },
  { num: "05", category: "SEO",        q: "Will my Maryland website rank in Google's Local Pack?",          a: "Local Pack rankings need your Google Business Profile, review velocity, and local citations working together with your website. We handle the website side: LocalBusiness schema with correct NAP data for your specific city, service area pages covering your county and neighboring cities, internal linking, and Core Web Vitals in the green. That combination is the technical foundation every Local Pack ranking in Maryland is built on." },
  { num: "06", category: "Migration",  q: "Can you redesign my existing Maryland business website?",        a: "Yes. Many Maryland businesses have been on the same Wix, GoDaddy, or outdated WordPress theme for years - built before Core Web Vitals or local schema requirements created a real ranking gap. We benchmark every page before touching anything, build a complete 301 redirect map, run a zero-downtime DNS cutover, and monitor Search Console for 30 days after launch to catch any slippage early." },
