---
<BaseLayout
  title="Web Design Maryland | WordPress & SEO | Upcoming Brand"
  description="Web design Maryland businesses trust for real Google rankings. Custom WordPress builds, 90+ PageSpeed, fixed pricing. Serving all 18 cities across Maryland's DC Metro, Baltimore, and Eastern Shore regions."
  canonicalUrl={canonical}
>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />

  <AnnouncementBar />
  <Navigation />

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section class="lp-hero" id="hero">
    <div class="container lp-hero-wrap">

      <!-- LEFT -->
      <div class="lp-hero-left">
        <div class="lp-hero-tags">
          <span class="lp-hero-pill">
            <span class="lp-hero-dot" aria-hidden="true"></span>
            WordPress Specialists &middot; {city}, {stateAbbr}
          </span>
          <span class="lp-hero-eyebrow">A studio, not a factory</span>
        </div>

        <h1 class="lp-h1">
          <span class="lp-h1-line">{city}</span>
          <span class="lp-h1-line lp-h1-accent-line"><em class="lp-h1-accent">web design that ranks,</em></span>
          <span class="lp-h1-line lp-h1-italic">converts &amp; keeps working.</span>
        </h1>

        <p class="lp-hero-lede">
          Upcoming Brand is a Maryland-based WordPress web design studio. We design and build
          custom WordPress websites for <strong>law firms from Bethesda to Baltimore, medical practices
          along the I-270 biotech corridor and York Road, contractors in every Maryland county,</strong> and
          small businesses from Frederick to the Eastern Shore - sites built for the way Maryland actually searches.
        </p>

        <div class="lp-hero-ctas">
          <a href="#contact" class="lp-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/locations/" class="lp-btn-ghost">
            See all Maryland cities
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="lp-hero-trust">
          <span class="lp-trust-item">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Top Rated &middot; Upwork
          </span>
          <span class="lp-trust-dot" aria-hidden="true"></span>
          <span class="lp-trust-item">400+ projects &middot; 12 countries</span>
          <span class="lp-trust-dot" aria-hidden="true"></span>
          <span class="lp-trust-item">Remote-first &middot; Zoom &middot; Async</span>
        </div>
      </div>

      <!-- RIGHT: dark form card -->
      <div class="lp-hero-right">
        <div class="lp-form-card">
          <div class="lp-form-header">
            <p class="lp-form-eyebrow">Free discovery call &middot; {city}</p>
            <h2 class="lp-form-title">Tell us about your project</h2>
            <p class="lp-form-sub">We reply within 4 business hours. No sales pitch - just an honest conversation about what you need.</p>
          </div>

          <form class="lp-form" id="lp-hero-form" name="maryland-inquiry" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value="maryland-inquiry" />
            <input type="hidden" name="location" value="Maryland, MD" />
            <div class="hp-field" aria-hidden="true">
              <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>
            <input type="hidden" name="_timestamp" id="lp-form-timestamp" value="" />

            <div class="lp-form-row">
              <label class="lp-form-label" for="lp-name">Your name</label>
              <input class="lp-form-input" type="text" id="lp-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
            </div>

            <div class="lp-form-row">
              <label class="lp-form-label" for="lp-email">Email address</label>
              <input class="lp-form-input" type="email" id="lp-email" name="email" placeholder="jane@company.com" required autocomplete="email" />
            </div>

            <div class="lp-form-row">
              <span class="lp-form-label" id="lbl-biz-lp">Business type</span>
              <div class="cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-biz-lp" data-name="business_type">
                <button type="button" class="cs-trigger" aria-haspopup="listbox">
                  <span class="cs-val">Select your industry</span>
                  <svg class="cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="cs-list" role="listbox" aria-label="Business type">
                  <li class="cs-opt" role="option" data-value="Law Firm / Attorney">Law Firm / Attorney</li>
                  <li class="cs-opt" role="option" data-value="Dental Practice">Dental Practice</li>
                  <li class="cs-opt" role="option" data-value="Medical Clinic">Medical Clinic</li>
                  <li class="cs-opt" role="option" data-value="Real Estate">Real Estate</li>
                  <li class="cs-opt" role="option" data-value="Restaurant / Hospitality">Restaurant / Hospitality</li>
                  <li class="cs-opt" role="option" data-value="Contractor / Trades">Contractor / Trades</li>
                  <li class="cs-opt" role="option" data-value="Nonprofit / Church">Nonprofit / Church</li>
                  <li class="cs-opt" role="option" data-value="Ecommerce / Retail">Ecommerce / Retail</li>
                  <li class="cs-opt" role="option" data-value="Small Business / Startup">Small Business / Startup</li>
                  <li class="cs-opt" role="option" data-value="Other">Other</li>
                </ul>
                <input type="hidden" name="business_type" class="cs-hidden" />
              </div>
            </div>

            <div class="lp-form-row">
              <span class="lp-form-label" id="lbl-budget-lp">Estimated budget</span>
              <div class="cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-budget-lp" data-name="budget">
                <button type="button" class="cs-trigger" aria-haspopup="listbox">
                  <span class="cs-val">Select a range</span>
                  <svg class="cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="cs-list" role="listbox" aria-label="Budget">
                  <li class="cs-opt" role="option" data-value="$1,500 - $3,500">$1,500 - $3,500 &nbsp;<span class="cs-badge">Starter</span></li>
                  <li class="cs-opt" role="option" data-value="$3,500 - $6,000">$3,500 - $6,000 &nbsp;<span class="cs-badge">Standard</span></li>
                  <li class="cs-opt" role="option" data-value="$6,000 - $10,000">$6,000 - $10,000 &nbsp;<span class="cs-badge">Custom</span></li>
                  <li class="cs-opt" role="option" data-value="Not sure yet">Not sure yet</li>
                </ul>
                <input type="hidden" name="budget" class="cs-hidden" />
              </div>
            </div>

            <button type="submit" class="lp-form-submit">
              Get a free quote
