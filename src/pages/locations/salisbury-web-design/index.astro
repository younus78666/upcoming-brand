<script>
  // ── CUSTOM DROPDOWNS ─────────────────────────────────────────
  function initCustomSelects() {
    document.querySelectorAll('.cs-wrap').forEach((wrap) => {
      const trigger = wrap.querySelector('.cs-trigger');
      const valSpan = wrap.querySelector('.cs-val');
      const hidden  = wrap.querySelector('.cs-hidden');
      const opts    = wrap.querySelectorAll('.cs-opt');

      const open  = () => wrap.setAttribute('aria-expanded', 'true');
      const close = () => wrap.setAttribute('aria-expanded', 'false');
      const isOpen = () => wrap.getAttribute('aria-expanded') === 'true';

      trigger.addEventListener('click', (e) => { e.stopPropagation(); isOpen() ? close() : open(); });

      opts.forEach((opt) => {
        opt.setAttribute('tabindex', '0');
        opt.addEventListener('click', () => {
          valSpan.textContent = opt.querySelector('.cs-badge')
            ? opt.childNodes[0].textContent.trim()
            : opt.textContent.trim();
          hidden.value = opt.dataset.value;
          opts.forEach(o => o.classList.remove('selected'));
          opt.classList.add('selected');
          wrap.classList.add('has-value');
          close();
          trigger.focus();
        });
        opt.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); }
        });
      });

      document.addEventListener('click', (e) => { if (!wrap.contains(e.target)) close(); });
      wrap.addEventListener('keydown', (e) => { if (e.key === 'Escape') { close(); trigger.focus(); } });
    });
  }

  // ── SPAM PROTECTION ──────────────────────────────────────────
  function initSpamProtection() {
    const ts = document.getElementById('lp-form-timestamp');
    if (ts) ts.value = Date.now().toString();

    const form = document.getElementById('lp-hero-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      const elapsed = Date.now() - parseInt(ts?.value || '0', 10);
      if (elapsed < 2000) { e.preventDefault(); return; }
      const bot = form.querySelector('[name="bot-field"]');
      if (bot && bot.value !== '') { e.preventDefault(); return; }
    });
  }

  // ── FAQ ACCORDION ─────────────────────────────────────────────
  function initFaq() {
    const items = document.querySelectorAll('[data-faq-item]');
    items.forEach((item) => {
      const btn    = item.querySelector('.lp-faq-trigger');
      const answer = item.querySelector('.lp-faq-answer');
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        items.forEach((other) => {
          other.querySelector('.lp-faq-trigger').setAttribute('aria-expanded', 'false');
          other.querySelector('.lp-faq-answer').hidden = true;
        });
        if (!expanded) {
          btn.setAttribute('aria-expanded', 'true');
          answer.hidden = false;
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCustomSelects();
    initSpamProtection();
    initFaq();
  });
</script>
