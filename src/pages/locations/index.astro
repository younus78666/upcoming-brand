---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const canonical = "https://upcomingbrand.com/locations/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "name": "Web Design Maryland | All Locations | Upcoming Brand",
      "url": canonical,
      "description": "WordPress web design for Maryland businesses. Serving 18+ cities across Baltimore, DC metro, Howard County, Western MD, and the Eastern Shore. Fixed-scope pricing, 90+ PageSpeed, 6-10 week delivery.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".lp-h1", ".loc-region-intro"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Locations", "item": canonical }
        ]
      }
    }
  ]
});

const featured = [
  {
    name: "Baltimore",
    slug: "baltimore-web-design",
    region: "Baltimore Area",
    pop: "575K",
    income: "$54K",
    industry: "Healthcare · Legal · Hospitality",
    blurb: "Maryland's largest city. Healthcare, legal, hospitality, and a fast-growing creative class along the harbor and Mt. Vernon corridor.",
    accent: "01"
  },
  {
    name: "Bethesda",
    slug: "bethesda-web-design",
    region: "DC Metro Corridor",
    pop: "68K",
    income: "$170K",
    industry: "Medical · Legal · Consulting",
    blurb: "NIH-anchored professional corridor. The highest-income market in Maryland — home to medical specialists, law firms, and consultancies.",
    accent: "02"
  },
  {
    name: "Frederick",
    slug: "frederick-web-design",
    region: "Western Maryland",
    pop: "80K",
    income: "$80K",
    industry: "Trades · Hospitality · Retail",
    blurb: "I-70/I-270 crossroads with a historic downtown and the fastest-growing outer-suburb economy in Western Maryland.",
    accent: "03"
  }
];

const regions = [
  {
    label: "Baltimore Area",
    anchor: "baltimore-area",
    tag: "Urban core",
    intro: "Baltimore City and the I-695 beltway corridor — a 575K-population urban core wrapped by Towson, Catonsville, and Dundalk's Baltimore County submarkets.",
    cities: [
      { name: "Baltimore",    county: "Baltimore City",  slug: "baltimore-web-design",    pop: "575K", income: "$54K",  hook: "Baltimore City and the I-695 beltway corridor." },
      { name: "Towson",       county: "Baltimore Co.",   slug: "towson-web-design",        pop: "60K",  income: "$84K",  hook: "Baltimore County seat. GBMC, St. Joseph, Towson University." },
      { name: "Catonsville",  county: "Baltimore Co.",   slug: "catonsville-web-design",   pop: "44K",  income: "$95K",  hook: "UMBC, Frederick Road arts district, 1920s-60s housing." },
      { name: "Dundalk",      county: "Baltimore Co.",   slug: "dundalk-web-design",       pop: "63K",  income: "$58K",  hook: "Tradepoint Atlantic, working-class waterfront." },
    ],
  },
  {
    label: "DC Metro Corridor",
    anchor: "dc-metro",
    tag: "Highest-income",
    intro: "Maryland's wealthiest sub-region. Montgomery County's I-270 tech corridor plus the Prince George's and Charles County commuter markets.",
    cities: [
      { name: "Bethesda",      county: "Montgomery Co.",      slug: "bethesda-web-design",      pop: "68K",  income: "$170K", hook: "NIH campus, high-income professional corridor, Chevy Chase." },
      { name: "Rockville",     county: "Montgomery Co.",      slug: "rockville-web-design",     pop: "67K",  income: "$120K", hook: "Montgomery County seat, I-270 tech corridor, Pike & Rose." },
      { name: "Silver Spring", county: "Montgomery Co.",      slug: "silver-spring-web-design", pop: "83K",  income: "$94K",  hook: "Discovery HQ, diverse urban market, Metro Red Line." },
      { name: "Gaithersburg",  county: "Montgomery Co.",      slug: "gaithersburg-web-design",  pop: "71K",  income: "$110K", hook: "NIST, Kentlands, King Farm, I-270 planned communities." },
      { name: "Germantown",    county: "Montgomery Co.",      slug: "germantown-web-design",    pop: "91K",  income: "$95K",  hook: "Most diverse MD community, 130+ languages, MARC rail." },
      { name: "Bowie",         county: "Prince George's Co.", slug: "bowie-web-design",         pop: "58K",  income: "$117K", hook: "Largest PG County city, Bowie State HBCU, DC + Annapolis 30 min." },
      { name: "Waldorf",       county: "Charles Co.",         slug: "waldorf-web-design",       pop: "70K",  income: "$93K",  hook: "Fast-growing suburb, military families, DC 30 min on US-301." },
    ],
  },
  {
    label: "Howard County & Annapolis",
    anchor: "howard-annapolis",
    tag: "Wealth corridor",
    intro: "Howard County's planned-community wealth corridor and the Annapolis maritime + state-government economy.",
    cities: [
      { name: "Columbia",       county: "Howard Co.",       slug: "columbia-web-design",       pop: "104K", income: "$125K", hook: "10-village planned community, Johns Hopkins HCGH, $120K+ HHI." },
      { name: "Ellicott City",  county: "Howard Co.",       slug: "ellicott-city-web-design",  pop: "73K",  income: "$135K", hook: "Howard County seat, Old EC National Historic District." },
      { name: "Annapolis",      county: "Anne Arundel Co.", slug: "annapolis-web-design",      pop: "40K",  income: "$95K",  hook: "State capital, Naval Academy, maritime economy, tourism." },
    ],
  },
  {
    label: "Western Maryland",
    anchor: "western-md",
    tag: "I-70 / I-81",
    intro: "I-70 / I-81 corridor markets — Frederick's fast-growing suburban economy, Hagerstown's tri-state hub, and Westminster's Carroll County seat.",
    cities: [
      { name: "Frederick",    county: "Frederick Co.",  slug: "frederick-web-design",    pop: "80K", income: "$80K", hook: "I-70/I-270 crossroads, historic downtown, fast-growing outer suburb." },
      { name: "Hagerstown",   county: "Washington Co.", slug: "hagerstown-web-design",   pop: "44K", income: "$45K", hook: "I-70/I-81 Hub City, tri-state market, Meritus Medical Center." },
      { name: "Westminster",  county: "Carroll Co.",    slug: "westminster-web-design",  pop: "19K", income: "$70K", hook: "Carroll County seat, Carroll Hospital, McDaniel College." },
    ],
  },
  {
    label: "Eastern Shore",
    anchor: "eastern-shore",
    tag: "Delmarva",
    intro: "The Delmarva peninsula's commercial and healthcare hub, anchored by TidalHealth and 30 minutes from Ocean City.",
    cities: [
      { name: "Salisbury",    county: "Wicomico Co.", slug: "salisbury-web-design",    pop: "33K", income: "$48K", hook: "Delmarva hub, TidalHealth Level II Trauma, Ocean City 30 min." },
    ],
  },
];

const totalCities = regions.reduce((sum, r) => sum + r.cities.length, 0);
---
<BaseLayout
  title="Web Design Maryland | All 18 Locations | Upcoming Brand"
  description="WordPress web design for Maryland businesses. Serving 18+ cities across Baltimore, DC metro, Howard County, Western MD, and the Eastern Shore. Fixed-scope pricing, 90+ PageSpeed, 6-10 week delivery."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO (matched to city page H1 style) ====== -->
    <section class="loc-hero">
      <div class="container loc-hero-wrap">

        <!-- LEFT -->
        <div class="loc-hero-left">
          <div class="loc-hero-tags">
            <span class="loc-hero-pill">
              <span class="loc-hero-dot" aria-hidden="true"></span>
              WordPress Specialists &middot; Maryland
            </span>
            <span class="loc-hero-eyebrow">{totalCities} cities &middot; 5 regions</span>
          </div>

          <h1 class="lp-h1">
            <span class="lp-h1-line">Maryland</span>
            <span class="lp-h1-line lp-h1-accent-line"><em class="lp-h1-accent">web design that ranks,</em></span>
            <span class="lp-h1-line lp-h1-italic">city by city.</span>
          </h1>

          <p class="loc-hero-lede">
            Based in Maryland and serving <strong>{totalCities}+ cities across five regions</strong> — from Baltimore's urban core to Bethesda's NIH corridor and the Eastern Shore. Every project runs entirely remote: Zoom discovery, async design reviews, weekly staging links. Fixed-scope pricing. 90+ PageSpeed guaranteed.
          </p>

          <div class="loc-hero-ctas">
            <a href="/contact/" class="lp-btn-primary">
              Book a discovery call
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/" class="lp-btn-ghost">
              View pricing
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div class="loc-hero-trust">
            <span class="loc-trust-line">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Top Rated &middot; Upwork
            </span>
            <span class="loc-trust-dot" aria-hidden="true"></span>
            <span class="loc-trust-line">400+ projects &middot; 12 countries</span>
            <span class="loc-trust-dot" aria-hidden="true"></span>
            <span class="loc-trust-line">Remote-first &middot; Zoom &middot; Async</span>
          </div>
        </div>

        <!-- RIGHT: Coverage map panel -->
        <div class="loc-hero-panel" aria-hidden="true">
          <div class="loc-panel-header">
            <span class="loc-panel-label">Maryland · Coverage map</span>
            <span class="loc-panel-pulse"></span>
          </div>

          <svg class="loc-panel-svg" viewBox="0 0 400 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Stylized map of Maryland regions">
            <!-- Stylized Maryland silhouette -->
            <path d="M 30 110 L 90 100 L 160 92 L 230 88 L 290 90 L 320 100 L 348 118 L 364 142 L 360 168 L 350 192 L 332 216 L 300 230 L 270 232 L 244 226 L 224 214 L 212 200 L 220 180 L 230 162 L 224 148 L 206 142 L 186 152 L 162 162 L 134 168 L 106 168 L 80 162 L 56 150 L 38 134 Z"
                  fill="rgba(212,147,46,0.06)"
                  stroke="rgba(212,147,46,0.4)"
                  stroke-width="1.5"
                  stroke-linejoin="round"/>

            <!-- Subtle grid -->
            <defs>
              <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(15,20,25,0.04)" stroke-width="0.5"/>
              </pattern>
            </defs>
            <rect width="400" height="280" fill="url(#grid)" opacity="0.6"/>

            <!-- Bay cutout suggestion -->
            <path d="M 200 160 Q 210 175 215 195 Q 218 210 222 220" fill="none" stroke="rgba(15,20,25,0.18)" stroke-width="1" stroke-dasharray="2 3"/>

            <!-- Region pins - approximate geographic positioning -->
            <g class="loc-pin">
              <circle cx="62" cy="130" r="3.5" fill="#D4932E"/>
              <circle cx="62" cy="130" r="8" fill="rgba(212,147,46,0.18)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="118" cy="125" r="3.5" fill="#D4932E"/>
              <circle cx="118" cy="125" r="8" fill="rgba(212,147,46,0.18)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="148" cy="155" r="4.5" fill="#D4932E"/>
              <circle cx="148" cy="155" r="11" fill="rgba(212,147,46,0.22)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="182" cy="138" r="3.5" fill="#D4932E"/>
              <circle cx="182" cy="138" r="8" fill="rgba(212,147,46,0.18)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="208" cy="125" r="5" fill="#D4932E"/>
              <circle cx="208" cy="125" r="12" fill="rgba(212,147,46,0.22)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="218" cy="158" r="3.5" fill="#D4932E"/>
              <circle cx="218" cy="158" r="8" fill="rgba(212,147,46,0.18)" class="loc-pin-halo"/>
            </g>
            <g class="loc-pin">
              <circle cx="298" cy="195" r="3.5" fill="#D4932E"/>
              <circle cx="298" cy="195" r="8" fill="rgba(212,147,46,0.18)" class="loc-pin-halo"/>
            </g>

            <!-- Region labels -->
            <g class="loc-label-group">
              <line x1="62" y1="130" x2="40" y2="80" stroke="rgba(15,20,25,0.25)" stroke-width="0.75"/>
              <text x="40" y="72" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(15,20,25,0.6)" text-anchor="start">Western MD</text>
            </g>
            <g class="loc-label-group">
              <line x1="208" y1="125" x2="240" y2="62" stroke="rgba(15,20,25,0.25)" stroke-width="0.75"/>
              <text x="240" y="54" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(15,20,25,0.6)" text-anchor="start">Baltimore</text>
            </g>
            <g class="loc-label-group">
              <line x1="148" y1="155" x2="80" y2="240" stroke="rgba(15,20,25,0.25)" stroke-width="0.75"/>
              <text x="80" y="252" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(15,20,25,0.6)" text-anchor="start">DC Metro</text>
            </g>
            <g class="loc-label-group">
              <line x1="298" y1="195" x2="340" y2="252" stroke="rgba(15,20,25,0.25)" stroke-width="0.75"/>
              <text x="320" y="265" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(15,20,25,0.6)" text-anchor="start">Eastern Shore</text>
            </g>
          </svg>

          <div class="loc-panel-footer">
            <div class="loc-panel-stat">
              <span class="loc-panel-stat-num">{totalCities}</span>
              <span class="loc-panel-stat-label">Cities</span>
            </div>
            <div class="loc-panel-stat">
              <span class="loc-panel-stat-num">5</span>
              <span class="loc-panel-stat-label">Regions</span>
            </div>
            <div class="loc-panel-stat">
              <span class="loc-panel-stat-num">100%</span>
              <span class="loc-panel-stat-label">Remote</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== TRUST STRIP (dark) ====== -->
    <section class="loc-trust">
      <div class="container">
        <div class="loc-trust-grid">
          <div class="loc-trust-item">
            <span class="loc-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.7 4.5L14 6l-3.5 3 1 4.5L8 11l-3.5 2.5L5.5 9 2 6l4.3-.5L8 1z" fill="currentColor"/></svg>
            </span>
            <span class="loc-trust-num">{totalCities}+</span>
            <span class="loc-trust-label">MD cities served</span>
          </div>
          <div class="loc-trust-divider" aria-hidden="true"></div>
          <div class="loc-trust-item">
            <span class="loc-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/></svg>
            </span>
            <span class="loc-trust-num">90+</span>
            <span class="loc-trust-label">PageSpeed</span>
          </div>
          <div class="loc-trust-divider" aria-hidden="true"></div>
          <div class="loc-trust-item">
            <span class="loc-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 6h12M5 1v3M11 1v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <span class="loc-trust-num">6&ndash;10</span>
            <span class="loc-trust-label">Week delivery</span>
          </div>
          <div class="loc-trust-divider" aria-hidden="true"></div>
          <div class="loc-trust-item">
            <span class="loc-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 9.5l3-3 2 2 5-5M9 3.5h3v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="loc-trust-num">$1.5K+</span>
            <span class="loc-trust-label">Fixed-scope</span>
          </div>
          <div class="loc-trust-divider" aria-hidden="true"></div>
          <div class="loc-trust-item">
            <span class="loc-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 8h12M8 1.5c2 2 2 11 0 13M8 1.5c-2 2-2 11 0 13" stroke="currentColor" stroke-width="1.2"/></svg>
            </span>
            <span class="loc-trust-num">100%</span>
            <span class="loc-trust-label">Async / remote</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== JUMP NAV (sticky) ====== -->
    <nav class="loc-jumpnav" aria-label="Jump to region">
      <div class="container">
        <div class="loc-jumpnav-inner">
          <span class="loc-jumpnav-label">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Jump to region
          </span>
          {regions.map((r) => (
            <a href={`#${r.anchor}`} class="loc-jumpnav-pill">
              {r.label}
              <span class="loc-jumpnav-count">{r.cities.length}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- ====== FEATURED MARKETS ====== -->
    <section class="loc-featured">
      <div class="container">
        <div class="loc-featured-head">
          <p class="loc-section-eyebrow"><span class="loc-section-eyebrow-line"></span>Featured markets</p>
          <h2 class="loc-section-h2">
            Maryland's three <em>highest-velocity</em> markets.
          </h2>
          <p class="loc-section-lead">Where most of our project volume lives — Baltimore's urban core, Bethesda's medical and professional corridor, and Frederick's fast-growing outer suburbs.</p>
        </div>

        <div class="loc-featured-grid">
          {featured.map((city) => (
            <a href={`/locations/${city.slug}/`} class="loc-featured-card">
              <div class="loc-featured-card-top">
                <span class="loc-featured-num">{city.accent}</span>
                <span class="loc-featured-region">{city.region}</span>
                <span class="loc-featured-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>

              <h3 class="loc-featured-name">{city.name}</h3>

              <div class="loc-featured-stats">
                <div class="loc-featured-stat">
                  <span class="loc-featured-stat-num">{city.pop}</span>
                  <span class="loc-featured-stat-label">Population</span>
                </div>
                <div class="loc-featured-stat">
                  <span class="loc-featured-stat-num">{city.income}</span>
                  <span class="loc-featured-stat-label">Median HHI</span>
                </div>
              </div>

              <div class="loc-featured-industry">
                <span class="loc-featured-industry-label">Top verticals</span>
                <span class="loc-featured-industry-val">{city.industry}</span>
              </div>

              <p class="loc-featured-blurb">{city.blurb}</p>

              <span class="loc-featured-cta">
                <span>Web design for {city.name}</span>
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6h10M7 1l4 5-4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== REGION SECTIONS ====== -->
    {regions.map((region, idx) => (
      <section class="loc-region" id={region.anchor}>
        <div class="container">
          <div class="loc-region-head">
            <div class="loc-region-head-left">
              <div class="loc-region-eyebrow-row">
                <span class="loc-region-num mono-tag">Region {String(idx + 1).padStart(2, '0')} / 05</span>
                <span class="loc-region-tag">{region.tag}</span>
              </div>
              <h2 class="loc-section-h2 loc-region-h2">{region.label}</h2>
              <p class="loc-region-intro">{region.intro}</p>
            </div>
            <div class="loc-region-head-right">
              <div class="loc-region-count-block">
                <span class="loc-region-count">{region.cities.length}</span>
                <span class="loc-region-count-label">{region.cities.length === 1 ? 'City' : 'Cities'} served</span>
              </div>
            </div>
          </div>

          <div class="loc-city-grid">
            {region.cities.map((city, cityIdx) => (
              <a href={`/locations/${city.slug}/`} class="loc-city-card">
                <span class="loc-city-index mono-tag">{String(cityIdx + 1).padStart(2, '0')}</span>

                <div class="loc-city-card-top">
                  <span class="loc-city-pin" aria-hidden="true">
                    <svg width="12" height="14" viewBox="0 0 12 14" fill="none">
                      <path d="M6 0C3.24 0 1 2.24 1 5c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5z" fill="currentColor"/>
                      <circle cx="6" cy="5" r="1.8" fill="white" opacity="0.9"/>
                    </svg>
                  </span>
                  <div class="loc-city-card-name-block">
                    <span class="loc-city-name">{city.name}</span>
                    <span class="loc-city-county">{city.county}</span>
                  </div>
                  <span class="loc-city-arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>

                <p class="loc-city-hook">{city.hook}</p>

