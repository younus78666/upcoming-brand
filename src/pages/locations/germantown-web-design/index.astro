---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const city      = "Germantown";
const stateAbbr = "MD";
const slug      = "germantown-web-design";
const canonical = `https://upcomingbrand.com/locations/${slug}/`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://upcomingbrand.com/locations/germantown-web-design/#webpage",
      "url": "https://upcomingbrand.com/locations/germantown-web-design/",
      "name": `Web Design ${city} MD | WordPress & SEO | Upcoming Brand`,
      "description": `Web design ${city} businesses trust for real Google rankings. Custom WordPress builds, 90+ PageSpeed, fixed pricing. Serving Germantown, Damascus, Clarksburg, and upcounty Montgomery County.`,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/locations/germantown-web-design/#localbusiness" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".lp-hero-headline", ".lp-hero-sub"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://upcomingbrand.com/locations/" },
          { "@type": "ListItem", "position": 3, "name": "Germantown Web Design", "item": "https://upcomingbrand.com/locations/germantown-web-design/" }
        ]
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://upcomingbrand.com/locations/germantown-web-design/#localbusiness",
      "name": "Upcoming Brand - Web Design Germantown MD",
      "url": "https://upcomingbrand.com/locations/germantown-web-design/",
      "description": "WordPress web design for Germantown businesses. Fixed-scope pricing, 90+ PageSpeed, 6-10 week delivery.",
      "image": { "@id": "https://upcomingbrand.com/#logo" },
      "logo": { "@id": "https://upcomingbrand.com/#logo" },
      "priceRange": "$1,500-$15,000",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Credit Card, Bank Transfer",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Germantown",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 39.1732,
        "longitude": -77.2717
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
