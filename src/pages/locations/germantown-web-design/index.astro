      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a WordPress website cost in Germantown, MD?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most Germantown small business WordPress websites fall between $1,500 and $10,000. A simple 8-page site starts at $1,500-$3,500. A 15-20 page site with custom design and SEO runs $3,500-$6,000. Complex WooCommerce, medical practice, contractor, or nonprofit builds start at $6,000. Every quote is fixed-scope - one price, no hourly surprises." }
        },
        {
          "@type": "Question",
          "name": "Do you work with Germantown contractors and home improvement businesses?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Germantown has one of the most active contractor and renovation markets in upcounty Montgomery County - the housing stock is 30-40 years old, HOA communities are everywhere, and homeowners routinely compare three quotes on mobile before calling anyone. We build HomeAndConstructionBusiness schema, quote request forms that actually submit, and service area pages covering Damascus, Clarksburg, and Boyds so you rank for every search radius your customers actually use." }
        },
