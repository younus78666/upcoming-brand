---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const canonical = "https://upcomingbrand.com/hire-wordpress-designer/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Hire a WordPress Designer | Senior WordPress Designer for Hire | Upcoming Brand",
      "description": "Hire a senior WordPress designer who codes, ships schema, and guarantees 90+ Lighthouse. Fixed-scope projects from $1,500. 4-hour response. 48-hour quote. Direct access, not a freelance marketplace.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-02",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                       "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Hire a WordPress designer", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "Hire a WordPress Designer",
      "description": "Senior WordPress designer for hire. Custom WordPress design, schema architecture, Core Web Vitals optimization. Fixed-scope projects from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress design and development",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      }
    }
  ]
});

const checklist = [
  { item: "Built 400+ WordPress sites — across 9 verticals and 12 countries" },
  { item: "Custom Gutenberg block + theme development (no page builders)" },
  { item: "Schema architecture (LocalBusiness, FAQ, Service, vertical types)" },
  { item: "Core Web Vitals 90+ Lighthouse on every page, contractually" },
  { item: "WooCommerce, IDX, booking systems, multi-location schema" },
  { item: "Fixed-scope pricing — no hourly billing, no surprise invoices" },
  { item: "Direct founder access — same person on the call ships your code" },
  { item: "4-hour reply SLA. 48-hour fixed-scope quote turnaround." },
];

const vsOptions = [
  {
    name: "Marketplace freelancer",
    sub: "Upwork / Fiverr",
    items: [
      { good: false, text: "$200-$2,000 builds, often Bootstrap themes" },
      { good: false, text: "Hourly billing, scope creep risk" },
      { good: false, text: "Schema usually skipped" },
      { good: false, text: "Performance is best-effort" },
      { good: false, text: "Single point of failure" },
      { good: false, text: "Often offshore, time zone gaps" },
    ],
    accent: "muted",
  },
  {
    name: "Big-agency designer",
    sub: "50-person digital agency",
    items: [
      { good: true,  text: "Senior talent, polished process" },
      { good: false, text: "$15K-$80K minimums" },
      { good: false, text: "Account managers + creative directors layered in" },
      { good: false, text: "You don't talk to the actual designer" },
      { good: false, text: "6-month timelines for what should ship in 8 weeks" },
      { good: false, text: "Often outsource WordPress to junior contractors" },
    ],
    accent: "muted",
  },
  {
    name: "Upcoming Brand",
    sub: "Senior WordPress designer for hire",
    items: [
      { good: true, text: "Senior WordPress designer who also codes" },
      { good: true, text: "Fixed-scope from $1,500 — not hourly" },
      { good: true, text: "Schema-first on every project" },
      { good: true, text: "90+ Lighthouse contractually guaranteed" },
      { good: true, text: "Direct founder access, no relays" },
      { good: true, text: "US-based, 4-hour reply SLA, 48-hour quote" },
    ],
    accent: "amber",
  },
];

const process = [
  { num: "01", step: "Send a brief", detail: "Email a project description or fill the contact form. Takes 3 minutes." },
  { num: "02", step: "4-hour reply",  detail: "We respond within 4 business hours, ask any clarifying questions, and propose discovery times." },
  { num: "03", step: "Discovery call", detail: "Free 45-minute Zoom: competitive set, schema map, Local Pack gaps, conversion review." },
  { num: "04", step: "Fixed quote",     detail: "Within 48 hours: PDF with full scope, milestones, deliverables, and one fixed price." },
  { num: "05", step: "Sign + kickoff",   detail: "On signature and 40% deposit, kickoff scheduled within 5 business days." },
];

const skills = [
  {
    area: "Custom WordPress design",
    detail: "Designed in Figma, mapped to your schema graph, coded as custom Gutenberg blocks. No page builders, no $400/year plugin licences.",
  },
  {
    area: "WordPress development",
    detail: "Modern PHP, ACF Pro, custom post types, performant theme architecture. Editable forever by you or any other developer.",
  },
  {
    area: "Schema + on-page SEO",
    detail: "LocalBusiness, FAQ, Service, vertical-specific types. RankMath setup. Internal linking, Search Console + Bing Webmaster.",
  },
  {
    area: "Core Web Vitals",
    detail: "Image optimization, critical CSS, lazy loading, server-level tuning. 90+ Lighthouse on every page, contractually.",
  },
  {
    area: "WooCommerce + integrations",
    detail: "Subscriptions, configurators, multi-vendor, custom checkout flows, Stripe / Authorize.net, IDX feeds, booking systems.",
  },
  {
    area: "Migrations + redesigns",
    detail: "Wix / Squarespace / GoDaddy / outdated WordPress to custom builds. 301 redirect mapping, zero-downtime DNS cutover, 30-day Search Console watch.",
  },
];

const faqs = [
  {
    q: "How do I hire a WordPress designer?",
    a: "Three steps: send us a brief (form or email), book a free 45-minute discovery call, and sign the fixed-scope quote we send within 48 hours. The quote is held at the stated price for 30 days. We don't do funnels, qualifying calls, or 'just checking in' emails. One reply, one quote, one decision.",
  },
  {
    q: "What does it cost to hire a WordPress designer?",
    a: "Senior WordPress designers in the US typically charge $80-$200/hr or $4,000-$25,000+ per fixed-scope project. Marketplace freelancers go as low as $200-$2,000 with the trade-offs you'd expect (no schema, basic performance). Upcoming Brand sits at $1,500-$15,000 per project, fixed-scope, with schema and 90+ Lighthouse contractually included. We're not the cheapest option — we're the best value if you actually need the site to rank and convert.",
  },
  {
    q: "Should I hire a freelance WordPress designer or an agency?",
    a: "Freelancers work for very simple sites or tight budgets. An agency is the better fit when you need: schema architecture, contractual Core Web Vitals, compliance work (HIPAA, MRPC), continuity if a single developer disappears, and post-launch monitoring. Upcoming Brand is structured to give you agency-level deliverables at freelancer-adjacent pricing — fixed scope from $1,500, no agency overhead.",
  },
  {
    q: "Can I hire a WordPress designer without going through Upwork or Fiverr?",
    a: "Yes — and we'd recommend it for any project above $1,500. Marketplaces solve discovery, but they introduce platform fees, payment gates, and review-driven incentives that can lead to inflated 5-star culture without real accountability. Direct hire (this page) gives you a written contract, fixed price, and a real human you can email post-launch. We were on Upwork as Top Rated for years; we still are. We'd just rather work with you directly.",
  },
  {
    q: "How fast can you start a project?",
    a: "Discovery within 24-48 hours of your first email. Fixed-scope quote within 48 hours of the discovery call. Project kickoff within 5 business days of signature and deposit. The full timeline depends on scope: Starter (8 pages) ships in 4-6 weeks, Growth in 6-8 weeks, Custom in 8-10 weeks.",
  },
  {
    q: "Do you only work with Maryland businesses?",
    a: "No. We're based in Maryland but we work entirely remote with clients across all US states and 12 countries. Discovery on Zoom, async build with weekly staging links, written status updates. Distance has zero effect on the work. Maryland clients get our local schema and Local Pack expertise; out-of-state clients get the same engineering bar.",
  },
];
---
<BaseLayout
  title="Hire a WordPress Designer | Senior Designer for Hire from $1,500 | Upcoming Brand"
  description="Hire a senior WordPress designer who codes, ships schema, and guarantees 90+ Lighthouse. Fixed-scope projects from $1,500. 4-hour response. 48-hour quote. Direct access, not a freelance marketplace."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">Hire a WordPress designer</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">Hire a WordPress designer</span>
          <span class="page-h1-line"><em class="page-h1-accent">who actually codes,</em></span>
          <span class="page-h1-line page-h1-italic">ships schema, and guarantees performance.</span>
        </h1>

        <p class="page-lead">
          Skip the freelance marketplace. <strong>Upcoming Brand is a senior WordPress designer for hire</strong> who handles design, custom development, schema architecture, and Core Web Vitals — bundled into one fixed-scope quote. <strong>Projects from $1,500. Reply in 4 hours. Quote in 48.</strong>
        </p>

        <div class="page-hero-ctas">
          <a href="/contact/" class="lp-btn-primary">
            Hire the designer
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/work/" class="lp-btn-ghost">
            See past work
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Top Rated &middot; Upwork
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">From $1,500 &middot; Fixed-scope</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">90+ Lighthouse guaranteed</span>
        </div>
      </div>
    </section>

    <!-- ====== CHECKLIST CARD (8 reasons) ====== -->
    <section class="hire-checklist">
      <div class="container">
        <div class="hire-checklist-card">
          <div class="hire-checklist-head">
            <span class="hire-checklist-pulse" aria-hidden="true"></span>
            <span class="hire-checklist-label">When you hire Upcoming Brand</span>
          </div>
          <ul class="hire-checklist-list" role="list">
            {checklist.map((c, i) => (
              <li class="hire-checklist-item">
                <span class="hire-checklist-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="hire-checklist-check" aria-hidden="true">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="hire-checklist-text">{c.item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ====== VS OPTIONS ====== -->
    <section class="hire-vs">
      <div class="container">
        <div class="hire-vs-head">
          <p class="hire-section-eyebrow">
            <span class="hire-section-eyebrow-line"></span>
            Three ways to hire
          </p>
          <h2 class="page-h2">
            Three places to hire <em>a WordPress designer.</em>
          </h2>
          <p class="page-section-lead">Marketplace freelancer, big-agency contract, or direct hire. The trade-offs are real — and the one on the right is the option most clients land on.</p>
        </div>

        <div class="hire-vs-grid">
          {vsOptions.map((opt) => (
            <article class={`hire-vs-card hire-vs-card-${opt.accent}`}>
              <div class="hire-vs-card-head">
                <span class="hire-vs-card-name">{opt.name}</span>
                <span class="hire-vs-card-sub">{opt.sub}</span>
              </div>
              <ul class="hire-vs-card-list">
                {opt.items.map((it) => (
                  <li>
                    <span class={`hire-vs-icon ${it.good ? 'hire-vs-icon-yes' : 'hire-vs-icon-no'}`} aria-hidden="true">
                      {it.good ? (
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      ) : (
                        <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                      )}
                    </span>
                    <span>{it.text}</span>
                  </li>
                ))}
              </ul>
              {opt.accent === "amber" && (
                <a href="/contact/" class="hire-vs-card-cta">
                  Hire Upcoming Brand
                  <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== SKILLS / SCOPE ====== -->
    <section class="hire-skills">
      <div class="container">
        <div class="hire-skills-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Skills under one hire</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 hire-skills-h2">
            Six skills <em>you'd otherwise hire separately.</em>
          </h2>
          <p class="hire-skills-lead">Most projects need a designer, a developer, an SEO specialist, and a performance engineer. We bundle all four — plus migrations and integrations — into one engagement.</p>
        </div>

        <div class="hire-skills-grid">
          {skills.map((s, i) => (
            <article class="hire-skill-card">
              <span class="hire-skill-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="hire-skill-area">{s.area}</h3>
              <p class="hire-skill-detail">{s.detail}</p>
              <div class="hire-skill-bar" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== HOW TO HIRE (process) ====== -->
    <section class="hire-process">
      <div class="container">
        <div class="hire-process-head">
          <p class="hire-section-eyebrow">
            <span class="hire-section-eyebrow-line"></span>
            How to hire
          </p>
          <h2 class="page-h2">
            From email <em>to project kickoff.</em>
          </h2>
          <p class="page-section-lead">Five steps. The first three are free. Total time from first email to kickoff: typically 7-10 business days.</p>
        </div>

        <div class="hire-process-grid">
          {process.map((p, i) => (
            <div class="hire-process-step">
              <div class="hire-process-num-row">
                <span class="hire-process-num">{p.num}</span>
                {i < process.length - 1 && (
                  <span class="hire-process-arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                )}
              </div>
              <h3 class="hire-process-step-title">{p.step}</h3>
              <p class="hire-process-step-detail">{p.detail}</p>
            </div>
          ))}
        </div>

        <div class="hire-process-cta">
          <span class="hire-process-cta-label">Ready to start?</span>
          <a href="/contact/" class="hire-process-cta-btn">
            Send a project brief
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="hire-faq">
      <div class="container">
        <div class="hire-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Hiring FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 hire-faq-h2">
            Six questions <em>about hiring a WordPress designer.</em>
          </h2>
        </div>

        <div class="hire-faq-list">
          {faqs.map((f, i) => (
            <details class="hire-faq-item">
              <summary class="hire-faq-q">
                <span class="hire-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="hire-faq-q-text">{f.q}</span>
                <span class="hire-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="hire-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Ready to hire</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            Hire a senior<br>
            <em>WordPress designer today.</em>
          </h2>
          <p class="page-cta-lead">A free 45-minute discovery call. We map your competitive set, identify the schema and Local Pack gaps, and send a fixed-scope quote within 48 hours.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">
              Hire the designer
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/" class="page-cta-ghost-light">
              View pricing
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM (mirrored)
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .page-eyebrow-line-light { background: rgba(212,147,46,0.5); }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline-block;
  }
  .page-h1-accent::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0.05em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }
  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }
  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .lp-btn-primary, .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
