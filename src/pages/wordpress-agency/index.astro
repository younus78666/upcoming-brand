---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import Marquee from '../../components/Marquee.astro';

import BottomFormCTA from '../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/wordpress-agency/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Agency | Custom Web Design & Development | Upcoming Brand",
      "description": "Upcoming Brand is a WordPress agency based in Maryland. Custom WordPress web design, development, schema architecture, and Core Web Vitals optimization. Fixed-scope, 90+ Lighthouse, 6-10 week delivery. From $1,500.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-02",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",             "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "WordPress agency", "item": canonical }
        ]
      }
    },
    {
      "@type": ["ProfessionalService", "LocalBusiness"],
      "@id": `${canonical}#service`,
      "name": "Upcoming Brand WordPress Agency",
      "url": canonical,
      "description": "WordPress agency offering custom WordPress web design, WooCommerce development, schema architecture, and Core Web Vitals optimization. Fixed-scope projects from $1,500.",
      "image": { "@id": "https://upcomingbrand.com/#logo" },
      "logo": { "@id": "https://upcomingbrand.com/#logo" },
      "priceRange": "$1,500-$15,000",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Credit Card, Bank Transfer",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "State", "name": "Maryland", "sameAs": "https://en.wikipedia.org/wiki/Maryland" },
        { "@type": "Country", "name": "United States" }
      ],
      "serviceType": ["WordPress web design", "WordPress development", "WooCommerce development", "WordPress SEO", "WordPress maintenance"],
      "knowsAbout": [
        "WordPress agency",
        "WordPress web design agency",
        "WordPress website design company",
        "WordPress development agency",
        "Custom WordPress development",
        "Schema.org architecture",
        "Core Web Vitals optimization",
        "WooCommerce development",
        "Local Pack ranking",
        "Web design and development agency"
      ],
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "17:00"
      }],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5",
        "worstRating": "1"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "WordPress Agency Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Starter WordPress Build" },
            "name": "Starter",
            "price": "1500",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Growth WordPress Build" },
            "name": "Growth",
            "price": "3500",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Custom WordPress Build" },
            "name": "Custom",
            "price": "6000",
            "priceCurrency": "USD"
          }
        ]
      },
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "parentOrganization": { "@id": "https://upcomingbrand.com/#organization" }
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to hire a WordPress agency",
      "description": "The five-step process to hire a fixed-scope WordPress agency, from project brief to kickoff.",
      "totalTime": "P10D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Send a project brief",       "text": "Email a project description or fill the contact form. Most WordPress agencies respond within one business day." },
        { "@type": "HowToStep", "position": 2, "name": "Book a discovery call",       "text": "A senior member of the agency runs a 45-minute Zoom call covering competitive set, schema map, Local Pack gaps, and conversion architecture." },
        { "@type": "HowToStep", "position": 3, "name": "Receive a fixed-scope quote", "text": "Within 48 hours of the discovery call, the agency sends a PDF with full scope, milestones, deliverables, and one fixed price held for 30 days." },
        { "@type": "HowToStep", "position": 4, "name": "Sign and pay deposit",         "text": "Sign the SOW and pay the deposit (typically 40%). The agency schedules kickoff within 5 business days." },
        { "@type": "HowToStep", "position": 5, "name": "Async build and launch",       "text": "The build runs async with weekly staging URLs and written status updates. Launch includes a complete redirect map, zero-downtime DNS cutover, and 30-day post-launch monitoring." }
      ]
    }
  ]
});

const services = [
  {
    num: "01",
    title: "Custom WordPress design",
    detail: "Designed around your schema map and conversion architecture. Custom Gutenberg blocks, no page builders, no $400/year plugin licences. Editable forever by you or any developer.",
    keyword: "WordPress design",
    href: "/services/wordpress-web-design/",
  },
  {
    num: "02",
    title: "WordPress website development",
    detail: "Senior WordPress development services using modern PHP, ACF Pro, custom post types, and performant theme architecture. Built for editors as much as for visitors.",
    keyword: "WordPress development services",
    href: "/services/wordpress-web-design/",
  },
  {
    num: "03",
    title: "WooCommerce development",
    detail: "Complete WooCommerce builds: subscriptions, configurators, multi-vendor, custom checkout flows, payment integrations. WooCommerce schema and Core Web Vitals shipped at launch.",
    keyword: "WooCommerce agency",
    href: "/services/woocommerce-development/",
  },
  {
    num: "04",
    title: "WordPress SEO and schema",
    detail: "LocalBusiness, FAQ, Service, and vertical-specific schema mapped before design begins. RankMath configuration, internal linking strategy, Search Console and Bing Webmaster setup.",
    keyword: "WordPress SEO agency",
    href: "/services/wordpress-seo-services/",
  },
  {
    num: "05",
    title: "Core Web Vitals",
    detail: "90+ Lighthouse on every page, contractually. Image optimization, critical CSS, lazy loading, and server-level tuning so the site ships green and stays green.",
    keyword: "Web performance agency",
    href: "/services/wordpress-speed-optimization/",
  },
  {
    num: "06",
    title: "Migrations and redesigns",
    detail: "Wix, Squarespace, GoDaddy, or outdated WordPress to custom WordPress. Complete redirect map, zero-downtime DNS cutover, 30-day Search Console watch post-launch.",
    keyword: "WordPress migration",
    href: "/services/wordpress-migration/",
  },
  {
    num: "07",
    title: "WordPress maintenance",
    detail: "Care plans from $150/month with weekly updates, off-site backups, uptime monitoring, security patching, and a 4-hour SLA. Direct founder access, not a help-desk queue.",
    keyword: "WordPress maintenance services",
    href: "/services/wordpress-care-plans/",
  },
  {
    num: "08",
    title: "Audits and sprints",
    detail: "Standalone $1,500 audits (schema, performance, Local Pack, content gaps) and 2-week speed sprints to bring an existing site to 90+ Lighthouse.",
    keyword: "WordPress audit",
    href: "/services/seo-audit/",
  },
];

const whenYouNeed = [
  {
    num: "01",
    signal: "Your current site ranks for nothing",
    detail: "Beautiful site, blank Search Console. Usually means missing schema, weak Core Web Vitals, and no Local Pack signals. A WordPress agency rebuilds the technical foundation those rankings need.",
  },
  {
    num: "02",
    signal: "You're stuck on Wix, Squarespace, or GoDaddy",
    detail: "These platforms cap your schema flexibility, page speed, and ability to build the conversion architecture serious businesses need. Migrating to a custom WordPress build is the standard fix.",
  },
  {
    num: "03",
    signal: "A freelancer disappeared mid-project",
    detail: "It happens. Single-developer dependencies are a single point of failure. An agency offers continuity, documentation, and a vetted network if specialists are needed.",
  },
  {
    num: "04",
    signal: "You're scaling past 'simple website'",
    detail: "Adding WooCommerce, IDX feeds, multi-location schema, booking systems, or compliance layers (HIPAA, MRPC) takes you past freelancer scope. WordPress agencies live in that territory.",
  },
  {
    num: "05",
    signal: "Your current 'agency' bills hourly with no end",
    detail: "Quotes that grow with each invoice, no fixed delivery date, scope creep priced into your weekly bill. A fixed-scope WordPress agency replaces that with one PDF, one number, signed before code is written.",
  },
  {
    num: "06",
    signal: "You don't know who's actually doing the work",
    detail: "Project managers relay messages between you and faceless implementation teams. Direct-access agencies put you in the same conversation as the person writing the code.",
  },
];

const whyUs = [
  {
    num: "01",
    title: "Fixed-scope, not hourly",
    detail: "Every WordPress agency project is fixed-scope. One number agreed before code is written. No hourly billing, no scope-creep retainers, no surprise invoices.",
  },
  {
    num: "02",
    title: "Schema-first architecture",
    detail: "Generic agencies skip schema because they don't understand it. We map LocalBusiness, FAQ, Service, and vertical-specific schema first, before a single block is designed.",
  },
  {
    num: "03",
    title: "Performance as a deliverable",
    detail: "90+ Lighthouse on every page. Contractually. If a project ships below the bar, we don't invoice the final milestone.",
  },
  {
    num: "04",
    title: "Direct access, no relays",
    detail: "The person you book the discovery call with is the same person who writes your schema, builds your blocks, and ships your launch. No account managers.",
  },
];

const verticals = [
  { name: "Law firms",          href: "/industries/law-firm-website-design/",       icon: "scales" },
  { name: "Dental practices",   href: "/industries/dental-website-design/",         icon: "tooth" },
  { name: "Medical clinics",    href: "/industries/medical-website-design/",        icon: "med" },
  { name: "Real estate",        href: "/industries/real-estate-website-design/",    icon: "home" },
  { name: "Restaurants",        href: "/industries/restaurant-website-design/",     icon: "fork" },
  { name: "Contractors",        href: "/industries/contractor-website-design/",     icon: "tool" },
  { name: "Nonprofits",         href: "/industries/nonprofit-website-design/",      icon: "heart" },
  { name: "Ecommerce",          href: "/industries/ecommerce-website-design/",      icon: "cart" },
  { name: "Accountants / CPAs", href: "/industries/accountant-website-design/",     icon: "calc" },
];

const comparison = [
  { factor: "Pricing model",     freelancer: "Hourly, scope-creep risk",     agency: "Fixed-scope, one PDF, no surprises" },
  { factor: "Schema architecture", freelancer: "Often skipped or generic",     agency: "Mapped first, vertical-specific" },
  { factor: "Core Web Vitals",   freelancer: "Best-effort",                  agency: "Contractually 90+ Lighthouse" },
  { factor: "Continuity",        freelancer: "Solo, hit by bus = project dies", agency: "Studio + vetted network" },
  { factor: "Compliance",        freelancer: "DIY",                          agency: "HIPAA-aware forms, MRPC copy, FEC-safe donations" },
  { factor: "Post-launch",       freelancer: "Often invisible",              agency: "30-day Search Console watch + care plans" },
  { factor: "Communication",     freelancer: "Direct",                       agency: "Direct (with us, no account managers)" },
];

const faqs = [
  {
    q: "What does a WordPress agency actually do?",
    a: "A WordPress agency designs, develops, optimises, and maintains WordPress websites. The clients are typically businesses that need more than a freelancer can deliver and less overhead than a 50-person digital agency. The strongest WordPress agencies bundle four services in one engagement: custom design, custom development (no page builders), schema and SEO architecture, and Core Web Vitals optimisation. Upcoming Brand is structured exactly this way: every project ships with all four as a baseline, regardless of tier.",
  },
  {
    q: "How much does a WordPress agency charge?",
    a: "Quality WordPress agency pricing in the US runs $1,500 to $15,000 for most small-to-mid business projects, with enterprise builds (multi-location, multi-language, complex integrations) ranging $20,000-$80,000+. Hourly rates at WordPress agencies typically run $80-$200/hr, but the higher-quality firms have moved to fixed-scope pricing. Upcoming Brand is fixed-scope only: Starter at $1,500, Growth at $3,500, Custom from $6,000. The full scope is documented before you sign. See our <a href='/pricing/'>full pricing breakdown</a> for what's in each tier.",
  },
  {
    q: "WordPress agency vs freelancer: which is right?",
    a: "Freelancers work well for very simple sites, MVPs, or projects with tight budgets where you accept the trade-offs (no schema, basic performance, single point of failure). A WordPress agency is the better fit when you need schema-led architecture, contractual Core Web Vitals, compliance work (HIPAA, MRPC, FEC), continuity if a single developer leaves, and post-launch monitoring. We accept projects from $1,500 specifically so businesses don't have to choose between freelancer cheap and agency expensive. If you've decided on the freelancer side, see our <a href='/hire-wordpress-designer/'>hire a WordPress designer</a> page.",
  },
  {
    q: "What's the difference between a WordPress web design agency and a WordPress development agency?",
    a: "In practice, none. Most senior firms do both. A 'WordPress web design agency' implies the project is design-led; a 'WordPress development agency' implies it's engineering-led. Upcoming Brand is both: our designers know schema and our developers know conversion architecture. The same person who runs the discovery call writes the schema and ships the launch. There's no design-then-throw-over-the-wall-to-dev hand-off.",
  },
  {
    q: "Do you work as a white-label WordPress agency for other agencies?",
    a: "Selectively. We white-label WordPress development for marketing agencies and design studios that need a senior implementation partner. Pricing is the same as direct-client work; the agreement is project-by-project rather than retainer; and we don't talk to your client unless you bring us in. Email with the project brief and we'll respond within 4 business hours.",
  },
  {
    q: "Are you a Maryland-based WordPress agency or do you work nationally?",
    a: "Both. We're based in Maryland and have built sites for businesses across all US states, plus 12 countries internationally. Every project runs entirely remote: discovery on Zoom, async build with weekly staging links, written status updates. Maryland clients get the local schema and Local Pack expertise; out-of-state clients get the same engineering bar. Distance has zero effect on the work.",
  },
  {
    q: "How fast can a WordPress agency project be delivered?",
    a: "Standard delivery: Starter (8 pages) in 4-6 weeks, Growth (15-20 pages) in 6-8 weeks, Custom (WooCommerce / IDX / multi-location) in 8-10 weeks. The biggest variable is how quickly you review and approve design rounds. We keep building on our end, but the timeline pauses if content or feedback is delayed beyond the SOW window.",
  },
];
---
<BaseLayout
  title="WordPress Agency Maryland | Web Design & Development Services | Upcoming Brand"
  description="Upcoming Brand is a WordPress agency in Maryland offering web design and development services. Schema architecture, Core Web Vitals, WooCommerce, fixed-scope from $1,500. 90+ Lighthouse guaranteed. Maryland-based, serving the US."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WordPress agency · Maryland'
      pillText='WordPress Specialists · Maryland'
      h1Lines={[
        { text: 'A WordPress agency' },
        { text: 'that ships sites that rank.', type: 'accent' },
        { text: 'Schema-first. Fixed-scope.', type: 'italic' },
      ]}
      lead='Upcoming Brand is a Maryland-based <strong>WordPress agency</strong> offering <strong>WordPress web design and development services</strong> for serious businesses. WooCommerce, schema architecture, and Core Web Vitals optimization come bundled into every project. Searching for a "WordPress agency near me"? We work with Maryland clients locally and US-wide remotely. <strong>Fixed-scope from $1,500. 90+ Lighthouse guaranteed. 6-10 week delivery.</strong>'
      formName='wp-agency-inquiry'
      servicePresetValue='Agency Inquiry'
      trustLines={['Top Rated · Upwork', '400+ projects · 12 countries', '5+ years · 9 verticals']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your business',
          subtitle: 'Company and what you sell.',
          fields: [
            { type: 'text', name: 'company', label: 'Company or brand', placeholder: 'Smith & Co.', autocomplete: 'organization' },
            { type: 'select', name: 'business_type', label: 'Business type', required: true,
              options: ['Law Firm / Attorney', 'Dental / Medical', 'Real Estate', 'Restaurant / Hospitality', 'Contractor / Trades', 'Nonprofit / Church', 'Ecommerce / Retail', 'Small Business / Startup', 'Other'] },
          ],
        },
        {
          title: 'Project scope',
          subtitle: 'Which services and budget.',
          fields: [
            { type: 'select', name: 'service_mix', label: 'Services needed', required: true,
              options: ['Full website build', 'Redesign existing WP site', 'WooCommerce store', 'SEO + schema only', 'Care plan + maintenance', 'Bundle 3-5 services', 'Not sure yet'] },
            { type: 'select', name: 'budget', label: 'Budget range', required: true,
              options: ['Under $1,500', '$1,500 to $3,500', '$3,500 to $6,000', '$6,000 to $15,000', '$15,000+', 'Not sure yet'] },
          ],
        },
        {
          title: 'Timeline + goal',
          subtitle: 'When you need it live and what success looks like.',
          fields: [
            { type: 'select', name: 'timeline', label: 'Timeline', required: true,
              options: ['ASAP, within 4 weeks', 'Standard, 6 to 10 weeks', 'Flexible, 3+ months', 'Just exploring'] },
            { type: 'textarea', name: 'message', label: 'Project goal', placeholder: 'Three sentences. We will ask the rest in the reply.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- ====== WHY US ====== -->
    <section class="agency-why">
      <div class="container">
        <div class="agency-why-head">
          <p class="agency-section-eyebrow">
            <span class="agency-section-eyebrow-line"></span>
            What makes us different
          </p>
          <h2 class="page-h2">
            Why Maryland businesses pick <em>Upcoming Brand</em> over generic WordPress agencies.
          </h2>
          <p class="page-section-lead">Four things every WordPress agency claims. Four things we put in the contract.</p>
        </div>

        <div class="agency-why-grid">
          {whyUs.map((w) => (
            <article class="agency-why-card">
              <span class="agency-why-num">{w.num}</span>
              <h3 class="agency-why-title">{w.title}</h3>
              <p class="agency-why-detail">{w.detail}</p>
              <div class="agency-why-line" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== DEFINITION BLOCK (Know intent + AI Overview citation) ====== -->
    <section class="agency-define">
      <div class="container">
        <div class="agency-define-card">
          <div class="agency-define-head">
            <span class="agency-define-pulse" aria-hidden="true"></span>
            <span class="agency-define-label">Definition</span>
          </div>
          <h2 class="page-h2 agency-define-h2">
            What is a WordPress agency?
          </h2>
          <p class="agency-define-answer">
            <strong>A WordPress agency is a studio that designs, builds, and maintains WordPress websites for businesses.</strong> Unlike a freelancer, a WordPress agency offers continuity, a vetted network of specialists, and the technical depth needed for schema architecture, Core Web Vitals optimization, and compliance work. Unlike a 50-person digital agency, a WordPress-focused studio bundles design, development, SEO, and performance into one engagement without account-manager layers.
          </p>
          <div class="agency-define-meta">
            <div class="agency-define-meta-item">
              <span class="agency-define-meta-label">Also known as</span>
              <span class="agency-define-meta-val">WordPress design agency, WordPress development company, WordPress web design studio</span>
            </div>
            <div class="agency-define-meta-item">
              <span class="agency-define-meta-label">Category</span>
              <span class="agency-define-meta-val">Web design and development agency, specialized in WordPress</span>
            </div>
            <div class="agency-define-meta-item">
              <span class="agency-define-meta-label">Typical engagement</span>
              <span class="agency-define-meta-val">$1,500 to $80,000 per project, fixed-scope or hourly</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== WHEN YOU NEED ONE (Causation frame) ====== -->
    <section class="agency-when">
      <div class="container">
        <div class="agency-when-head">
          <p class="agency-section-eyebrow">
            <span class="agency-section-eyebrow-line"></span>
            When to hire one
          </p>
          <h2 class="page-h2">
            Six signals <em>you need a WordPress agency.</em>
          </h2>
          <p class="page-section-lead">If two or more of these match your situation, the right answer is hiring a <a href="/services/wordpress-web-design/">WordPress development services</a> partner with the depth to fix the underlying issue. Not all problems need an agency. These six usually do.</p>
        </div>

        <div class="agency-when-grid">
          {whenYouNeed.map((w) => (
            <article class="agency-when-card">
              <span class="agency-when-num">{w.num}</span>
              <h3 class="agency-when-signal">{w.signal}</h3>
              <p class="agency-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== SERVICES ====== -->
    <section class="agency-services">
      <div class="container">
        <div class="agency-services-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Agency services</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 agency-services-h2">
            Eight WordPress services <em>under one roof.</em>
          </h2>
          <p class="agency-services-lead">A full WordPress agency stack covering design, development, SEO, performance, maintenance, and audits, with no hand-offs between specialist silos.</p>
        </div>

        <div class="agency-services-grid">
          {services.map((s) => (
            <a href={s.href} class="agency-service-card">
              <div class="agency-service-head">
                <span class="agency-service-num">{s.num}</span>
                <span class="agency-service-keyword">{s.keyword}</span>
              </div>
              <h3 class="agency-service-title">{s.title}</h3>
              <p class="agency-service-detail">{s.detail}</p>
              <span class="agency-service-link" aria-hidden="true">
                See service
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div class="agency-service-bar" aria-hidden="true"></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== VERTICALS ====== -->
    <section class="agency-verticals">
      <div class="container">
        <div class="agency-verticals-head">
          <p class="agency-section-eyebrow">
            <span class="agency-section-eyebrow-line"></span>
            Verticals served
          </p>
          <h2 class="page-h2">
            Nine industries. <em>Vertical-specific schema on every project.</em>
          </h2>
          <p class="page-section-lead">A generic WordPress agency builds for everyone the same way. We build differently per vertical: different schema, different compliance, different conversion architecture.</p>
        </div>

        <div class="agency-verticals-grid">
          {verticals.map((v) => (
            <a href={v.href} class="agency-vertical">
              <span class="agency-vertical-icon" aria-hidden="true">
                {v.icon === "scales" && (<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 7h18M5 7l3 8h-6zM19 7l3 8h-6z"/></svg>)}
