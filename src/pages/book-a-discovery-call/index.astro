---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const canonical = "https://upcomingbrand.com/book-a-discovery-call/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Book a Discovery Call | Upcoming Brand WordPress Studio",
      "description": "Book a free 45-minute discovery call with the founder of Upcoming Brand. Competitive set audit, schema map, Local Pack gap analysis, and conversion review. No sales pitch.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-02",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                  "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Book a discovery call", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "Free 45-Minute WordPress Discovery Call",
      "description": "Free competitive set audit, schema map review, Local Pack gap analysis, and conversion architecture review with the founder of Upcoming Brand.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      },
      "serviceType": "Discovery consultation"
    }
  ]
});

const callAgenda = [
  {
    num: "01",
    minutes: "5 min",
    title: "Where you are now",
    detail: "What's working, what isn't, what triggered the search for an agency. We listen first.",
  },
  {
    num: "02",
    minutes: "10 min",
    title: "Competitive set audit",
    detail: "We pull up your top 5 SERP competitors live, look at what's helping them rank, and identify the gaps you can win.",
  },
  {
    num: "03",
    minutes: "10 min",
    title: "Schema + Local Pack review",
    detail: "What schema your industry needs, what's missing on your current site, and the Local Pack composition for your service area.",
  },
  {
    num: "04",
    minutes: "10 min",
    title: "Conversion architecture",
    detail: "How your current site is (or isn't) converting visitors. We look at hero, forms, CTAs, and the path from search result to inquiry.",
  },
  {
    num: "05",
    minutes: "10 min",
    title: "Scope + next steps",
    detail: "If we're a fit, we agree on scope, deliverables, and timeline. If we're not, we'll point you to a studio that's a better match.",
  },
];

const prepare = [
  {
    item: "Your current site URL",
    detail: "If you have one. If you don't, that's also fine — we'll talk about what to build.",
  },
  {
    item: "1-2 competitor URLs",
    detail: "The businesses you actually lose work to. The ones at the top of Google for the searches you care about.",
  },
  {
    item: "Top 3 services or revenue lines",
    detail: "What does your business actually sell? Which services drive the most revenue?",
  },
  {
    item: "Geographic service area",
    detail: "City, state, or radius — wherever you do business. We use this to map Local Pack opportunity.",
  },
  {
    item: "Rough budget and timeline",
    detail: "We don't need exact numbers, just a range. It helps us spend the call on what's actually possible.",
  },
];

const faqs = [
  {
    q: "Is the discovery call really free?",
    a: "Yes. No fee, no card, no obligation. We block 45 minutes for it because we use the time to do real audit work — competitive set, schema gaps, Local Pack composition. The output is genuinely useful even if you don't hire us. About 1 in 4 calls don't result in a project, and that's fine.",
  },
  {
    q: "Who's actually on the call?",
    a: "The founder. Not a sales rep, not a strategist, not an account executive. The same person who'll write your schema, build your blocks, audit your Core Web Vitals, and ship your launch. One channel, one chain of accountability — starting from minute one.",
  },
  {
    q: "What happens after the call?",
    a: "Within 24 hours we send a written summary of what we discussed, including the audit findings (competitive set, schema gaps, Local Pack analysis). Within 48 hours, if we agreed there's a project to scope, you'll receive a fixed-scope quote in PDF format with milestones, deliverables, and one fixed price. The quote is held at the stated price for 30 days.",
  },
  {
    q: "What if I'm not ready to commit?",
    a: "Most clients aren't ready on the call itself, and that's expected. We don't do pressure selling, follow-up funnels, or 'just checking in' emails for weeks. After the quote, we leave it open. If you want to move forward later, the price is held for 30 days. After that we re-quote at then-current rates.",
  },
  {
    q: "Do you work with clients outside Maryland?",
    a: "Yes. We're based in Maryland but we work entirely remotely. Clients across all US states and 12 countries get the same process: discovery on Zoom, async build with weekly staging links, written status updates. Distance has zero effect on the work.",
  },
  {
    q: "Can we do the call by phone instead of Zoom?",
    a: "We strongly prefer Zoom (or Google Meet) because we share screen during the audit — pulling up SERPs, schema validators, Lighthouse, and competitor sites in real time. The visual is half the value of the call. If video isn't possible we can still do it by phone, but you'll get less out of the 45 minutes.",
  },
];
---
<BaseLayout
  title="Book a Free Discovery Call | Upcoming Brand WordPress"
  description="Book a free 45-min discovery call with Upcoming Brand's founder. Includes a competitive audit, schema map, and Local Pack gap analysis. No sales pitch."
  canonicalUrl={canonical}
  noindex
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">Book a discovery call</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">A 45-minute Zoom call.</span>
          <span class="page-h1-line"><em class="page-h1-accent">Real audit work.</em></span>
          <span class="page-h1-line page-h1-italic">No sales pitch attached.</span>
        </h1>

        <p class="page-lead">
          Pick a time that works. The founder runs a live competitive audit, maps your schema and Local Pack gaps, reviews your conversion architecture, and answers anything else you want to throw at us. <strong>Free, no obligation, output you can use even if you don't hire us.</strong>
        </p>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Free &middot; 45 minutes
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">Direct with founder</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">Audit + quote within 48 hours</span>
        </div>
      </div>
    </section>

    <!-- ====== BOOKING SECTION ====== -->
    <section class="book-booking">
      <div class="container">
        <div class="book-booking-grid">

          <!-- Calendar embed column -->
          <div class="book-calendar-card">
            <div class="book-calendar-head">
              <div class="book-calendar-meta">
                <span class="book-calendar-pulse" aria-hidden="true"></span>
                <span class="book-calendar-label">Live availability</span>
              </div>
              <span class="book-calendar-tz">Eastern Time (US)</span>
            </div>

            <!-- Calendar embed placeholder — replace with Calendly / Cal.com when ready -->
            <div class="book-calendar-embed" id="calendar-embed">
              <div class="book-calendar-placeholder">
                <span class="book-calendar-placeholder-icon" aria-hidden="true">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </span>
                <h2 class="book-calendar-placeholder-title">Calendar embed will load here</h2>
                <p class="book-calendar-placeholder-desc">Replace this block with a Calendly, Cal.com, or SavvyCal embed snippet. Until then, use the email button below to schedule directly.</p>
                <a href="mailto:hello@upcomingbrand.com?subject=Book%20a%20discovery%20call" class="book-calendar-fallback">
                  Email to schedule
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
              <!-- Drop-in example for Calendly:
              <div class="calendly-inline-widget" data-url="https://calendly.com/your-handle/discovery" style="min-width:320px;height:680px;"></div>
              <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
              -->
            </div>

            <div class="book-calendar-foot">
              <div class="book-calendar-foot-stat">
                <span class="book-calendar-foot-num">45</span>
                <span class="book-calendar-foot-label">Minutes</span>
              </div>
              <div class="book-calendar-foot-stat">
                <span class="book-calendar-foot-num">$0</span>
                <span class="book-calendar-foot-label">Free</span>
              </div>
              <div class="book-calendar-foot-stat">
                <span class="book-calendar-foot-num">1:1</span>
                <span class="book-calendar-foot-label">With founder</span>
              </div>
            </div>
          </div>

          <!-- Side: agenda + email fallback -->
          <aside class="book-side">
            <div class="book-agenda-card">
              <div class="book-agenda-head">
                <span class="book-agenda-eyebrow">Call agenda</span>
                <h2 class="book-agenda-h2">
                  How <em>45 minutes</em> breaks down.
                </h2>
              </div>

              <ol class="book-agenda-list">
                {callAgenda.map((step) => (
                  <li class="book-agenda-step">
                    <span class="book-agenda-num">{step.num}</span>
                    <div class="book-agenda-content">
                      <div class="book-agenda-meta">
                        <span class="book-agenda-min">{step.minutes}</span>
                        <span class="book-agenda-divider" aria-hidden="true"></span>
                        <span class="book-agenda-title">{step.title}</span>
                      </div>
                      <p class="book-agenda-detail">{step.detail}</p>
                    </div>
                  </li>
                ))}
              </ol>

              <div class="book-agenda-foot">
                <span class="book-agenda-foot-label">Total</span>
                <span class="book-agenda-foot-val">45 minutes</span>
                <span class="book-agenda-foot-tag">Always free</span>
              </div>
            </div>

            <div class="book-email-card">
              <span class="book-email-eyebrow">Can't pick a time right now?</span>
              <p class="book-email-text">Send a brief instead. We'll reply within 4 business hours and propose three slots based on your availability.</p>
              <a href="/contact/" class="book-email-cta">
                Send a project brief
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ====== HOW TO PREPARE ====== -->
    <section class="book-prepare">
      <div class="container">
        <div class="book-prepare-head">
          <p class="book-section-eyebrow">
            <span class="book-section-eyebrow-line"></span>
            How to prepare
          </p>
          <h2 class="page-h2">
            Five things to have ready <em>(none of them are mandatory).</em>
          </h2>
          <p class="page-section-lead">If you arrive with these, the 45 minutes spends entirely on audit work instead of context-gathering. If you don't have them, no problem — we ask the questions live.</p>
        </div>

        <div class="book-prepare-grid">
          {prepare.map((p, i) => (
            <article class="book-prepare-card">
              <span class="book-prepare-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="book-prepare-item">{p.item}</h3>
              <p class="book-prepare-detail">{p.detail}</p>
              <span class="book-prepare-check" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M3 6.5l2.5 2.5L10 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="book-faq">
      <div class="container">
        <div class="book-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Discovery call FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 book-faq-h2">
            Six questions <em>before you book.</em>
          </h2>
        </div>

        <div class="book-faq-list">
          {faqs.map((f, i) => (
            <details class="book-faq-item">
              <summary class="book-faq-q">
                <span class="book-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="book-faq-q-text">{f.q}</span>
                <span class="book-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="book-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Ready to book</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            45 minutes.<br>
            <em>Worth it whether you hire us or not.</em>
          </h2>
          <p class="page-cta-lead">Real audit work, not a sales pitch. Competitive set, schema gaps, Local Pack composition, conversion architecture. Pick a slot above or send a brief.</p>
          <div class="page-cta-buttons">
            <a href="#calendar-embed" class="lp-btn-primary page-cta-primary">
              Pick a time
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v12M2 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/contact/" class="page-cta-ghost-light">
              Send a brief
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }
  .page-h1-accent::after { display: none; }
  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }
  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }
  .page-trust-line {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .page-trust-dot {
    width: 3px; height: 3px;
    background: var(--ink-muted);
    border-radius: 50%;
    opacity: 0.4;
  }

  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(26px, 3vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 12px 0 0;
  }
  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-section-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 16px auto 0;
  }

  .lp-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg { transition: transform 0.22s ease; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }

  .book-section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber-deep);
    margin: 0;
    font-weight: 500;
  }
  .book-section-eyebrow-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--amber);
  }

  /* ===========================================
     BOOKING SECTION
     =========================================== */
  .book-booking {
    background: var(--paper);
    padding: clamp(56px, 8vh, 96px) 0;
    border-bottom: 1px solid var(--line);
    scroll-margin-top: 24px;
  }

  .book-booking-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: flex-start;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Calendar card */
  .book-calendar-card {
    background: var(--cream);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    position: sticky;
    top: 24px;
  }

  .book-calendar-head {
    padding: 18px 24px;
    background: var(--paper);
    border-bottom: 1px dashed var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .book-calendar-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .book-calendar-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: book-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 0 4px rgba(92,128,64,0.18);
  }

  @keyframes book-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .book-calendar-label {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
  }

  .book-calendar-tz {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--amber-deep);
    background: rgba(212,147,46,0.08);
    border: 1px solid rgba(212,147,46,0.2);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
  }

  .book-calendar-embed {
    min-height: 480px;
    padding: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cream);
    position: relative;
  }

  /* Placeholder shown until calendar widget is dropped in */
  .book-calendar-placeholder {
    text-align: center;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

