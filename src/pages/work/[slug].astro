---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { projects, type Project } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

interface Props { project: Project; }
const { project } = Astro.props;
const canonical = `https://www.upcomingbrand.com/work/${project.slug}/`;

// Phase grouping: split approach steps into 3 phases
const totalSteps = project.approach.length;
const d = Math.floor(totalSteps * 0.34);          // discovery boundary
const b = Math.floor(totalSteps * 0.84);           // build boundary
const phases = [
  { id: '01', label: 'Discovery & Audit',    sub: 'Weeks 1–2',  steps: project.approach.slice(0, d) },
  { id: '02', label: 'Design & Build',       sub: 'Weeks 3–6',  steps: project.approach.slice(d, b) },
  { id: '03', label: 'Launch & Optimize',    sub: 'Month 2+',   steps: project.approach.slice(b) },
].filter(p => p.steps.length > 0);

// Total monthly search volume from clientKeywords
const totalVol = project.clientKeywords.reduce((sum, k) => {
  const n = parseInt(k.vol.replace(/,/g, ''), 10);
  return sum + (isNaN(n) ? 0 : n);
}, 0);
const totalVolStr = totalVol >= 1000
  ? (totalVol >= 100000 ? `${Math.round(totalVol / 1000)}K` : `${(totalVol / 1000).toFixed(1)}K`)
  : totalVol.toString();

const related = projects.filter((p) => p.filter === project.filter && p.slug !== project.slug).slice(0, 3);
const moreProjects = projects.filter((p) => p.slug !== project.slug).slice(0, 3);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonical}#article`,
      "headline": `${project.name}: ${project.headline}`,
      "description": project.summary,
      "author": { "@id": "https://www.upcomingbrand.com/#organization" },
      "publisher": { "@id": "https://www.upcomingbrand.com/#organization" },
      "datePublished": "2026-05-03",
      "dateModified": "2026-05-31",
      "mainEntityOfPage": { "@id": `${canonical}#webpage` }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": `${project.name} | Case Study | Upcoming Brand`,
      "description": project.summary,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://www.upcomingbrand.com/#website" },
      "dateModified": "2026-05-31",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://www.upcomingbrand.com/work/" },
          { "@type": "ListItem", "position": 3, "name": project.name, "item": canonical }
        ]
      }
    }
  ]
});
---
<BaseLayout
  title={`${project.name} | Case Study | Upcoming Brand`}
  description={project.summary}
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLd} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ════════════════════════════════════════
         HERO
    ════════════════════════════════════════ -->
    <section class="cs-hero">
      <div class="cs-hero-orb cs-hero-orb-1" aria-hidden="true"></div>
      <div class="cs-hero-orb cs-hero-orb-2" aria-hidden="true"></div>
      <div class="container">

        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a href="/work/" class="cs-back-link">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Portfolio
          </a>
          <span class="cs-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="cs-breadcrumb-cur">{project.name}</span>
        </nav>

        <div class="cs-hero-grid">
          <div class="cs-hero-left">
            <div class="cs-hero-pills">
              <span class="cs-pill cs-pill-vertical">{project.vertical}</span>
              <span class="cs-pill cs-pill-mono">{project.scope}</span>
              <span class="cs-pill cs-pill-mono">{project.timeline}</span>
              <span class="cs-pill cs-pill-budget">{project.budget}</span>
            </div>
            <h1 class="cs-hero-name">{project.name}</h1>
            <p class="cs-hero-result">{project.headline}</p>
            <p class="cs-hero-summary">{project.summary}</p>
            <div class="cs-hero-meta-row">
              <div class="cs-hero-meta-item">
                <span class="cs-hmi-label">Client</span>
                <span class="cs-hmi-val">{project.client.type}</span>
              </div>
              <div class="cs-hero-meta-sep" aria-hidden="true"></div>
              <div class="cs-hero-meta-item">
                <span class="cs-hmi-label">Team</span>
                <span class="cs-hmi-val">{project.client.size}</span>
              </div>
              <div class="cs-hero-meta-sep" aria-hidden="true"></div>
              <div class="cs-hero-meta-item">
                <span class="cs-hmi-label">Market</span>
                <span class="cs-hmi-val">{project.client.market}</span>
              </div>
            </div>
          </div>

          <div class="cs-hero-stat-card">
            <div class="cs-hsc-glow" aria-hidden="true"></div>
            <div class="cs-hsc-badge">Top result</div>
            <div class="cs-hsc-big">{project.metrics[0].after}</div>
            {project.metrics[0].delta && <span class="cs-hsc-delta">{project.metrics[0].delta}</span>}
            <div class="cs-hsc-label">{project.metrics[0].label}</div>
            <div class="cs-hsc-from">from <s>{project.metrics[0].before}</s></div>

            <div class="cs-hsc-divider"></div>

            <ul class="cs-hsc-list" role="list">
              {project.metrics.slice(1).map((m) => (
                <li class="cs-hsc-item">
                  <span class="cs-hsc-item-label">{m.label}</span>
                  <span class="cs-hsc-item-val">{m.after}</span>
                </li>
              ))}
            </ul>

            <a href="#inquiry" class="cs-hsc-cta">Start a similar project</a>
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="cs-hsc-live">
                View live site
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 1h10M11 1v10M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         SITE SCREENSHOT MOCKUP
    ════════════════════════════════════════ -->
    <section class="cs-screens">
      <div class="container">
        <div class="cs-screens-grid">

          <!-- Before -->
          <div class="cs-screen-wrap cs-screen-before">
            <div class="cs-screen-label-row">
              <span class="cs-screen-badge cs-screen-badge-before">
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true"><circle cx="4" cy="4" r="3.5" fill="currentColor"/></svg>
                Before
              </span>
              <span class="cs-screen-sub">Original site</span>
            </div>
            <div class="cs-browser-frame cs-browser-before">
              <div class="cs-browser-bar">
                <span class="cs-browser-dot"></span><span class="cs-browser-dot"></span><span class="cs-browser-dot"></span>
                <div class="cs-browser-url">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><rect x="1" y="1" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M4 6h4M4 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                  Old site · Wix / Squarespace / legacy WordPress
                </div>
              </div>
              <div class="cs-browser-body cs-browser-body-before">
                <!-- Visual representation of broken/old site -->
                <div class="cs-mockup-before">
                  <div class="cs-mb-nav"></div>
                  <div class="cs-mb-hero">
                    <div class="cs-mb-hero-text">
                      <div class="cs-mb-line cs-mb-line-title"></div>
                      <div class="cs-mb-line cs-mb-line-sub"></div>
                      <div class="cs-mb-line cs-mb-line-sub cs-mb-line-short"></div>
                    </div>
                    <div class="cs-mb-hero-score">
                      <div class="cs-mb-score-label">{project.metrics.find(m => m.label.toLowerCase().includes('lighthouse') || m.label.toLowerCase().includes('score')) ? 'Mobile Score' : project.metrics[0].label.split(' ').slice(0,2).join(' ')}</div>
                      <div class="cs-mb-score-bad">{project.metrics.find(m => m.label.toLowerCase().includes('lighthouse'))?.before ?? project.metrics[0].before.replace(' words','').split('/')[0]}</div>
                    </div>
                  </div>
                  <div class="cs-mb-content">
                    <div class="cs-mb-card"></div>
                    <div class="cs-mb-card"></div>
                    <div class="cs-mb-card"></div>
                  </div>
                  <div class="cs-mb-warning">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2L13 12H1L7 2z" stroke="currentColor" stroke-width="1.2"/><path d="M7 6v3M7 10.5v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    {project.metrics.find(m => m.label.toLowerCase().includes('lighthouse')) ? 'No schema · No Local Pack · Slow mobile' : `${project.metrics[0].before} · ${project.metrics[2]?.before ?? 'No structure'} duplicates · Thin content`}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Arrow -->
          <div class="cs-screens-arrow" aria-hidden="true">
            <div class="cs-sa-line"></div>
            <svg class="cs-sa-icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="23" stroke="rgba(212,147,46,0.3)" stroke-width="1"/>
              <circle cx="24" cy="24" r="23" stroke="url(#sa-grad)" stroke-width="1.5" stroke-dasharray="144" stroke-dashoffset="36"/>
              <path d="M16 24h16M28 18l6 6-6 6" stroke="#D4932E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <defs>
                <linearGradient id="sa-grad" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#D4932E" stop-opacity="0"/>
                  <stop offset="50%" stop-color="#D4932E"/>
                  <stop offset="100%" stop-color="#A86F1F"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="cs-sa-line"></div>
          </div>

          <!-- After -->
          <div class="cs-screen-wrap cs-screen-after">
            <div class="cs-screen-label-row">
              <span class="cs-screen-badge cs-screen-badge-after">
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true"><circle cx="4" cy="4" r="3.5" fill="currentColor"/></svg>
                After
              </span>
              <span class="cs-screen-sub">New WordPress site</span>
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="cs-screen-visit">
                  Visit ↗
                </a>
              )}
            </div>
            <div class="cs-browser-frame cs-browser-after">
              <div class="cs-browser-bar">
                <span class="cs-browser-dot"></span><span class="cs-browser-dot"></span><span class="cs-browser-dot"></span>
                <div class="cs-browser-url cs-browser-url-live">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M6 1a5 5 0 100 10A5 5 0 006 1zM1 6h10M6 1C4.5 3 3.8 4.5 3.8 6S4.5 9 6 11M6 1c1.5 2 2.2 3.5 2.2 5S7.5 9 6 11" stroke="currentColor" stroke-width="1.1"/></svg>
                  wordpress · custom theme · {project.techStack.slice(0, 2).join(' · ')}
                </div>
              </div>
              <div class="cs-browser-body cs-browser-body-after">
                <div class="cs-mockup-after">
                  <div class="cs-ma-nav">
                    <div class="cs-ma-logo"></div>
                    <div class="cs-ma-nav-links">
                      <div class="cs-ma-nav-link"></div>
                      <div class="cs-ma-nav-link"></div>
                      <div class="cs-ma-nav-link"></div>
                      <div class="cs-ma-cta-btn"></div>
                    </div>
                  </div>
                  <div class="cs-ma-hero">
                    <div class="cs-ma-hero-left">
                      <div class="cs-ma-h1"></div>
                      <div class="cs-ma-sub"></div>
                      <div class="cs-ma-sub cs-ma-sub-short"></div>
                      <div class="cs-ma-btns">
                        <div class="cs-ma-btn-primary"></div>
                        <div class="cs-ma-btn-ghost"></div>
                      </div>
                    </div>
                    <div class="cs-ma-hero-score">
                      <div class="cs-ma-score-ring">
                        <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
                          <circle cx="28" cy="28" r="24" fill="none" stroke="rgba(212,147,46,0.2)" stroke-width="4"/>
                          <circle cx="28" cy="28" r="24" fill="none" stroke="#D4932E" stroke-width="4" stroke-linecap="round"
                            stroke-dasharray="150.8" stroke-dashoffset="18" transform="rotate(-90 28 28)"/>
                        </svg>
                        <span class="cs-ma-score-num">{project.metrics.find(m => m.label.includes('Lighthouse') || m.label.includes('mobile'))?.after?.replace(/[^0-9]/g, '').slice(0, 2) ?? '9'}+</span>
                      </div>
                      <div class="cs-ma-score-label">Mobile Score</div>
                    </div>
                  </div>
                  <div class="cs-ma-content">
                    <div class="cs-ma-services">
                      {project.deliverables.slice(0, 3).map((d) => (
                        <div class="cs-ma-service-card">
                          <div class="cs-ma-svc-icon"></div>
                          <div class="cs-ma-svc-label">{d.split(' ').slice(0, 3).join(' ')}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         TRANSFORMATION METRICS
    ════════════════════════════════════════ -->
    <section class="cs-transform">
      <div class="container">
        <div class="cs-transform-head">
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Measured results</p>
          <h2 class="cs-section-h2">The transformation, <em>by the numbers.</em></h2>
        </div>
        <div class="cs-tf-grid">
          {project.metrics.map((m, i) => (
            <div class={`cs-tf-card${i === 0 ? ' cs-tf-card-hero' : ''}`}>
              <span class="cs-tf-label">{m.label}</span>
              <div class="cs-tf-row">
                <div class="cs-tf-before">
                  <span class="cs-tf-tag">Before</span>
                  <span class="cs-tf-val cs-tf-val-before">{m.before}</span>
                </div>
                <div class="cs-tf-arrow-wrap" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M4 12h16M14 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div class="cs-tf-after">
                  <span class="cs-tf-tag cs-tf-tag-after">After</span>
                  <span class="cs-tf-val cs-tf-val-after">{m.after}</span>
                </div>
              </div>
              {m.delta && <div class="cs-tf-delta">{m.delta}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         CHALLENGE
    ════════════════════════════════════════ -->
    <section class="cs-challenge">
      <div class="container cs-challenge-grid">
        <div class="cs-challenge-text">
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>The challenge</p>
          <h2 class="cs-section-h2">Where the project <em>started.</em></h2>
          <p class="cs-prose">{project.challenge}</p>
          <div class="cs-client-chips">
            <div class="cs-chip">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><rect x="1" y="1.5" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M3 5h6M3 7.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {project.client.type}
            </div>
            <div class="cs-chip">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="4.5" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M1.5 10.5c0-2.5 2-3.5 4.5-3.5s4.5 1 4.5 3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {project.client.size}
            </div>
            <div class="cs-chip">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.2"/><path d="M6 1.5v1.5M6 9v1.5M1.5 6H3M9 6h1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {project.client.market}
            </div>
          </div>
        </div>

        <div class="cs-testimonial-card">
          <div class="cs-tc-accent" aria-hidden="true"></div>
          <svg class="cs-tc-quote" width="36" height="28" viewBox="0 0 36 28" fill="none" aria-hidden="true">
            <path d="M8 20V12c0-4 2-6 6-7l1.5 3C13 9 12 10 12 12h4v8H8zm16 0V12c0-4 2-6 6-7l1.5 3C29 9 28 10 28 12h4v8H24z" fill="currentColor"/>
          </svg>
          <blockquote class="cs-tc-text">{project.testimonial.quote}</blockquote>
          <cite class="cs-tc-cite">
            <span class="cs-tc-role">{project.testimonial.role}</span>
            <span class="cs-tc-company">{project.client.type}</span>
          </cite>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         APPROACH — 3-PHASE TIMELINE
    ════════════════════════════════════════ -->
    <section class="cs-approach">
      <div class="container">
        <div class="cs-approach-head">
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Our approach</p>
          <h2 class="cs-section-h2">How we shipped it, <em>phase by phase.</em></h2>
          <p class="cs-approach-sub">Every project runs through the same three-phase process. Discovery first, build second, optimize ongoing. No shortcuts.</p>
        </div>

        <div class="cs-phases-track">
          {phases.map((phase, pi) => (
            <div class="cs-phase-col">
              <div class="cs-phase-header">
                <div class="cs-phase-num-wrap">
                  <span class="cs-phase-num">{phase.id}</span>
                </div>
                <div>
                  <div class="cs-phase-name">{phase.label}</div>
                  <div class="cs-phase-sub">{phase.sub}</div>
                </div>
              </div>

              <div class="cs-phase-steps">
                {phase.steps.map((step, si) => (
                  <div class="cs-phase-step">
                    <div class="cs-ps-icon" aria-hidden="true">
                      {pi === 0 && (
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
                          <path d="M5 7l1.5 1.5L9 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      )}
                      {pi === 1 && (
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <rect x="1.5" y="1.5" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.3"/>
                          <path d="M4 7h6M4 4.5h3M4 9.5h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                        </svg>
                      )}
                      {pi === 2 && (
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M2 10l3-3 2 2 5-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                          <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
                        </svg>
                      )}
                    </div>
                    <p class="cs-ps-text">{step}</p>
                  </div>
                ))}
              </div>

              {pi < phases.length - 1 && (
                <div class="cs-phase-connector" aria-hidden="true">
                  <svg width="100%" height="32" viewBox="0 0 300 32" preserveAspectRatio="none" fill="none">
                    <path d="M0 16 Q150 2 300 16" stroke="url(#phase-conn)" stroke-width="1.5" stroke-dasharray="6 4"/>
                    <polygon points="294,12 300,16 294,20" fill="#D4932E" opacity="0.7"/>
                    <defs>
                      <linearGradient id="phase-conn" x1="0" y1="0" x2="300" y2="0" gradientUnits="userSpaceOnUse">
                        <stop offset="0%" stop-color="#D4932E" stop-opacity="0.3"/>
                        <stop offset="60%" stop-color="#D4932E" stop-opacity="0.8"/>
                        <stop offset="100%" stop-color="#A86F1F"/>
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         DELIVERABLES + STACK
    ════════════════════════════════════════ -->
    <section class="cs-built">
      <div class="container cs-built-grid">

        <div>
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Deliverables</p>
          <h2 class="cs-section-h2">What was <em>built and shipped.</em></h2>
          <ul class="cs-deliver-list" role="list">
            {project.deliverables.map((d) => (
              <li class="cs-deliver-item">
                <span class="cs-deliver-check" aria-hidden="true">
                  <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {d}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Tech stack</p>
          <h2 class="cs-section-h2">What it <em>runs on.</em></h2>
          <div class="cs-stack-list">
            {project.techStack.map((t) => (
              <div class="cs-stack-item">
                <div class="cs-si-icon" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4-2 4 2v4l-4 2-4-2V4z" stroke="currentColor" stroke-width="1.2"/></svg>
                </div>
                <div>
                  <span class="cs-si-name">{t}</span>
                  <span class="cs-si-tag">
                    {t.toLowerCase().includes('wordpress') ? 'CMS' :
                     t.toLowerCase().includes('cloudway') || t.toLowerCase().includes('wp engine') || t.toLowerCase().includes('kinsta') ? 'Hosting' :
                     t.toLowerCase().includes('stripe') || t.toLowerCase().includes('givewp') || t.toLowerCase().includes('woo') ? 'Payments' :
                     t.toLowerCase().includes('rank') || t.toLowerCase().includes('seo') || t.toLowerCase().includes('whitespark') ? 'SEO' :
                     t.toLowerCase().includes('cloudflare') || t.toLowerCase().includes('bunny') || t.toLowerCase().includes('algolia') ? 'Performance' :
                     'Plugin'}
                  </span>
                </div>
              </div>
            ))}
          </div>

          <div class="cs-built-facts">
            <div class="cs-bf-row">
              <span class="cs-bf-key">Timeline</span>
              <span class="cs-bf-val">{project.timeline}</span>
            </div>
            <div class="cs-bf-row">
              <span class="cs-bf-key">Investment</span>
              <span class="cs-bf-val">{project.budget}</span>
            </div>
            <div class="cs-bf-row">
              <span class="cs-bf-key">Platform</span>
              <span class="cs-bf-val">WordPress (self-hosted)</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ════════════════════════════════════════
         CLIENT KEYWORD DEMAND
    ════════════════════════════════════════ -->
    <section class="cs-demand">
      <div class="container">
        <div class="cs-demand-inner">
          <div class="cs-demand-left">
            <p class="cs-eyebrow cs-eyebrow-light"><span class="cs-eyebrow-line" aria-hidden="true"></span>Search demand</p>
            <h2 class="cs-demand-h2">What {project.client.type.toLowerCase()}s' <em>customers search for.</em></h2>
            <p class="cs-demand-sub">These are real monthly searches people make when looking for a business like this one. The new site is built to capture them.</p>
            <div class="cs-demand-total">
              <span class="cs-demand-total-num">{totalVolStr}</span>
              <span class="cs-demand-total-label">combined searches / month<br/>in their market</span>
            </div>
          </div>
          <div class="cs-demand-right">
            <div class="cs-kw-grid">
              {project.clientKeywords.map((kw) => (
                <div class={`cs-kw-card cs-kw-intent-${kw.intent}`}>
                  <span class="cs-kw-intent-dot" aria-hidden="true"></span>
                  <div class="cs-kw-body">
                    <span class="cs-kw-term">{kw.term}</span>
                    <div class="cs-kw-stats">
                      <span class="cs-kw-vol">{kw.vol}/mo</span>
                      <span class="cs-kw-cpc">{kw.cpc} CPC</span>
                      <span class="cs-kw-badge">{kw.intent}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <p class="cs-kw-note">
              Data via Ubersuggest · US search volume · intent classified by query type
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         ROI BAND
    ════════════════════════════════════════ -->
    <section class="cs-roi">
      <div class="cs-roi-orb" aria-hidden="true"></div>
      <div class="container cs-roi-grid">
        <div class="cs-roi-text">
          <p class="cs-eyebrow cs-eyebrow-light"><span class="cs-eyebrow-line" aria-hidden="true"></span>Why it matters</p>
          <h2 class="cs-roi-h2">WordPress done right <em>pays back the investment.</em></h2>
          <p class="cs-roi-sub">Every project we ship is designed to generate leads, bookings, or revenue — not just look good. The metrics above are what our clients track 90 days post-launch.</p>
          <a href="#inquiry" class="cs-roi-btn">Get similar results →</a>
        </div>
        <div class="cs-roi-metrics">
          {project.metrics.map((m) => (
            <div class="cs-roi-metric">
              <span class="cs-roi-after">{m.after}</span>
              <span class="cs-roi-label">{m.label}</span>
              {m.delta && <span class="cs-roi-delta">{m.delta}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         INQUIRY + LINKS
    ════════════════════════════════════════ -->
    <section class="cs-cta-block" id="inquiry">
      <div class="container cs-cta-grid">

        <div class="cs-form-card">
          <div class="cs-form-stripe" aria-hidden="true"></div>
          <p class="cs-eyebrow cs-eyebrow-light"><span class="cs-eyebrow-line" aria-hidden="true"></span>Start a project</p>
          <h2 class="cs-form-title">Want results like these?</h2>
          <p class="cs-form-sub">Tell us about your site. We reply within 4 business hours — no pitch, just an honest assessment.</p>

          <form class="cs-form" name={`work-${project.slug}`} method="POST" data-uc-form={`work-${project.slug}`} novalidate>
            <input type="hidden" name="form-name" value={`work-${project.slug}`} />
            <input type="hidden" name="reference_project" value={project.slug} />
            <div style="display:none"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
            <div class="cs-form-2col">
              <div class="cs-field">
                <label class="cs-label" for={`f-name-${project.slug}`}>Your name</label>
                <input class="cs-input" type="text" id={`f-name-${project.slug}`} name="name" placeholder="Jane Smith" required autocomplete="name" />
              </div>
              <div class="cs-field">
                <label class="cs-label" for={`f-email-${project.slug}`}>Email</label>
                <input class="cs-input" type="email" id={`f-email-${project.slug}`} name="email" placeholder="jane@company.com" required autocomplete="email" />
              </div>
            </div>
            <div class="cs-field">
              <label class="cs-label" for={`f-msg-${project.slug}`}>What are you trying to fix or build?</label>
              <textarea class="cs-input cs-textarea" id={`f-msg-${project.slug}`} name="message" rows="3" placeholder={`Similar goals to this project? Tell us the situation.`} required></textarea>
            </div>
            <button type="submit" class="cs-submit">
              Send brief
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <p class="cs-form-footer">4-hour reply · Fixed-scope quote · No retainer required · <a href="/privacy-policy/">Privacy policy</a></p>
          </form>
        </div>

        <div class="cs-links-panel">
          {(project.relatedServices?.length || project.relatedIndustries?.length) && (
            <div class="cs-lp-block">
              <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Services behind this project</p>
              <div class="cs-link-list">
                {project.relatedServices?.map((href) => (
                  <a href={href} class="cs-link-row">
                    <div>
                      <span class="cs-lr-tag">Service</span>
                      <span class="cs-lr-name">{href.replace('/services/', '').replace(/\/$/, '').replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</span>
                    </div>
                    <svg width="10" height="10" viewBox="0 0 11 11" fill="none" aria-hidden="true" class="cs-lr-arrow"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
                {project.relatedIndustries?.map((href) => (
                  <a href={href} class="cs-link-row">
                    <div>
                      <span class="cs-lr-tag">Industry page</span>
                      <span class="cs-lr-name">{href.replace('/industries/', '').replace(/\/$/, '').replace(/-website-design/, '').replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())} Website Design</span>
                    </div>
                    <svg width="10" height="10" viewBox="0 0 11 11" fill="none" aria-hidden="true" class="cs-lr-arrow"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
              </div>
            </div>
          )}
          {related.length > 0 && (
            <div class="cs-lp-block">
              <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>Similar projects</p>
              <div class="cs-link-list">
                {related.map((p) => (
                  <a href={`/work/${p.slug}/`} class="cs-link-row">
                    <div>
                      <span class="cs-lr-tag">{p.vertical} · {p.timeline}</span>
                      <span class="cs-lr-name">{p.name}</span>
                    </div>
                    <svg width="10" height="10" viewBox="0 0 11 11" fill="none" aria-hidden="true" class="cs-lr-arrow"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

      </div>
    </section>

    <!-- ════════════════════════════════════════
         MORE PROJECTS
    ════════════════════════════════════════ -->
    <section class="cs-more">
      <div class="container">
        <div class="cs-more-head">
          <p class="cs-eyebrow"><span class="cs-eyebrow-line" aria-hidden="true"></span>More work</p>
          <h2 class="cs-section-h2">Other projects <em>in the archive.</em></h2>
        </div>
        <div class="cs-more-grid">
          {moreProjects.map((p) => (
            <a href={`/work/${p.slug}/`} class="cs-more-card">
              <div class="cs-mc-top">
                <span class="cs-mc-vertical">{p.vertical}</span>
                <span class="cs-mc-budget">{p.budget}</span>
              </div>
              <h3 class="cs-mc-name">{p.name}</h3>
              <p class="cs-mc-headline">{p.headline}</p>
              <div class="cs-mc-metrics">
                {p.metrics.slice(0, 2).map((m) => (
                  <div class="cs-mc-metric">
                    <span class="cs-mc-val">{m.after}</span>
                    <span class="cs-mc-label">{m.label}</span>
                  </div>
                ))}
              </div>
              <span class="cs-mc-cta">Read case study →</span>
            </a>
          ))}
        </div>
        <div class="cs-more-footer">
          <a href="/work/" class="cs-more-all">View all case studies →</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

