}
.cs-si-name { font-family: var(--f-mono); font-size: 12px; font-weight: 600; color: var(--ink); display: block; }
.cs-si-tag { font-family: var(--f-mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-muted); font-weight: 500; display: block; margin-top: 2px; }

.cs-built-facts { display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-top: 16px; }
.cs-bf-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: var(--paper); border-bottom: 1px solid var(--line); }
.cs-bf-row:last-child { border-bottom: none; }
.cs-bf-key { font-family: var(--f-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); font-weight: 600; }
.cs-bf-val { font-size: 13px; font-weight: 500; color: var(--ink); }

/* ─── CLIENT KEYWORD DEMAND ──────────────────────── */
.cs-demand {
  background: var(--ink); padding: clamp(52px, 7vh, 80px) 0;
  position: relative; overflow: hidden;
}
.cs-demand::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(212,147,46,0.3), transparent);
}
.cs-demand-inner { display: grid; grid-template-columns: 360px 1fr; gap: clamp(28px, 5vw, 64px); align-items: start; }
.cs-demand-left { display: flex; flex-direction: column; gap: 12px; }
.cs-demand-h2 {
  font-family: var(--f-display); font-weight: 500;
  font-size: clamp(24px, 3vw, 34px); line-height: 1.15; letter-spacing: -0.025em;
  color: var(--cream); margin: 0;
}
.cs-demand-h2 em { font-style: italic; font-weight: 300; color: var(--amber); }
.cs-demand-sub { font-size: 14px; line-height: 1.65; color: rgba(244,239,230,0.5); margin: 0; }

.cs-demand-total {
  display: flex; align-items: baseline; gap: 10px;
  padding: 18px 20px; background: rgba(212,147,46,0.1);
  border: 1px solid rgba(212,147,46,0.25); border-radius: 16px; margin-top: 6px;
}
.cs-demand-total-num { font-family: var(--f-display); font-size: clamp(36px, 4.5vw, 52px); font-weight: 700; color: var(--amber); letter-spacing: -0.04em; line-height: 1; }
.cs-demand-total-label { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(244,239,230,0.55); line-height: 1.5; font-weight: 600; }

.cs-kw-grid { display: flex; flex-direction: column; gap: 8px; }
.cs-kw-card {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 14px 16px; background: rgba(244,239,230,0.04);
  border: 1px solid rgba(244,239,230,0.09); border-radius: 14px;
  transition: all 0.25s ease;
}
.cs-kw-card:hover { background: rgba(244,239,230,0.07); border-color: rgba(212,147,46,0.3); transform: translateX(4px); }
.cs-kw-intent-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.cs-kw-intent-local .cs-kw-intent-dot { background: var(--amber); }
.cs-kw-intent-commercial .cs-kw-intent-dot { background: #7ec87e; }
.cs-kw-intent-informational .cs-kw-intent-dot { background: #7eb4e8; }

.cs-kw-body { flex: 1; display: flex; flex-direction: column; gap: 5px; }
.cs-kw-term { font-size: 13.5px; color: rgba(244,239,230,0.8); font-weight: 500; line-height: 1.35; }
.cs-kw-stats { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.cs-kw-vol { font-family: var(--f-mono); font-size: 10px; color: var(--amber); font-weight: 700; }
.cs-kw-cpc { font-family: var(--f-mono); font-size: 10px; color: rgba(244,239,230,0.38); }
.cs-kw-badge {
  font-family: var(--f-mono); font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 2px 7px; border-radius: 999px; font-weight: 600;
}
.cs-kw-intent-local .cs-kw-badge { background: rgba(212,147,46,0.15); color: var(--amber); }
.cs-kw-intent-commercial .cs-kw-badge { background: rgba(126,200,126,0.15); color: #7ec87e; }
.cs-kw-intent-informational .cs-kw-badge { background: rgba(126,180,232,0.15); color: #7eb4e8; }

.cs-kw-note { font-family: var(--f-mono); font-size: 9px; color: rgba(244,239,230,0.3); letter-spacing: 0.08em; margin-top: 8px; }

/* ─── ROI BAND ───────────────────────────────────── */
.cs-roi {
  background: var(--ink); padding: clamp(64px, 9vh, 96px) 0;
  position: relative; overflow: hidden;
  border-top: 1px solid rgba(244,239,230,0.08);
}
.cs-roi-orb {
  position: absolute; width: 640px; height: 640px; top: -220px; left: -150px;
  background: radial-gradient(circle, rgba(212,147,46,0.12) 0%, transparent 58%);
  filter: blur(50px); pointer-events: none;
}
.cs-roi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 5vw, 64px); align-items: center; position: relative; z-index: 1; }
.cs-roi-h2 { font-family: var(--f-display); font-weight: 500; font-size: clamp(24px, 3vw, 34px); line-height: 1.15; letter-spacing: -0.025em; color: var(--cream); margin: 8px 0 0; }
.cs-roi-h2 em { font-style: italic; font-weight: 300; color: var(--amber); }
.cs-roi-sub { font-size: 14px; line-height: 1.65; color: rgba(244,239,230,0.5); margin: 10px 0 0; max-width: 50ch; }
.cs-roi-btn {
  display: inline-flex; align-items: center; margin-top: 18px;
  padding: 12px 22px; background: var(--amber); color: var(--ink);
  border-radius: 14px; font-size: 14px; font-weight: 600; text-decoration: none; transition: background 0.2s ease;
}
.cs-roi-btn:hover { background: var(--amber-deep); }
.cs-roi-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.cs-roi-metric {
  padding: 20px 18px; background: rgba(244,239,230,0.05);
  border: 1px solid rgba(244,239,230,0.09); border-radius: 16px;
  display: flex; flex-direction: column; gap: 5px;
  transition: all 0.25s ease;
}
.cs-roi-metric:hover { background: rgba(244,239,230,0.08); border-color: rgba(212,147,46,0.25); }
.cs-roi-after { font-family: var(--f-display); font-size: clamp(24px, 3vw, 34px); font-weight: 600; color: var(--amber); letter-spacing: -0.03em; line-height: 1; }
.cs-roi-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(244,239,230,0.45); font-weight: 600; }
.cs-roi-delta { display: inline-flex; align-self: flex-start; padding: 2px 8px; background: rgba(212,147,46,0.18); color: var(--amber); border-radius: 999px; font-family: var(--f-mono); font-size: 10px; font-weight: 700; margin-top: 2px; }

/* ─── CTA BLOCK ──────────────────────────────────── */
.cs-cta-block { background: var(--cream); padding: clamp(64px, 9vh, 96px) 0; border-bottom: 1px solid var(--line); }
.cs-cta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 5vw, 56px); align-items: start; }

.cs-form-card { background: var(--ink); border-radius: 22px; padding: 30px 26px; position: relative; overflow: hidden; }
.cs-form-stripe { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--amber), var(--amber-deep), transparent); }
.cs-form-title { font-family: var(--f-display); font-size: clamp(22px, 2.8vw, 30px); font-weight: 500; letter-spacing: -0.025em; color: var(--cream); margin: 8px 0 4px; line-height: 1.2; }
.cs-form-sub { font-size: 13.5px; line-height: 1.6; color: rgba(244,239,230,0.5); margin: 0 0 18px; }
.cs-form { display: flex; flex-direction: column; gap: 10px; }
.cs-form-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.cs-field { display: flex; flex-direction: column; gap: 5px; }
.cs-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(244,239,230,0.5); font-weight: 600; }
.cs-input { padding: 10px 13px; background: rgba(244,239,230,0.06); border: 1px solid rgba(244,239,230,0.14); border-radius: 12px; font-family: var(--f-body); font-size: 13.5px; color: var(--cream); transition: border-color 0.2s, box-shadow 0.2s; }
.cs-input::placeholder { color: rgba(244,239,230,0.3); }
.cs-input:focus { outline: none; border-color: var(--amber); box-shadow: 0 0 0 3px rgba(212,147,46,0.18); }
.cs-textarea { resize: vertical; min-height: 80px; font-family: var(--f-body); }
.cs-submit { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 20px; background: var(--amber); color: var(--ink); border: none; border-radius: 14px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; margin-top: 4px; }
.cs-submit:hover { background: var(--amber-deep); }
.cs-form-footer { font-size: 10.5px; line-height: 1.5; color: rgba(244,239,230,0.38); text-align: center; margin: 4px 0 0; }
.cs-form-footer a { color: var(--amber); text-decoration: underline; text-underline-offset: 2px; }

.cs-links-panel { display: flex; flex-direction: column; gap: 22px; }
.cs-lp-block { display: flex; flex-direction: column; gap: 8px; }
.cs-link-list { display: flex; flex-direction: column; gap: 6px; margin-top: 6px; }
.cs-link-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 13px 15px; background: var(--paper); border: 1.5px solid var(--line); border-radius: 14px; text-decoration: none; color: inherit; transition: all 0.25s ease; }
.cs-link-row:hover { border-color: var(--amber); transform: translateX(3px); }
