.cs-phase-sub { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(244,239,230,0.4); margin-top: 2px; }

.cs-phase-steps {
  display: flex; flex-direction: column; gap: 0;
  border: 1px solid rgba(244,239,230,0.08); border-top: none;
  border-radius: 0 0 16px 16px; overflow: hidden;
  background: rgba(15,20,25,0.96);
}
.cs-phase-step {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 16px 18px; border-bottom: 1px solid rgba(244,239,230,0.06);
  transition: background 0.2s ease;
}
.cs-phase-step:last-child { border-bottom: none; }
.cs-phase-step:hover { background: rgba(212,147,46,0.06); }
.cs-ps-icon {
  width: 28px; height: 28px; flex-shrink: 0; border-radius: 8px;
  background: rgba(212,147,46,0.1); color: var(--amber);
  display: flex; align-items: center; justify-content: center; margin-top: 1px;
}
.cs-ps-text { font-size: 13.5px; line-height: 1.62; color: rgba(244,239,230,0.62); margin: 0; }

.cs-phase-connector {
  width: 100%; padding: 0; margin: 12px 0; opacity: 0.9;
}

/* ─── DELIVERABLES + STACK ────────────────────────── */
.cs-built {
  background: var(--cream); padding: clamp(52px, 7vh, 80px) 0;
  border-bottom: 1px solid var(--line);
}
.cs-built-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 5vw, 64px); align-items: start; }

.cs-deliver-list { list-style: none; padding: 0; margin: 14px 0 0; display: flex; flex-direction: column; gap: 8px; }
.cs-deliver-item {
  display: grid; grid-template-columns: 26px 1fr; gap: 10px; align-items: flex-start;
  padding: 12px 14px; background: var(--paper); border: 1.5px solid var(--line);
  border-radius: 14px; font-size: 14px; line-height: 1.5; color: var(--ink-soft);
  transition: border-color 0.2s ease;
}
.cs-deliver-item:hover { border-color: var(--amber); }
.cs-deliver-check {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(92,128,64,0.12); color: #4a7a28;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}

.cs-stack-list { display: flex; flex-direction: column; gap: 8px; margin: 14px 0 0; }
.cs-stack-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; background: var(--paper); border: 1.5px solid var(--line);
  border-radius: 14px; transition: all 0.2s ease;
}
.cs-stack-item:hover { border-color: var(--amber); transform: translateX(4px); }
.cs-si-icon {
  width: 32px; height: 32px; flex-shrink: 0; border-radius: 10px;
