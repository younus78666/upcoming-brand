---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import BottomFormCTA from '../../components/BottomFormCTA.astro';
import { projects, type Project } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

interface Props { project: Project; }
const { project } = Astro.props;
const canonical = `https://upcomingbrand.com/work/${project.slug}/`;

const related = projects.filter((p) => p.filter === project.filter && p.slug !== project.slug).slice(0, 3);
const otherProjects = projects.filter((p) => p.slug !== project.slug && p.filter !== project.filter).slice(0, 3);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${canonical}#article`,
      "headline": `${project.name}: ${project.headline}`,
      "description": project.summary,
      "author": { "@id": "https://upcomingbrand.com/#organization" },
      "publisher": { "@id": "https://upcomingbrand.com/#organization" },
      "datePublished": "2026-05-03",
      "dateModified": "2026-05-03",
      "mainEntityOfPage": { "@id": `${canonical}#webpage` }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": `${project.name} | Case Study | Upcoming Brand`,
      "description": project.summary,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Portfolio",  "item": "https://upcomingbrand.com/work/" },
          { "@type": "ListItem", "position": 3, "name": project.name, "item": canonical }
        ]
      }
    }
  ]
});

const sidebarFormId = `cs-sidebar-${project.slug}`;
---
<BaseLayout
  title={`${project.name}: ${project.headline} | Case Study | Upcoming Brand`}
  description={project.summary}
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLd} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- HERO (full width) -->
    <section class="cs-hero">
      <div class="container">
        <div class="cs-hero-inner">
          <a href="/work/" class="cs-back">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            All projects
          </a>
          <div class="cs-meta">
            <span class="cs-vertical-pill">{project.vertical}</span>
            <span class="cs-timeline">{project.timeline}</span>
          </div>
          <h1 class="cs-h1">{project.name}</h1>
          <p class="cs-headline"><em>{project.headline}</em></p>
          <p class="cs-summary">{project.summary}</p>
        </div>
      </div>
    </section>

    <!-- METRICS BAND (full width) -->
    <section class="cs-metrics">
      <div class="container">
        <div class="cs-metrics-head">
          <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Results</p>
          <h2 class="cs-h2">Measured outcome <em>after launch.</em></h2>
        </div>
        <div class="cs-metrics-grid">
          {project.metrics.map((m) => (
            <div class="cs-metric">
              <span class="cs-metric-label">{m.label}</span>
              <div class="cs-metric-numbers">
                <span class="cs-metric-before">{m.before}</span>
                <span class="cs-metric-arrow" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                <span class="cs-metric-after">{m.after}</span>
              </div>
              {m.delta && <span class="cs-metric-delta">{m.delta}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BODY: 2-col with sticky sidebar -->
    <section class="cs-body">
      <div class="container cs-body-grid">

        <!-- ===== SIDEBAR ===== -->
        <aside class="cs-sidebar">

          <!-- Form card -->
          <div class="cs-side-card cs-side-form">
            <div class="cs-side-form-stripe" aria-hidden="true"></div>
            <span class="cs-side-eyebrow">Want similar work?</span>
            <h3 class="cs-side-title">Want to build a similar project?</h3>
            <p class="cs-side-sub">Tell us about your situation. 4-hour reply, no sales pitch.</p>
            <form class="cs-side-formel" id={sidebarFormId} name={`work-${project.slug}-sidebar`} method="POST" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
              <input type="hidden" name="form-name" value={`work-${project.slug}-sidebar`} />
              <input type="hidden" name="reference_project" value={project.slug} />
              <div class="cs-side-hp" aria-hidden="true"><label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
              <div class="cs-side-row">
                <label class="cs-side-label" for={`${sidebarFormId}-name`}>Your name</label>
                <input class="cs-side-input" type="text" id={`${sidebarFormId}-name`} name="name" placeholder="Jane Smith" required autocomplete="name" />
              </div>
              <div class="cs-side-row">
                <label class="cs-side-label" for={`${sidebarFormId}-email`}>Email</label>
                <input class="cs-side-input" type="email" id={`${sidebarFormId}-email`} name="email" placeholder="jane@company.com" required autocomplete="email" />
              </div>
              <div class="cs-side-row">
                <label class="cs-side-label" for={`${sidebarFormId}-message`}>What is the project?</label>
                <textarea class="cs-side-input cs-side-textarea" id={`${sidebarFormId}-message`} name="message" rows="3" placeholder={`Similar to ${project.name}, but for...`} required></textarea>
              </div>
              <button type="submit" class="cs-side-submit">
                Send brief
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <p class="cs-side-note">By sending, you agree to our <a href="/privacy-policy/">privacy policy</a>.</p>
            </form>
          </div>

          <!-- Project facts -->
          <div class="cs-side-card">
            <span class="cs-side-eyebrow">Project at a glance</span>
            <dl class="cs-side-facts">
              <div class="cs-side-fact">
                <dt>Vertical</dt>
                <dd>{project.vertical}</dd>
              </div>
              <div class="cs-side-fact">
                <dt>Client size</dt>
                <dd>{project.client.size}</dd>
              </div>
              <div class="cs-side-fact">
                <dt>Market</dt>
                <dd>{project.client.market}</dd>
              </div>
              <div class="cs-side-fact">
                <dt>Timeline</dt>
                <dd>{project.timeline}</dd>
              </div>
              <div class="cs-side-fact">
                <dt>Investment</dt>
                <dd>{project.budget}</dd>
              </div>
            </dl>
          </div>

          <!-- Related projects -->
          {related.length > 0 && (
            <div class="cs-side-card">
              <span class="cs-side-eyebrow">Similar projects</span>
              <ul class="cs-side-list">
                {related.map((p) => (
                  <li>
                    <a href={`/work/${p.slug}/`} class="cs-side-link">
                      <span class="cs-side-link-name">{p.name}</span>
                      <span class="cs-side-link-meta">{p.vertical} · {p.timeline}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

        </aside>

        <!-- ===== MAIN COLUMN ===== -->
        <div class="cs-main">

          <!-- Challenge -->
          <div class="cs-block cs-challenge">
            <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Challenge</p>
            <h2 class="cs-h2">Where the project started.</h2>
            <p class="cs-block-text">{project.challenge}</p>
          </div>

          <!-- Approach -->
          <div class="cs-block cs-approach">
            <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Approach</p>
            <h2 class="cs-h2">How we shipped it.</h2>
            <ol class="cs-approach-list">
              {project.approach.map((step, i) => (
                <li class="cs-approach-item">
                  <span class="cs-approach-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="cs-approach-text">{step}</span>
                </li>
              ))}
            </ol>
          </div>

          <!-- Deliverables + Tech -->
          <div class="cs-block cs-spec">
            <div class="cs-spec-grid">
              <div class="cs-spec-col">
                <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Deliverables</p>
                <h2 class="cs-h2">What was delivered.</h2>
                <ul class="cs-spec-list">
                  {project.deliverables.map((d) => (
                    <li class="cs-spec-item">
                      <span class="cs-spec-check" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                      {d}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="cs-spec-col">
                <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Tech stack</p>
                <h2 class="cs-h2">What it runs on.</h2>
                <div class="cs-tech-stack">
                  {project.techStack.map((t) => <span class="cs-tech-pill">{t}</span>)}
                </div>
              </div>
            </div>
          </div>

          <!-- Testimonial -->
          <div class="cs-block cs-testimonial-block">
            <svg class="cs-quote-mark" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <path d="M12 28v-8c0-4 2-6 6-7l1 2c-3 1-4 2-4 4h3v9h-6zm14 0v-8c0-4 2-6 6-7l1 2c-3 1-4 2-4 4h3v9h-6z" fill="currentColor"/>
            </svg>
            <blockquote class="cs-quote">{project.testimonial.quote}</blockquote>
            <cite class="cs-cite">— {project.testimonial.role}, {project.client.type}</cite>
          </div>

          <!-- Related Services + Industries (inline in main col) -->
          {(project.relatedServices?.length || project.relatedIndustries?.length) && (
            <div class="cs-block cs-related-pages-block">
              <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>Want similar work?</p>
              <h2 class="cs-h2">Services that <em>shipped this project.</em></h2>
              <div class="cs-related-grid">
                {project.relatedServices?.map((href) => (
                  <a href={href} class="cs-related-card">
                    <span class="cs-related-tag">Service</span>
                    <span class="cs-related-name">{href.replace('/services/', '').replace(/\/$/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                    <span class="cs-related-arrow"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                  </a>
                ))}
                {project.relatedIndustries?.map((href) => (
                  <a href={href} class="cs-related-card">
                    <span class="cs-related-tag">Industry</span>
                    <span class="cs-related-name">{href.replace('/industries/', '').replace(/\/$/, '').replace(/-website-design/, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
                    <span class="cs-related-arrow"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

      </div>
    </section>

    <!-- MORE PROJECTS (full width below) -->
    <section class="cs-more">
      <div class="container">
        <div class="cs-related-head">
          <p class="cs-section-eyebrow"><span class="cs-section-eyebrow-line"></span>More work</p>
          <h2 class="cs-h2">Other projects <em>in the archive.</em></h2>
        </div>
        <div class="cs-more-grid">
          {[...related, ...otherProjects].slice(0, 3).map((p) => (
            <a href={`/work/${p.slug}/`} class="cs-more-card">
              <div class="cs-more-meta">
                <span class="cs-more-vertical">{p.vertical}</span>
                <span class="cs-more-timeline">{p.timeline}</span>
              </div>
              <h3 class="cs-more-name">{p.name}</h3>
              <p class="cs-more-headline">{p.headline}</p>
              <span class="cs-more-cta">Read case study <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
  <BottomFormCTA formName={`work-${project.slug}-cta`} heading="Want a project like this?" sub="Tell us about your situation. We map your competitive set and send a fixed-scope quote within 48 hours." />
  <Footer />
</BaseLayout>

<style>
  .cs-section-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); margin: 0; font-weight: 500; }
  .cs-section-eyebrow-line { display: inline-block; width: 32px; height: 1px; background: var(--amber); }
  .cs-h2 { font-family: var(--f-display); font-weight: 400; font-size: clamp(24px, 3vw, 34px); line-height: 1.15; letter-spacing: -0.025em; color: var(--ink); margin: 12px 0 0; }
  .cs-h2 em { font-style: italic; font-weight: 300; color: var(--amber-deep); }

  /* ===== HERO ===== */
  .cs-hero { background: var(--cream); padding: clamp(48px, 7vh, 88px) 0 clamp(40px, 6vh, 64px); border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
  .cs-hero::before { content: ""; position: absolute; top: -300px; right: -200px; width: 700px; height: 700px; background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%); pointer-events: none; }
  .cs-hero-inner { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
  .cs-back { display: inline-flex; align-items: center; gap: 6px; font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); text-decoration: none; transition: color 0.2s ease; align-self: flex-start; }
  .cs-back:hover { color: var(--amber-deep); }
  .cs-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .cs-vertical-pill { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); padding: 4px 12px; background: rgba(212,147,46,0.1); border-radius: var(--radius-pill); font-weight: 600; }
  .cs-timeline { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); padding: 4px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-pill); }
  .cs-h1 { font-family: var(--f-display); font-weight: 500; font-size: clamp(30px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.025em; color: var(--ink); margin: 4px 0 0; }
  .cs-headline { font-family: var(--f-display); font-size: clamp(18px, 2vw, 22px); line-height: 1.4; color: var(--amber-deep); margin: 0; font-weight: 300; }
  .cs-headline em { font-style: italic; }
  .cs-summary { font-size: clamp(15px, 1.2vw, 17px); line-height: 1.6; color: var(--ink-soft); margin: 0; max-width: 64ch; }

  /* ===== METRICS ===== */
  .cs-metrics { background: var(--ink); color: var(--cream); padding: clamp(56px, 8vh, 88px) 0; position: relative; overflow: hidden; border-bottom: 1px solid var(--line); }
  .cs-metrics::before { content: ""; position: absolute; top: -200px; left: -100px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(212,147,46,0.1) 0%, transparent 60%); pointer-events: none; }
  .cs-metrics-head { text-align: center; max-width: 720px; margin: 0 auto 36px; display: flex; flex-direction: column; align-items: center; gap: 8px; position: relative; z-index: 1; }
  .cs-metrics-head .cs-h2 { color: var(--cream); }
  .cs-metrics-head .cs-h2 em { color: var(--amber); }
  .cs-metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }
  .cs-metric { padding: 22px 20px; background: rgba(244,239,230,0.04); border: 1px solid rgba(244,239,230,0.12); border-radius: var(--radius-md); display: flex; flex-direction: column; gap: 8px; }
  .cs-metric-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(244,239,230,0.6); font-weight: 600; }
  .cs-metric-numbers { display: flex; align-items: baseline; gap: 8px; }
  .cs-metric-before { font-family: var(--f-mono); font-size: 13px; color: rgba(244,239,230,0.5); text-decoration: line-through; }
  .cs-metric-arrow { color: var(--amber); display: inline-flex; }
  .cs-metric-after { font-family: var(--f-display); font-size: 24px; line-height: 1; font-weight: 600; color: var(--amber); letter-spacing: -0.02em; }
  .cs-metric-delta { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; color: var(--cream); padding: 3px 8px; background: rgba(212,147,46,0.18); border-radius: var(--radius-pill); align-self: flex-start; font-weight: 600; }

  /* ===== BODY 2-COL ===== */
  .cs-body { background: var(--cream); padding: clamp(48px, 6vh, 80px) 0; border-bottom: 1px solid var(--line); }
  .cs-body-grid { display: grid; grid-template-columns: 320px 1fr; gap: clamp(24px, 4vw, 56px); align-items: start; }

  /* SIDEBAR */
  .cs-sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 24px; align-self: start; }
  .cs-side-card { background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-lg); padding: 22px 22px; position: relative; overflow: hidden; }
  .cs-side-form { background: var(--ink); color: var(--cream); border-color: var(--amber); padding: 24px 22px; }
  .cs-side-form-stripe { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent 0%, var(--amber) 30%, var(--amber-deep) 70%, transparent 100%); }
  .cs-side-eyebrow { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600; }
  .cs-side-form .cs-side-eyebrow { color: var(--amber); }
  .cs-side-title { font-family: var(--f-display); font-size: 20px; line-height: 1.2; letter-spacing: -0.02em; color: var(--ink); margin: 4px 0 6px; font-weight: 500; }
  .cs-side-form .cs-side-title { color: var(--cream); }
  .cs-side-sub { font-size: 12.5px; line-height: 1.5; color: rgba(244,239,230,0.7); margin: 0 0 14px; }
  .cs-side-formel { display: flex; flex-direction: column; gap: 10px; }
  .cs-side-hp { position: absolute; left: -10000px; }
  .cs-side-row { display: flex; flex-direction: column; gap: 4px; }
  .cs-side-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(244,239,230,0.65); font-weight: 600; }
  .cs-side-input { padding: 9px 12px; background: rgba(244,239,230,0.06); border: 1px solid rgba(244,239,230,0.18); border-radius: var(--radius-md); font-family: var(--f-body); font-size: 13.5px; color: var(--cream); transition: border-color 0.2s ease, box-shadow 0.2s ease; }
  .cs-side-input::placeholder { color: rgba(244,239,230,0.4); }
  .cs-side-input:focus { outline: none; border-color: var(--amber); box-shadow: 0 0 0 3px rgba(212,147,46,0.22); background: rgba(244,239,230,0.09); }
  .cs-side-textarea { resize: vertical; min-height: 70px; font-family: var(--f-body); }
  .cs-side-submit { display: inline-flex; align-items: center; justify-content: center; gap: 7px; width: 100%; padding: 11px 14px; background: var(--amber); color: var(--ink); border: none; border-radius: var(--radius-md); font-family: var(--f-body); font-size: 13.5px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; margin-top: 4px; }
  .cs-side-submit:hover { background: var(--amber-deep); }
  .cs-side-note { font-size: 10.5px; line-height: 1.45; color: rgba(244,239,230,0.5); margin: 8px 0 0; text-align: center; }
  .cs-side-note a { color: var(--amber); text-decoration: underline; text-underline-offset: 2px; }

  .cs-side-facts { display: flex; flex-direction: column; gap: 10px; margin: 12px 0 0; }
  .cs-side-fact { display: grid; grid-template-columns: 1fr auto; gap: 12px; padding-bottom: 10px; border-bottom: 1px dashed var(--line); }
  .cs-side-fact:last-child { border-bottom: none; padding-bottom: 0; }
  .cs-side-fact dt { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); font-weight: 600; }
  .cs-side-fact dd { font-size: 12.5px; color: var(--ink); margin: 0; text-align: right; font-weight: 500; }

  .cs-side-list { list-style: none; padding: 0; margin: 12px 0 0; display: flex; flex-direction: column; gap: 4px; }
  .cs-side-link { display: flex; flex-direction: column; gap: 3px; padding: 10px 12px; background: var(--cream); border: 1px solid var(--line); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: all 0.2s ease; }
  .cs-side-link:hover { border-color: var(--amber); transform: translateX(2px); }
  .cs-side-link-name { font-family: var(--f-display); font-size: 14px; line-height: 1.25; color: var(--ink); font-weight: 500; }
  .cs-side-link-meta { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); }

  /* MAIN COL */
