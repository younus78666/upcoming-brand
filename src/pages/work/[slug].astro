.cs-browser-body-after { background: #0F1419; padding: 0; min-height: 260px; }
.cs-mockup-after { padding: 16px; display: flex; flex-direction: column; gap: 12px; min-height: 260px; }
.cs-ma-nav { display: flex; align-items: center; justify-content: space-between; }
.cs-ma-logo { width: 80px; height: 18px; background: rgba(212,147,46,0.4); border-radius: 4px; }
.cs-ma-nav-links { display: flex; align-items: center; gap: 8px; }
.cs-ma-nav-link { width: 36px; height: 8px; background: rgba(244,239,230,0.15); border-radius: 4px; }
.cs-ma-cta-btn { width: 56px; height: 22px; background: var(--amber); border-radius: 6px; opacity: 0.8; }
.cs-ma-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; padding: 12px 0; }
.cs-ma-hero-left { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.cs-ma-h1 { width: 75%; height: 16px; background: rgba(244,239,230,0.7); border-radius: 4px; }
.cs-ma-sub { width: 90%; height: 7px; background: rgba(244,239,230,0.25); border-radius: 4px; }
