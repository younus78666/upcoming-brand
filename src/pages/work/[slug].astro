.cs-ma-btns { display: flex; gap: 6px; margin-top: 4px; }
.cs-ma-btn-primary { width: 72px; height: 22px; background: var(--amber); border-radius: 6px; opacity: 0.9; }
.cs-ma-btn-ghost { width: 64px; height: 22px; border: 1px solid rgba(244,239,230,0.25); border-radius: 6px; }
.cs-ma-hero-score { position: relative; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.cs-ma-score-ring { position: relative; display: flex; align-items: center; justify-content: center; }
.cs-ma-score-num {
  position: absolute; font-family: var(--f-display); font-size: 14px; font-weight: 700;
  color: var(--amber); letter-spacing: -0.03em;
}
.cs-ma-score-label { font-family: var(--f-mono); font-size: 7.5px; color: rgba(244,239,230,0.4); text-transform: uppercase; letter-spacing: 0.08em; }
.cs-ma-content { margin-top: auto; }
.cs-ma-services { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
.cs-ma-service-card { background: rgba(244,239,230,0.05); border: 1px solid rgba(244,239,230,0.1); border-radius: 6px; padding: 8px; }
.cs-ma-svc-icon { width: 18px; height: 18px; background: rgba(212,147,46,0.2); border-radius: 4px; margin-bottom: 5px; }
.cs-ma-svc-label { font-family: var(--f-mono); font-size: 7px; color: rgba(244,239,230,0.45); line-height: 1.3; display: block; }

/* Arrow between mockups */
.cs-screens-arrow {
  display: flex; flex-direction: column; align-items: center; gap: 0;
  width: 64px; flex-shrink: 0;
}
.cs-sa-line { flex: 1; width: 1px; min-height: 40px; background: linear-gradient(180deg, transparent, rgba(212,147,46,0.3), transparent); }
.cs-sa-icon { flex-shrink: 0; }

/* ─── TRANSFORMATION METRICS ─────────────────────── */
.cs-transform {
  background: var(--paper); padding: clamp(52px, 7vh, 80px) 0;
  border-bottom: 1px solid var(--line);
}
.cs-transform-head { text-align: center; max-width: 600px; margin: 0 auto 36px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
.cs-tf-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.cs-tf-card {
  background: var(--cream); border: 1.5px solid var(--line); border-radius: 20px;
  padding: 20px 18px; display: flex; flex-direction: column; gap: 10px;
  transition: all 0.3s ease; position: relative; overflow: hidden;
}
.cs-tf-card-hero { background: var(--ink); border-color: rgba(212,147,46,0.35); }
.cs-tf-card:hover { border-color: var(--amber); transform: translateY(-3px); box-shadow: 0 10px 32px rgba(212,147,46,0.1); }

.cs-tf-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); font-weight: 600; }
.cs-tf-card-hero .cs-tf-label { color: rgba(244,239,230,0.5); }

.cs-tf-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.cs-tf-before, .cs-tf-after { display: flex; flex-direction: column; gap: 2px; }
.cs-tf-tag { font-family: var(--f-mono); font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; }
.cs-tf-tag { color: var(--ink-muted); }
.cs-tf-tag-after { color: var(--amber-deep); }
.cs-tf-card-hero .cs-tf-tag { color: rgba(244,239,230,0.38); }
.cs-tf-card-hero .cs-tf-tag-after { color: var(--amber); }

.cs-tf-val { font-family: var(--f-display); letter-spacing: -0.025em; line-height: 1.05; }
.cs-tf-val-before { font-size: clamp(15px, 1.8vw, 20px); color: var(--ink-muted); text-decoration: line-through; text-decoration-thickness: 1px; font-weight: 400; }
.cs-tf-val-after { font-size: clamp(20px, 2.4vw, 28px); color: var(--ink); font-weight: 600; }
.cs-tf-card-hero .cs-tf-val-before { color: rgba(244,239,230,0.28); }
.cs-tf-card-hero .cs-tf-val-after { color: var(--amber); }

.cs-tf-arrow-wrap { color: var(--amber); flex-shrink: 0; }
.cs-tf-card-hero .cs-tf-arrow-wrap { color: rgba(212,147,46,0.6); }

.cs-tf-delta {
  display: inline-flex; align-self: flex-start; padding: 3px 9px;
  background: rgba(92,128,64,0.12); color: #4a7a28;
  border-radius: 999px; font-family: var(--f-mono); font-size: 10px; font-weight: 700;
}
.cs-tf-card-hero .cs-tf-delta { background: rgba(212,147,46,0.2); color: var(--amber); }

/* ─── CHALLENGE ──────────────────────────────────── */
.cs-challenge {
  background: var(--cream); padding: clamp(52px, 7vh, 80px) 0;
  border-bottom: 1px solid var(--line);
}
.cs-challenge-grid { display: grid; grid-template-columns: 1fr 360px; gap: clamp(28px, 5vw, 64px); align-items: center; }
.cs-challenge-text { display: flex; flex-direction: column; gap: 14px; }
.cs-client-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px; }
.cs-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 12px; background: var(--paper); border: 1px solid var(--line); border-radius: 999px;
  font-size: 12px; color: var(--ink-soft); transition: border-color 0.2s ease;
}
.cs-chip:hover { border-color: var(--amber); }
.cs-chip svg { color: var(--amber-deep); flex-shrink: 0; }

.cs-testimonial-card {
  background: var(--ink); border-radius: 22px; padding: 30px 26px;
  display: flex; flex-direction: column; gap: 10px;
  position: relative; overflow: hidden;
  box-shadow: 0 20px 52px rgba(15,20,25,0.22);
}
.cs-tc-accent {
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, transparent, var(--amber), transparent);
}
.cs-tc-quote { color: rgba(212,147,46,0.35); flex-shrink: 0; }
.cs-tc-text { font-family: var(--f-display); font-size: clamp(15px, 1.8vw, 20px); line-height: 1.52; color: var(--cream); font-style: italic; font-weight: 400; margin: 0; }
.cs-tc-cite { font-style: normal; display: flex; flex-direction: column; gap: 2px; }
.cs-tc-role { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber); font-weight: 700; }
.cs-tc-company { font-size: 12px; color: rgba(244,239,230,0.45); }

/* ─── APPROACH — 3-PHASE ─────────────────────────── */
.cs-approach {
  background: var(--paper); padding: clamp(52px, 7vh, 80px) 0;
  border-bottom: 1px solid var(--line);
}
.cs-approach-head { max-width: 680px; margin-bottom: 40px; display: flex; flex-direction: column; gap: 8px; }
.cs-approach-sub { font-size: 14.5px; line-height: 1.7; color: var(--ink-muted); margin: 6px 0 0; max-width: 56ch; }

.cs-phases-track {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 0; position: relative;
}
.cs-phase-col { position: relative; padding: 0 24px 0 0; }
.cs-phase-col:last-child { padding-right: 0; }

.cs-phase-header {
  display: flex; align-items: center; gap: 14px;
  padding: 18px 20px; background: var(--ink); border-radius: 16px 16px 0 0;
  border: 1px solid rgba(244,239,230,0.1); border-bottom: none;
  margin-bottom: 0;
}
.cs-phase-num-wrap {
  width: 40px; height: 40px; border-radius: 50%;
