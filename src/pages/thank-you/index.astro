---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const canonical = "https://upcomingbrand.com/thank-you/";

const FORM_LABELS: Record<string, string> = {
  'contact':                    'Your contact inquiry',
  'hero-inquiry':               'Your homepage inquiry',
  'bottom-cta':                 'Your inquiry',
  'tools-cta':                  'Your tool request',
  'services-cta':               'Your services inquiry',
  'pricing-cta':                'Your pricing inquiry',
  'reviews-cta':                'Your inquiry',
  'about-cta':                  'Your inquiry',
  'work-cta':                   'Your portfolio inquiry',
  'industries-cta':             'Your industry inquiry',
  'locations-cta':              'Your location inquiry',
  'process-cta':                'Your process inquiry',
  'team-cta':                   'Your inquiry',
  'careers-cta':                'Your application',
  'discovery-call':             'Your discovery call request',
  'hire-designer':              'Your hire-a-designer inquiry',
  'wp-agency-cta':              'Your WordPress agency inquiry',
  'accountant-inquiry':         'Your accountant-website inquiry',
  'church-inquiry':             'Your church-website inquiry',
  'contractor-inquiry':         'Your contractor-website inquiry',
  'dental-inquiry':             'Your dental-website inquiry',
  'ec-inquiry':                 'Your ecommerce inquiry',
  'gym-inquiry':                'Your gym-website inquiry',
  'lawfirm-inquiry':            'Your law-firm inquiry',
  'medical-inquiry':            'Your medical-website inquiry',
  'nonprofit-inquiry':          'Your nonprofit-website inquiry',
  'realestate-inquiry':         'Your real-estate inquiry',
  'restaurant-inquiry':         'Your restaurant-website inquiry',
  'smallbiz-inquiry':           'Your small-business inquiry',
};
const formLabelsJson = JSON.stringify(FORM_LABELS);

// Hand-picked reviews for the thank-you page (high-trust, varied industries, recent)
const featuredReviews = [
  {
    quote: "We were ranking page 4 for our most important keyword. Three months after launch we hit Local Pack #1 and it has not budged. The discovery call alone was worth more than two prior agency engagements.",
    name: "Margaret Coleman",
    role: "Managing Partner",
    company: "Coleman & Reyes Law",
    location: "Bethesda, MD",
    initials: "MC",
  },
  {
    quote: "Old site was on Squarespace with no schema and no Local Pack visibility. New WordPress site ranks Local Pack for two practice-area searches in my submarket. ROI was clear within four months.",
    name: "Mei-Lin Chen",
    role: "Partner",
    company: "Chen Business Law",
    location: "Bethesda, MD",
    initials: "MLC",
  },
  {
    quote: "I was a solo practitioner with a freelancer-built site that took 11 seconds to load on mobile. New site loads instantly, ranks for my target city + practice area, and the intake form is converting around 6 percent.",
    name: "Aisha Mansoor",
    role: "Solo Attorney",
    company: "Mansoor Estate Law",
    location: "Silver Spring, MD",
    initials: "AM",
  },
];

// Quick-stats for the trust strip
const stats = [
  { num: "5.0", label: "Average rating",    note: "Across every reviewed project" },
  { num: "90+", label: "Lighthouse",        note: "Contractually delivered" },
  { num: "1 day", label: "Reply time",      note: "Real human, founder-led" },
  { num: "60-90d", label: "Local Pack",     note: "Average ranking timeline" },
];
---
<BaseLayout
  title="Thank you — Upcoming Brand"
  description="Your message landed in our inbox. A real reply is on the way within one business day."
  canonicalUrl={canonical}
  noindex={true}
>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content" class="ty">

    <!-- ============== HERO (DARK / INK) ============== -->
    <section class="ty-hero">
      <div class="ty-hero-glow"></div>
      <div class="ty-container">
        <div class="ty-hero-inner">
          <div class="ty-logo-row">
            <img
              src="/01-header-logo-light-edited.png"
              alt="Upcoming Brand"
              width="180"
              height="48"
              class="ty-logo"
            />
          </div>

          <div class="ty-eyebrow-strip">
            <span class="ty-eyebrow-line"></span>
            <span class="ty-eyebrow-text" id="ty-eyebrow">Message received</span>
            <span class="ty-eyebrow-line"></span>
          </div>

          <h1 class="ty-h1" id="ty-headline">
            <span class="ty-h1-line">Thanks for reaching out.</span>
            <span class="ty-h1-line"><em class="ty-h1-accent">Your message just landed in our inbox.</em></span>
          </h1>

          <p class="ty-lead" id="ty-lead">
            We read every single inquiry personally. No auto-routing. No junior account managers. A real reply with thoughts on your project is on its way.
          </p>

          <div class="ty-pills">
            <div class="ty-pill">
              <span class="ty-pill-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="ty-pill-text">Submission confirmed</span>
            </div>
            <div class="ty-pill">
              <span class="ty-pill-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M1 3l6 4 6-4M1 3v8h12V3M1 3l6 4 6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="ty-pill-text">Confirmation sent to your inbox</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== TRUST STRIP (CREAM-SOFT) ============== -->
    <section class="ty-stats">
      <div class="ty-container">
        <div class="ty-stats-grid">
          {stats.map((s) => (
            <div class="ty-stat">
              <div class="ty-stat-num">{s.num}</div>
              <div class="ty-stat-label">{s.label}</div>
              <div class="ty-stat-note">{s.note}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============== WHAT HAPPENS NEXT (PAPER) ============== -->
    <section class="ty-next">
      <div class="ty-container">
        <div class="ty-section-head">
          <div class="ty-section-eyebrow"><span class="ty-eyebrow-line ty-eyebrow-line-amber"></span><span class="ty-eyebrow-text-amber">The next 24 hours</span></div>
          <h2 class="ty-section-h2">What happens next</h2>
          <p class="ty-section-sub">A clear, predictable process. No surprises.</p>
        </div>

        <ol class="ty-steps">
          <li class="ty-step">
            <span class="ty-step-num">01</span>
            <div class="ty-step-body">
              <h3 class="ty-step-h3">Within one business day</h3>
              <p>You will get a real reply from us with thoughts on your project. Specific. Useful. Not a templated "thanks for reaching out."</p>
            </div>
          </li>
          <li class="ty-step">
            <span class="ty-step-num">02</span>
            <div class="ty-step-body">
              <h3 class="ty-step-h3">If it is a fit, we book a call</h3>
              <p>30-minute discovery call on Zoom or Google Meet. We come prepared with questions specific to your business — not a generic agency pitch deck.</p>
            </div>
          </li>
          <li class="ty-step">
            <span class="ty-step-num">03</span>
            <div class="ty-step-body">
              <h3 class="ty-step-h3">If it is not a fit, we tell you</h3>
              <p>And we point you to someone better suited. No pretending. No sunk-cost agreements. Your time matters.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============== REVIEWS (CREAM) ============== -->
    <section class="ty-reviews">
      <div class="ty-container">
        <div class="ty-section-head">
          <div class="ty-section-eyebrow"><span class="ty-eyebrow-line ty-eyebrow-line-amber"></span><span class="ty-eyebrow-text-amber">5.0 average rating</span></div>
          <h2 class="ty-section-h2">What clients say after working with us</h2>
          <p class="ty-section-sub">Real verified reviews from Maryland businesses we have shipped sites for.</p>
        </div>

        <div class="ty-reviews-grid">
          {featuredReviews.map((r) => (
            <article class="ty-review-card">
              <div class="ty-review-stars" aria-label="5 out of 5 stars">
                <svg width="92" height="16" viewBox="0 0 92 16" fill="none" aria-hidden="true">
                  <g fill="#D4932E"><path d="M8 .8l1.95 4.55L15 5.8l-3.85 3.35L12.3 14 8 11.55 3.7 14l1.15-4.85L1 5.8l5.05-.45L8 .8z"/></g>
                  <g fill="#D4932E" transform="translate(19 0)"><path d="M8 .8l1.95 4.55L15 5.8l-3.85 3.35L12.3 14 8 11.55 3.7 14l1.15-4.85L1 5.8l5.05-.45L8 .8z"/></g>
                  <g fill="#D4932E" transform="translate(38 0)"><path d="M8 .8l1.95 4.55L15 5.8l-3.85 3.35L12.3 14 8 11.55 3.7 14l1.15-4.85L1 5.8l5.05-.45L8 .8z"/></g>
                  <g fill="#D4932E" transform="translate(57 0)"><path d="M8 .8l1.95 4.55L15 5.8l-3.85 3.35L12.3 14 8 11.55 3.7 14l1.15-4.85L1 5.8l5.05-.45L8 .8z"/></g>
                  <g fill="#D4932E" transform="translate(76 0)"><path d="M8 .8l1.95 4.55L15 5.8l-3.85 3.35L12.3 14 8 11.55 3.7 14l1.15-4.85L1 5.8l5.05-.45L8 .8z"/></g>
                </svg>
              </div>
              <blockquote class="ty-review-quote">"{r.quote}"</blockquote>
              <div class="ty-review-author">
                <span class="ty-review-avatar" aria-hidden="true">{r.initials}</span>
                <div class="ty-review-meta">
                  <div class="ty-review-name">{r.name}</div>
                  <div class="ty-review-role">{r.role}, {r.company}</div>
                  <div class="ty-review-loc">{r.location}</div>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="ty-reviews-cta">
          <a href="/reviews/" class="ty-link-amber">
            See all client reviews
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============== EXPLORE (PAPER) ============== -->
    <section class="ty-explore">
      <div class="ty-container">
        <div class="ty-section-head">
          <div class="ty-section-eyebrow"><span class="ty-eyebrow-line ty-eyebrow-line-amber"></span><span class="ty-eyebrow-text-amber">While you wait</span></div>
          <h2 class="ty-section-h2">Browse around</h2>
          <p class="ty-section-sub">Three places worth your time before our reply lands.</p>
        </div>

        <div class="ty-explore-grid">
          <a href="/work/" class="ty-explore-card">
            <div class="ty-explore-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 10l3 3 7-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="ty-explore-card-eyebrow">See</div>
            <div class="ty-explore-card-name">Recent work</div>
            <div class="ty-explore-card-desc">Real projects with real Lighthouse scores and Local Pack rankings.</div>
            <span class="ty-explore-card-cta">View portfolio
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a href="/process/" class="ty-explore-card">
            <div class="ty-explore-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            </div>
            <div class="ty-explore-card-eyebrow">Read</div>
            <div class="ty-explore-card-name">Our process</div>
            <div class="ty-explore-card-desc">Discovery, schema mapping, build, launch, and monthly support — all spelled out.</div>
            <span class="ty-explore-card-cta">See the process
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a href="/tools/schema-generator/" class="ty-explore-card">
            <div class="ty-explore-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.5 6 6 .5-4.5 4 1.5 6L12 15l-5.5 3.5 1.5-6L3.5 8.5l6-.5L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <div class="ty-explore-card-eyebrow">Use</div>
            <div class="ty-explore-card-name">Free schema generator</div>
            <div class="ty-explore-card-desc">Multi-entity LocalBusiness + Service + FAQ schema. AI-assisted polish, no email needed.</div>
            <span class="ty-explore-card-cta">Open the tool
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============== DIRECT CONTACT (DARK / INK) ============== -->
    <section class="ty-direct">
      <div class="ty-container">
        <div class="ty-direct-card">
          <div class="ty-direct-eyebrow">Anything urgent?</div>
          <h2 class="ty-direct-h2">Reach us directly.</h2>
          <p class="ty-direct-sub">If your project is time-sensitive or you have a specific question, the founder is one email away.</p>

          <div class="ty-direct-actions">
            <a href="mailto:hello@upcomingbrand.com" class="ty-btn ty-btn-amber">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 3l6 4 6-4M1 3v8h12V3M1 3l6 4 6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              hello@upcomingbrand.com
            </a>
            <a href="/contact/" class="ty-btn ty-btn-ghost">
              Send another message
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div class="ty-direct-hours">
            <span class="ty-dot"></span>
            <span>Replies within 1 business day · Mon-Fri, 9 AM-6 PM ET</span>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <script is:inline define:vars={{ formLabelsJson }}>
    (function(){
      var FORM_LABELS = JSON.parse(formLabelsJson);
      var params = new URLSearchParams(window.location.search);
      var first = (params.get('name') || '').trim();
      var formName = (params.get('form') || '').trim();
      if(first){
        var safe = first.replace(/[<>&]/g, '');
        var h1 = document.getElementById('ty-headline');
        if(h1){
          h1.innerHTML =
            '<span class="ty-h1-line">Thanks, ' + safe + '.</span>' +
            '<span class="ty-h1-line"><em class="ty-h1-accent">Your message just landed in our inbox.</em></span>';
        }
      }
      if(formName && FORM_LABELS[formName]){
        var eb = document.getElementById('ty-eyebrow');
        if(eb) eb.textContent = FORM_LABELS[formName] + ' is in';
      }
    })();
  </script>
</BaseLayout>

<style>
  /* ===== Shared ===== */
  .ty { --ty-max: 1080px; }
  .ty-container {
    max-width: var(--ty-max);
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 32px);
  }

  .ty-eyebrow-strip {
    display: inline-flex; align-items: center; gap: 14px;
    flex-wrap: nowrap; justify-content: center;
    width: 100%;
  }
  .ty-eyebrow-line {
    display: inline-block; width: 48px; height: 1px;
    background: rgba(244,239,230,0.4); flex-shrink: 0;
  }
  .ty-eyebrow-line-amber { background: var(--amber); }
  .ty-eyebrow-text {
    font-family: var(--f-mono); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(244,239,230,0.85); font-weight: 500; white-space: nowrap;
  }
  .ty-eyebrow-text-amber {
    font-family: var(--f-mono); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--amber-deep); font-weight: 500; white-space: nowrap;
  }

  .ty-section-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .ty-section-eyebrow {
    display: inline-flex; align-items: center; gap: 14px;
    margin-bottom: 16px;
  }
  .ty-section-h2 {
    font-family: var(--f-display); font-weight: 500;
    font-size: clamp(28px, 4vw, 42px); line-height: 1.1;
    letter-spacing: -0.025em; color: var(--ink);
    margin: 0 0 12px;
  }
  .ty-section-sub {
    font-size: clamp(15px, 1.2vw, 17px); line-height: 1.6;
    color: var(--ink-muted); margin: 0;
  }

  .ty-link-amber {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--f-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--amber-deep); font-weight: 600;
    text-decoration: none;
    padding: 12px 18px;
    border: 1.5px solid var(--amber);
    border-radius: var(--radius-pill);
    transition: all 0.25s ease;
    background: transparent;
  }
  .ty-link-amber:hover {
    background: var(--amber);
    color: var(--ink);
  }

  /* ===== HERO (DARK) ===== */
  .ty-hero {
    position: relative;
    background: var(--ink);
    color: var(--cream);
    padding: clamp(72px, 10vh, 132px) 0 clamp(72px, 10vh, 120px);
    overflow: hidden;
    text-align: center;
  }
  .ty-hero-glow {
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 900px; height: 900px;
    background: radial-gradient(circle, rgba(212,147,46,0.15) 0%, transparent 60%);
    pointer-events: none;
  }
  .ty-hero-inner {
    position: relative; z-index: 1;
    max-width: 720px; margin: 0 auto;
    display: flex; flex-direction: column;
    align-items: center; gap: 20px;
  }
  .ty-logo-row { margin-bottom: 4px; }
  .ty-logo {
    max-width: 180px; height: auto;
    opacity: 0.95;
  }
  .ty-h1 {
    font-family: var(--f-display); font-weight: 500;
    font-size: clamp(34px, 5.5vw, 60px); line-height: 1.04;
    letter-spacing: -0.03em;
    display: flex; flex-direction: column; gap: 4px;
    margin: 8px 0 0; text-align: center;
  }
  .ty-h1-line { display: block; color: var(--cream); }
  .ty-h1-accent { font-style: italic; font-weight: 300; color: var(--amber); }
  .ty-lead {
    font-size: clamp(15px, 1.2vw, 17px); line-height: 1.65;
    color: rgba(244,239,230,0.78);
    max-width: 56ch; margin: 4px auto 0;
  }
  .ty-pills {
    display: flex; flex-wrap: wrap; gap: 10px;
    justify-content: center; margin-top: 24px;
  }
  .ty-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px;
    background: rgba(244,239,230,0.06);
    border: 1px solid rgba(244,239,230,0.16);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono); font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--cream);
    backdrop-filter: blur(6px);
  }
  .ty-pill-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--amber); color: var(--ink);
  }
  .ty-pill-text { font-weight: 500; }

  /* ===== STATS (CREAM-SOFT) ===== */
  .ty-stats {
    background: var(--cream-soft);
    padding: clamp(40px, 6vh, 56px) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .ty-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }
  .ty-stat {
    text-align: center;
    padding: 14px 12px;
    border-right: 1px dashed var(--line);
  }
  .ty-stat:last-child { border-right: none; }
  .ty-stat-num {
    font-family: var(--f-display); font-weight: 500;
    font-size: clamp(28px, 3.5vw, 40px); line-height: 1;
    letter-spacing: -0.02em;
    color: var(--amber-deep);
    margin-bottom: 6px;
  }
  .ty-stat-label {
    font-family: var(--f-mono); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink); font-weight: 600;
    margin-bottom: 4px;
  }
  .ty-stat-note {
    font-size: 12px; color: var(--ink-muted);
    line-height: 1.4;
  }

  /* ===== WHAT HAPPENS NEXT (PAPER) ===== */
  .ty-next {
    background: var(--paper);
    padding: clamp(64px, 9vh, 100px) 0;
  }
  .ty-steps {
    list-style: none; padding: 0; margin: 0;
    max-width: 880px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 16px;
  }
  .ty-step {
    display: flex; gap: 22px; align-items: flex-start;
    padding: 26px 28px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
  }
  .ty-step:hover {
    border-color: var(--amber);
    transform: translateX(2px);
    box-shadow: 0 6px 20px rgba(212,147,46,0.08);
  }
  .ty-step-num {
    font-family: var(--f-mono); font-size: 12px;
    font-weight: 700; letter-spacing: 0.08em;
    color: var(--amber-deep);
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 7px 11px; border-radius: 6px;
    flex-shrink: 0;
  }
  .ty-step-body { flex: 1; }
  .ty-step-h3 {
    font-family: var(--f-display); font-size: 18px;
    font-weight: 600; color: var(--ink);
    margin: 0 0 6px; letter-spacing: -0.01em;
  }
  .ty-step-body p {
    margin: 0; font-size: 14px; line-height: 1.65;
