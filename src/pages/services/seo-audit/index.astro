---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/services/seo-audit/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "SEO Audit Service | Technical SEO Audit & Local SEO Audit | Upcoming Brand",
      "description": "Senior SEO audit service: technical SEO audit, schema audit, Core Web Vitals audit, content gap analysis, and local SEO audit. Prioritised action list. Fixed-scope $1,500. Audit fee credited toward implementation.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",   "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "SEO Audit",  "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "SEO Audit Service",
      "description": "Senior SEO audit service covering technical SEO, schema, Core Web Vitals, content, and local SEO. Delivered as a prioritised action list. Fixed-scope $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "SEO audit",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "SEO audit",
        "SEO audit service",
        "SEO audit services",
        "Technical SEO audit",
        "Local SEO audit",
        "Website SEO audit",
        "WordPress SEO audit",
        "Site audit",
        "SEO audit report",
        "SEO audit checklist",
        "SEO audit cost",
        "Schema audit",
        "Core Web Vitals audit"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to run an SEO audit",
      "description": "The five-phase SEO audit methodology covering technical SEO, schema, Core Web Vitals, content, and local SEO.",
      "totalTime": "P5D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Crawl and inventory", "text": "Full site crawl (Screaming Frog or Sitebulb), URL inventory, indexation status, and Search Console performance baseline." },
        { "@type": "HowToStep", "position": 2, "name": "Technical SEO check", "text": "Schema validation, canonical tags, robots.txt, sitemap, redirect map, hreflang, broken links, server status codes." },
        { "@type": "HowToStep", "position": 3, "name": "Performance audit",   "text": "Lighthouse + PageSpeed Insights on top 10 pages, Core Web Vitals field data review, image optimization check." },
        { "@type": "HowToStep", "position": 4, "name": "Content + on-page",   "text": "Title tag and meta optimization, heading hierarchy, internal linking analysis, content gap vs top SERP results." },
        { "@type": "HowToStep", "position": 5, "name": "Prioritised action list", "text": "Findings sorted by impact and effort. Top 10 fixes ranked. Delivered as a written report you keep regardless of who implements." }
      ]
    }
  ]
});

const audited = [
  "Site crawl with full URL inventory and indexation status",
  "Technical SEO audit: schema, canonicals, robots.txt, sitemap, hreflang",
  "Core Web Vitals audit on top 10 pages (Lighthouse + field data)",
  "Schema validation against Google Structured Data Testing tool",
  "Title tag and meta description audit across the site",
  "Heading hierarchy and on-page content structure",
  "Internal linking strategy and topical authority gaps",
  "Image optimization, alt text, and page weight analysis",
  "Local SEO audit: GBP, citations, NAP consistency, Local Pack",
  "Content gap analysis vs top SERP competitors",
  "Backlink profile review and toxic link check",
  "Search Console performance data and ranking baseline",
];

const tiers = [
  {
    name: "Standard",
    price: "$1,500",
    duration: "5-7 business days",
    summary: "Comprehensive SEO audit covering technical, on-page, schema, performance, and content. Delivered as a prioritised action list.",
    fits: ["Sites under 200 pages", "First SEO audit", "Pre-redesign baseline"],
    href: "/contact/?plan=audit-standard",
    highlight: true,
  },
  {
    name: "Technical",
    price: "$2,500",
    duration: "7-10 business days",
    summary: "Deep technical SEO audit with site crawl analysis, schema deep-dive, Core Web Vitals on every key page, log file review.",
    fits: ["Sites 200-2,000 pages", "Migration prep", "Lost-rankings diagnosis"],
    href: "/contact/?plan=audit-technical",
  },
  {
    name: "Enterprise",
    price: "From $4,500",
    duration: "2-3 weeks",
    summary: "Enterprise audit for large sites: multi-language, multi-region, complex catalogs, log files, and JS rendering deep-dives.",
    fits: ["Sites 2,000+ pages", "International / multi-language", "Complex JS frameworks"],
    href: "/contact/?plan=audit-enterprise",
  },
];

const whenAudit = [
  { num: "01", signal: "Rankings dropped and you don't know why",  detail: "Common after migrations, redesigns, or Google updates. An SEO audit identifies the exact cause and provides a prioritised fix list." },
  { num: "02", signal: "Site looks great, ranks for nothing",        detail: "Beautiful design, empty Search Console. Almost always means missing schema, weak Core Web Vitals, or no internal linking strategy." },
  { num: "03", signal: "Pre-redesign / pre-migration baseline",      detail: "Before redesigning or migrating, audit the existing site so you can validate post-launch that you didn't lose anything." },
  { num: "04", signal: "Inheriting a site from another developer",   detail: "If the previous developer skipped schema, broke redirects, or shipped 40+ active plugins, an audit surfaces what needs fixing first." },
  { num: "05", signal: "Local Pack rankings disappeared",             detail: "Local SEO audit checks GBP, citations, NAP consistency, schema, and local landing pages to identify why you fell out." },
  { num: "06", signal: "You want a take-it-anywhere fix list",       detail: "Sometimes you don't want a full implementation engagement. The audit alone gives you a prioritised list any developer can execute." },
];

const auditVsFree = [
  { factor: "Depth",            free: "Plugin scan: 10-20 surface-level checks", paid: "Senior auditor: 100+ checks across 5 dimensions" },
  { factor: "Schema",           free: "Generic warnings, no fix recommendations", paid: "Validated against vertical-specific requirements with code-ready fixes" },
  { factor: "Performance",      free: "Single Lighthouse score reproduced",       paid: "Lighthouse + field data + image and asset audit on top 10 pages" },
  { factor: "Content + content gap", free: "Skipped entirely",                    paid: "Top SERP competitor analysis + gap inventory" },
  { factor: "Action list",      free: "PDF list ranked by automation, not impact", paid: "Prioritised by impact x effort with implementation notes" },
  { factor: "Local SEO",        free: "Skipped or generic",                       paid: "GBP, citations, NAP, Local Pack composition fully audited" },
];

const faqs = [
  {
    q: "What is an SEO audit?",
    a: "An SEO audit is a comprehensive review of a website's ability to rank in search engines. A quality SEO audit covers five dimensions: technical SEO (schema, canonicals, sitemaps, robots.txt), on-page SEO (titles, meta, headings, internal linking), Core Web Vitals (Lighthouse, page speed, image optimization), content (gap analysis vs competitors), and local SEO (GBP, citations, NAP consistency). The output is a prioritised action list ranked by impact and effort.",
  },
  {
    q: "How much does an SEO audit cost?",
    a: "Quality SEO audit services run $1,500 to $5,000+ depending on site size and complexity. Standard audits for sites under 200 pages run $1,500-$2,500. Technical audits with deep crawl analysis on sites 200-2,000 pages run $2,500-$4,500. Enterprise audits for sites with 2,000+ pages, multiple languages, or complex JS frameworks start at $4,500. Hourly SEO consultant rates run $80-$300/hr; the better firms have moved to fixed-scope.",
  },
  {
    q: "Are free SEO audits worth anything?",
    a: "Free SEO audits are usually plugin scans (Ubersuggest, Neil Patel, SEMrush free tier, HubSpot Website Grader) that surface 10-20 surface-level checks. They identify obvious issues like missing meta descriptions or broken canonicals but skip the things that actually move rankings: schema architecture, Core Web Vitals deep-dive, content gaps, internal linking strategy, and Local Pack composition. Useful as a free starting point. Not a substitute for a real audit.",
  },
  {
    q: "What's the difference between a technical SEO audit and a regular SEO audit?",
    a: "A regular SEO audit covers all five dimensions (technical, on-page, performance, content, local) at sufficient depth. A technical SEO audit focuses just on the technical layer: deep crawl analysis, server log review, schema deep-dive, JavaScript rendering analysis, hreflang validation, redirect chain analysis. Technical audits are typically commissioned when a site has dropped rankings and the owner suspects technical issues, not content issues.",
  },
  {
    q: "How long does an SEO audit take?",
    a: "Standard audits take 5-7 business days from kickoff to delivery. Technical audits take 7-10 business days. Enterprise audits take 2-3 weeks. The variable is site size: a 50-page site can be fully audited in 3 days; a 5,000-page enterprise site with multi-language requires significantly more crawl time and analysis. We commit to a delivery date in the SOW; if we miss it, we credit 10% of the audit fee.",
  },
  {
    q: "Do I have to implement the audit findings with you?",
    a: "No. The audit is a standalone deliverable: a written report with prioritised action items you can take to any developer. We sell the audit at $1,500 specifically as a take-it-anywhere starting point. If you do want us to implement, the $1,500 audit fee is credited toward the implementation engagement (Standard SEO services start at $3,500). About 60% of audit clients return for implementation; 40% take the report to their existing team.",
  },
  {
    q: "Can you audit a WordPress site specifically?",
    a: "Yes. WordPress SEO audits are a significant portion of our audit work. We dive deeper on WordPress-specific issues: plugin bloat, theme schema gaps, RankMath / Yoast configuration, custom post type SEO, page builder code soup, and WooCommerce schema if applicable. WordPress SEO audits are scoped at the same $1,500 standard rate; if your site has more than 200 pages or complex WooCommerce, we'll quote the Technical or Enterprise tier.",
  },
];
---
<BaseLayout
  title="SEO Audit Service | Technical SEO Audit | Upcoming Brand"
  description="Technical SEO audit: schema, Core Web Vitals, content gaps, and local SEO. Prioritised action list. Fixed-scope $1,500, credited toward implementation."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='SEO audit service'
      pillText='SEO Audits · Maryland'
      h1Lines={[
        { text: 'SEO audit service' },
        { text: 'from a senior auditor', type: 'accent' },
        { text: 'who actually fixes things.', type: 'italic' },
      ]}
      lead='A real <strong>SEO audit service</strong> covering technical SEO, schema, Core Web Vitals, content, and local SEO. Delivered as a prioritised action list, not a 60-page PDF nobody reads. <strong>Fixed-scope $1,500.</strong> Audit fee credited toward implementation if you come back. Better than any free SEO audit tool.'
      formName='seo-audit-inquiry'
      trustLines={['From $1,500 fixed-scope', '5-day delivery', 'Take-it-anywhere fix list']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'What we will audit.',
          fields: [
            { type: 'url',  name: 'site_url',     label: 'Site URL to audit', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
            { type: 'select', name: 'platform', label: 'Site platform', required: true,
              options: ['WordPress', 'Shopify', 'Webflow', 'Squarespace', 'Wix', 'Custom / Headless', 'Other'] },
          ],
        },
        {
          title: 'Site size',
          subtitle: 'Page count and current rankings.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
              options: ['Under 25 pages', '25 to 100 pages', '100 to 500 pages', '500 to 5,000 pages', '5,000+ pages', 'Not sure'] },
            { type: 'select', name: 'monthly_traffic', label: 'Monthly organic visitors', required: true,
              options: ['Under 500', '500 to 5,000', '5,000 to 50,000', '50,000+', 'Not sure'] },
          ],
        },
        {
          title: 'Audit focus',
          subtitle: 'What problem you want solved.',
          fields: [
            { type: 'select', name: 'audit_focus', label: 'Primary audit focus', required: true,
              options: ['Full technical + content audit', 'Technical / Core Web Vitals only', 'Schema architecture', 'Content / on-page only', 'Local SEO audit', 'Pre-migration audit', 'Not sure, recommend'] },
            { type: 'textarea', name: 'message', label: 'What is going wrong?', placeholder: 'Traffic dropped, rankings stuck, recent algo hit.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- DEFINITION -->
    <section class="aud-define">
      <div class="container">
        <div class="aud-define-card">
          <div class="aud-define-head">
            <span class="aud-define-pulse" aria-hidden="true"></span>
            <span class="aud-define-label">Executive Summary</span>
          </div>
          <h2 class="page-h2 aud-define-h2">
            What is an SEO audit?
          </h2>
          <p class="aud-define-answer">
            <strong>An SEO audit is a comprehensive review of a website's ability to rank in search engines.</strong> Quality SEO audit services cover five dimensions: technical SEO (schema, canonicals, sitemaps, robots.txt), on-page SEO (titles, meta, headings, internal linking), Core Web Vitals (Lighthouse, page speed, asset optimization), content (gap analysis vs competitors), and local SEO (GBP, citations, NAP, Local Pack composition). The output is a prioritised action list ranked by impact and effort, delivered as a written report you keep regardless of who implements.
          </p>
          <div class="aud-define-meta">
            <div class="aud-define-meta-item">
              <span class="aud-define-meta-label">Investment</span>
              <span class="aud-define-meta-val">$1,500 (Standard) to $5,000+ (Enterprise)</span>
            </div>
            <div class="aud-define-meta-item">
              <span class="aud-define-meta-label">Delivery</span>
              <span class="aud-define-meta-val">5-7 business days for standard audit</span>
            </div>
            <div class="aud-define-meta-item">
              <span class="aud-define-meta-label">Output</span>
              <span class="aud-define-meta-val">Prioritised action list, take-it-anywhere</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT WE AUDIT -->
    <section class="aud-includes">
      <div class="container">
        <div class="aud-includes-head">
          <p class="aud-section-eyebrow">
            <span class="aud-section-eyebrow-line"></span>
            What we audit
          </p>
          <h2 class="page-h2">
            Twelve checks <em>across five dimensions.</em>
          </h2>
          <p class="page-section-lead">Technical, on-page, performance, content, and local. Each delivered with code-ready fix recommendations, not just warnings.</p>
        </div>

        <div class="aud-includes-grid">
          {audited.map((item, i) => (
            <div class="aud-include">
              <span class="aud-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="aud-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="aud-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TIERS -->
    <section class="aud-tiers" id="tiers">
      <div class="container">
        <div class="aud-tiers-head">
          <p class="aud-section-eyebrow">
            <span class="aud-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>SEO audit packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="aud-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`aud-tier ${t.highlight ? 'aud-tier-highlight' : ''}`}>
              {t.highlight && <span class="aud-tier-flag">Most chosen</span>}
              <span class="aud-tier-name">{t.name}</span>
              <span class="aud-tier-price">{t.price}</span>
              <span class="aud-tier-duration">{t.duration}</span>
              <p class="aud-tier-summary">{t.summary}</p>
              <div class="aud-tier-fits">
                <span class="aud-tier-fits-label">Fits</span>
                <ul class="aud-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="aud-tier-cta">
                Book {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHEN -->
    <section class="aud-when">
      <div class="container">
        <div class="aud-when-head">
          <p class="aud-section-eyebrow">
            <span class="aud-section-eyebrow-line"></span>
            When you need one
          </p>
          <h2 class="page-h2">
            Six signals <em>your site needs an SEO audit.</em>
          </h2>
        </div>

        <div class="aud-when-grid">
          {whenAudit.map((w) => (
            <article class="aud-when-card">
              <span class="aud-when-num">{w.num}</span>
              <h3 class="aud-when-signal">{w.signal}</h3>
              <p class="aud-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON: paid vs free -->
    <section class="aud-compare">
      <div class="container">
        <div class="aud-compare-head">
          <p class="aud-section-eyebrow">
            <span class="aud-section-eyebrow-line"></span>
            Paid vs free SEO audits
          </p>
          <h2 class="page-h2">
            What a paid SEO audit covers <em>that free SEO audit tools skip.</em>
          </h2>
        </div>

        <div class="aud-compare-table-wrap">
          <table class="aud-compare-table">
            <thead>
              <tr>
                <th class="aud-compare-th-factor">Audit dimension</th>
                <th class="aud-compare-th-free">Free SEO audit tool</th>
                <th class="aud-compare-th-paid">
                  <span class="aud-compare-amber-pill">Paid audit</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {auditVsFree.map((c) => (
                <tr>
                  <td class="aud-compare-factor">{c.factor}</td>
                  <td class="aud-compare-free">
                    <span class="aud-compare-icon-no" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </span>
                    {c.free}
                  </td>
                  <td class="aud-compare-paid">
                    <span class="aud-compare-icon-yes" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {c.paid}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="aud-faq">
      <div class="container">
        <div class="aud-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">SEO audit FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 aud-faq-h2">
            Seven questions <em>before you book.</em>
          </h2>
        </div>

        <div class="aud-faq-list">
          {faqs.map((f, i) => (
            <details class="aud-faq-item">
              <summary class="aud-faq-q">
                <span class="aud-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="aud-faq-q-text">{f.q}</span>
                <span class="aud-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="aud-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
</main>
  <BottomFormCTA formName="seo-audit-cta" 
    formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'What we will audit.',
          fields: [
            { type: 'url',  name: 'site_url',     label: 'Site URL to audit', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
            { type: 'select', name: 'platform', label: 'Site platform', required: true,
              options: ['WordPress', 'Shopify', 'Webflow', 'Squarespace', 'Wix', 'Custom / Headless', 'Other'] },
          ],
        },
        {
          title: 'Site size',
          subtitle: 'Page count and current rankings.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
              options: ['Under 25 pages', '25 to 100 pages', '100 to 500 pages', '500 to 5,000 pages', '5,000+ pages', 'Not sure'] },
            { type: 'select', name: 'monthly_traffic', label: 'Monthly organic visitors', required: true,
              options: ['Under 500', '500 to 5,000', '5,000 to 50,000', '50,000+', 'Not sure'] },
          ],
        },
        {
          title: 'Audit focus',
          subtitle: 'What problem you want solved.',
          fields: [
            { type: 'select', name: 'audit_focus', label: 'Primary audit focus', required: true,
              options: ['Full technical + content audit', 'Technical / Core Web Vitals only', 'Schema architecture', 'Content / on-page only', 'Local SEO audit', 'Pre-migration audit', 'Not sure, recommend'] },
            { type: 'textarea', name: 'message', label: 'What is going wrong?', placeholder: 'Traffic dropped, rankings stuck, recent algo hit.', required: true, rows: 2 },
          ],
        },
      ]}
  />

  <Footer />
</BaseLayout>

<style>
  .page-hero { background: var(--cream); border-bottom: 1px solid var(--line); padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px); position: relative; overflow: hidden; text-align: center; }
  .page-hero::before { content: ""; position: absolute; top: -300px; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%); pointer-events: none; }
  .page-hero-inner { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 28px; }
  .page-eyebrow-strip { display: inline-flex; align-items: center; gap: 14px; flex-wrap: nowrap; justify-content: center; }
  .page-eyebrow-line { display: inline-block; width: 48px; height: 1px; background: var(--amber); flex-shrink: 0; }
