---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-security/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Security Service | Malware Removal & Hardening | Upcoming Brand",
      "description": "WordPress security service from a senior security expert. WordPress malware removal, site hardening, firewall setup, security audits. Emergency hacked site recovery in 24-48 hours. Fixed-scope from $750.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                 "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",             "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Security",   "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Security Service",
      "description": "Senior WordPress security service covering site hardening, WordPress malware removal, firewall configuration, security audits, and 24-48 hour hacked site recovery. Fixed-scope from $750.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress security",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "750",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress security",
        "WordPress security service",
        "WordPress security expert",
        "WordPress malware removal",
        "Remove malware WordPress",
        "WordPress hacked",
        "WordPress site hacked",
        "Fix hacked WordPress site",
        "WordPress malware scanner",
        "WordPress firewall",
        "WordPress hardening",
        "WordPress security audit",
        "WordPress security check",
        "WordPress site security",
        "Secure WordPress site",
        "WordPress security best practices",
        "WordPress vulnerability"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to secure a WordPress site",
      "description": "The five-phase WordPress security methodology covering audit, hardening, malware scan, firewall setup, and ongoing monitoring.",
      "totalTime": "P5D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Security audit",        "text": "WPScan vulnerability check, plugin and theme version review, file integrity scan, user permission audit, and Search Console security warnings review." },
        { "@type": "HowToStep", "position": 2, "name": "Site hardening",         "text": "Disable file editing, enforce strong passwords, lock down /wp-admin, change wp-config salts, restrict XML-RPC, and remove unused plugins and themes." },
        { "@type": "HowToStep", "position": 3, "name": "Malware scan and clean", "text": "Deep server-side malware scan via Wordfence or MalCare. Quarantine and remove malicious files. Clean injected database content. Verify against Google Safe Browsing." },
        { "@type": "HowToStep", "position": 4, "name": "Firewall + 2FA",          "text": "Cloudflare WAF or Wordfence firewall configuration, two-factor authentication for admins, login attempt limits, and geo-blocking high-risk regions." },
        { "@type": "HowToStep", "position": 5, "name": "Monitoring + reports",    "text": "Daily file integrity scans, uptime monitoring, weekly security reports, and 24-hour incident response retainer for ongoing engagements." }
      ]
    }
  ]
});

const secured = [
  "Vulnerability scan via WPScan + plugin and theme version audit",
  "wp-config.php hardening: salt rotation, file editing disabled, debug off",
  "Login security: 2FA enforcement, failed login limits, /wp-admin lockdown",
  "Database hardening: prefix change, user permission audit, query monitoring",
  "File integrity baseline + daily scan via Wordfence or MalCare",
  "Web Application Firewall: Cloudflare WAF or Wordfence Premium config",
  "Malware scan: server-side, deep, with quarantine and clean process",
  "XML-RPC restriction or full disable based on REST API requirements",
  "User role audit: stale admins removed, role-based capability review",
  "SSL / TLS configuration: HSTS, secure headers, CSP baseline",
  "Backup verification: off-site daily backups tested for restore",
  "Search Console security: Safe Browsing status + manual action review",
];

const tiers = [
  {
    name: "Audit",
    price: "$750",
    duration: "3 business days",
    summary: "WordPress security audit only. Vulnerability scan, hardening checklist, malware screen, prioritised fix list. Take to any developer.",
    fits: ["Sites under 50 pages", "Pre-launch baseline", "Take-it-anywhere fix list"],
    href: "/contact/?plan=security-audit",
  },
  {
    name: "Standard",
    price: "$1,500",
    duration: "5-7 business days",
    summary: "Full WordPress security hardening: audit plus implementation. Site hardening, malware scan, firewall setup, 2FA, monitoring baseline. 30-day post-launch monitoring included.",
    fits: ["Sites under 200 pages", "Marketing sites", "First serious security sprint"],
    href: "/contact/?plan=security-standard",
    highlight: true,
  },
  {
    name: "Recovery",
    price: "From $750",
    duration: "24-48 hours",
    summary: "Emergency WordPress malware removal and hacked site recovery. Server-side malware clean, file restoration, Search Console reconsideration request, post-incident hardening.",
    fits: ["Hacked or infected sites", "Google Safe Browsing flagged", "Manual action recovery"],
    href: "/contact/?plan=security-recovery",
  },
];

const whenSecurity = [
  { num: "01", signal: "Site flagged by Google Safe Browsing",    detail: "If your WordPress site shows the red warning in Chrome or Search Console, you have malware or a phishing redirect. Recovery removes the infection and submits the reconsideration request." },
  { num: "02", signal: "Suspicious admin users you don't recognize", detail: "New admin accounts you didn't create are the most common sign of compromise. A WordPress security audit identifies the entry point and locks it down before more damage." },
  { num: "03", signal: "Site running 30+ active plugins",          detail: "Every active plugin is an attack surface. WordPress sites with 30+ plugins have measurably higher breach rates because vulnerable plugins go unpatched. Hardening starts with a plugin audit." },
  { num: "04", signal: "Pre-launch or post-redesign hardening",    detail: "Before going live with a new WordPress site, harden it. Default WordPress installs ship with several settings that are convenient for setup but risky for production. Hardening takes 4 hours, costs $750, prevents most common breaches." },
  { num: "05", signal: "Strange redirects or popups appearing",     detail: "Visitors landing on your homepage but redirected to spam, gambling, or pharma sites means injected JavaScript or .htaccess malware. Server-side malware scan and clean is the only fix; security plugins miss this." },
  { num: "06", signal: "Inheriting a WordPress site",                detail: "If you took over a WordPress site from another developer or agency, run a security audit. Old admin accounts, weak passwords, outdated plugins, and unmonitored backups are the norm, not the exception." },
];

const securityVsPlugin = [
  { factor: "Vulnerability scanning",  free: "Plugin scans local file changes only",                     paid: "WPScan API + manual code review of plugins, themes, and core" },
  { factor: "Malware removal",         free: "Plugin quarantines flagged files, breaks the site",         paid: "Server-side scan, surgical clean, database injection removal, integrity verification" },
  { factor: "Hardening configuration", free: "Generic toggle list",                                        paid: "Per-site hardening: wp-config, .htaccess, file permissions, user roles, capability audit" },
  { factor: "Firewall configuration",  free: "Plugin firewall (server-bypassable)",                        paid: "Cloudflare WAF + Wordfence firewall in tandem, custom rules per site type" },
  { factor: "Hacked site recovery",    free: "Plugin support tells you to pay for premium",                paid: "24-48 hour incident response with reconsideration request and post-incident audit" },
  { factor: "Ongoing monitoring",       free: "Free tier = email alerts, paid tier = real monitoring",       paid: "Daily file integrity, uptime, vulnerability database checks, weekly written report" },
];

const layers = [
  { name: "Hardening",     full: "Site configuration",  detail: "wp-config salts, file editing disabled, /wp-admin restricted, XML-RPC controlled, user role audit, plugin and theme version pinned." },
  { name: "Firewall",      full: "Web Application Firewall", detail: "Cloudflare WAF or Wordfence firewall blocking SQL injection, XSS, brute-force, and known exploit patterns at the edge." },
  { name: "Authentication", full: "Login + access control", detail: "Two-factor authentication for admins, failed login limits, geo-blocking, application passwords for REST API, no shared accounts." },
  { name: "Monitoring",    full: "Detection + alerting", detail: "Daily file integrity scans, malware scanners, uptime monitoring, Search Console security alerts, weekly written reports." },
];

const faqs = [
  {
    q: "What is WordPress security?",
    a: "WordPress security is the practice of preventing, detecting, and responding to attacks against a WordPress site. Quality WordPress security covers four layers: hardening (wp-config, file permissions, user roles, plugin audit), firewall (Cloudflare WAF or Wordfence blocking attacks at the edge), authentication (2FA, failed login limits, geo-blocking), and monitoring (daily integrity scans, malware detection, written reports). The output is a site that resists 99 percent of automated attacks and recovers fast from the rare manual breach.",
  },
  {
    q: "How much does WordPress security cost?",
    a: "Quality WordPress security services run $750 to $5,000+ depending on site complexity. A WordPress security audit alone runs $750 for sites under 50 pages. Standard hardening (audit plus implementation) runs $1,500. Emergency hacked site recovery runs $750 to $2,500 depending on infection depth. Ongoing monitoring runs $150 to $500/mo via care plans. Hourly WordPress security expert rates run $80 to $250/hr.",
  },
  {
    q: "Can a free WordPress security plugin replace a security service?",
    a: "Free WordPress security plugins (Wordfence Free, iThemes Security, All In One WP Security) handle 40 to 60 percent of the work. They scan for known malware signatures, log failed logins, and warn about outdated plugins. They do not perform per-site hardening, configure server-level firewalls, audit user roles for capability creep, or recover hacked sites. Free plugins are useful as a baseline but not a substitute for a real security engagement.",
  },
  {
    q: "How do I know if my WordPress site is hacked?",
    a: "Common signs of a hacked WordPress site include: Google Safe Browsing flag in Search Console, unfamiliar admin users in /wp-admin, strange redirects to spam or pharma sites, popups or ads you did not add, search results showing Japanese or pharma keywords for your domain, sudden traffic drop in Search Console, and unfamiliar files in /wp-content/uploads with .php extensions. If any of these match, do not just install a plugin. Get a real security audit and recovery.",
  },
  {
    q: "How long does WordPress malware removal take?",
    a: "Standard WordPress malware removal takes 24 to 48 hours from kickoff to clean confirmation. Simple infections (single injection, recent breach) clean in 4 to 8 hours. Deep infections (months of compromise, multiple backdoors, database injection) take 48 hours and may require a partial site rebuild. Google Safe Browsing reconsideration adds 1 to 14 days for Google to re-crawl and clear the warning, which is outside our control.",
  },
  {
    q: "Will hardening my WordPress site break it?",
    a: "Done correctly, hardening will not break a WordPress site. Done badly (generic security plugins applying every toggle), hardening can break image uploads, REST API features, page builders, and WooCommerce checkout flows. The difference is per-site testing: every hardening rule we apply is verified on staging before production. The Standard package includes a written changelog so you can revert any specific change if it conflicts with future development.",
  },
  {
    q: "Do you offer ongoing WordPress security monitoring?",
    a: "Yes. The Pro and WooCommerce care plans include daily security monitoring: file integrity scans, malware checks, uptime monitoring, vulnerability database alerts, and weekly written reports. The Essential care plan covers basic monitoring without security focus. Standalone monitoring without a care plan is available at $150/mo with a 12-month minimum. Most clients bundle security with care plans for cost efficiency.",
  },
];
---
<BaseLayout
  title="WordPress Security Service | Malware Removal & Hardening from $750 | Upcoming Brand"
  description="Senior WordPress security service: site hardening, WordPress malware removal, firewall setup, security audits. Emergency hacked site recovery in 24-48 hours. Fixed-scope from $750."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='WordPress security service'
      pillText='WordPress Security · Maryland'
      h1Lines={[
        { text: 'WordPress security service' },
        { text: 'from a senior security expert', type: 'accent' },
        { text: 'who actually removes malware.', type: 'italic' },
      ]}
      lead='<strong>WordPress security service</strong> covering site hardening, <strong>WordPress malware removal</strong>, firewall setup, security audits, and emergency recovery. Hire a <strong>WordPress security expert</strong> who handles all four layers in one engagement. <strong>Fixed-scope from $750. Emergency recovery in 24-48 hours.</strong>'
      formName='wp-security-inquiry'
      trustLines={['From $750 fixed-scope', '24-48 hr emergency recovery', 'Per-site hardening, no plugin defaults']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'What we will secure.',
          fields: [
            { type: 'url',  name: 'site_url', label: 'WordPress site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
            { type: 'select', name: 'security_status', label: 'Current status', required: true,
              options: ['Site is hacked or compromised (urgent)', 'Suspect a breach but not sure', 'Site is fine, want hardening', 'Pre-launch hardening', 'Post-redesign hardening', 'Inheriting site, want audit'] },
          ],
        },
        {
          title: 'Site details',
          subtitle: 'Host, plugin count, and store status.',
          fields: [
            { type: 'select', name: 'current_host', label: 'Current host', required: true,
              options: ['Kinsta', 'WP Engine', 'SiteGround', 'Cloudways', 'Bluehost', 'GoDaddy', 'Hostinger', 'Other / Not sure'] },
            { type: 'select', name: 'plugin_count', label: 'Active plugin count', required: true,
              options: ['Under 10', '10 to 25', '25 to 50', '50+', 'Not sure'] },
          ],
        },
        {
          title: 'Engagement scope',
          subtitle: 'Which package fits and what success looks like.',
          fields: [
            { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
              options: ['Security audit only ($750)', 'Standard hardening ($1,500)', 'Emergency recovery ($750+)', 'Ongoing monitoring + care plan', 'Not sure yet'] },
            { type: 'textarea', name: 'message', label: 'What is happening?', placeholder: 'Hacked, suspect breach, want preventative hardening, recent attack.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- DEFINITION -->
    <section class="sec-define">
      <div class="container">
        <div class="sec-define-card">
          <div class="sec-define-head">
            <span class="sec-define-pulse" aria-hidden="true"></span>
            <span class="sec-define-label">Definition</span>
          </div>
          <h2 class="page-h2 sec-define-h2">
            What is WordPress security?
          </h2>
          <p class="sec-define-answer">
            <strong>WordPress security is the practice of preventing, detecting, and responding to attacks against a WordPress site.</strong> Quality WordPress security services cover four layers: hardening (wp-config, file permissions, user roles, plugin audit), firewall (Cloudflare WAF or Wordfence blocking attacks at the edge), authentication (two-factor authentication, failed login limits, geo-blocking), and monitoring (daily integrity scans, malware detection, written reports). The output is a WordPress site that resists 99 percent of automated attacks and recovers fast from the rare manual breach.
          </p>
          <div class="sec-define-meta">
            <div class="sec-define-meta-item">
              <span class="sec-define-meta-label">Investment</span>
              <span class="sec-define-meta-val">$750 (Audit) to $5,000+ (Recovery)</span>
            </div>
            <div class="sec-define-meta-item">
              <span class="sec-define-meta-label">Delivery</span>
              <span class="sec-define-meta-val">5-7 days standard, 24-48 hr emergency</span>
            </div>
            <div class="sec-define-meta-item">
              <span class="sec-define-meta-label">Outcome</span>
              <span class="sec-define-meta-val">Hardened site, monitored, recoverable</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LAYERS -->
    <section class="sec-layers">
      <div class="container">
        <div class="sec-layers-head">
          <p class="sec-section-eyebrow">
            <span class="sec-section-eyebrow-line"></span>
            Four security layers
          </p>
          <h2 class="page-h2">
            Four layers <em>that stop 99% of WordPress attacks.</em>
          </h2>
          <p class="page-section-lead">WordPress security is not one fix; it is a stack. Each layer catches what the previous layer missed. A single security plugin covers parts of two layers; a real engagement covers all four.</p>
        </div>

        <div class="sec-layers-grid">
          {layers.map((c) => (
            <article class="sec-layer-card">
              <div class="sec-layer-card-head">
                <span class="sec-layer-abbr">{c.name}</span>
              </div>
              <h3 class="sec-layer-name">{c.full}</h3>
              <p class="sec-layer-detail">{c.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- WHAT WE COVER -->
    <section class="sec-includes">
      <div class="container">
        <div class="sec-includes-head">
          <p class="sec-section-eyebrow">
            <span class="sec-section-eyebrow-line"></span>
            What we cover
          </p>
          <h2 class="page-h2">
            Twelve checks <em>across four security layers.</em>
          </h2>
          <p class="page-section-lead">Hardening, firewall, authentication, and monitoring. Every check is documented in the engagement changelog so future developers know what was changed and why.</p>
        </div>

        <div class="sec-includes-grid">
          {secured.map((item, i) => (
            <div class="sec-include">
              <span class="sec-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="sec-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="sec-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TIERS -->
    <section class="sec-tiers" id="tiers">
      <div class="container">
        <div class="sec-tiers-head">
          <p class="sec-section-eyebrow">
            <span class="sec-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress security packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope. Recovery is priced per incident based on infection depth, with a $750 minimum and a 24-48 hour SLA from confirmation.</p>
        </div>

        <div class="sec-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`sec-tier ${t.highlight ? 'sec-tier-highlight' : ''}`}>
              {t.highlight && <span class="sec-tier-flag">Most chosen</span>}
              <span class="sec-tier-name">{t.name}</span>
              <span class="sec-tier-price">{t.price}</span>
              <span class="sec-tier-duration">{t.duration}</span>
              <p class="sec-tier-summary">{t.summary}</p>
              <div class="sec-tier-fits">
                <span class="sec-tier-fits-label">Fits</span>
                <ul class="sec-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="sec-tier-cta">
                Book {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHEN -->
    <section class="sec-when">
      <div class="container">
        <div class="sec-when-head">
          <p class="sec-section-eyebrow">
            <span class="sec-section-eyebrow-line"></span>
            When you need it
          </p>
          <h2 class="page-h2">
            Six signals <em>your WordPress site needs security work.</em>
          </h2>
        </div>

        <div class="sec-when-grid">
          {whenSecurity.map((w) => (
            <article class="sec-when-card">
              <span class="sec-when-num">{w.num}</span>
              <h3 class="sec-when-signal">{w.signal}</h3>
              <p class="sec-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON -->
    <section class="sec-compare">
      <div class="container">
        <div class="sec-compare-head">
          <p class="sec-section-eyebrow">
            <span class="sec-section-eyebrow-line"></span>
            Paid service vs free WordPress security plugin
          </p>
          <h2 class="page-h2">
            What a paid security engagement covers <em>that a free WordPress security plugin skips.</em>
          </h2>
        </div>

        <div class="sec-compare-table-wrap">
          <table class="sec-compare-table">
            <thead>
              <tr>
                <th class="sec-compare-th-factor">Security area</th>
                <th class="sec-compare-th-free">Free security plugin</th>
                <th class="sec-compare-th-paid">
                  <span class="sec-compare-amber-pill">Paid engagement</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {securityVsPlugin.map((c) => (
                <tr>
                  <td class="sec-compare-factor">{c.factor}</td>
                  <td class="sec-compare-free">
                    <span class="sec-compare-icon-no" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </span>
                    {c.free}
                  </td>
                  <td class="sec-compare-paid">
                    <span class="sec-compare-icon-yes" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {c.paid}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="sec-faq">
      <div class="container">
        <div class="sec-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">WordPress security FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 sec-faq-h2">
            Seven questions <em>before you book.</em>
          </h2>
        </div>

        <div class="sec-faq-list">
          {faqs.map((f, i) => (
            <details class="sec-faq-item">
              <summary class="sec-faq-q">
                <span class="sec-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="sec-faq-q-text">{f.q}</span>
                <span class="sec-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="sec-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Book security work</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            Real WordPress security.<br>
            <em>$750 audit. $1,500 hardening. 24-48 hr recovery.</em>
          </h2>
          <p class="page-cta-lead">If your site is actively hacked, mark it urgent in the form. We respond to emergencies within 4 hours during business days, 8 hours otherwise.</p>
          <div class="page-cta-buttons">
