---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-web-design/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Web Design Services Maryland | Custom WordPress Website Design | Upcoming Brand",
      "description": "Custom WordPress web design services in Maryland. Custom Gutenberg blocks, schema architecture, 90+ Lighthouse, fixed-scope from $1,500. Built for businesses that need to rank, convert, and stay maintainable.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                 "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",             "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Web Design", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "Custom WordPress Web Design",
      "description": "Custom WordPress website design with schema architecture, custom Gutenberg blocks, and 90+ Lighthouse on launch day. Fixed-scope projects from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress web design",
      "areaServed": [
        { "@type": "State", "name": "Maryland" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress web design",
        "Custom WordPress design",
        "WordPress website design",
        "WordPress designer",
        "Custom Gutenberg blocks",
        "WordPress theme development",
        "Schema.org architecture",
        "Core Web Vitals optimization"
      ]
    }
  ]
});

const includes = [
  "Custom design in Figma — mapped to your schema graph and conversion architecture",
  "Custom Gutenberg blocks (no page builders, no $400/year plugin licences)",
  "Mobile-first responsive design from phones up to wide desktop",
  "LocalBusiness + FAQ + vertical-specific schema architecture",
  "Custom WordPress theme with modern PHP, ACF Pro, and custom post types",
  "Contact and lead-capture forms with anti-spam protection",
  "Google Analytics 4 + Search Console + Bing Webmaster setup",
  "Image optimization, lazy loading, and Core Web Vitals tuning",
  "90+ Lighthouse score on every page on launch day, contractually",
  "Two structured design rounds with comment-thread feedback",
  "Pre-launch redirect map and zero-downtime DNS cutover",
  "30-day post-launch monitoring with written report at day 30",
];

const tiers = [
  {
    name: "Starter",
    price: "$1,500",
    duration: "4-6 weeks",
    summary: "8-page custom WordPress build for solo practitioners and small businesses graduating from Wix, Squarespace, or GoDaddy.",
    fits: ["Solo professionals", "Small businesses (1-3 staff)", "Graduating from Wix / Squarespace"],
    href: "/pricing/#starter",
  },
  {
    name: "Growth",
    price: "$3,500",
    duration: "6-8 weeks",
    summary: "15-20 pages with city / service landing pages, vertical-specific schema, and the full Local Pack optimization stack.",
    fits: ["Multi-location businesses", "Local-pack-targeted services", "Multi-vertical service businesses"],
    href: "/pricing/#growth",
    highlight: true,
  },
  {
    name: "Custom",
    price: "From $6,000",
    duration: "8-10 weeks",
    summary: "WooCommerce, IDX, multi-location schema, custom plugin development, or anything outside the Starter / Growth scope.",
    fits: ["Ecommerce / WooCommerce", "Real estate IDX", "Enterprise / multi-location"],
    href: "/pricing/#custom",
  },
];

const process = [
  { num: "01", phase: "Discovery",    duration: "45 min",    detail: "Free Zoom call: competitive set audit, schema map, Local Pack gap analysis, conversion review." },
  { num: "02", phase: "Fixed quote",   duration: "48 hours",  detail: "PDF with full scope, milestones, deliverables, and one fixed price held for 30 days." },
  { num: "03", phase: "Design rounds", duration: "1-2 weeks", detail: "Async design review on a private staging URL with two structured rounds." },
  { num: "04", phase: "Build + schema", duration: "3-6 weeks", detail: "Custom blocks, theme development, schema implementation, weekly written status updates." },
  { num: "05", phase: "Launch",         duration: "1 week",    detail: "Pre-launch performance audit, 301 redirect map, zero-downtime DNS cutover." },
  { num: "06", phase: "Monitoring",     duration: "30 days",   detail: "Daily Search Console checks for first 7 days, then weekly. Day-30 written launch report." },
];

const verticals = [
  { name: "Law firms",       href: "/industries/law-firm-website-design/" },
  { name: "Dental",          href: "/industries/dental-website-design/" },
  { name: "Medical",         href: "/industries/medical-website-design/" },
  { name: "Real estate",     href: "/industries/real-estate-website-design/" },
  { name: "Contractors",     href: "/industries/contractor-website-design/" },
  { name: "Restaurants",     href: "/industries/restaurant-website-design/" },
  { name: "Nonprofits",      href: "/industries/nonprofit-website-design/" },
  { name: "Ecommerce",       href: "/industries/ecommerce-website-design/" },
  { name: "Accountants",     href: "/industries/accountant-website-design/" },
];

const faqs = [
  {
    q: "How much does custom WordPress web design cost?",
    a: "Quality custom WordPress web design in the US runs $1,500-$15,000 for most small-to-mid business projects. The cheapest credible builds (Starter tier) start around $1,500 and ship a custom 8-page site with schema, performance, and Core Web Vitals included. Mid-tier custom builds with city landing pages and Local Pack optimization run $3,500-$6,000 (Growth tier). Complex builds with WooCommerce, IDX, or multi-location schema start at $6,000 (Custom tier).",
  },
  {
    q: "What's the difference between custom WordPress design and a theme?",
    a: "A theme is a pre-built template you customize within its constraints. Custom WordPress design is built from scratch around your specific content patterns, schema needs, and conversion architecture. Themes look fast in a demo and become a maintenance tax for years (proprietary plugins, theme-locked features, design constraints). Custom WordPress is editable forever — you or any other developer can modify it without negotiating with a theme vendor.",
  },
  {
    q: "Why don't you use page builders like Elementor or Divi?",
    a: "Page builders solve a different problem than custom WordPress web design. They make it easy for non-developers to drag-and-drop layouts, but the trade-off is bloated HTML, slow Core Web Vitals, and dependency on a $200-$400/year licence to keep editing. Custom Gutenberg blocks ship the design as native WordPress content, edit at half the page weight, and stay maintainable forever. The only place we'll use Elementor is when a client explicitly wants it — even then we'll explain the trade-offs first.",
  },
  {
    q: "How long does a WordPress web design project take?",
    a: "Standard delivery: Starter (8 pages) ships in 4-6 weeks, Growth (15-20 pages) in 6-8 weeks, Custom (WooCommerce / IDX / multi-location) in 8-10 weeks. The biggest variable is how quickly you provide content and approve design rounds — we keep building on our end, but the timeline pauses if we're waiting on you for more than 5 business days.",
  },
  {
    q: "Will the new site lose my Google rankings?",
    a: "Not if the migration is handled correctly. We map every existing URL, build a complete 301 redirect map, run the cutover during a low-traffic window, and monitor Search Console for 30 days post-launch. Properly migrated WordPress sites typically recover all top-10 rankings within 4 weeks. We've handled hundreds of migrations with zero ranking loss when we control the redirect map and DNS schedule.",
  },
  {
    q: "Do you write the website copy or do I provide it?",
    a: "We write copy on every project tier. You complete a structured questionnaire after discovery — services, audiences, credentials, vertical context — and we draft service pages, team bios, FAQs, and city landing pages. One review round is included in every tier. For regulated industries (legal, medical, dental) we handle the compliance framing under MRPC, HIPAA-aware language, and ethics-board-safe testimonial framing.",
  },
  {
    q: "What's included in the 90+ Lighthouse guarantee?",
    a: "Every page on launch day must hit 90+ in all four Lighthouse categories: Performance, Accessibility, Best Practices, and SEO. If a page ships below the bar, we don't invoice the final launch milestone until it's green. The guarantee covers our build — not third-party embedded content (chat widgets, video embeds, marketing pixels) that you add post-launch. We document those exceptions in the launch report.",
  },
  {
    q: "Can you redesign my existing WordPress site without rebuilding it?",
    a: "Sometimes. If the existing site has clean architecture (no plugin bloat, valid schema, decent performance baseline) we can run a redesign sprint that refreshes the visual layer without touching the codebase. If the site has 40+ active plugins, broken schema, or Lighthouse scores in the 30s, redesign is the wrong tool — you need a rebuild. We audit the current state during discovery and recommend the right approach honestly. Redesigns start at $2,500.",
  },
];
---
<BaseLayout
  title="WordPress Web Design Services Maryland | Custom WordPress Website Design | Upcoming Brand"
  description="Custom WordPress web design services in Maryland. Custom Gutenberg blocks, schema architecture, 90+ Lighthouse, fixed-scope from $1,500. Built for businesses that need to rank, convert, and stay maintainable."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">WordPress web design service</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">Custom WordPress web design</span>
          <span class="page-h1-line"><em class="page-h1-accent">that ships schema, hits 90+ Lighthouse,</em></span>
          <span class="page-h1-line page-h1-italic">and stays editable forever.</span>
        </h1>

        <p class="page-lead">
          <strong>WordPress web design services</strong> for Maryland businesses that need a site that ranks in Google, converts visitors, and stays maintainable for the next ten years. Custom Gutenberg blocks. Schema-first architecture. 90+ Lighthouse contractually. <strong>Fixed-scope from $1,500.</strong>
        </p>

        <div class="page-hero-ctas">
          <a href="/contact/" class="lp-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#tiers" class="lp-btn-ghost">
            View tiers
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v12M2 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">From $1,500 fixed-scope</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">90+ Lighthouse guaranteed</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">4-6 to 10 week delivery</span>
        </div>
      </div>
    </section>

    <!-- ====== INCLUDES ====== -->
    <section class="svc-includes">
      <div class="container">
        <div class="svc-includes-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            What's included
          </p>
          <h2 class="page-h2">
            Twelve things <em>every project ships with.</em>
          </h2>
          <p class="page-section-lead">Tier-independent. Starter projects ship with the same engineering bar as Custom builds — only scope and complexity change.</p>
        </div>

        <div class="svc-includes-grid">
          {includes.map((item, i) => (
            <div class="svc-include">
              <span class="svc-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="svc-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="svc-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="svc-tiers" id="tiers">
      <div class="container">
        <div class="svc-tiers-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress web design packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="svc-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`svc-tier ${t.highlight ? 'svc-tier-highlight' : ''}`}>
              {t.highlight && <span class="svc-tier-flag">Most chosen</span>}
              <span class="svc-tier-name">{t.name}</span>
              <span class="svc-tier-price">{t.price}</span>
              <span class="svc-tier-duration">{t.duration}</span>
              <p class="svc-tier-summary">{t.summary}</p>
              <div class="svc-tier-fits">
                <span class="svc-tier-fits-label">Fits</span>
                <ul class="svc-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="svc-tier-cta">
                See tier
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== PROCESS ====== -->
    <section class="svc-process">
      <div class="container">
        <div class="svc-process-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">How we build</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 svc-process-h2">
            Six phases <em>from email to launch.</em>
          </h2>
          <p class="svc-process-lead">Every WordPress web design project moves through the same six phases — async by default, schema-led, Lighthouse 90+ as a deliverable.</p>
        </div>

        <ol class="svc-process-list">
          {process.map((p) => (
            <li class="svc-process-step">
              <span class="svc-process-num">{p.num}</span>
              <div class="svc-process-content">
                <div class="svc-process-meta">
                  <span class="svc-process-phase">{p.phase}</span>
                  <span class="svc-process-divider" aria-hidden="true"></span>
                  <span class="svc-process-duration">{p.duration}</span>
                </div>
                <p class="svc-process-detail">{p.detail}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="svc-process-foot">
          <a href="/process/" class="svc-process-link">
            See full process page
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ====== VERTICALS ====== -->
    <section class="svc-verticals">
      <div class="container">
        <div class="svc-verticals-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            Industry expertise
          </p>
          <h2 class="page-h2">
            WordPress web design <em>across nine verticals.</em>
          </h2>
          <p class="page-section-lead">Each vertical gets vertical-specific schema, compliance-aware copy, and conversion architecture matched to how that industry's customers actually decide.</p>
        </div>

        <div class="svc-verticals-grid">
          {verticals.map((v) => (
            <a href={v.href} class="svc-vertical">
              <span class="svc-vertical-name">{v.name}</span>
              <span class="svc-vertical-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="svc-faq">
      <div class="container">
        <div class="svc-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">WordPress web design FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 svc-faq-h2">
            Eight questions <em>before you hire.</em>
          </h2>
        </div>

        <div class="svc-faq-list">
          {faqs.map((f, i) => (
            <details class="svc-faq-item">
              <summary class="svc-faq-q">
                <span class="svc-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="svc-faq-q-text">{f.q}</span>
                <span class="svc-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="svc-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Ready to start</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            WordPress web design<br>
            <em>that earns its rankings.</em>
          </h2>
          <p class="page-cta-lead">A free 45-minute discovery call. We map your competitive set, identify the schema and Local Pack gaps, and send a fixed-scope quote within 48 hours.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">
              Book a discovery call
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/services/" class="page-cta-ghost-light">
              View all services
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* SHARED */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(32px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline-block;
  }
  .page-h1-accent::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0.05em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }
  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }
  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .lp-btn-primary, .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lp-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg, .lp-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }
  .lp-btn-ghost:hover svg { transform: translate(2px, -2px); }

  .page-hero-trust {
