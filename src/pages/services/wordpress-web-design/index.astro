      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faqpage`,
      "mainEntity": [
        { "@type": "Question", "name": "How much does custom WordPress web design cost?",                          "acceptedAnswer": { "@type": "Answer", "text": "Quality custom WordPress web design in the US runs $1,500-$15,000 for most small-to-mid business projects. Starter tier builds start around $1,500 for a custom 8-page site with schema, performance, and Core Web Vitals included. Growth tier runs $3,500-$6,000. Custom builds with WooCommerce, IDX, or multi-location schema start at $6,000." } },
        { "@type": "Question", "name": "What's the difference between custom WordPress design and a theme?",       "acceptedAnswer": { "@type": "Answer", "text": "A theme is a pre-built template you customize within its constraints. Custom WordPress design is built from scratch around your specific content patterns, schema needs, and conversion architecture." } },
        { "@type": "Question", "name": "What page builder do you use for WordPress projects?",                     "acceptedAnswer": { "@type": "Answer", "text": "We build on Elementor Pro and Astra Pro. Elementor Pro gives editors a visual drag-and-drop interface that stays manageable long-term, and Astra Pro is one of the fastest, most performance-friendly WordPress themes available." } },
        { "@type": "Question", "name": "How long does a WordPress web design project take?",                       "acceptedAnswer": { "@type": "Answer", "text": "Starter (8 pages) ships in 4-6 weeks, Growth (15-20 pages) in 6-8 weeks, Custom (WooCommerce / IDX / multi-location) in 8-10 weeks." } },
        { "@type": "Question", "name": "Will the new site lose my Google rankings?",                               "acceptedAnswer": { "@type": "Answer", "text": "Not if the migration is handled correctly. We map every existing URL, build a complete 301 redirect map, run the cutover during a low-traffic window, and monitor Search Console for 30 days post-launch." } },
        { "@type": "Question", "name": "Do you write the website copy or do I provide it?",                        "acceptedAnswer": { "@type": "Answer", "text": "We write copy on every project tier. You complete a structured questionnaire after discovery and we draft service pages, team bios, FAQs, and city landing pages." } },
        { "@type": "Question", "name": "What's included in the 90+ Lighthouse guarantee?",                        "acceptedAnswer": { "@type": "Answer", "text": "Every page on launch day must hit 90+ in all four Lighthouse categories: Performance, Accessibility, Best Practices, and SEO. If a page ships below the bar, we don't invoice the final launch milestone until it's green." } },
        { "@type": "Question", "name": "Can you redesign my existing WordPress site without rebuilding it?",        "acceptedAnswer": { "@type": "Answer", "text": "Sometimes. If the existing site has clean architecture (no plugin bloat, valid schema, decent performance baseline) we can run a redesign sprint that refreshes the visual layer without touching the codebase. Redesigns start at $2,500." } },
        { "@type": "Question", "name": "What does a custom WordPress website include?",                            "acceptedAnswer": { "@type": "Answer", "text": "Every custom WordPress website includes: custom Figma design, Elementor Pro on Astra Pro, mobile-first responsive layouts, LocalBusiness and FAQ schema, Google Analytics 4 and Search Console setup, image optimization, contact forms, 90+ Lighthouse on every page, WCAG 2.1 AA accessibility review, two design review rounds, a full 301 redirect map, and 30 days of post-launch monitoring." } },
        { "@type": "Question", "name": "Is custom WordPress design worth it?",                                      "acceptedAnswer": { "@type": "Answer", "text": "For most Maryland businesses competing in local search, yes. A custom WordPress build gives you schema control, 90+ Lighthouse, and ADA compliance that template-based sites structurally cannot match." } }
      ]
    }
