import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://www.upcomingbrand.com/services/wordpress-web-design/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Web Design Maryland | Custom WordPress Website Design | Upcoming Brand",
      "description": "Custom WordPress web design services in Maryland. Elementor Pro on Astra Pro, schema architecture, 90+ Lighthouse, fixed-scope from $1,500. Built for businesses that need to rank, convert, and stay maintainable.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://www.upcomingbrand.com/#website" },
      "about": { "@id": "https://www.upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://www.upcomingbrand.com/#logo" },
