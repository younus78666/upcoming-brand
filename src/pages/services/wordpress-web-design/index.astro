const faqs = [
  {
    q: "How much does custom WordPress web design cost?",
    a: "Quality custom WordPress web design in the US runs $1,500-$15,000 for most small-to-mid business projects. The cheapest credible builds (Starter tier) start around $1,500 and ship a custom 8-page site with schema, performance, and Core Web Vitals included. Mid-tier custom builds with city landing pages and Local Pack optimization run $3,500-$6,000 (Growth tier). Complex builds with WooCommerce, IDX, or multi-location schema start at $6,000 (Custom tier).",
  },
  {
    q: "What's the difference between custom WordPress design and a theme?",
    a: "A theme is a pre-built template you customize within its constraints. Custom WordPress design is built from scratch around your specific content patterns, schema needs, and conversion architecture. Themes look fast in a demo and become a maintenance tax for years (proprietary plugins, theme-locked features, design constraints). Custom WordPress is editable forever, by you or any other developer, without negotiating with a theme vendor.",
  },
  {
    q: "What page builder do you use for WordPress projects?",
    a: "We build on Elementor Pro and Astra Pro. Elementor Pro gives editors a visual drag-and-drop interface that stays manageable long-term, and Astra Pro is one of the fastest, most performance-friendly WordPress themes available. We configure both for speed: no unused widget libraries, performance-optimized asset loading, and all layouts tested to 90+ Lighthouse before launch.",
  },
  {
    q: "How long does a WordPress web design project take?",
    a: "Standard delivery: Starter (8 pages) ships in 4-6 weeks, Growth (15-20 pages) in 6-8 weeks, Custom (WooCommerce / IDX / multi-location) in 8-10 weeks. The biggest variable is how quickly you provide content and approve design rounds. We keep building on our end, but the timeline pauses if we're waiting on you for more than 5 business days.",
  },
  {
    q: "Will the new site lose my Google rankings?",
    a: "Not if the migration is handled correctly. We map every existing URL, build a complete 301 redirect map, run the cutover during a low-traffic window, and monitor Search Console for 30 days post-launch. Properly migrated WordPress sites typically recover all top-10 rankings within 4 weeks. We've handled hundreds of migrations with zero ranking loss when we control the redirect map and DNS schedule.",
  },
  {
    q: "Do you write the website copy or do I provide it?",
    a: "We write copy on every project tier. You complete a structured questionnaire after discovery (services, audiences, credentials, vertical context) and we draft service pages, team bios, FAQs, and city landing pages. One review round is included in every tier. For regulated industries (legal, medical, dental) we handle the compliance framing under MRPC, HIPAA-aware language, and ethics-board-safe testimonial framing.",
  },
  {
    q: "What's included in the 90+ Lighthouse guarantee?",
    a: "Every page on launch day must hit 90+ in all four Lighthouse categories: Performance, Accessibility, Best Practices, and SEO. If a page ships below the bar, we don't invoice the final launch milestone until it's green. The guarantee covers our build, not third-party embedded content (chat widgets, video embeds, marketing pixels) that you add post-launch. We document those exceptions in the launch report.",
  },
  {
    q: "Can you redesign my existing WordPress site without rebuilding it?",
    a: "Sometimes. If the existing site has clean architecture (no plugin bloat, valid schema, decent performance baseline) we can run a redesign sprint that refreshes the visual layer without touching the codebase. If the site has 40+ active plugins, broken schema, or Lighthouse scores in the 30s, redesign is the wrong tool. You need a rebuild. We audit the current state during discovery and recommend the right approach honestly. Redesigns start at $2,500.",
  },
  {
    q: "What does a custom WordPress website include?",
    a: "Every custom WordPress website we build includes: custom Figma design matched to your schema graph and brand identity, Elementor Pro on Astra Pro (no per-site plugin fees), mobile-first responsive layouts, LocalBusiness and FAQ schema, Google Analytics 4 and Search Console setup, image optimization with WebP and lazy loading, contact and lead forms with anti-spam, 90+ Lighthouse on every page, WCAG 2.1 AA accessibility review, two structured design review rounds, a full 301 redirect map for migrations, and 30 days of post-launch Search Console monitoring with a written report at day 30.",
  },
  {
    q: "Is custom WordPress design worth it?",
    a: "For most Maryland businesses competing in local search, yes. A custom WordPress build gives you schema control, 90+ Lighthouse, and ADA compliance that template-based sites structurally cannot match. The cost difference between a $400 ThemeForest theme and a $1,500 custom build pays back in two ways: better local rankings from schema accuracy, and lower long-term maintenance cost from not fighting a stock theme's constraints every time you update the site. If you're getting fewer than 200 visits per month or have no competition in your market, a template may be sufficient. Be honest about where you are in your market before investing in custom.",
  },
];
---
<BaseLayout
  title="WordPress Web Design Maryland | Custom WordPress Website Design | Upcoming Brand"
  description="Custom WordPress website design in Maryland. Elementor Pro on Astra Pro, schema architecture, 90+ Lighthouse. Fixed-scope from $1,500. Maryland's WordPress web design agency, built to rank."
  canonicalUrl={canonical}
  ogImage="https://www.upcomingbrand.com/og/wordpress-web-design.jpg"
  ogImageAlt="Custom WordPress web design services Maryland — Upcoming Brand"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WordPress web design service'
      pillText='WordPress Specialists · Maryland'
      h1Lines={[
        { text: 'Custom WordPress web design' },
        { text: 'that ships schema, hits 90+ Lighthouse,', type: 'accent' },
        { text: 'and stays editable forever.', type: 'italic' },
      ]}
      lead='<strong>WordPress web design services</strong> and <strong>custom WordPress development</strong> for Maryland businesses that need a site that ranks in Google, converts visitors, and stays maintainable for the next ten years. Responsive website design built on Elementor Pro and Astra Pro. Schema-first architecture. 90+ Lighthouse contractually. <strong>Fixed-scope from $1,500.</strong>'
      formName='wp-web-design-inquiry'
      trustLines={['From $1,500 fixed-scope', '90+ Lighthouse guaranteed', '4-6 to 10 week delivery']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'Current platform',
          subtitle: 'Where your site lives now (or starting fresh).',
          fields: [
            { type: 'select', name: 'current_platform', label: 'Current website platform', required: true,
              options: ['No existing site', 'Old WordPress site', 'Wix', 'Squarespace', 'Webflow', 'Shopify', 'GoDaddy / Hostinger builder', 'Custom HTML', 'Other'] },
            { type: 'url', name: 'current_site', label: 'Current site URL', placeholder: 'https://yoursite.com', optional: true, autocomplete: 'url' },
          ],
        },
        {
          title: 'Project size',
          subtitle: 'Page count and budget.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Pages needed', required: true,
              options: ['1 to 5 pages', '6 to 15 pages', '16 to 40 pages', '40+ pages', 'Not sure yet'] },
            { type: 'select', name: 'budget', label: 'Budget range', required: true,
              options: ['Under $1,500', '$1,500 to $3,500', '$3,500 to $6,000', '$6,000 to $15,000', '$15,000+', 'Not sure yet'] },
          ],
        },
        {
          title: 'Timeline + goal',
          subtitle: 'When you need it live and what it must do.',
          fields: [
            { type: 'select', name: 'timeline', label: 'Timeline', required: true,
              options: ['ASAP, within 4 weeks', 'Standard, 6 to 10 weeks', 'Flexible, 3+ months', 'Just exploring'] },
            { type: 'textarea', name: 'message', label: 'Design goal', placeholder: 'What does the new site need to accomplish?', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- ====== AEO KEY TAKEAWAYS ====== -->
    <section class="wwd-kt-section">
