      "@id": `${canonical}#howto`,
      "name": "How to design a WordPress website",
      "description": "The five-step process for designing and building a custom WordPress website with schema, performance, and conversion architecture built in.",
      "totalTime": "P6W",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Map the schema and content architecture", "text": "Identify which schema types your business needs (LocalBusiness, FAQ, Service, vertical-specific). Map the content patterns that will become Elementor Pro templates." },
