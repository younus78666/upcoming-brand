        { "@type": "HowToStep", "position": 3, "name": "Build with Elementor Pro and Astra Pro",   "text": "Elementor Pro layouts on Astra Pro with performance-tuned markup, ACF Pro, and custom post types. Built for speed and long-term editability." },
        { "@type": "HowToStep", "position": 4, "name": "Optimize for Core Web Vitals",             "text": "Image optimization, critical CSS, lazy loading, and server-level tuning. Target 90+ Lighthouse on every page before launch." },
