  },
  {
    type: "Gutenberg block editor",
    badge: "Native WordPress",
    desc: "The built-in WordPress block editor: no third-party page builder required. All content is stored as clean, portable HTML. Best for content publishers and businesses reducing plugin dependency. We build reusable block patterns for consistent editing.",
  },
  {
    type: "Custom PHP theme (FSE)",
    badge: "Maximum performance",
    desc: "A PHP theme built from scratch using WordPress Full Site Editing. Zero page builder overhead. Achieves 95+ Lighthouse on every page without caching tricks. Best for high-traffic sites and enterprises where performance is a hard requirement.",
  },
];

const whyCustom = [
  {
    num: "01",
    reason: "Schema that Google can actually read",
    detail: "Stock themes ship without structured data or with generic schema that mismatches your business type. Custom WordPress design builds LocalBusiness, Service, FAQ, and vertical-specific schema directly into the template layer. Google AI Overviews cite structured content. Generic themes get crawled and ignored.",
  },
  {
    num: "02",
    reason: "Core Web Vitals you can actually hit",
    detail: "Premium themes average 55-65 on Google Lighthouse. Custom builds targeting 90+ are engineered differently from the start: critical CSS inlined, unused scripts removed, images lazy-loaded, TTFB optimized at the server level. You cannot retrofit 90+ onto a bloated theme stack.",
  },
  {
    num: "03",
    reason: "AI-ready content architecture",
    detail: "Google AI Overviews, Bing Copilot, and ChatGPT all cite pages with direct Q+A structure, factual density, and clean semantic HTML. A custom WordPress build lets you architect every page for machine extraction, not just human reading. Template sites can't do this without a full rebuild.",
  },
  {
    num: "04",
    reason: "ADA compliance that protects your business",
    detail: "WCAG 2.1 AA compliance reduces ADA lawsuit exposure and is required under Maryland HB 1024 for covered organizations. Stock themes routinely fail contrast ratios, keyboard navigation, and screen reader compatibility. Our WordPress experts build accessibility into the markup from day one, not as an afterthought.",
  },
];

const compareRows = [
  { feature: "Schema / structured data",      wp: "Full control",           wix: "None",                  sq: "Limited",               webflow: "Limited" },
  { feature: "Lighthouse Performance score",   wp: "90+ achievable",         wix: "50-70 typical",         sq: "60-75 typical",         webflow: "80-90 possible" },
  { feature: "Custom post types",              wp: "Yes",                    wix: "No",                    sq: "No",                    webflow: "Yes (CMS)" },
  { feature: "Plugin ecosystem",               wp: "60,000+ plugins",        wix: "Limited marketplace",   sq: "No plugins",            webflow: "Limited" },
  { feature: "Code and content ownership",     wp: "100% yours forever",     wix: "Locked to Wix",         sq: "Locked to Squarespace", webflow: "100% yours" },
  { feature: "ADA / WCAG compliance control",  wp: "Full",                   wix: "Limited",               sq: "Limited",               webflow: "Full" },
  { feature: "AI Overview optimization",       wp: "Full (semantic HTML)",   wix: "None",                  sq: "None",                  webflow: "Limited" },
  { feature: "Platform lock-in risk",          wp: "None (open source)",     wix: "High",                  sq: "High",                  webflow: "Moderate" },
