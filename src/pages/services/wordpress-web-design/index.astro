---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/services/wordpress-web-design/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Web Design Services Maryland | Custom WordPress Website Design | Upcoming Brand",
      "description": "Custom WordPress web design services in Maryland. Custom Gutenberg blocks, schema architecture, 90+ Lighthouse, fixed-scope from $1,500. Built for businesses that need to rank, convert, and stay maintainable.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                 "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",             "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Web Design", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "Custom WordPress Web Design",
      "description": "Custom WordPress website design with schema architecture, custom Gutenberg blocks, and 90+ Lighthouse on launch day. Fixed-scope projects from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress web design",
      "areaServed": [
        { "@type": "State", "name": "Maryland" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress web design",
        "Custom WordPress design",
        "Custom WordPress development",
        "Custom WordPress development services",
        "WordPress website design",
        "WordPress website development",
        "WordPress website development company",
        "WordPress designer",
        "WordPress developer services",
        "Custom Gutenberg blocks",
        "WordPress theme development",
        "Responsive website design services",
        "Schema.org architecture",
        "Core Web Vitals optimization"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to design a WordPress website",
      "description": "The five-step process for designing and building a custom WordPress website with schema, performance, and conversion architecture built in.",
      "totalTime": "P6W",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Map the schema and content architecture", "text": "Identify which schema types your business needs (LocalBusiness, FAQ, Service, vertical-specific). Map the content patterns that will become custom Gutenberg blocks." },
        { "@type": "HowToStep", "position": 2, "name": "Design in Figma",                          "text": "Mobile-first responsive designs in Figma, mapped against the schema and conversion architecture decided in step one. Two structured review rounds." },
        { "@type": "HowToStep", "position": 3, "name": "Build custom blocks and theme",            "text": "Custom Gutenberg blocks and a custom WordPress theme with modern PHP, ACF Pro, and performance-tuned markup. No page builders." },
        { "@type": "HowToStep", "position": 4, "name": "Optimize for Core Web Vitals",             "text": "Image optimization, critical CSS, lazy loading, and server-level tuning. Target 90+ Lighthouse on every page before launch." },
        { "@type": "HowToStep", "position": 5, "name": "Launch and monitor",                        "text": "Pre-launch performance audit, 301 redirect map, zero-downtime DNS cutover. Daily Search Console monitoring for the first 30 days post-launch." }
      ]
    }
  ]
});

const includes = [
  "Custom design in Figma, mapped to your schema graph and conversion architecture",
  "Custom Gutenberg blocks (no page builders, no $400/year plugin licences)",
  "Mobile-first responsive design from phones up to wide desktop",
  "LocalBusiness + FAQ + vertical-specific schema architecture",
  "Custom WordPress theme with modern PHP, ACF Pro, and custom post types",
  "Contact and lead-capture forms with anti-spam protection",
  "Google Analytics 4 + Search Console + Bing Webmaster setup",
  "Image optimization, lazy loading, and Core Web Vitals tuning",
  "90+ Lighthouse score on every page on launch day, contractually",
  "Two structured design rounds with comment-thread feedback",
  "Pre-launch redirect map and zero-downtime DNS cutover",
  "30-day post-launch monitoring with written report at day 30",
];

const tiers = [
  {
    name: "Starter",
    price: "$1,500",
    duration: "4-6 weeks",
    summary: "8-page custom WordPress build for solo practitioners and small businesses graduating from Wix, Squarespace, or GoDaddy.",
    fits: ["Solo professionals", "Small businesses (1-3 staff)", "Graduating from Wix / Squarespace"],
    href: "/pricing/#starter",
  },
  {
    name: "Growth",
    price: "$3,500",
    duration: "6-8 weeks",
    summary: "15-20 pages with city / service landing pages, vertical-specific schema, and the full Local Pack optimization stack.",
    fits: ["Multi-location businesses", "Local-pack-targeted services", "Multi-vertical service businesses"],
    href: "/pricing/#growth",
    highlight: true,
  },
  {
    name: "Custom",
    price: "From $6,000",
    duration: "8-10 weeks",
    summary: "WooCommerce, IDX, multi-location schema, custom plugin development, or anything outside the Starter / Growth scope.",
    fits: ["Ecommerce / WooCommerce", "Real estate IDX", "Enterprise / multi-location"],
    href: "/pricing/#custom",
  },
];

const process = [
  { num: "01", phase: "Discovery",    duration: "45 min",    detail: "Free Zoom call: competitive set audit, schema map, Local Pack gap analysis, conversion review." },
  { num: "02", phase: "Fixed quote",   duration: "48 hours",  detail: "PDF with full scope, milestones, deliverables, and one fixed price held for 30 days." },
  { num: "03", phase: "Design rounds", duration: "1-2 weeks", detail: "Async design review on a private staging URL with two structured rounds." },
  { num: "04", phase: "Build + schema", duration: "3-6 weeks", detail: "Custom blocks, theme development, schema implementation, weekly written status updates." },
  { num: "05", phase: "Launch",         duration: "1 week",    detail: "Pre-launch performance audit, 301 redirect map, zero-downtime DNS cutover." },
  { num: "06", phase: "Monitoring",     duration: "30 days",   detail: "Daily Search Console checks for first 7 days, then weekly. Day-30 written launch report." },
];

const customDev = [
  {
    num: "01",
    area: "Custom Gutenberg blocks",
    detail: "Block-based editing tied to your specific content patterns. Editors get on-brand layouts without page builders.",
  },
  {
    num: "02",
    area: "Custom WordPress themes",
    detail: "Modern PHP, ACF Pro, semantic HTML, and accessible markup. Built for editors as much as for visitors.",
  },
  {
    num: "03",
    area: "Custom post types and taxonomies",
    detail: "Properties, services, locations, case studies, testimonials. Each modeled with the right fields and schema.",
  },
  {
    num: "04",
    area: "Custom plugin development",
    detail: "When the right plugin doesn't exist, we build it. Lightweight, documented, and maintained as part of the project.",
  },
  {
    num: "05",
    area: "Custom integrations",
    detail: "CRM connections, IDX feeds, booking systems, payment gateways, multi-vendor commerce, subscription flows.",
  },
  {
    num: "06",
    area: "Responsive WordPress design",
    detail: "Mobile-first builds tested across iOS Safari, Chrome Mobile, iPad, and full desktop. No hidden mobile breakpoints.",
  },
];

const whenDesign = [
  {
    num: "01",
    signal: "Generic theme that ships with no schema",
    detail: "If your current site uses a stock theme bought from ThemeForest or Astra, schema is almost certainly missing or incomplete. A custom WordPress design rebuilds the foundation.",
  },
  {
    num: "02",
    signal: "Lighthouse score below 70",
    detail: "Below 70 in Performance usually means plugin bloat, slow hosting, or missed image optimization. Custom WordPress development services targeting Core Web Vitals fix the underlying problem.",
  },
  {
    num: "03",
    signal: "Editing requires a developer for everything",
    detail: "If you need to email a developer to change a hero image, your site is built wrong. Custom Gutenberg blocks let editors update content without breaking layouts.",
  },
  {
    num: "04",
    signal: "Locked into a $400/year page builder licence",
    detail: "Elementor Pro, Divi, WPBakery: each charges per-site annually and breaks layouts on update. A custom WordPress website development engagement removes the dependency.",
  },
  {
    num: "05",
    signal: "Mobile experience is broken or slow",
    detail: "70%+ of traffic comes from phones. If mobile pagespeed is below 60 or layouts break, responsive WordPress design with mobile-first methodology is the fix.",
  },
  {
    num: "06",
    signal: "You're scaling past simple website",
    detail: "Adding WooCommerce, multi-language, multi-location schema, IDX, or booking takes you past template territory. Custom WordPress development services handle the complexity.",
  },
];

const verticals = [
  { name: "Law firms",       href: "/industries/law-firm-website-design/" },
  { name: "Dental",          href: "/industries/dental-website-design/" },
  { name: "Medical",         href: "/industries/medical-website-design/" },
  { name: "Real estate",     href: "/industries/real-estate-website-design/" },
  { name: "Contractors",     href: "/industries/contractor-website-design/" },
  { name: "Restaurants",     href: "/industries/restaurant-website-design/" },
  { name: "Nonprofits",      href: "/industries/nonprofit-website-design/" },
  { name: "Ecommerce",       href: "/industries/ecommerce-website-design/" },
  { name: "Accountants",     href: "/industries/accountant-website-design/" },
];

const faqs = [
  {
    q: "How much does custom WordPress web design cost?",
    a: "Quality custom WordPress web design in the US runs $1,500-$15,000 for most small-to-mid business projects. The cheapest credible builds (Starter tier) start around $1,500 and ship a custom 8-page site with schema, performance, and Core Web Vitals included. Mid-tier custom builds with city landing pages and Local Pack optimization run $3,500-$6,000 (Growth tier). Complex builds with WooCommerce, IDX, or multi-location schema start at $6,000 (Custom tier).",
  },
  {
    q: "What's the difference between custom WordPress design and a theme?",
    a: "A theme is a pre-built template you customize within its constraints. Custom WordPress design is built from scratch around your specific content patterns, schema needs, and conversion architecture. Themes look fast in a demo and become a maintenance tax for years (proprietary plugins, theme-locked features, design constraints). Custom WordPress is editable forever, by you or any other developer, without negotiating with a theme vendor.",
  },
  {
    q: "Why don't you use page builders like Elementor or Divi?",
    a: "Page builders solve a different problem than custom WordPress web design. They make it easy for non-developers to drag-and-drop layouts, but the trade-off is bloated HTML, slow Core Web Vitals, and dependency on a $200-$400/year licence to keep editing. Custom Gutenberg blocks ship the design as native WordPress content, edit at half the page weight, and stay maintainable forever. The only place we'll use Elementor is when a client explicitly wants it. Even then we'll explain the trade-offs first.",
  },
  {
    q: "How long does a WordPress web design project take?",
    a: "Standard delivery: Starter (8 pages) ships in 4-6 weeks, Growth (15-20 pages) in 6-8 weeks, Custom (WooCommerce / IDX / multi-location) in 8-10 weeks. The biggest variable is how quickly you provide content and approve design rounds. We keep building on our end, but the timeline pauses if we're waiting on you for more than 5 business days.",
  },
  {
    q: "Will the new site lose my Google rankings?",
    a: "Not if the migration is handled correctly. We map every existing URL, build a complete 301 redirect map, run the cutover during a low-traffic window, and monitor Search Console for 30 days post-launch. Properly migrated WordPress sites typically recover all top-10 rankings within 4 weeks. We've handled hundreds of migrations with zero ranking loss when we control the redirect map and DNS schedule.",
  },
  {
    q: "Do you write the website copy or do I provide it?",
    a: "We write copy on every project tier. You complete a structured questionnaire after discovery (services, audiences, credentials, vertical context) and we draft service pages, team bios, FAQs, and city landing pages. One review round is included in every tier. For regulated industries (legal, medical, dental) we handle the compliance framing under MRPC, HIPAA-aware language, and ethics-board-safe testimonial framing.",
  },
  {
    q: "What's included in the 90+ Lighthouse guarantee?",
    a: "Every page on launch day must hit 90+ in all four Lighthouse categories: Performance, Accessibility, Best Practices, and SEO. If a page ships below the bar, we don't invoice the final launch milestone until it's green. The guarantee covers our build, not third-party embedded content (chat widgets, video embeds, marketing pixels) that you add post-launch. We document those exceptions in the launch report.",
  },
  {
    q: "Can you redesign my existing WordPress site without rebuilding it?",
    a: "Sometimes. If the existing site has clean architecture (no plugin bloat, valid schema, decent performance baseline) we can run a redesign sprint that refreshes the visual layer without touching the codebase. If the site has 40+ active plugins, broken schema, or Lighthouse scores in the 30s, redesign is the wrong tool. You need a rebuild. We audit the current state during discovery and recommend the right approach honestly. Redesigns start at $2,500.",
  },
];
---
<BaseLayout
  title="WordPress Web Design Services & Custom Development | Maryland | Upcoming Brand"
  description="Custom WordPress web design and development services in Maryland. Responsive design, custom Gutenberg blocks, schema architecture, 90+ Lighthouse. Fixed-scope from $1,500. Built for businesses that need to rank, convert, and stay maintainable."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WordPress web design service'
      pillText='WordPress Specialists · Maryland'
      h1Lines={[
        { text: 'Custom WordPress web design' },
        { text: 'that ships schema, hits 90+ Lighthouse,', type: 'accent' },
        { text: 'and stays editable forever.', type: 'italic' },
      ]}
      lead='<strong>WordPress web design services</strong> and <strong>custom WordPress development</strong> for Maryland businesses that need a site that ranks in Google, converts visitors, and stays maintainable for the next ten years. Responsive website design with custom Gutenberg blocks. Schema-first architecture. 90+ Lighthouse contractually. <strong>Fixed-scope from $1,500.</strong>'
      formName='wp-web-design-inquiry'
      trustLines={['From $1,500 fixed-scope', '90+ Lighthouse guaranteed', '4-6 to 10 week delivery']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'Current platform',
          subtitle: 'Where your site lives now (or starting fresh).',
          fields: [
            { type: 'select', name: 'current_platform', label: 'Current website platform', required: true,
              options: ['No existing site', 'Old WordPress site', 'Wix', 'Squarespace', 'Webflow', 'Shopify', 'GoDaddy / Hostinger builder', 'Custom HTML', 'Other'] },
            { type: 'url', name: 'current_site', label: 'Current site URL', placeholder: 'https://yoursite.com', optional: true, autocomplete: 'url' },
          ],
        },
        {
          title: 'Project size',
          subtitle: 'Page count and budget.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Pages needed', required: true,
              options: ['1 to 5 pages', '6 to 15 pages', '16 to 40 pages', '40+ pages', 'Not sure yet'] },
            { type: 'select', name: 'budget', label: 'Budget range', required: true,
              options: ['Under $1,500', '$1,500 to $3,500', '$3,500 to $6,000', '$6,000 to $15,000', '$15,000+', 'Not sure yet'] },
          ],
        },
        {
          title: 'Timeline + goal',
          subtitle: 'When you need it live and what it must do.',
          fields: [
            { type: 'select', name: 'timeline', label: 'Timeline', required: true,
              options: ['ASAP, within 4 weeks', 'Standard, 6 to 10 weeks', 'Flexible, 3+ months', 'Just exploring'] },
            { type: 'textarea', name: 'message', label: 'Design goal', placeholder: 'What does the new site need to accomplish?', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- ====== INCLUDES ====== -->
    <section class="svc-includes">
      <div class="container">
        <div class="svc-includes-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            What's included
          </p>
          <h2 class="page-h2">
            Twelve things <em>every project ships with.</em>
          </h2>
          <p class="page-section-lead">Tier-independent. Starter projects ship with the same engineering bar as Custom builds. Only scope and complexity change.</p>
        </div>

        <div class="svc-includes-grid">
          {includes.map((item, i) => (
            <div class="svc-include">
              <span class="svc-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="svc-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="svc-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== DEFINITION BLOCK (Know intent + AI Overview citation) ====== -->
    <section class="svc-define">
      <div class="container">
        <div class="svc-define-card">
          <div class="svc-define-head">
            <span class="svc-define-pulse" aria-hidden="true"></span>
            <span class="svc-define-label">Definition</span>
          </div>
          <h2 class="page-h2 svc-define-h2">
            What is custom WordPress web design?
          </h2>
          <p class="svc-define-answer">
            <strong>Custom WordPress web design is a website built from scratch on the WordPress platform, tailored to your specific content patterns, schema needs, and conversion architecture.</strong> Unlike pre-built themes from marketplaces (ThemeForest, Astra) and unlike page-builder templates (Elementor, Divi), custom WordPress design gives you native Gutenberg blocks that match your exact business needs, perform better in Core Web Vitals, and stay maintainable for years without licence fees.
          </p>
          <div class="svc-define-meta">
            <div class="svc-define-meta-item">
              <span class="svc-define-meta-label">Also known as</span>
              <span class="svc-define-meta-val">Custom WordPress development, bespoke WordPress design, custom WP theme</span>
            </div>
            <div class="svc-define-meta-item">
              <span class="svc-define-meta-label">Typical scope</span>
              <span class="svc-define-meta-val">8 to 50+ pages with vertical-specific schema and conversion architecture</span>
            </div>
            <div class="svc-define-meta-item">
              <span class="svc-define-meta-label">Investment</span>
              <span class="svc-define-meta-val">$1,500 (Starter) to $15,000+ (Custom WooCommerce / multi-location)</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== CUSTOM DEVELOPMENT (targets 'custom wordpress development' KW) ====== -->
    <section class="svc-customdev">
      <div class="container">
        <div class="svc-customdev-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            Custom WordPress development services
          </p>
          <h2 class="page-h2">
            Six development capabilities <em>under one engagement.</em>
          </h2>
          <p class="page-section-lead">A WordPress web design service is only as deep as the development underneath. We bundle six custom development capabilities into every project, from custom blocks to multi-vendor commerce.</p>
        </div>

        <div class="svc-customdev-grid">
          {customDev.map((c) => (
            <article class="svc-customdev-card">
              <span class="svc-customdev-num">{c.num}</span>
              <h3 class="svc-customdev-area">{c.area}</h3>
              <p class="svc-customdev-detail">{c.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== WHEN YOU NEED IT (Causation frame) ====== -->
    <section class="svc-when">
      <div class="container">
        <div class="svc-when-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            When you need custom design
          </p>
          <h2 class="page-h2">
            Six signals <em>your site needs a custom WordPress build.</em>
          </h2>
          <p class="page-section-lead">If two or more of these match, the right answer is custom WordPress web design and development services, not another theme. Move from template territory to a build that scales.</p>
        </div>

        <div class="svc-when-grid">
          {whenDesign.map((w) => (
            <article class="svc-when-card">
              <span class="svc-when-num">{w.num}</span>
              <h3 class="svc-when-signal">{w.signal}</h3>
              <p class="svc-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="svc-tiers" id="tiers">
      <div class="container">
        <div class="svc-tiers-head">
          <p class="svc-section-eyebrow">
            <span class="svc-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress web design packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="svc-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`svc-tier ${t.highlight ? 'svc-tier-highlight' : ''}`}>
              {t.highlight && <span class="svc-tier-flag">Most chosen</span>}
              <span class="svc-tier-name">{t.name}</span>
              <span class="svc-tier-price">{t.price}</span>
              <span class="svc-tier-duration">{t.duration}</span>
              <p class="svc-tier-summary">{t.summary}</p>
              <div class="svc-tier-fits">
                <span class="svc-tier-fits-label">Fits</span>
                <ul class="svc-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="svc-tier-cta">
                See tier
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== PROCESS ====== -->
    <section class="svc-process">
      <div class="container">
        <div class="svc-process-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">How we build</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 svc-process-h2">
            Six phases <em>from email to launch.</em>
          </h2>
          <p class="svc-process-lead">Every WordPress web design project moves through the same six phases. Async by default, schema-led, Lighthouse 90+ as a deliverable.</p>
        </div>

        <ol class="svc-process-list">
          {process.map((p) => (
            <li class="svc-process-step">
              <span class="svc-process-num">{p.num}</span>
              <div class="svc-process-content">
                <div class="svc-process-meta">
                  <span class="svc-process-phase">{p.phase}</span>
                  <span class="svc-process-divider" aria-hidden="true"></span>
                  <span class="svc-process-duration">{p.duration}</span>
                </div>
                <p class="svc-process-detail">{p.detail}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="svc-process-foot">
          <a href="/process/" class="svc-process-link">
            See full process page
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ====== VERTICALS ====== -->
    <section class="svc-verticals">
      <div class="container">
