---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/services/local-seo-maryland/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Local SEO Services Maryland | Google Business Profile + Local Pack | Upcoming Brand",
      "description": "Local SEO services for Maryland businesses and US-wide remote clients. Google Business Profile optimization, citation building, NAP consistency, Local Pack ranking, schema. Fixed-scope from $1,500.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",            "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "Local SEO Maryland",  "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "Local SEO Services Maryland",
      "description": "Senior local SEO services covering Google Business Profile optimization, citation building, NAP consistency, LocalBusiness schema, Local Pack ranking strategy, and review acquisition. Maryland-based, US-wide remote. Fixed-scope from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "Local SEO",
      "areaServed": [
        { "@type": "State", "name": "Maryland" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "Local SEO",
        "Local SEO services",
        "Local SEO Maryland",
        "Local SEO Baltimore",
        "Local SEO agency",
        "Local SEO expert",
        "Local SEO company",
        "Local SEO for small business",
        "Local SEO audit",
        "Google Business Profile optimization",
        "Google My Business optimization",
        "GBP optimization",
        "Local Pack ranking",
        "Local citation building",
        "NAP consistency",
        "LocalBusiness schema"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to rank in the Local Pack",
      "description": "The five-phase local SEO methodology covering Google Business Profile, citations, NAP consistency, schema, and review acquisition.",
      "totalTime": "P30D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Local SEO audit",       "text": "Google Business Profile audit, citation inventory, NAP consistency check across 50+ directories, LocalBusiness schema audit, competitor Local Pack analysis." },
        { "@type": "HowToStep", "position": 2, "name": "GBP optimization",       "text": "Google Business Profile categories, services, products, posts, photos, business description, and Q&A optimization. Verification fixed if needed." },
        { "@type": "HowToStep", "position": 3, "name": "Citation + NAP cleanup",  "text": "Submit to top 50 industry-specific directories, fix NAP inconsistencies via Whitespark or Yext, and remove duplicate listings." },
        { "@type": "HowToStep", "position": 4, "name": "On-page + schema",        "text": "LocalBusiness schema on every key page, location landing pages with neighborhood-specific content, internal linking from service pages." },
        { "@type": "HowToStep", "position": 5, "name": "Reviews + monitoring",    "text": "Review acquisition strategy, response templates, monthly Local Pack tracking, and 90-day report on Local Pack position changes." }
      ]
    }
  ]
});

const covered = [
  "Google Business Profile audit + complete optimization (categories, services, posts)",
  "Citation building across 50+ industry-specific directories",
  "NAP consistency cleanup across Yelp, BBB, Facebook, Apple Maps, Bing Places",
  "LocalBusiness schema on every key page (with vertical-specific subtypes)",
  "Local Pack competitor analysis: top 5 ranking sites for each target city",
  "Neighborhood landing pages with embedded maps + service area schema",
  "Review acquisition strategy + response templates",
  "GBP photo optimization (geotagged, EXIF-tagged, optimized)",
  "GBP Q&A seeding with target-keyword answers",
  "GBP Posts strategy (offers, events, updates) tied to seasonal demand",
  "Internal linking from service pages to location pages and back",
  "Monthly Local Pack rank tracking on top 5 keywords per location",
];

const tiers = [
  {
    name: "Audit",
    price: "$750",
    duration: "5 business days",
    summary: "Local SEO audit only. GBP audit, citation inventory, NAP consistency, competitor Local Pack analysis. Prioritised fix list, take-it-anywhere.",
    fits: ["Single location", "First Local SEO assessment", "Pre-implementation baseline"],
    href: "/contact/?plan=local-seo-audit",
  },
  {
    name: "Standard",
    price: "$1,500",
    duration: "30 days to deliver, ongoing tracking",
    summary: "Full Local SEO: audit plus GBP optimization, citation building, NAP cleanup, LocalBusiness schema, review acquisition kit. 90-day Local Pack tracking included.",
    fits: ["Single location", "Service businesses", "Want to win the Local Pack"],
    href: "/contact/?plan=local-seo-standard",
    highlight: true,
  },
  {
    name: "Multi-location",
    price: "From $3,000",
    duration: "30-60 days",
    summary: "Multi-location Local SEO for businesses with 2-20 locations. Per-location GBP setup, location landing pages, citation work, schema, and consolidated reporting.",
    fits: ["2-20 locations", "Franchises / chains", "Service-area businesses"],
    href: "/contact/?plan=local-seo-multi",
  },
];

const whenLocal = [
  { num: "01", signal: "Not in the Local Pack for your main service",      detail: "If you do not show in the top 3 Local Pack results when searching '[your service] near me' from your service area, you are losing clicks to whoever does. Local SEO moves you into Pack visibility within 60 to 90 days for most verticals." },
  { num: "02", signal: "Inconsistent NAP across directories",                detail: "Different phone numbers, address formats, or business names across Yelp, BBB, Facebook, and Apple Maps confuse Google's confidence in your business. NAP cleanup is the single highest-impact local SEO fix." },
  { num: "03", signal: "Google Business Profile sitting unoptimized",         detail: "Most small businesses claim their GBP, fill in the basics, and never touch it again. Posts, photos, services, products, Q&A, and category optimization compound over months and pull you up in the Pack." },
  { num: "04", signal: "Competitors with fewer reviews ranking above you",   detail: "If competitors with 30 reviews rank above you with 80 reviews, the issue is not review quantity. It is GBP optimization, citation depth, NAP consistency, or LocalBusiness schema. Audit reveals which one." },
  { num: "05", signal: "Multi-location business with no per-city pages",      detail: "Service-area or multi-location businesses without per-city landing pages cannot rank for '[service] [city]' searches. Each location needs a dedicated page with neighborhood content, embedded maps, and LocalBusiness schema." },
  { num: "06", signal: "Recently moved or rebranded",                          detail: "Address changes, business name changes, and rebranding events are when Local Pack rankings collapse. Local SEO recovery rebuilds citations, updates GBP, and restores NAP consistency on the new identity." },
];

const localPackFactors = [
  { name: "Proximity",   weight: "~30%", detail: "How close your verified business address is to the searcher. Not directly controllable but mitigated by service-area listings and per-location pages." },
  { name: "Relevance",   weight: "~30%", detail: "How closely GBP categories, services, business description, and on-site content match the search intent. Heavily controllable via GBP optimization and on-page work." },
  { name: "Prominence",  weight: "~30%", detail: "Citations across directories, review quantity and quality, brand mentions, backlinks. Built over months via citation work, review acquisition, and content." },
  { name: "Engagement",   weight: "~10%", detail: "GBP posts, photo additions, Q&A activity, profile completion percentage, and recency of updates. Controllable via ongoing GBP management." },
];

const faqs = [
  {
    q: "What is local SEO?",
    a: "Local SEO is the practice of optimizing a business to rank in geographically-targeted search results, especially Google's Local Pack (the map-based 3-result block above organic results). Local SEO covers four pillars: Google Business Profile optimization, citation building and NAP consistency across directories, LocalBusiness schema and on-page optimization, and review acquisition. The output is consistent Local Pack visibility for '[service] near me' and '[service] [city]' searches that drive walk-in or call-in business.",
  },
  {
    q: "How much does local SEO cost?",
    a: "Quality local SEO services run $750 to $5,000+ per location depending on competition and scope. A local SEO audit alone runs $750. Standard single-location local SEO (audit plus implementation plus 90-day tracking) runs $1,500. Multi-location local SEO for 2 to 20 locations starts at $3,000 and scales by location count. Hourly local SEO consultant rates run $80 to $250/hr; the better firms ship fixed-scope work.",
  },
  {
    q: "How long does local SEO take to work?",
    a: "Local Pack ranking improvements typically appear in 60 to 90 days for low-to-medium competition verticals (lawyers, dentists, contractors in suburban markets). Highly competitive verticals (personal injury law in major metros, real estate in dense markets) take 6 to 12 months. The 30-day delivery window covers implementation; the ranking impact compounds as Google reindexes citations, schema, and GBP signals.",
  },
  {
    q: "Do you only serve Maryland businesses?",
    a: "No. Upcoming Brand is Maryland-based, but local SEO work is location-agnostic. We serve Maryland clients (Baltimore, Annapolis, Frederick, Bethesda, Rockville, Silver Spring, Columbia, Towson, Gaithersburg, Germantown) and US-wide remote clients across all 50 states. Local SEO does not require physical proximity to the client; it requires the client's service area to be clearly defined.",
  },
  {
    q: "What is the Local Pack?",
    a: "The Local Pack is Google's map-based search result block that appears for geographically-relevant queries. It shows three businesses with name, rating, address, hours, and a 'Directions' or 'Website' button. The Local Pack appears above organic results for queries like 'dentist near me', 'plumber baltimore', or 'restaurants in annapolis'. Ranking in the Local Pack typically drives more leads than ranking #1 organic for the same query.",
  },
  {
    q: "How is local SEO different from regular SEO?",
    a: "Regular SEO targets organic search results and the broader web. Local SEO specifically targets geographically-bounded results: the Local Pack, Google Maps, and Apple Maps. Local SEO uses different ranking factors (proximity, GBP signals, citations, NAP consistency) than regular SEO (backlinks, content depth, technical signals). Most service businesses need both: regular SEO drives top-of-funnel discovery, local SEO drives bottom-of-funnel calls and visits.",
  },
  {
    q: "Do I need both Google Business Profile and a website?",
    a: "Yes. Google Business Profile alone ranks in the Local Pack but cannot rank for broader organic queries, cannot accept payments, cannot host detailed service descriptions, and cannot capture leads via forms. The website handles organic visibility, conversion, content depth, and credibility. The two work together: GBP drives Pack clicks, the website converts those visits. Local SEO optimizes both.",
  },
];
---
<BaseLayout
  title="Local SEO Services Maryland | Google Business Profile + Local Pack from $1,500 | Upcoming Brand"
  description="Senior local SEO services for Maryland and US-wide remote clients. Google Business Profile optimization, citation building, NAP consistency, Local Pack ranking. Fixed-scope from $1,500. 60-90 day Pack visibility."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='Local SEO services'
      pillText='Local SEO · Maryland + US-wide remote'
      h1Lines={[
        { text: 'Local SEO services' },
        { text: 'from a senior local SEO expert', type: 'accent' },
        { text: 'who actually wins the Local Pack.', type: 'italic' },
      ]}
      lead='<strong>Local SEO services</strong> covering Google Business Profile optimization, citation building, NAP consistency, LocalBusiness schema, and Local Pack ranking strategy. <strong>Maryland-based, US-wide remote.</strong> Hire a <strong>local SEO expert</strong> who handles all four pillars in one engagement. <strong>Fixed-scope from $1,500. Local Pack visibility in 60-90 days.</strong>'
      formName='local-seo-inquiry'
      trustLines={['From $1,500 fixed-scope', '60-90 day Pack visibility', 'Maryland + US-wide remote']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your business',
          subtitle: 'Type, location, GBP status.',
          fields: [
            { type: 'select', name: 'business_type', label: 'Business type', required: true,
              options: ['Law Firm / Attorney', 'Dental / Medical', 'Real Estate', 'Restaurant / Hospitality', 'Contractor / Trades', 'Nonprofit / Church', 'Service business', 'Retail', 'Other'] },
            { type: 'select', name: 'gbp_status', label: 'Google Business Profile status', required: true,
              options: ['Claimed and verified', 'Claimed but unverified', 'Not claimed yet', 'Multiple listings (need cleanup)', 'Not sure'] },
          ],
        },
        {
          title: 'Locations',
          subtitle: 'Where you operate.',
          fields: [
            { type: 'select', name: 'location_count', label: 'Number of locations', required: true,
              options: ['Single location', '2-5 locations', '6-20 locations', '20+ locations', 'Service-area only (no storefront)'] },
            { type: 'text', name: 'primary_city', label: 'Primary city / metro', placeholder: 'Baltimore, MD' },
          ],
        },
        {
          title: 'Engagement scope',
          subtitle: 'Which package fits and what success looks like.',
          fields: [
            { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
              options: ['Local SEO audit ($750)', 'Standard local SEO ($1,500)', 'Multi-location ($3,000+)', 'Not sure yet'] },
            { type: 'textarea', name: 'message', label: 'What is the goal?', placeholder: 'Specific keywords or cities you want to rank for, current Local Pack position.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <section class="lcl-define">
      <div class="container">
        <div class="lcl-define-card">
          <div class="lcl-define-head">
            <span class="lcl-define-pulse" aria-hidden="true"></span>
            <span class="lcl-define-label">Definition</span>
          </div>
          <h2 class="page-h2 lcl-define-h2">
            What is local SEO?
          </h2>
          <p class="lcl-define-answer">
            <strong>Local SEO is the practice of optimizing a business to rank in geographically-targeted search results, especially Google's Local Pack.</strong> Quality local SEO services cover four pillars: Google Business Profile optimization (categories, services, posts, photos, Q&A), citation building and NAP consistency across 50+ directories, LocalBusiness schema and on-page optimization, and review acquisition strategy. The output is consistent Local Pack visibility for "[service] near me" and "[service] [city]" searches that drive walk-in or call-in business.
          </p>
          <div class="lcl-define-meta">
            <div class="lcl-define-meta-item">
              <span class="lcl-define-meta-label">Investment</span>
              <span class="lcl-define-meta-val">$750 (Audit) to $3,000+ (Multi-location)</span>
            </div>
            <div class="lcl-define-meta-item">
              <span class="lcl-define-meta-label">Delivery</span>
              <span class="lcl-define-meta-val">30 days to implement, 60-90 days to rank</span>
            </div>
            <div class="lcl-define-meta-item">
              <span class="lcl-define-meta-label">Outcome</span>
              <span class="lcl-define-meta-val">Local Pack visibility, GBP optimized, citations clean</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="lcl-factors">
      <div class="container">
        <div class="lcl-factors-head">
          <p class="lcl-section-eyebrow">
            <span class="lcl-section-eyebrow-line"></span>
            Local Pack ranking factors
          </p>
          <h2 class="page-h2">
            Four factors <em>that decide Local Pack ranking.</em>
          </h2>
          <p class="page-section-lead">Google's Local Pack ranking is a weighted combination of four signals. Each requires a different optimization approach. A real local SEO engagement targets all four, not just GBP optimization.</p>
        </div>

        <div class="lcl-factors-grid">
          {localPackFactors.map((c) => (
            <article class="lcl-factor-card">
              <div class="lcl-factor-card-head">
                <span class="lcl-factor-name">{c.name}</span>
                <span class="lcl-factor-weight">{c.weight}</span>
              </div>
              <p class="lcl-factor-detail">{c.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="lcl-includes">
      <div class="container">
        <div class="lcl-includes-head">
          <p class="lcl-section-eyebrow">
            <span class="lcl-section-eyebrow-line"></span>
            What we cover
          </p>
          <h2 class="page-h2">
            Twelve checks <em>across four local SEO pillars.</em>
          </h2>
          <p class="page-section-lead">GBP, citations, schema, and reviews. Every engagement ships with a written report including before/after Local Pack position screenshots and a 90-day rank tracking dashboard.</p>
        </div>

        <div class="lcl-includes-grid">
          {covered.map((item, i) => (
            <div class="lcl-include">
              <span class="lcl-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="lcl-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="lcl-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="lcl-tiers" id="tiers">
      <div class="container">
        <div class="lcl-tiers-head">
          <p class="lcl-section-eyebrow">
            <span class="lcl-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>local SEO packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope. Multi-location pricing scales linearly per location after the base setup, with volume discounts for 10+ locations.</p>
        </div>

        <div class="lcl-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`lcl-tier ${t.highlight ? 'lcl-tier-highlight' : ''}`}>
              {t.highlight && <span class="lcl-tier-flag">Most chosen</span>}
              <span class="lcl-tier-name">{t.name}</span>
              <span class="lcl-tier-price">{t.price}</span>
              <span class="lcl-tier-duration">{t.duration}</span>
              <p class="lcl-tier-summary">{t.summary}</p>
              <div class="lcl-tier-fits">
                <span class="lcl-tier-fits-label">Fits</span>
                <ul class="lcl-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="lcl-tier-cta">
                Book {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="lcl-when">
      <div class="container">
        <div class="lcl-when-head">
          <p class="lcl-section-eyebrow">
            <span class="lcl-section-eyebrow-line"></span>
            When you need it
          </p>
          <h2 class="page-h2">
            Six signals <em>your business needs local SEO.</em>
          </h2>
        </div>

        <div class="lcl-when-grid">
          {whenLocal.map((w) => (
            <article class="lcl-when-card">
              <span class="lcl-when-num">{w.num}</span>
              <h3 class="lcl-when-signal">{w.signal}</h3>
              <p class="lcl-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="lcl-faq">
      <div class="container">
        <div class="lcl-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Local SEO FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 lcl-faq-h2">
            Seven questions <em>before you book.</em>
          </h2>
        </div>

        <div class="lcl-faq-list">
          {faqs.map((f, i) => (
            <details class="lcl-faq-item">
              <summary class="lcl-faq-q">
                <span class="lcl-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="lcl-faq-q-text">{f.q}</span>
                <span class="lcl-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="lcl-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Book local SEO</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            Local SEO that wins the Pack.<br>
            <em>$1,500. 60-90 day visibility.</em>
          </h2>
          <p class="page-cta-lead">A free 15-minute call to assess your Local Pack opportunity. We send the SOW within 24 hours and start the audit on signature.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">
              Book local SEO
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/services/wordpress-seo-services/" class="page-cta-ghost-light">
              See full WordPress SEO services
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <BottomFormCTA formName="local-seo-cta"
    formSteps={[
      {
        title: 'Tell us who you are',
        subtitle: 'Just your name and email. 30 seconds.',
        fields: [
          { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
          { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
        ],
      },
      {
        title: 'About your business',
        subtitle: 'Type, location, GBP status.',
        fields: [
          { type: 'select', name: 'business_type', label: 'Business type', required: true,
            options: ['Law Firm / Attorney', 'Dental / Medical', 'Real Estate', 'Restaurant / Hospitality', 'Contractor / Trades', 'Nonprofit / Church', 'Service business', 'Retail', 'Other'] },
          { type: 'select', name: 'gbp_status', label: 'Google Business Profile status', required: true,
            options: ['Claimed and verified', 'Claimed but unverified', 'Not claimed yet', 'Multiple listings (need cleanup)', 'Not sure'] },
        ],
      },
      {
        title: 'Locations',
        subtitle: 'Where you operate.',
        fields: [
          { type: 'select', name: 'location_count', label: 'Number of locations', required: true,
            options: ['Single location', '2-5 locations', '6-20 locations', '20+ locations', 'Service-area only (no storefront)'] },
          { type: 'text', name: 'primary_city', label: 'Primary city / metro', placeholder: 'Baltimore, MD' },
        ],
      },
      {
        title: 'Engagement scope',
        subtitle: 'Which package fits and what success looks like.',
        fields: [
          { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
            options: ['Local SEO audit ($750)', 'Standard local SEO ($1,500)', 'Multi-location ($3,000+)', 'Not sure yet'] },
