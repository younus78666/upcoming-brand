---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-speed-optimization/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Speed Optimization Service | Core Web Vitals & Performance | Upcoming Brand",
      "description": "WordPress speed optimization service from a senior performance expert. Core Web Vitals tuning, image optimization, server response time, render-blocking removal. 90+ Lighthouse contractually. Fixed-scope from $1,500.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                          "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",                      "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Speed Optimization", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Speed Optimization Service",
      "description": "Senior WordPress speed optimization service covering Core Web Vitals (LCP, INP, CLS), TTFB, render-blocking removal, image optimization, asset minification, and database tuning. 90+ Lighthouse contractually. Fixed-scope from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress speed optimization",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress speed optimization",
        "WordPress speed optimization service",
        "Speed up WordPress",
        "WordPress performance optimization",
        "WordPress site speed",
        "WordPress page speed",
        "WordPress speed test",
        "Core Web Vitals WordPress",
        "WordPress LCP optimization",
        "WordPress INP optimization",
        "WordPress CLS optimization",
        "WordPress TTFB",
        "WordPress Lighthouse score",
        "WordPress speed plugin",
        "Optimize WordPress",
        "WordPress slow"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to optimize WordPress speed",
      "description": "The five-phase WordPress speed optimization methodology covering audit, server, frontend, images, and verification.",
      "totalTime": "P7D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Baseline audit",          "text": "Lighthouse + PageSpeed Insights on top 10 pages, Core Web Vitals field data review (LCP, INP, CLS, TTFB), waterfall analysis, plugin and theme inventory." },
        { "@type": "HowToStep", "position": 2, "name": "Server and host tuning",  "text": "TTFB measurement, host evaluation, OPcache and object caching configuration, PHP version bump, database query analysis, and HTTP/3 verification." },
        { "@type": "HowToStep", "position": 3, "name": "Frontend optimization",   "text": "Render-blocking JS and CSS removal, critical CSS inlining, defer / async on non-critical scripts, preconnect and preload tuning, font subsetting." },
        { "@type": "HowToStep", "position": 4, "name": "Image and asset pipeline", "text": "WebP / AVIF conversion, responsive srcset, lazy loading, lossless compression, hero LCP image preload, and CDN setup." },
        { "@type": "HowToStep", "position": 5, "name": "Verification + 30-day monitoring", "text": "Re-test Lighthouse + field data, validate 90+ scores on every key page, set up monthly performance monitoring, and deliver a written before / after report." }
      ]
    }
  ]
});

const optimized = [
  "Core Web Vitals audit (LCP, INP, CLS, TTFB) on top 10 pages",
  "Render-blocking JavaScript and CSS removal",
  "Image optimization: WebP / AVIF conversion, responsive srcset, lazy loading",
  "Server response time tuning (TTFB under 600ms target)",
  "Object caching, OPcache, and database query optimization",
  "Critical CSS inlining and font preload tuning",
  "JavaScript defer / async configuration on non-critical scripts",
  "Plugin audit: identify the 3-5 plugins eating 80% of load time",
  "CDN setup or migration (Cloudflare, BunnyCDN, KeyCDN)",
  "PHP version bump and OPcache tuning if hosting permits",
  "Lighthouse 90+ verification on every key page (contractual)",
  "Written before / after report with field data and recommendations",
];

const tiers = [
  {
    name: "Audit",
    price: "$750",
    duration: "3 business days",
    summary: "WordPress speed audit only. Lighthouse on 10 pages, Core Web Vitals field data review, prioritised fix list. Take to any developer.",
    fits: ["Sites under 50 pages", "Take-it-anywhere fix list", "Pre-implementation baseline"],
    href: "/contact/?plan=speed-audit",
  },
  {
    name: "Standard",
    price: "$1,500",
    duration: "5-7 business days",
    summary: "Full WordPress speed optimization: audit plus implementation. Core Web Vitals tuning, image pipeline, render-blocking removal, server cache configuration. 90+ Lighthouse contractually.",
    fits: ["Sites under 200 pages", "Marketing sites", "First serious optimization sprint"],
    href: "/contact/?plan=speed-standard",
    highlight: true,
  },
  {
    name: "Custom",
    price: "From $4,500",
    duration: "2-3 weeks",
    summary: "Complex WordPress speed optimization: WooCommerce stores, multilingual sites, custom plugins, JS-heavy frontends. Full waterfall and database deep-dive.",
    fits: ["WooCommerce / 500+ products", "Multilingual / multisite", "JS-heavy custom themes"],
    href: "/contact/?plan=speed-custom",
  },
];

const whenSpeed = [
  { num: "01", signal: "Lighthouse score under 50",            detail: "If your mobile Lighthouse score is below 50 you are losing rankings to competitors who score 80+. Speed optimization moves you to 90+ on every key page in one engagement." },
  { num: "02", signal: "TTFB above 1.5 seconds",                 detail: "Time to First Byte above 1.5s means the server is the bottleneck. Object caching, OPcache tuning, and database query optimization typically halve TTFB without changing hosts." },
  { num: "03", signal: "Mobile Core Web Vitals failing",         detail: "If LCP is above 2.5s, INP above 200ms, or CLS above 0.1 on mobile, you are flagged in Search Console. Speed optimization fixes the field data, not just the lab score." },
  { num: "04", signal: "Site feels slow but Lighthouse passes",  detail: "Lighthouse runs on a fast simulated connection. Real users on 4G see different numbers. Field data audits reveal the gap between lab tests and reality." },
  { num: "05", signal: "Plugin bloat after years of additions",   detail: "Sites accumulating 30+ active plugins almost always have 5-10 that contribute zero value while eating 60% of load time. A plugin audit identifies what to cut." },
  { num: "06", signal: "About to migrate to a new host",          detail: "Hosts oversell speed. Migrating to Kinsta, WP Engine, or Cloudways without optimization rarely fixes more than 30% of the problem. Optimize first, then migrate if still needed." },
];

const speedVsPlugin = [
  { factor: "Diagnosis depth",      free: "Plugin scan: enable cache, ship, hope",                paid: "Lighthouse + field data + waterfall on top 10 pages" },
  { factor: "Core Web Vitals",      free: "Plugin tries to fix LCP via blanket lazy-load",         paid: "Per-page LCP element identification, hero preload, INP root cause analysis" },
  { factor: "Render-blocking",      free: "Generic defer-all-scripts (breaks the site)",           paid: "Per-script analysis: keep critical, defer non-critical, async measurement scripts" },
  { factor: "Image pipeline",       free: "Bulk lossy compression",                                  paid: "WebP / AVIF conversion, responsive srcset, hero preload, lazy load below the fold" },
  { factor: "Server response time", free: "Skipped (plugin can't touch the server)",                 paid: "TTFB measurement, OPcache tuning, object cache config, database query review" },
  { factor: "Verification",          free: "Hope Lighthouse improves",                                paid: "Pre/post Lighthouse 90+ on every key page, contractually" },
];

const cwvFrames = [
  { name: "LCP",   full: "Largest Contentful Paint", target: "Under 2.5 seconds", detail: "Hero image or main content render time. Optimized via image preload, server response, and render-blocking removal." },
  { name: "INP",   full: "Interaction to Next Paint", target: "Under 200 ms",     detail: "Time from user click / tap to next visual update. Optimized via JavaScript defer, third-party script audit, and main-thread work reduction." },
  { name: "CLS",   full: "Cumulative Layout Shift",   target: "Under 0.1",        detail: "Visual stability score. Fixed via reserved image dimensions, font display swap, and ad / embed slot reservations." },
  { name: "TTFB",  full: "Time to First Byte",        target: "Under 600 ms",     detail: "Server response time. Optimized via object caching, OPcache, PHP tuning, database queries, and host-level configuration." },
];

const faqs = [
  {
    q: "What is WordPress speed optimization?",
    a: "WordPress speed optimization is the process of reducing how long your WordPress site takes to load and become interactive. Quality WordPress speed optimization covers five layers: server response (TTFB, caching, PHP tuning), frontend rendering (render-blocking JS / CSS, critical CSS), images (WebP / AVIF, lazy loading, hero preload), Core Web Vitals (LCP, INP, CLS field data), and ongoing monitoring. The output is a Lighthouse 90+ score on every key page along with green Core Web Vitals in Search Console.",
  },
  {
    q: "How much does WordPress speed optimization cost?",
    a: "Quality WordPress speed optimization services run $750 to $5,000+ depending on site complexity. A speed audit alone runs $750. Standard speed optimization (audit plus full implementation) runs $1,500 for sites under 200 pages. Custom speed optimization for WooCommerce stores, multilingual sites, or JS-heavy custom themes starts at $4,500. Hourly WordPress speed expert rates run $80 to $250/hr; the better firms ship fixed-scope work.",
  },
  {
    q: "Can a free WordPress speed plugin replace this service?",
    a: "Free WordPress speed plugins (W3 Total Cache, WP Super Cache, Autoptimize) handle 30 to 50 percent of the work and break the rest. They enable caching but cannot diagnose render-blocking specifics, identify the LCP element on each page, or fix server-side TTFB. Paid plugins (WP Rocket, FlyingPress, Perfmatters) are better but still apply the same blanket settings to every site. Real WordPress speed optimization requires per-page analysis a plugin cannot perform.",
  },
  {
    q: "What is a good WordPress Lighthouse score?",
    a: "A good WordPress Lighthouse mobile score is 90 or above. Anything 70 to 89 is acceptable but suboptimal. Below 70 is actively losing search visibility. Desktop scores of 95+ are achievable for most marketing sites; mobile is harder because Lighthouse simulates a slower 4G connection. Our contract guarantees 90+ mobile Lighthouse on every key page after optimization.",
  },
  {
    q: "How long does WordPress speed optimization take?",
    a: "Standard WordPress speed optimization takes 5 to 7 business days from kickoff to delivery. The audit phase takes 1 to 2 days. Implementation runs 2 to 4 days. Verification and monitoring setup runs 1 day. Custom projects (WooCommerce, multilingual, JS-heavy themes) take 2 to 3 weeks. We commit to a delivery date in the SOW and credit 10 percent of the fee if we miss it.",
  },
  {
    q: "Do you guarantee a specific Lighthouse score?",
    a: "Yes. The Standard and Custom packages guarantee 90+ mobile Lighthouse on every key page contractually. The Audit-only package does not guarantee a score because we are not implementing the fixes. If we miss the contractual score on a Standard or Custom engagement, we work the issue at no charge until it passes or refund 50 percent of the fee.",
  },
  {
    q: "Will speeding up my WordPress site improve rankings?",
    a: "Speed is one of many ranking factors but it has measurable impact in two specific cases. First, when a site is below the Core Web Vitals threshold, Google treats it as a usability signal that suppresses rankings. Moving from red to green typically returns 5 to 15 percent of lost traffic. Second, when bounce rate is high, faster pages reduce bounce, which improves engagement signals. Speed alone will not lift a site that has weak content or no schema; it removes a barrier rather than creating new traffic.",
  },
];
---
<BaseLayout
  title="WordPress Speed Optimization Service | Core Web Vitals from $1,500 | Upcoming Brand"
  description="Senior WordPress speed optimization service: Core Web Vitals (LCP, INP, CLS), render-blocking removal, image pipeline, server tuning. 90+ Lighthouse contractually. Fixed-scope from $1,500. 5-day delivery."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='WordPress speed optimization'
      pillText='WordPress Speed · Maryland'
      h1Lines={[
        { text: 'WordPress speed optimization' },
        { text: 'from a senior performance expert', type: 'accent' },
        { text: 'who actually hits 90+ Lighthouse.', type: 'italic' },
      ]}
      lead='<strong>WordPress speed optimization service</strong> covering Core Web Vitals (LCP, INP, CLS), render-blocking removal, image pipeline, server response time, and database tuning. Hire a <strong>WordPress speed expert</strong> who handles all five layers in one engagement. <strong>Fixed-scope from $1,500. 90+ Lighthouse contractually.</strong>'
      formName='wp-speed-inquiry'
      trustLines={['From $1,500 fixed-scope', '90+ Lighthouse guaranteed', '5-7 day delivery']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'What we will speed up.',
          fields: [
            { type: 'url',  name: 'site_url', label: 'WordPress site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
            { type: 'select', name: 'lighthouse_score', label: 'Current mobile Lighthouse score', required: true,
              options: ['Under 30', '30 to 49', '50 to 69', '70 to 89', '90+', 'Not sure / never tested'] },
          ],
        },
        {
          title: 'Site complexity',
          subtitle: 'Host, page count, and store status.',
          fields: [
            { type: 'select', name: 'current_host', label: 'Current host', required: true,
              options: ['Kinsta', 'WP Engine', 'SiteGround', 'Cloudways', 'Bluehost', 'GoDaddy', 'Hostinger', 'Other / Not sure'] },
            { type: 'select', name: 'site_type', label: 'Site type', required: true,
              options: ['Marketing site under 50 pages', 'Marketing site 50 to 200 pages', 'Blog / content site 200+ pages', 'WooCommerce store', 'Multilingual / multisite', 'Custom JS-heavy theme'] },
          ],
        },
        {
          title: 'Engagement scope',
          subtitle: 'Which package fits and what success looks like.',
          fields: [
            { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
              options: ['Speed audit only ($750)', 'Standard speed optimization ($1,500)', 'Custom / WooCommerce ($4,500+)', 'Not sure yet'] },
            { type: 'textarea', name: 'message', label: 'What is slow about your site?', placeholder: 'Specific pages, recent slowdown, conversion drop, ranking loss.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- DEFINITION -->
    <section class="spd-define">
      <div class="container">
        <div class="spd-define-card">
          <div class="spd-define-head">
            <span class="spd-define-pulse" aria-hidden="true"></span>
            <span class="spd-define-label">Executive Summary</span>
          </div>
          <h2 class="page-h2 spd-define-h2">
            What is WordPress speed optimization?
          </h2>
          <p class="spd-define-answer">
            <strong>WordPress speed optimization is the process of reducing how long your WordPress site takes to load and become interactive.</strong> Quality WordPress speed optimization services cover five layers: server response (TTFB, object caching, PHP tuning), frontend rendering (render-blocking JS and CSS, critical CSS), image pipeline (WebP, AVIF, lazy loading, hero preload), Core Web Vitals tuning (LCP, INP, CLS field data), and ongoing monitoring. The output is a Lighthouse 90+ score on every key page along with green Core Web Vitals in Search Console.
          </p>
          <div class="spd-define-meta">
            <div class="spd-define-meta-item">
              <span class="spd-define-meta-label">Investment</span>
              <span class="spd-define-meta-val">$750 (Audit) to $5,000+ (Custom)</span>
            </div>
            <div class="spd-define-meta-item">
              <span class="spd-define-meta-label">Delivery</span>
              <span class="spd-define-meta-val">5-7 business days for standard scope</span>
            </div>
            <div class="spd-define-meta-item">
              <span class="spd-define-meta-label">Outcome</span>
              <span class="spd-define-meta-val">90+ mobile Lighthouse, green Core Web Vitals</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CORE WEB VITALS BREAKDOWN -->
    <section class="spd-cwv">
      <div class="container">
        <div class="spd-cwv-head">
          <p class="spd-section-eyebrow">
            <span class="spd-section-eyebrow-line"></span>
            Core Web Vitals
          </p>
          <h2 class="page-h2">
            Four metrics <em>that decide your search visibility.</em>
          </h2>
          <p class="page-section-lead">Google's Core Web Vitals are the field-data benchmarks that decide whether Search Console flags your site as slow. WordPress speed optimization targets each metric individually, not via a blanket plugin setting.</p>
        </div>

        <div class="spd-cwv-grid">
          {cwvFrames.map((c) => (
            <article class="spd-cwv-card">
              <div class="spd-cwv-card-head">
                <span class="spd-cwv-abbr">{c.name}</span>
                <span class="spd-cwv-target">{c.target}</span>
              </div>
              <h3 class="spd-cwv-name">{c.full}</h3>
              <p class="spd-cwv-detail">{c.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- WHAT WE OPTIMIZE -->
    <section class="spd-includes">
      <div class="container">
        <div class="spd-includes-head">
          <p class="spd-section-eyebrow">
            <span class="spd-section-eyebrow-line"></span>
            What we optimize
          </p>
          <h2 class="page-h2">
            Twelve checks <em>across five layers.</em>
          </h2>
          <p class="page-section-lead">Server, frontend, images, Core Web Vitals, and verification. Every fix is documented with before / after numbers in the final report.</p>
        </div>

        <div class="spd-includes-grid">
          {optimized.map((item, i) => (
            <div class="spd-include">
              <span class="spd-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="spd-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="spd-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TIERS -->
    <section class="spd-tiers" id="tiers">
      <div class="container">
        <div class="spd-tiers-head">
          <p class="spd-section-eyebrow">
            <span class="spd-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress speed packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="spd-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`spd-tier ${t.highlight ? 'spd-tier-highlight' : ''}`}>
              {t.highlight && <span class="spd-tier-flag">Most chosen</span>}
              <span class="spd-tier-name">{t.name}</span>
              <span class="spd-tier-price">{t.price}</span>
              <span class="spd-tier-duration">{t.duration}</span>
              <p class="spd-tier-summary">{t.summary}</p>
              <div class="spd-tier-fits">
                <span class="spd-tier-fits-label">Fits</span>
                <ul class="spd-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="spd-tier-cta">
                Book {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHEN -->
    <section class="spd-when">
      <div class="container">
        <div class="spd-when-head">
          <p class="spd-section-eyebrow">
            <span class="spd-section-eyebrow-line"></span>
            When you need it
          </p>
          <h2 class="page-h2">
            Six signals <em>your WordPress site needs speed optimization.</em>
          </h2>
        </div>

        <div class="spd-when-grid">
          {whenSpeed.map((w) => (
            <article class="spd-when-card">
              <span class="spd-when-num">{w.num}</span>
              <h3 class="spd-when-signal">{w.signal}</h3>
              <p class="spd-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON: paid vs plugin -->
    <section class="spd-compare">
      <div class="container">
        <div class="spd-compare-head">
          <p class="spd-section-eyebrow">
            <span class="spd-section-eyebrow-line"></span>
            Paid service vs free WordPress speed plugin
          </p>
          <h2 class="page-h2">
            What a paid speed engagement covers <em>that a free WordPress speed plugin skips.</em>
          </h2>
        </div>

        <div class="spd-compare-table-wrap">
          <table class="spd-compare-table">
            <thead>
              <tr>
                <th class="spd-compare-th-factor">Optimization area</th>
                <th class="spd-compare-th-free">Free speed plugin</th>
                <th class="spd-compare-th-paid">
                  <span class="spd-compare-amber-pill">Paid engagement</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {speedVsPlugin.map((c) => (
                <tr>
                  <td class="spd-compare-factor">{c.factor}</td>
                  <td class="spd-compare-free">
                    <span class="spd-compare-icon-no" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </span>
                    {c.free}
                  </td>
                  <td class="spd-compare-paid">
                    <span class="spd-compare-icon-yes" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {c.paid}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="spd-faq">
      <div class="container">
        <div class="spd-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">WordPress speed FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 spd-faq-h2">
            Seven questions <em>before you book.</em>
          </h2>
        </div>

        <div class="spd-faq-list">
          {faqs.map((f, i) => (
            <details class="spd-faq-item">
              <summary class="spd-faq-q">
                <span class="spd-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="spd-faq-q-text">{f.q}</span>
                <span class="spd-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="spd-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
</main>
  <BottomFormCTA formName="wp-speed-cta"
    formSteps={[
      {
        title: 'Tell us who you are',
        subtitle: 'Just your name and email. 30 seconds.',
