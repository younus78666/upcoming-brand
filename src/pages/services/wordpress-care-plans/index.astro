---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/services/wordpress-care-plans/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Care Plans & Maintenance Services Maryland | Upcoming Brand",
      "description": "WordPress care plans from $150/month. Weekly updates, off-site backups, uptime monitoring, security patching, and a 4-hour SLA direct to the founder. Month-to-month, no annual contracts.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",            "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Care Plans", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Care Plans & Maintenance Services",
      "description": "Monthly WordPress maintenance services: core + plugin updates, off-site backups, uptime monitoring, security patching, and 4-hour SLA support direct from the founder. Month-to-month, no annual contract.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress maintenance",
      "areaServed": { "@type": "Country", "name": "United States" },
      "knowsAbout": [
        "WordPress maintenance services",
        "WordPress care plans",
        "WordPress care plan",
        "WordPress maintenance plan",
        "WordPress website maintenance",
        "WordPress site maintenance",
        "WordPress support",
        "WordPress support services",
        "Website maintenance services",
        "WordPress updates",
        "WordPress backups",
        "WordPress security monitoring",
        "Ongoing WordPress maintenance",
        "WordPress maintenance retainer"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "WordPress Care Plan Tiers",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Essential Care Plan" }, "price": "150", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "150", "priceCurrency": "USD", "billingDuration": "P1M" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Growth Care Plan" },    "price": "275", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "275", "priceCurrency": "USD", "billingDuration": "P1M" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pro Care Plan" },        "price": "400", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "400", "priceCurrency": "USD", "billingDuration": "P1M" } }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      }
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to maintain a WordPress website",
      "description": "The four-week WordPress maintenance schedule that protects performance, security, and rankings between major releases.",
      "totalTime": "P1M",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Test plugin and core updates on staging",   "text": "Before pushing any update to production, test on a staging clone. If anything breaks, roll back. Document each update for the monthly report." },
        { "@type": "HowToStep", "position": 2, "name": "Run an off-site encrypted backup",          "text": "Full database plus uploads to encrypted off-site storage (S3 or Google Drive). Verified weekly with a restore test." },
        { "@type": "HowToStep", "position": 3, "name": "Monitor uptime and security",                "text": "5-minute interval uptime monitoring with email alerts. Wordfence security scan plus manual review of changed files and access patterns." },
        { "@type": "HowToStep", "position": 4, "name": "Audit performance and schema",                "text": "Lighthouse plus PageSpeed Insights. Flag any page that drops below 90. Verify LocalBusiness, FAQ, Service schemas still render. Check Search Console for warnings." }
      ]
    }
  ]
});

const definitionRoles = [
  {
    type: "WordPress care plan",
    summary: "Recurring monthly engagement covering technical maintenance, monitoring, security, and limited content updates.",
    typical: "$150 - $400/month, month-to-month",
  },
  {
    type: "WordPress maintenance services",
    summary: "Broader category that covers care plans plus one-off engagements (recovery, audits, specific updates).",
    typical: "Plans monthly, projects quoted per scope",
  },
  {
    type: "WordPress support",
    summary: "Reactive break/fix engagement, hourly or block-of-hours, no proactive maintenance schedule.",
    typical: "$150/hr or $1,500 / 10-hour block",
  },
];

const whenCare = [
  {
    num: "01",
    signal: "You need updates but no in-house WordPress person",
    detail: "If nobody on your team logs into wp-admin weekly to test plugin updates and run backups, your site is already drifting toward a security incident or a broken update. A WordPress maintenance plan stops the drift.",
  },
  {
    num: "02",
    signal: "Your last DIY update broke the site",
    detail: "WooCommerce or Elementor pushed an update, you clicked update, the homepage broke. Now you're paying a freelancer $300 to roll back. A care plan tests every update on staging first, no production breakage.",
  },
  {
    num: "03",
    signal: "You don't have working backups",
    detail: "If your hosting provider's daily backup is your only safety net, you're one ransomware attack away from rebuilding from scratch. Off-site encrypted backups are the foundation of every legitimate WordPress maintenance service.",
  },
  {
    num: "04",
    signal: "You can't reach a human when something breaks",
    detail: "$99/month bot plans don't have a human you can email at 11 PM when checkout breaks. A real care plan has a 1-4 hour human SLA, including weekends on Pro tier.",
  },
  {
    num: "05",
    signal: "Site speed has slowly degraded",
    detail: "Lighthouse was 92 at launch, now it's 67. Plugin bloat, image optimization drift, server config changes. A monthly Core Web Vitals audit catches it before rankings drop.",
  },
  {
    num: "06",
    signal: "You're paying $300/hour every time something breaks",
    detail: "Ad-hoc emergency support is the most expensive way to maintain a site. A predictable $150-$400/month care plan replaces $1,000+ emergency invoices with proactive prevention.",
  },
];

const tiers = [
  {
    name: "Essential",
    price: "$150",
    cadence: "/month",
    summary: "The minimum viable care plan. Updates, backups, monitoring, security. For sites under ~10,000 monthly visitors.",
    features: [
      "Weekly WordPress core + plugin updates",
      "Daily off-site backups (S3 / Google Drive)",
      "Uptime monitoring with 5-minute checks",
      "Security firewall + malware scanning",
      "Monthly performance check (Lighthouse)",
      "4-hour business-hours support SLA",
    ],
    notIncluded: [
      "Content updates",
      "Design changes",
      "SEO reports",
    ],
    href: "/contact/?plan=essential",
  },
  {
    name: "Growth",
    price: "$275",
    cadence: "/month",
    summary: "Everything in Essential plus content updates and quarterly SEO reporting. For sites under ~50,000 monthly visitors.",
    features: [
      "Everything in Essential, plus:",
      "Up to 1 hour of content updates per month",
      "Quarterly Search Console + ranking report",
      "Quarterly Core Web Vitals audit",
      "Schema validation + maintenance",
      "Priority support (2-hour SLA)",
    ],
    notIncluded: [
      "Net-new pages or features",
      "Major redesigns",
    ],
    href: "/contact/?plan=growth",
    highlight: true,
  },
  {
    name: "Pro",
    price: "$400",
    cadence: "/month",
    summary: "For high-traffic sites or businesses where the website is the primary lead-gen channel. Full strategic care.",
    features: [
      "Everything in Growth, plus:",
      "Up to 3 hours of content updates per month",
      "Monthly Search Console + ranking report",
      "Monthly Core Web Vitals audit",
      "1 strategic call per quarter",
      "1-hour SLA, weekend availability",
    ],
    notIncluded: [
      "Net-new feature development",
      "Major redesigns or migrations",
    ],
    href: "/contact/?plan=pro",
  },
];

const monthlyTasks = [
  { week: "Week 1", task: "Plugin updates",      detail: "Test on staging first. Roll back if any issue. Document each update in the monthly report." },
  { week: "Week 1", task: "WordPress core",      detail: "Test on staging. Apply during off-peak hours. Verify forms, schema, performance afterwards." },
  { week: "Week 2", task: "Off-site backup",     detail: "Full database + uploads to encrypted off-site storage (S3 or Google Drive). Verified weekly." },
  { week: "Week 2", task: "Uptime check",        detail: "5-minute interval monitoring with email alerts on any 1-minute outage. SLA-tracked." },
  { week: "Week 3", task: "Security scan",       detail: "Wordfence + manual review of changed files, suspicious logins, and access patterns." },
  { week: "Week 3", task: "Performance audit",   detail: "Lighthouse + PageSpeed Insights. Flag any page that drops below 90." },
  { week: "Week 4", task: "Schema validation",   detail: "Verify LocalBusiness, FAQ, Service schemas still render. Check Search Console for warnings." },
  { week: "Week 4", task: "Monthly report",      detail: "Written email with all updates applied, performance numbers, uptime %, and any issues found." },
];

const slaBreakdown = [
  { tier: "Essential",         sla: "4 business hours", channel: "Email",            availability: "Mon-Fri" },
  { tier: "Growth",            sla: "2 business hours", channel: "Email + Slack",   availability: "Mon-Fri" },
  { tier: "Pro",               sla: "1 hour",           channel: "Email + Slack + SMS", availability: "Mon-Fri + weekends" },
];

const faqs = [
  {
    q: "Do I have to be locked into an annual contract?",
    a: "No. All Upcoming Brand WordPress care plans are month-to-month with no minimum term. Cancel any time with no penalty or fee. We don't believe in trapping clients with annual commitments. If the plan isn't worth it, you should be able to leave. About 90% of clients who start a care plan stay on it indefinitely; the few who cancel typically do so because they sold the business or shut down the site.",
  },
  {
    q: "What's the difference between a $99/month plan and a $150 care plan?",
    a: "$99/month plans are typically automated. A bot updates plugins on a schedule with no testing, no backups before changes, no manual review, and no human you can actually email when something breaks. Our care plans involve a person testing every update on staging first, rolling back if anything breaks, monitoring uptime live, and personally responding to your emails within hours. The $51 difference buys real human accountability instead of automation that fails silently.",
  },
  {
    q: "What does the 4-hour SLA actually cover?",
    a: "The 4-hour SLA on Essential (2-hour on Growth, 1-hour on Pro) covers our response to your email or ticket, not necessarily resolution. We respond within the SLA window, diagnose the issue, and either fix it immediately (usually) or give you a written ETA for resolution. For critical issues (site down, security breach), we begin work immediately regardless of SLA. We've never let a critical incident sit unaddressed past 30 minutes.",
  },
  {
    q: "Can I include content changes in the plan, or is that extra?",
    a: "Essential covers technical maintenance only, no content edits. Growth includes 1 hour of content updates per month (rolls over up to 3 months unused). Pro includes 3 hours per month. Any content work beyond your plan's allotment is billed at $150/hr in 30-minute increments, with a written estimate before work begins. Most clients on Growth or Pro never exceed their monthly content allotment.",
  },
  {
    q: "What happens if my site gets hacked?",
    a: "Care plans include malware recovery as part of the security work. We restore from the most recent clean backup, identify and patch the vulnerability, scan for residual malware, and document the incident in writing. There's no hourly billing for incident response on care plan clients. If your site isn't on a care plan, recovery is billed at $150/hr or as a $1,000 fixed-scope security recovery engagement.",
  },
  {
    q: "Do care plans cover the hosting bill?",
    a: "No. You pay your own hosting (we recommend specific hosts at three price points: Cloudways for budget, Kinsta for mid-tier, WP Engine for enterprise). Care plans cover the maintenance, monitoring, and support, not the server. We chose this structure so you keep ownership of the hosting account; if you ever cancel the care plan, you don't lose your server.",
  },
  {
    q: "Can I add a care plan later, after the project launches?",
    a: "Yes. Care plans can start at any time: at launch, three months later, or three years later. Most projects start their care plan at launch because the 30-day post-launch monitoring is included in the build engagement, and clients tend to want continuity. But there's no cliff. You can pause the relationship at launch and pick up a care plan later when it makes sense.",
  },
];
---
<BaseLayout
  title="WordPress Maintenance Services & Care Plans | Website Maintenance from $150/mo | Upcoming Brand"
  description="WordPress maintenance services and care plans from $150/month. Website maintenance, weekly updates, off-site backups, uptime monitoring, security patching, 4-hour SLA direct to the founder. Month-to-month, no annual contracts."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WordPress maintenance & care plans'
      pillText='WordPress Specialists · Maryland'
      h1Lines={[
        { text: 'WordPress maintenance' },
        { text: 'that is actually maintained.', type: 'accent' },
        { text: 'Not a bot, not a help desk.', type: 'italic' },
      ]}
      lead='<strong>WordPress maintenance services and care plans from $150/month.</strong> A real <strong>WordPress website maintenance plan</strong> with weekly core + plugin updates tested on staging, daily off-site backups, uptime monitoring, security patching, and a written monthly report. <strong>4-hour SLA direct to the founder. Month-to-month, no annual contract.</strong>'
      formName='wp-care-plan-inquiry'
      trustLines={['From $150/month', 'Month-to-month', '4-hour SLA · Direct to founder']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'Where your WordPress site lives.',
          fields: [
            { type: 'url',  name: 'site_url',     label: 'WordPress site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
            { type: 'select', name: 'current_host', label: 'Current host', required: true,
              options: ['Kinsta', 'WP Engine', 'SiteGround', 'Cloudways', 'Bluehost', 'GoDaddy', 'Hostinger', 'Other / Not sure'] },
          ],
        },
        {
          title: 'Site details',
          subtitle: 'Plugin count and approximate traffic.',
          fields: [
            { type: 'select', name: 'plugin_count', label: 'Active plugins', required: true,
              options: ['Under 10', '10 to 25', '25 to 50', '50+', 'Not sure'] },
            { type: 'select', name: 'monthly_traffic', label: 'Monthly visitors', required: true,
              options: ['Under 1,000', '1,000 to 10,000', '10,000 to 50,000', '50,000+', 'Not sure'] },
          ],
        },
        {
          title: 'Plan tier',
          subtitle: 'Which care plan fits your site.',
          fields: [
            { type: 'select', name: 'plan_tier', label: 'Plan tier', required: true,
              options: ['Essential ($150/mo)', 'Pro ($350/mo)', 'WooCommerce ($550/mo)', 'Not sure, recommend one'] },
            { type: 'textarea', name: 'message', label: 'Anything specific?', placeholder: 'Recurring issues, slow load, security concerns.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- ====== DEFINITION (Know intent + AI Overview citation) ====== -->
    <section class="care-define">
      <div class="container">
        <div class="care-define-card">
          <div class="care-define-head">
            <span class="care-define-pulse" aria-hidden="true"></span>
            <span class="care-define-label">In plain English</span>
          </div>
          <h2 class="page-h2 care-define-h2">
            What is a WordPress maintenance plan?
          </h2>
          <p class="care-define-answer">
            <strong>A WordPress maintenance plan is a recurring monthly service that keeps a WordPress website updated, secure, monitored, and performant.</strong> The strongest WordPress website maintenance services include weekly core and plugin updates tested on staging, daily off-site backups, uptime monitoring, security patching, and a defined SLA for support. Care plans are sometimes called WordPress site maintenance, WordPress support services, or website maintenance services depending on the agency.
          </p>

          <div class="care-define-roles">
            {definitionRoles.map((r) => (
              <div class="care-define-role">
                <span class="care-define-role-type">{r.type}</span>
                <p class="care-define-role-summary">{r.summary}</p>
                <span class="care-define-role-typical">{r.typical}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ====== WHEN YOU NEED ONE (Causation frame) ====== -->
    <section class="care-when">
      <div class="container">
        <div class="care-when-head">
          <p class="care-section-eyebrow">
            <span class="care-section-eyebrow-line"></span>
            When you need one
          </p>
          <h2 class="page-h2">
            Six signals <em>you need a WordPress maintenance service.</em>
          </h2>
          <p class="page-section-lead">If two or more match, the right answer is a real WordPress care plan, not a bot or a $99/month "managed hosting" upsell. Predictable monthly maintenance prevents most of the issues clients pay emergency rates to fix.</p>
        </div>

        <div class="care-when-grid">
          {whenCare.map((w) => (
            <article class="care-when-card">
              <span class="care-when-num">{w.num}</span>
              <h3 class="care-when-signal">{w.signal}</h3>
              <p class="care-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="care-tiers" id="tiers">
      <div class="container">
        <div class="care-tiers-head">
          <p class="care-section-eyebrow">
            <span class="care-section-eyebrow-line"></span>
            Three plans
          </p>
          <h2 class="page-h2">
            Three care plans. <em>One fixed monthly price.</em>
          </h2>
          <p class="page-section-lead">Every plan is month-to-month with no minimum term. Move up, down, or cancel any time without a fee.</p>
        </div>

        <div class="care-tiers-grid">
          {tiers.map((t) => (
            <article class={`care-tier ${t.highlight ? 'care-tier-highlight' : ''}`}>
              {t.highlight && <span class="care-tier-flag">Most chosen</span>}

              <span class="care-tier-name">{t.name}</span>

              <div class="care-tier-price-block">
                <span class="care-tier-price">{t.price}</span>
                <span class="care-tier-cadence">{t.cadence}</span>
              </div>

              <p class="care-tier-summary">{t.summary}</p>

              <a href={t.href} class={`care-tier-cta ${t.highlight ? 'care-tier-cta-amber' : ''}`}>
                Start {t.name}
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>

              <div class="care-tier-divider">
                <span class="care-tier-divider-label">What's included</span>
              </div>

              <ul class="care-tier-features">
                {t.features.map((f) => (
                  <li>
                    <span class="care-tier-check" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {f}
                  </li>
                ))}
              </ul>

              {t.notIncluded.length > 0 && (
                <ul class="care-tier-excludes">
                  {t.notIncluded.map((nf) => (
                    <li>
                      <span class="care-tier-x" aria-hidden="true">
                        <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </span>
                      {nf}
                    </li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>

        <div class="care-tiers-foot">
          <span class="care-tiers-foot-label">All plans include:</span>
          <span class="care-tiers-foot-pills">
            <span class="care-foot-pill">Month-to-month</span>
            <span class="care-foot-pill">No setup fee</span>
            <span class="care-foot-pill">Direct founder access</span>
            <span class="care-foot-pill">Written monthly report</span>
          </span>
        </div>
      </div>
    </section>

    <!-- ====== MONTHLY TASKS BREAKDOWN ====== -->
    <section class="care-tasks">
      <div class="container">
        <div class="care-tasks-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">What we do every month</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 care-tasks-h2">
            Eight tasks <em>every month, on every plan.</em>
          </h2>
          <p class="care-tasks-lead">A real human runs through this list every week. Updates tested on staging before production. Backups verified, not just scheduled.</p>
        </div>

        <div class="care-tasks-list">
          {monthlyTasks.map((t, i) => (
            <article class="care-task">
              <span class="care-task-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="care-task-content">
                <div class="care-task-meta">
                  <span class="care-task-week">{t.week}</span>
                  <span class="care-task-divider" aria-hidden="true"></span>
                  <span class="care-task-name">{t.task}</span>
                </div>
                <p class="care-task-detail">{t.detail}</p>
              </div>
              <span class="care-task-check" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M3 6.5l2.5 2.5L10 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== SLA TABLE ====== -->
    <section class="care-sla">
      <div class="container">
        <div class="care-sla-head">
          <p class="care-section-eyebrow">
            <span class="care-section-eyebrow-line"></span>
            SLA breakdown
          </p>
          <h2 class="page-h2">
            Response times <em>by plan tier.</em>
          </h2>
          <p class="page-section-lead">SLA covers our first response (diagnosis + ETA). Critical issues like site down or a security breach get worked on immediately regardless of plan tier.</p>
        </div>

        <div class="care-sla-table-wrap">
          <table class="care-sla-table">
            <thead>
              <tr>
                <th>Plan tier</th>
                <th>Response SLA</th>
                <th>Channel</th>
                <th>Availability</th>
              </tr>
            </thead>
            <tbody>
              {slaBreakdown.map((row) => (
                <tr>
                  <td class="care-sla-tier">{row.tier}</td>
                  <td>{row.sla}</td>
                  <td>{row.channel}</td>
                  <td>{row.availability}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="care-sla-foot">
          <span class="care-sla-foot-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </span>
          <p class="care-sla-foot-text">Average actual response time across all tiers in 2025: <strong>47 minutes.</strong> SLA is the floor, not the goal.</p>
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="care-faq">
      <div class="container">
        <div class="care-faq-head">
