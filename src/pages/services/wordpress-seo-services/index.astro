---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-seo-services/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress SEO Services & Schema | WordPress SEO Expert | Upcoming Brand",
      "description": "WordPress SEO services from a senior WordPress SEO expert. Schema architecture, RankMath setup, internal linking, on-page optimization. Fixed-scope from $1,500. Built for businesses that need to rank.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                  "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",              "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress SEO Services", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress SEO Services",
      "description": "Senior WordPress SEO services covering schema architecture, RankMath configuration, internal linking, on-page optimization, and Local Pack ranking. Fixed-scope projects from $1,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress SEO",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "1500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress SEO",
        "WordPress SEO services",
        "WordPress SEO expert",
        "WordPress SEO consultant",
        "WordPress SEO company",
        "WordPress SEO agency",
        "WordPress SEO audit",
        "WordPress SEO optimization",
        "WordPress SEO specialist",
        "SEO for WordPress sites",
        "WordPress local SEO",
        "WordPress schema markup",
        "RankMath setup",
        "Yoast SEO configuration",
        "On-page WordPress optimization"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to optimize a WordPress site for SEO",
      "description": "The five-phase WordPress SEO optimization process for businesses that need to rank in Google.",
      "totalTime": "P30D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Audit current state",          "text": "Schema audit, performance audit, content gap analysis, competitive set review, and Local Pack composition check." },
        { "@type": "HowToStep", "position": 2, "name": "Map the schema graph",         "text": "Identify which schema types your business needs (LocalBusiness, FAQ, Service, vertical-specific) and validate the current implementation." },
        { "@type": "HowToStep", "position": 3, "name": "Implement on-page SEO",        "text": "RankMath or Yoast setup, title and meta optimization, internal linking strategy, image alt text, heading hierarchy." },
        { "@type": "HowToStep", "position": 4, "name": "Fix Core Web Vitals",          "text": "Performance optimization to hit 90+ Lighthouse, since Core Web Vitals is a confirmed Google ranking factor." },
        { "@type": "HowToStep", "position": 5, "name": "Monitor and iterate",          "text": "Search Console + Bing Webmaster setup, weekly monitoring, content gap fills, and ranking baseline tracking." }
      ]
    }
  ]
});

const includes = [
  "Vertical-specific schema (LocalBusiness, FAQ, Service, plus industry types)",
  "RankMath Pro or Yoast SEO Premium configuration",
  "Internal linking strategy and execution",
  "Title tag and meta description optimization across the site",
  "Heading hierarchy and on-page structure audit",
  "Image alt text and structured data review",
  "XML sitemap and robots.txt setup",
  "Search Console and Bing Webmaster Tools integration",
  "Core Web Vitals optimization (90+ Lighthouse)",
  "30-day post-implementation Search Console monitoring",
];

const tiers = [
  {
    name: "Audit",
    price: "$1,500",
    duration: "1 week",
    summary: "WordPress SEO audit with prioritised action list. Schema, performance, content, internal linking, Local Pack composition.",
    fits: ["First-time SEO audit", "Pre-redesign baseline", "Take-it-anywhere fix list"],
    href: "/contact/?plan=seo-audit",
  },
  {
    name: "Implementation",
    price: "$3,500",
    duration: "3-4 weeks",
    summary: "Full on-page WordPress SEO implementation: schema, RankMath, internal links, content optimization, performance tuning.",
    fits: ["Existing WordPress site", "Audit findings to action", "Local Pack target"],
    href: "/contact/?plan=seo-implementation",
    highlight: true,
  },
  {
    name: "Ongoing",
    price: "From $1,500/mo",
    duration: "Monthly",
    summary: "Recurring WordPress SEO partnership: monthly audits, content gap fills, ranking monitoring, schema maintenance.",
    fits: ["Active growth phase", "Competitive vertical", "Multi-location / multi-vertical"],
    href: "/contact/?plan=seo-ongoing",
  },
];

const capabilities = [
  { num: "01", area: "Schema architecture",    detail: "LocalBusiness, FAQ, Service, plus vertical-specific (LegalService, Dentist, IDX). Validated against Google's structured data tools." },
  { num: "02", area: "RankMath / Yoast setup",  detail: "Full configuration of RankMath Pro or Yoast SEO Premium based on what your site already uses. Custom variables for templated pages." },
  { num: "03", area: "Internal linking",        detail: "Topical map, hub-and-spoke architecture, contextual anchor text. Built to spread authority where it converts." },
  { num: "04", area: "Local SEO",                detail: "WordPress local SEO with GBP optimization, citation strategy, NAP consistency, and Local Pack composition analysis." },
  { num: "05", area: "Core Web Vitals",          detail: "Performance optimization to hit 90+ Lighthouse on every page. Image optimization, lazy loading, critical CSS." },
  { num: "06", area: "Content optimization",     detail: "Title tags, meta descriptions, headings, alt text. Optimized for both rankings and AI Overview citations." },
];

const whenSeo = [
  {
    num: "01",
    signal: "Site looks great, ranks for nothing",
    detail: "Beautiful design with empty Search Console. Almost always means missing schema, weak Core Web Vitals, and no internal linking strategy. WordPress SEO services rebuild the technical foundation.",
  },
  {
    num: "02",
    signal: "Lost rankings after a redesign",
    detail: "Common pattern: client redesigns, rankings drop, nobody knows why. Usually a redirect map gone wrong, schema lost in the rebuild, or page weight that tanked Core Web Vitals.",
  },
  {
    num: "03",
    signal: "Competitors outrank you with worse content",
    detail: "Their content is shallower, their site is older, but they outrank you. Schema is doing the heavy lifting. WordPress schema markup catches up the gap.",
  },
  {
    num: "04",
    signal: "Stuck on page two for your main terms",
    detail: "Striking distance keywords (positions 11-30) usually need on-page tightening, internal linking, and schema additions to break into the top 10.",
  },
  {
    num: "05",
    signal: "Local Pack shows competitors, not you",
    detail: "If 'service near me' searches show three competitors instead of your business, the issue is GBP, citations, schema, or all three. WordPress local SEO services fix the technical side.",
  },
  {
    num: "06",
    signal: "Your last SEO consultant disappeared",
    detail: "Hourly retainer, monthly deliverables, no measurable results, and now they're not returning emails. A fixed-scope WordPress SEO engagement replaces the open-ended commitment.",
  },
];

const faqs = [
  {
    q: "What are WordPress SEO services?",
    a: "WordPress SEO services are professional engagements that improve a WordPress site's ability to rank in Google and Bing. Quality WordPress SEO services cover schema architecture (LocalBusiness, FAQ, Service, vertical-specific types), on-page optimization (titles, meta descriptions, headings, internal linking), Core Web Vitals tuning, and Search Console monitoring. The strongest WordPress SEO experts handle all four as a single engagement; cheaper services tend to focus on just one (usually schema or on-page).",
  },
  {
    q: "How much do WordPress SEO services cost?",
    a: "Quality WordPress SEO services run $1,500 to $5,000+ for one-time audits and implementation, or $1,500-$5,000+ per month for ongoing engagements. Hourly WordPress SEO consultant rates run $80-$250/hr; the higher-quality firms have moved to fixed-scope. Cheap WordPress SEO ($200/month plans) typically delivers automated reports with no actual implementation work and is a poor fit for businesses serious about ranking.",
  },
  {
    q: "Do I need a WordPress SEO expert or can I use Yoast / RankMath myself?",
    a: "If you're a content-only site with simple needs, Yoast or RankMath plus a few good guides will get you 70% of the way. For service businesses competing in commercial verticals (legal, medical, dental, real estate, contractor), a WordPress SEO expert is necessary because vertical-specific schema, Local Pack architecture, and internal linking strategy aren't covered by stock plugin tutorials. A specialist also catches the patterns generic checklists miss.",
  },
  {
    q: "What's the difference between RankMath and Yoast SEO?",
    a: "Both are excellent WordPress SEO plugins. RankMath has a more flexible schema framework and better Local Pack support; Yoast has more refined content readability tools and a longer track record. We work in both. The choice depends on what your site already uses and what your team is comfortable maintaining post-launch. We never force a switch unless the existing plugin is materially holding the site back.",
  },
  {
    q: "Is WordPress good for SEO compared to Shopify or Webflow?",
    a: "WordPress is the strongest SEO platform if you set it up correctly. The advantages: full control over schema markup, page speed, URL structure, internal linking, and content architecture. The trade-off: WordPress also lets you set it up wrong (40+ plugin bloat, page builder code soup, no schema). With proper WordPress SEO services, the platform outperforms Shopify and Webflow on every measurable SEO metric for businesses competing in organic search.",
  },
  {
    q: "How long does WordPress SEO take to show results?",
    a: "Schema and on-page changes typically show in Search Console within 4-12 weeks. Local Pack improvements (GBP optimization + citations) often show in 6-12 weeks. Major content gaps and internal linking restructure can take 3-6 months to fully reflect in rankings. SEO results compound over time; what you do in month 1 keeps paying dividends in month 12 if the foundation is solid.",
  },
  {
    q: "Can you fix SEO problems caused by a previous developer?",
    a: "Most often, yes. Common issues we inherit: schema implemented incorrectly (or duplicated), broken redirect maps from previous migrations, plugin bloat killing Core Web Vitals, internal linking that doesn't follow topical authority, and content that targets keywords nobody searches for. The audit ($1,500) surfaces exactly what's broken. The implementation tier ($3,500) fixes it.",
  },
];
---
<BaseLayout
  title="WordPress SEO Services & Schema | Hire a WordPress SEO Expert | Upcoming Brand"
  description="WordPress SEO services from a senior WordPress SEO expert. Schema architecture, RankMath setup, internal linking, on-page optimization. Fixed-scope from $1,500. Built for businesses that need to rank."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WordPress SEO services'
      pillText='WordPress SEO · Maryland'
      h1Lines={[
        { text: 'WordPress SEO services' },
        { text: 'from a senior WordPress SEO expert', type: 'accent' },
        { text: 'who actually moves rankings.', type: 'italic' },
      ]}
      lead={`<strong>WordPress SEO services</strong> covering schema architecture, RankMath setup, internal linking strategy, Core Web Vitals, and Local Pack optimization. Hire a <strong>WordPress SEO expert</strong> who handles all five in one engagement. <strong>Fixed-scope from $1,500.</strong> No retainer traps. No ranking promises we can't keep.`}
      formName='wp-seo-inquiry'
      trustLines={['Audits from $1,500', 'Schema-first architecture', '90+ Lighthouse contractually']}
    />
    <Marquee />

    <!-- ====== DEFINITION (Know intent) ====== -->
    <section class="seo-define">
      <div class="container">
        <div class="seo-define-card">
          <div class="seo-define-head">
            <span class="seo-define-pulse" aria-hidden="true"></span>
            <span class="seo-define-label">Definition</span>
          </div>
          <h2 class="page-h2 seo-define-h2">
            What are WordPress SEO services?
          </h2>
          <p class="seo-define-answer">
            <strong>WordPress SEO services are professional engagements that improve a WordPress website's ability to rank in Google and Bing search results.</strong> The strongest WordPress SEO services bundle four capabilities in one engagement: schema architecture (LocalBusiness, FAQ, Service, vertical-specific types), on-page optimization (titles, meta descriptions, headings, internal linking), Core Web Vitals tuning, and Search Console monitoring. Cheaper services typically focus on just one and miss the compound effect.
          </p>
          <div class="seo-define-meta">
            <div class="seo-define-meta-item">
              <span class="seo-define-meta-label">Also known as</span>
              <span class="seo-define-meta-val">WordPress SEO consulting, WordPress SEO optimization, SEO for WordPress sites</span>
            </div>
            <div class="seo-define-meta-item">
              <span class="seo-define-meta-label">Typical investment</span>
              <span class="seo-define-meta-val">$1,500 (audit) to $5,000+/mo (ongoing partnership)</span>
            </div>
            <div class="seo-define-meta-item">
              <span class="seo-define-meta-label">Time to results</span>
              <span class="seo-define-meta-val">4-12 weeks for technical, 3-6 months for full ranking impact</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== INCLUDES ====== -->
    <section class="seo-includes">
      <div class="container">
        <div class="seo-includes-head">
          <p class="seo-section-eyebrow">
            <span class="seo-section-eyebrow-line"></span>
            What's included
          </p>
          <h2 class="page-h2">
            Ten things <em>every WordPress SEO engagement covers.</em>
          </h2>
          <p class="page-section-lead">Tier-independent. The Audit tier covers the same ground as ongoing engagements; only depth and continuity change.</p>
        </div>

        <div class="seo-includes-grid">
          {includes.map((item, i) => (
            <div class="seo-include">
              <span class="seo-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="seo-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="seo-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="seo-tiers" id="tiers">
      <div class="container">
        <div class="seo-tiers-head">
          <p class="seo-section-eyebrow">
            <span class="seo-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress SEO engagements.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="seo-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`seo-tier ${t.highlight ? 'seo-tier-highlight' : ''}`}>
              {t.highlight && <span class="seo-tier-flag">Most chosen</span>}
              <span class="seo-tier-name">{t.name}</span>
              <span class="seo-tier-price">{t.price}</span>
              <span class="seo-tier-duration">{t.duration}</span>
              <p class="seo-tier-summary">{t.summary}</p>
              <div class="seo-tier-fits">
                <span class="seo-tier-fits-label">Fits</span>
                <ul class="seo-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="seo-tier-cta">
                Start {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== CAPABILITIES (dark) ====== -->
    <section class="seo-capabilities">
      <div class="container">
        <div class="seo-capabilities-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">What we ship</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 seo-capabilities-h2">
            Six WordPress SEO capabilities <em>under one engagement.</em>
          </h2>
          <p class="seo-capabilities-lead">A real WordPress SEO expert ships across all six. Not just a Yoast checklist run, not just a meta-title rewrite. The compound effect is the point.</p>
        </div>

        <div class="seo-capabilities-grid">
          {capabilities.map((c) => (
            <article class="seo-capability">
              <span class="seo-capability-num">{c.num}</span>
              <h3 class="seo-capability-area">{c.area}</h3>
              <p class="seo-capability-detail">{c.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== WHEN YOU NEED IT (Causation) ====== -->
    <section class="seo-when">
      <div class="container">
        <div class="seo-when-head">
          <p class="seo-section-eyebrow">
            <span class="seo-section-eyebrow-line"></span>
            When you need it
          </p>
          <h2 class="page-h2">
            Six signals <em>your site needs WordPress SEO services.</em>
          </h2>
          <p class="page-section-lead">If two or more match, the right answer is a WordPress SEO audit followed by full implementation. Not a hourly consultant retainer.</p>
        </div>

        <div class="seo-when-grid">
          {whenSeo.map((w) => (
            <article class="seo-when-card">
              <span class="seo-when-num">{w.num}</span>
              <h3 class="seo-when-signal">{w.signal}</h3>
              <p class="seo-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="seo-faq">
      <div class="container">
        <div class="seo-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">WordPress SEO FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 seo-faq-h2">
            Seven questions <em>before you hire.</em>
          </h2>
        </div>

        <div class="seo-faq-list">
          {faqs.map((f, i) => (
            <details class="seo-faq-item">
              <summary class="seo-faq-q">
                <span class="seo-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="seo-faq-q-text">{f.q}</span>
                <span class="seo-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="seo-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Ready to start</span>
            <span class="page-eyebrow-line page-eyebrow-line-amber"></span>
          </div>
          <h2 class="page-h2 page-cta-h2">
            Hire a WordPress<br>
            <em>SEO expert who ships.</em>
          </h2>
          <p class="page-cta-lead">A free 45-minute discovery call. We map your competitive set, identify the schema and Local Pack gaps, and send a fixed-scope quote within 48 hours.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">
              Hire the SEO expert
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/services/" class="page-cta-ghost-light">
              View all services
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }
  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(32px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }
  .page-h1-accent::after { display: none; }
  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }
  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }
  .page-lead strong { font-weight: 600; color: var(--ink); }
  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }
  .lp-btn-primary, .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
