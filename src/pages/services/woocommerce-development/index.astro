---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://www.upcomingbrand.com/services/woocommerce-development/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WooCommerce Development Services Maryland | WooCommerce Expert | Upcoming Brand",
      "description": "WooCommerce development services from a senior WooCommerce expert. Custom builds, subscriptions, multi-vendor, Stripe integration. Schema-first, 90+ Lighthouse, fixed-scope from $4,500.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://www.upcomingbrand.com/#website" },
      "about": { "@id": "https://www.upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://www.upcomingbrand.com/#logo" },
      "dateModified": "2026-05-30",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".svc-hero-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                     "item": "https://www.upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",                 "item": "https://www.upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WooCommerce Development", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WooCommerce Development Services",
      "description": "Senior WooCommerce development services covering custom builds, subscriptions, configurators, multi-vendor stores, payment integrations, and ongoing WooCommerce support. Fixed-scope projects from $4,500.",
      "provider": { "@id": "https://www.upcomingbrand.com/#organization" },
      "serviceType": "WooCommerce development",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "4500",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WooCommerce development",
        "WooCommerce development services",
        "WooCommerce developer",
        "WooCommerce expert",
        "Custom WooCommerce development",
        "Hire WooCommerce developer",
        "WooCommerce website development",
        "WooCommerce customization",
        "WooCommerce plugin development",
        "WooCommerce subscriptions",
        "WooCommerce multi-vendor",
        "WooCommerce Stripe integration",
        "WooCommerce support"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to build a WooCommerce store",
      "description": "The five-phase process for building a custom WooCommerce store with schema, performance, and conversion architecture built in.",
      "totalTime": "P8W",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Map products, schema, and checkout flow",   "text": "Catalog audit, product schema mapping (Product, Offer, AggregateRating), payment processor selection, and checkout flow design before any code is written." },
        { "@type": "HowToStep", "position": 2, "name": "Custom theme and Elementor Pro development", "text": "Custom WooCommerce theme with Elementor Pro product layouts on Astra Pro. No $400/year theme licences." },
        { "@type": "HowToStep", "position": 3, "name": "Integrations and payment gateways",         "text": "Stripe, Authorize.net, PayPal integration. Subscriptions, configurators, multi-vendor as scoped." },
        { "@type": "HowToStep", "position": 4, "name": "Schema and performance optimization",        "text": "Product schema across catalog, image optimization, lazy loading, and Core Web Vitals tuning. 90+ Lighthouse on every product page." },
        { "@type": "HowToStep", "position": 5, "name": "Launch and 30-day monitoring",                "text": "Pre-launch performance audit, redirect map (if migrating), DNS cutover, daily Search Console + sales monitoring for 30 days post-launch." }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      "mainEntity": [
        { "@type": "Question", "name": "What is WooCommerce development?", "acceptedAnswer": { "@type": "Answer", "text": "WooCommerce development is the work of building, customizing, and maintaining ecommerce stores on the WooCommerce platform, a free WordPress plugin powering 28% of all online stores. Services range from basic store setup to custom plugin engineering, payment gateway integration, multi-vendor marketplace builds, and performance optimization for high-volume catalogs." } },
        { "@type": "Question", "name": "How much does WooCommerce development cost?", "acceptedAnswer": { "@type": "Answer", "text": "Quality WooCommerce development costs $4,500 to $25,000+ for most small-to-mid stores in 2026. Setup builds (50 products, single payment gateway) start at $4,500. Custom builds with subscriptions, configurators, or multi-vendor run $8,500 to $15,000. Enterprise WooCommerce (high-volume, ERP integration, multi-currency) starts at $15,000 and can reach $80,000+. Hourly WooCommerce developer rates run $80 to $200/hr; higher-quality firms use fixed-scope pricing." } },
        { "@type": "Question", "name": "Should I hire a WooCommerce developer or use Shopify instead?", "acceptedAnswer": { "@type": "Answer", "text": "Use Shopify if you have under 50 simple products, do not need custom checkout flows, and accept the $79+/month platform fee. Hire a WooCommerce developer if you need subscriptions, configurators, multi-vendor, custom plugins, ERP integration, or platform ownership. The break-even point is roughly 12 to 18 months: above that, WooCommerce is almost always cheaper and more flexible." } },
        { "@type": "Question", "name": "What is the difference between a WooCommerce developer and a WooCommerce expert?", "acceptedAnswer": { "@type": "Answer", "text": "In practice, none. Developer implies engineering focus; expert implies senior strategic capability across both engineering and architecture. Quality WooCommerce hires bridge both: they can ship custom code and make architecture decisions about catalog structure, schema and SEO, payment flows, and performance." } },
        { "@type": "Question", "name": "Can you migrate my existing Shopify or BigCommerce store to WooCommerce?", "acceptedAnswer": { "@type": "Answer", "text": "Shopify-to-WooCommerce migrations are one of our most common engagements. The process covers catalog export with product images and metadata, schema mapping to WooCommerce custom fields, customer and order import, 301 redirect mapping for SEO preservation, and zero-downtime DNS cutover. Most Shopify migrations complete in 6 to 8 weeks and recover top-10 rankings within 4 weeks of launch. Pricing starts at $4,500 for catalogs under 200 products." } },
        { "@type": "Question", "name": "Do you offer ongoing WooCommerce support and maintenance?", "acceptedAnswer": { "@type": "Answer", "text": "Care plans from $150/month cover WooCommerce core and plugin updates tested on staging, daily off-site backups, security patching, performance monitoring, and a 4-hour SLA. Higher tiers include monthly performance audits, schema validation, and content and product updates." } },
        { "@type": "Question", "name": "How long does a WooCommerce development project take?", "acceptedAnswer": { "@type": "Answer", "text": "Standard timelines: Setup tier in 5 to 7 weeks, Custom in 8 to 10 weeks, Enterprise in 10 to 14 weeks. The biggest variables are catalog complexity, integration scope, and how quickly you provide product content." } }
      ]
    }
  ]
});

const includes = [
  "Custom WooCommerce theme on a performant base",
  "Product, Offer, and Review schema across the catalog",
  "Stripe, PayPal, and Authorize.net payment integration",
  "Elementor Pro for product layouts",
  "Mobile-first responsive checkout flow",
  "90+ Lighthouse on every product page (contractually)",
  "Search Console and Bing Webmaster setup",
  "30-day post-launch sales + ranking monitoring",
];

const tiers = [
  {
    name: "Setup",
    price: "$4,500",
    duration: "5-7 weeks",
    summary: "WooCommerce setup on a custom theme with up to 50 products, basic configurations, and one payment gateway.",
    fits: ["First-time stores", "Up to 50 products", "Single payment gateway"],
    href: "/contact/?plan=woo-setup",
  },
  {
    name: "Custom",
    price: "$8,500",
    duration: "8-10 weeks",
    summary: "Custom WooCommerce build with subscriptions, configurators, multi-vendor support, or specialty integrations.",
    fits: ["Subscriptions / memberships", "Product configurators", "Multi-vendor / marketplace"],
    href: "/contact/?plan=woo-custom",
    highlight: true,
  },
  {
    name: "Enterprise",
    price: "From $15,000",
    duration: "10-14 weeks",
    summary: "High-volume stores, custom plugin development, ERP / CRM sync, multi-currency, multi-language WooCommerce.",
    fits: ["High-volume catalogs (500+)", "ERP / CRM integration", "Multi-region / multi-currency"],
    href: "/contact/?plan=woo-enterprise",
  },
];

const storeComponents = [
  { num: "01", name: "Product catalog",     detail: `Product pages with variants, images, pricing tiers, and <a href="/tools/schema-generator/">Product/Offer/AggregateRating schema</a>. Supports simple, variable, grouped, and downloadable product types.` },
  { num: "02", name: "Payment gateway",     detail: "PCI-compliant checkout via Stripe, PayPal, or Authorize.net. Apple Pay, Google Pay, and ACH supported. No transaction fees beyond the gateway's own rate." },
  { num: "03", name: "Shipping and tax",    detail: "Real-time carrier rates (UPS, FedEx, USPS), flat-rate zones, free-shipping thresholds, and automated tax calculation via TaxJar or WooCommerce Tax." },
  { num: "04", name: "Inventory management", detail: `Stock tracking, low-stock alerts, backorder handling, and multi-warehouse inventory. Syncs to ERP systems (NetSuite, QuickBooks) at the Enterprise tier. Protected long-term by a <a href="/services/wordpress-care-plans/">WordPress care plan</a>.` },
  { num: "05", name: "Order management",    detail: "Admin order interface with status workflows (pending, processing, shipped, complete), customer-facing order history, and transactional email triggers." },
];

const capabilities = [
  { num: "01", area: "WooCommerce subscriptions",  detail: "Recurring billing, member-only products, payment retries, trial flows. Stripe Subscriptions or Authorize.net ARB." },
  { num: "02", area: "Product configurators",       detail: "Variable products, conditional options, custom add-ons. Real-time price updates as customers configure." },
  { num: "03", area: "Multi-vendor marketplaces",   detail: "WC Vendors or Dokan setup with vendor onboarding, payouts, commissions, and per-vendor analytics." },
  { num: "04", area: "Payment integrations",         detail: "Stripe, PayPal, Authorize.net, Square. ACH for high-ticket orders. Currency conversion as needed." },
  { num: "05", area: "Custom plugin development",    detail: "When the right plugin doesn't exist, we build it. Lightweight, documented, maintained." },
  { num: "06", area: "Performance + product schema", detail: "Product, Offer, AggregateRating schema across the catalog. Image optimization. 90+ Lighthouse." },
];

const whenWoo = [
  {
    num: "01",
    signal: "Selling more than 5 products online",
    detail: "Below 5 products you can probably get away with a simple Stripe Checkout link. Above that, you need WooCommerce-level catalog management, search, filtering, and analytics.",
  },
  {
    num: "02",
    signal: "You need subscriptions or memberships",
    detail: "Recurring billing, member-only content, or tiered pricing requires WooCommerce Subscriptions or a membership plugin. Shopify and Squarespace can't match the flexibility.",
  },
  {
    num: "03",
    signal: "Shopify monthly fees are eating margin",
    detail: "Shopify charges $79-$299/month plus transaction fees. WooCommerce on your own hosting is $20-$100/month total. For high-volume stores, the savings pay for the build in 6-18 months.",
  },
  {
    num: "04",
    signal: "You need configurable / custom products",
    detail: "Build-your-own-bundle, custom variations with conditional options, real-time pricing engines. WooCommerce + custom development handles cases Shopify won't.",
  },
  {
    num: "05",
    signal: "You're integrating with ERP or CRM",
    detail: "Sync inventory with NetSuite, sync customers with HubSpot, sync orders with QuickBooks. WooCommerce has the open API to make these integrations clean.",
  },
  {
    num: "06",
    signal: "You want to own the platform",
    detail: "Shopify can deplatform a store. WooCommerce on your own hosting is yours forever. For brands building long-term equity in the catalog, the platform ownership matters.",
  },
];

const wooVsShopify = [
  { factor: "Monthly fee",          shopify: "$79-$299/mo + transaction fees", woo: "Hosting only ($20-$100/mo)" },
  { factor: "Custom checkout",     shopify: "Limited to Shopify Plus tier",   woo: "Fully customizable on any plan" },
  { factor: "Subscriptions",       shopify: "Add-on apps, monthly fees",      woo: "WooCommerce Subscriptions one-time" },
  { factor: "Schema control",      shopify: "Theme-bound, limited fields",    woo: "Full Product / Offer / Review control" },
  { factor: "Plugin ecosystem",   shopify: "Apps with monthly subscriptions", woo: "Mostly one-time licences or free" },
  { factor: "Platform ownership",  shopify: "Shopify hosts; can deplatform", woo: "You own the codebase and data" },
];

const faqs = [
  {
    q: "What is WooCommerce development?",
    a: `WooCommerce development is the work of building, customizing, and maintaining ecommerce stores on the WooCommerce platform, a free <a href="/services/wordpress-web-design/">WordPress plugin</a> powering 28% of all online stores. WooCommerce development services range from basic store setup to custom plugin engineering, payment gateway integration, multi-vendor marketplace builds, and <a href="/services/wordpress-speed-optimization/">performance optimization</a> for high-volume catalogs.`,
  },
  {
    q: "How much does WooCommerce development cost?",
    a: `Quality WooCommerce development costs $4,500 to $25,000+ for most small-to-mid stores in 2026. Setup builds (50 products, single payment gateway) start at $4,500. Custom builds with subscriptions, configurators, or multi-vendor run $8,500–$15,000. Enterprise WooCommerce (high-volume, ERP integration, multi-currency) starts at $15,000 and can reach $80,000+. Hourly WooCommerce developer rates run $80–$200/hr; higher-quality firms have moved to <a href="/pricing/">fixed-scope pricing</a>. Hourly WooCommerce developer rates run $80–$200/hr.`,
  },
  {
    q: "Should I hire a WooCommerce developer or use Shopify instead?",
    a: `Use Shopify if you have under 50 simple products, don't need custom checkout flows, and accept the $79+/month platform fee. <a href="/hire-wordpress-designer/">Hire a WooCommerce developer</a> if you need subscriptions, configurators, multi-vendor, custom plugins, ERP integration, or platform ownership. The break-even point is roughly 12–18 months: above that, WooCommerce is almost always cheaper and more flexible. Below that, Shopify saves you the upfront build cost.`,
  },
  {
    q: "What's the difference between a WooCommerce developer and a WooCommerce expert?",
    a: `In practice, none. "Developer" implies engineering focus; "expert" implies senior strategic capability across both engineering and architecture. Quality WooCommerce hires bridge both: they can ship custom code AND make architecture decisions about catalog structure, <a href="/services/wordpress-seo-services/">schema and SEO</a>, payment flows, and performance. Don't hire someone who can only do one or the other.`,
  },
  {
    q: "Can you migrate my existing Shopify or BigCommerce store to WooCommerce?",
    a: `Shopify-to-WooCommerce migrations are one of our most common engagements. The process: catalog export with product images and metadata, schema mapping to WooCommerce custom fields, customer and order import, <a href="/services/wordpress-migration/">301 redirect mapping for SEO preservation</a>, and zero-downtime DNS cutover. Most Shopify migrations complete in 6–8 weeks and recover top-10 rankings within 4 weeks of launch. Pricing starts at $4,500 for catalogs under 200 products.`,
  },
  {
    q: "Do you offer ongoing WooCommerce support and maintenance?",
    a: `<a href="/services/wordpress-care-plans/">Care plans from $150/month</a> cover WooCommerce core and plugin updates tested on staging, daily off-site backups, security patching, performance monitoring, and a 4-hour SLA. Higher tiers include monthly performance audits, schema validation, and content and product updates. WooCommerce stores particularly benefit from active maintenance because plugin updates can break checkout flows in subtle ways.`,
  },
  {
    q: "How long does a WooCommerce development project take?",
    a: `Standard timelines: Setup tier in 5–7 weeks, Custom in 8–10 weeks, Enterprise in 10–14 weeks. The biggest variables are catalog complexity (50 vs 5,000 products), integration scope (single gateway vs multi-region with ERP), and how quickly you provide product content. We keep the build moving on our end, but timelines pause if we're waiting on you for more than 5 business days. See the full <a href="/process/">project process page</a> for a phase breakdown.`,
  },
];
---
<BaseLayout
  title="WooCommerce Development Services Maryland | WooCommerce Expert | Upcoming Brand"
  description="Senior WooCommerce development: custom builds, subscriptions, multi-vendor, Stripe integration. Schema-first, 90+ Lighthouse, fixed-scope from $4,500."
  canonicalUrl={canonical}
  ogImageAlt="WooCommerce Development Services Maryland | Upcoming Brand"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <ServiceHero
      eyebrow='WooCommerce development'
      pillText='WooCommerce Specialists · Maryland'
      h1Lines={[
        { text: 'WooCommerce development' },
        { text: 'from a senior WooCommerce expert', type: 'accent' },
        { text: 'who actually ships.', type: 'italic' },
      ]}
      lead='<strong>WooCommerce development services</strong> covering custom store builds, subscriptions, configurators, multi-vendor, and payment integrations. Want to <strong>hire a WooCommerce developer</strong> who handles design, schema, and performance in one engagement? <strong>Fixed-scope from $4,500.</strong> 90+ Lighthouse on every product page. 5-14 week delivery.'
      formName='woocommerce-inquiry'
      servicePresetValue='Ecommerce / Retail'
      trustLines={['From $4,500 fixed-scope', '90+ Lighthouse on product pages', '5-14 week delivery']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'Current store',
          subtitle: 'Where you sell now.',
          fields: [
            { type: 'select', name: 'current_platform', label: 'Current ecommerce platform', required: true,
              options: ['No store yet', 'Shopify', 'WooCommerce (existing)', 'BigCommerce', 'Magento / Adobe Commerce', 'Squarespace Commerce', 'Wix Stores', 'Etsy / Marketplace only', 'Other'] },
            { type: 'url', name: 'current_site', label: 'Current store URL', placeholder: 'https://yourstore.com', optional: true, autocomplete: 'url' },
          ],
        },
        {
          title: 'Store complexity',
          subtitle: 'Product count and what you need.',
          fields: [
            { type: 'select', name: 'product_count', label: 'Product count', required: true,
              options: ['Under 25', '25 to 100', '100 to 500', '500 to 5,000', '5,000+', 'Not sure yet'] },
            { type: 'select', name: 'features', label: 'Key features needed', required: true,
              options: ['Standard checkout', 'Subscriptions / recurring', 'Product configurator', 'Multi-vendor / marketplace', 'B2B / wholesale pricing', 'Memberships', 'Multiple of the above'] },
          ],
        },
        {
          title: 'Budget + timeline',
          subtitle: 'Scope and goal.',
          fields: [
            { type: 'select', name: 'budget', label: 'Budget range', required: true,
              options: ['$4,500 to $7,500', '$7,500 to $15,000', '$15,000 to $30,000', '$30,000+', 'Not sure yet'] },
            { type: 'textarea', name: 'message', label: 'Store goal', placeholder: 'What does the new store need to do?', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- ====== DEFINITION (Know intent + AI Overview citation) ====== -->
    <section class="woo-define">
      <div class="container">
        <div class="woo-define-card">
          <div class="woo-define-head">
            <span class="woo-define-pulse" aria-hidden="true"></span>
            <span class="woo-define-label">Executive Summary</span>
          </div>
          <h2 class="page-h2 woo-define-h2">
            What is WooCommerce development?
          </h2>
          <p class="woo-define-answer">
            <strong>WooCommerce development is the work of building, customizing, and maintaining ecommerce stores on the WooCommerce platform.</strong> WooCommerce is a free <a href="/services/wordpress-web-design/" class="woo-define-link">WordPress plugin</a> that powers 28% of all online stores. WooCommerce development services range from basic store setup to custom plugin engineering, payment gateway integration, multi-vendor marketplace builds, and <a href="/services/wordpress-speed-optimization/" class="woo-define-link">performance optimization</a> for high-volume catalogs.
          </p>
          <div class="woo-define-meta">
            <div class="woo-define-meta-item">
              <span class="woo-define-meta-label">Also known as</span>
              <span class="woo-define-meta-val">WooCommerce design, custom WooCommerce build, WooCommerce store development</span>
            </div>
            <div class="woo-define-meta-item">
              <span class="woo-define-meta-label">Typical investment</span>
              <span class="woo-define-meta-val">$4,500 (Setup) to $25,000+ (Enterprise)</span>
            </div>
            <div class="woo-define-meta-item">
              <span class="woo-define-meta-label">Market share</span>
              <span class="woo-define-meta-val">28% of all online stores; 50%+ of WP-based stores</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== COMPONENT FRAME (Frame 4) ====== -->
    <section class="woo-components">
      <div class="container">
        <div class="woo-components-head">
          <p class="woo-section-eyebrow">
            <span class="woo-section-eyebrow-line"></span>
            Store architecture
          </p>
          <h2 class="page-h2">What does <em>a WooCommerce store include?</em></h2>
          <p class="page-section-lead">A WooCommerce store is not a single plugin. It is five interconnected systems. Each one is configured and optimized during the build to work together without <a href="/services/wordpress-speed-optimization/">slowing your product pages</a>.</p>
        </div>
        <div class="woo-components-grid">
          {storeComponents.map((c) => (
            <div class="woo-component-item">
              <span class="woo-component-num">{c.num}</span>
              <div class="woo-component-body">
                <h3 class="woo-component-name">{c.name}</h3>
                <p class="woo-component-detail" set:html={c.detail} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== INCLUDES ====== -->
    <section class="woo-includes">
      <div class="container">
        <div class="woo-includes-head">
          <p class="woo-section-eyebrow">
            <span class="woo-section-eyebrow-line"></span>
            What's included
          </p>
          <h2 class="page-h2">
            What does <em>every WooCommerce project include?</em>
          </h2>
          <p class="page-section-lead">Tier-independent. The Setup tier ships with the same engineering bar as Enterprise; only catalog size and integration complexity change.</p>
        </div>

        <div class="woo-includes-grid">
          {includes.map((item, i) => (
            <div class="woo-include">
              <span class="woo-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="woo-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="woo-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== TIERS ====== -->
    <section class="woo-tiers" id="tiers">
      <div class="container">
        <div class="woo-tiers-head">
          <p class="woo-section-eyebrow">
            <span class="woo-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Which <em>WooCommerce development package fits your store?</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="woo-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`woo-tier ${t.highlight ? 'woo-tier-highlight' : ''}`}>
              {t.highlight && <span class="woo-tier-flag">Most chosen</span>}
              <span class="woo-tier-name">{t.name}</span>
              <span class="woo-tier-price">{t.price}</span>
              <span class="woo-tier-duration">{t.duration}</span>
              <p class="woo-tier-summary">{t.summary}</p>
              <div class="woo-tier-fits">
                <span class="woo-tier-fits-label">Fits</span>
                <ul class="woo-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="woo-tier-cta">
                Start {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
