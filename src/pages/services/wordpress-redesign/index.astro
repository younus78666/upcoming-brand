---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-redesign/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Redesign Service | Refresh Without Losing Rankings | Upcoming Brand",
      "description": "WordPress redesign service that refreshes your existing site without losing search rankings. Schema-preserved, redirect-mapped, Core Web Vitals improved. Fixed-scope from $2,500.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",            "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Redesign",  "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Redesign Service",
      "description": "Senior WordPress redesign service that refreshes existing WordPress sites without losing search rankings. Schema preserved, redirects mapped, Core Web Vitals improved. Fixed-scope from $2,500.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress redesign",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": { "@type": "Offer", "price": "2500", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "priceValidUntil": "2026-12-31" },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "12", "bestRating": "5" },
      "knowsAbout": ["WordPress redesign", "WordPress redesign service", "Redesign WordPress site", "Website redesign service", "WordPress refresh", "WordPress site refresh", "Rebrand WordPress site", "WordPress redesign cost"]
    }
  ]
});

const tiers = [
  { name: "Refresh",  price: "$2,500", duration: "3-5 weeks",   summary: "Visual refresh: new colors, typography, hero updates, CTA polish. Existing structure and pages preserved. No URL changes.", fits: ["Brand looks tired", "Homepage + 5 key pages", "No structural changes"], href: "/contact/?plan=redesign-refresh" },
  { name: "Standard", price: "$5,000", duration: "6-8 weeks",   summary: "Full WordPress redesign: new design system, custom blocks, schema rebuild, Core Web Vitals optimization. URL structure preserved. SEO-safe.", fits: ["Sites under 30 pages", "Full visual redesign", "Schema + performance work"], href: "/contact/?plan=redesign-standard", highlight: true },
  { name: "Custom",   price: "From $10,000", duration: "8-14 weeks", summary: "Major redesign with information architecture changes, content restructure, custom plugins, or WooCommerce overhaul. Includes redirect map and 30-day post-launch monitoring.", fits: ["Sites 30+ pages", "Site architecture changes", "WooCommerce stores"], href: "/contact/?plan=redesign-custom" },
];

const whenRedesign = [
  { num: "01", signal: "Site looks dated vs competitors",            detail: "If your WordPress site looks 5+ years old next to competitor sites, you are losing trust at first impression. A WordPress redesign refreshes the visual layer without rebuilding the entire site." },
  { num: "02", signal: "Built on a page builder we want to escape",  detail: "Sites stuck on Divi, Elementor, or Beaver Builder struggle on Lighthouse and lock you into vendor pricing. A redesign migrates to native Gutenberg blocks while preserving content and URLs." },
  { num: "03", signal: "Brand has evolved since launch",              detail: "New logo, new colors, new positioning, but the site still reflects the old brand. Redesign aligns the site with current brand without throwing away rankings or content." },
  { num: "04", signal: "Conversion rate is below 2%",                  detail: "If you drive traffic but do not convert, design and CTA placement are usually the issue. A conversion-focused redesign restructures CTAs, social proof, and forms based on what actually moves the needle." },
  { num: "05", signal: "Mobile experience is broken",                  detail: "Sites built before 2022 often pre-date mobile-first design. Redesign rebuilds with mobile as the primary breakpoint, then enhances for desktop. Lighthouse mobile scores typically jump 30+ points." },
  { num: "06", signal: "Need it done without losing rankings",         detail: "The most common redesign failure is rebuilding from scratch and watching rankings collapse. We preserve URL structure, schema, internal linking, and content depth so the redesign improves rankings rather than resetting them." },
];

const faqs = [
  { q: "What is a WordPress redesign?", a: "A WordPress redesign is the process of updating an existing WordPress site's visual design, structure, or both without losing the rankings, content, and traffic the original site has built. Quality WordPress redesigns preserve URL structure, schema, internal linking, and content depth while refreshing visual design, custom blocks, performance, and conversion architecture. The output is a site that looks better, ranks better, and converts better than the original." },
  { q: "How much does a WordPress redesign cost?", a: "Quality WordPress redesigns run $2,500 to $15,000+ depending on scope. A visual refresh (colors, typography, hero updates) runs $2,500 for sites under 10 pages. A full redesign (new design system, custom blocks, schema rebuild) runs $5,000 for sites under 30 pages. Custom redesigns with information architecture changes or WooCommerce overhauls start at $10,000. Hourly redesign rates run $80 to $250/hr; the better firms ship fixed-scope." },
  { q: "Will a WordPress redesign hurt my SEO rankings?", a: "Done correctly, a WordPress redesign improves SEO rankings rather than hurting them. Done badly (URL changes without redirects, schema removed, internal linking broken, content depth reduced), redesigns can drop rankings 30 to 60 percent. Our process preserves URL structure by default, validates schema on every page, maintains content depth, and rebuilds internal linking. Redirect maps cover any unavoidable URL changes." },
  { q: "How long does a WordPress redesign take?", a: "A visual refresh takes 3 to 5 weeks. A full redesign takes 6 to 8 weeks. Custom redesigns with structural changes take 8 to 14 weeks. The variable is page count and content rewrite scope. We commit to a delivery date in the SOW and credit 10 percent of the fee if we miss it." },
  { q: "Do you redesign Divi or Elementor sites?", a: "Yes. We migrate Divi and Elementor sites to native Gutenberg blocks during the redesign. This removes the page builder dependency, halves typical page weight, and lifts Lighthouse scores by 30+ points. Migration is included in the Standard and Custom redesign tiers without additional cost. The Refresh tier preserves the existing builder for budget-constrained projects." },
  { q: "What is the difference between a redesign and a rebuild?", a: "A redesign preserves the existing site's URL structure, content, and SEO equity while refreshing design and structure. A rebuild starts from scratch with new URLs, new content, and a new architecture. Redesigns cost less, take less time, and protect rankings. Rebuilds make sense when the site is so structurally broken that fixing it costs more than starting fresh. We default to redesign unless the site has fundamental architecture problems." },
];
---
<BaseLayout
  title="WordPress Redesign Service | Refresh Without Losing Rankings from $2,500 | Upcoming Brand"
  description="Senior WordPress redesign service: visual refresh, custom block migration, schema rebuild, Core Web Vitals improvement. SEO-safe, URL-preserving. Fixed-scope from $2,500."
  canonicalUrl={canonical}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={jsonLd} /></Fragment>
  <AnnouncementBar />
  <Navigation />

  <main id="main-content">
    <ServiceHero
      eyebrow='WordPress redesign service'
      pillText='WordPress Redesign · Maryland'
      h1Lines={[
        { text: 'WordPress redesign service' },
        { text: 'that refreshes your site', type: 'accent' },
        { text: 'without losing rankings.', type: 'italic' },
      ]}
      lead='<strong>WordPress redesign service</strong> that refreshes your existing WordPress site without resetting your SEO equity. Schema preserved, URLs preserved, content depth preserved, internal linking rebuilt. The new site looks modern, ranks better, and converts more visitors. <strong>Fixed-scope from $2,500. 3-8 week delivery.</strong>'
      formName='wp-redesign-inquiry'
      trustLines={['From $2,500 fixed-scope', 'URLs + schema preserved', '90+ Lighthouse on launch']}
      formSteps={[
        { title: 'Tell us who you are', subtitle: 'Just your name and email. 30 seconds.', fields: [
          { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
          { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
        ]},
        { title: 'About your site', subtitle: 'What we will redesign.', fields: [
          { type: 'url',  name: 'site_url', label: 'Current WordPress site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
          { type: 'select', name: 'current_builder', label: 'Current page builder / theme', required: true,
            options: ['Native Gutenberg blocks', 'Elementor', 'Divi', 'Beaver Builder', 'Custom theme', 'Theme from ThemeForest', 'Not sure'] },
        ]},
        { title: 'Redesign scope', subtitle: 'Page count and what changes.', fields: [
          { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
            options: ['Under 10 pages', '10 to 30 pages', '30 to 100 pages', '100+ pages', 'Not sure'] },
          { type: 'select', name: 'redesign_type', label: 'Redesign type', required: true,
            options: ['Visual refresh only', 'Full redesign with new design system', 'Architecture + content restructure', 'WooCommerce overhaul', 'Not sure, recommend'] },
        ]},
        { title: 'Engagement scope', subtitle: 'Which package fits.', fields: [
          { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
            options: ['Refresh ($2,500)', 'Standard ($5,000)', 'Custom ($10,000+)', 'Not sure yet'] },
          { type: 'textarea', name: 'message', label: 'What does the redesign need to accomplish?', placeholder: 'Conversion goals, brand changes, performance issues.', required: true, rows: 2 },
        ]},
      ]}
    />
    <Marquee />

    <section class="rds-define">
      <div class="container">
        <div class="rds-define-card">
          <div class="rds-define-head">
            <span class="rds-define-pulse" aria-hidden="true"></span>
            <span class="rds-define-label">Definition</span>
          </div>
          <h2 class="page-h2 rds-define-h2">What is a WordPress redesign?</h2>
          <p class="rds-define-answer">
            <strong>A WordPress redesign is the process of updating an existing WordPress site's visual design, structure, or both without losing the rankings, content, and traffic the original site has built.</strong> Quality WordPress redesigns preserve URL structure, schema, internal linking, and content depth while refreshing visual design, custom blocks, performance, and conversion architecture. The output is a site that looks better, ranks better, and converts better than the original.
          </p>
          <div class="rds-define-meta">
            <div class="rds-define-meta-item"><span class="rds-define-meta-label">Investment</span><span class="rds-define-meta-val">$2,500 (Refresh) to $15,000+ (Custom)</span></div>
            <div class="rds-define-meta-item"><span class="rds-define-meta-label">Delivery</span><span class="rds-define-meta-val">3-8 weeks for standard scope</span></div>
            <div class="rds-define-meta-item"><span class="rds-define-meta-label">Outcome</span><span class="rds-define-meta-val">Refreshed design, preserved SEO, faster site</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="rds-tiers" id="tiers">
      <div class="container">
        <div class="rds-tiers-head">
          <p class="rds-section-eyebrow"><span class="rds-section-eyebrow-line"></span>Three tiers</p>
          <h2 class="page-h2">Three <em>WordPress redesign packages.</em></h2>
          <p class="page-section-lead">Each tier is fixed-scope. The Refresh tier is for budget-constrained brand updates; Standard is the most common engagement; Custom handles structural changes.</p>
        </div>
        <div class="rds-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`rds-tier ${t.highlight ? 'rds-tier-highlight' : ''}`}>
              {t.highlight && <span class="rds-tier-flag">Most chosen</span>}
              <span class="rds-tier-name">{t.name}</span>
              <span class="rds-tier-price">{t.price}</span>
              <span class="rds-tier-duration">{t.duration}</span>
              <p class="rds-tier-summary">{t.summary}</p>
              <div class="rds-tier-fits">
                <span class="rds-tier-fits-label">Fits</span>
                <ul class="rds-tier-fits-list">{t.fits.map((f) => (<li>{f}</li>))}</ul>
              </div>
              <span class="rds-tier-cta">Book {t.name} <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="rds-when">
      <div class="container">
        <div class="rds-when-head">
          <p class="rds-section-eyebrow"><span class="rds-section-eyebrow-line"></span>When you need it</p>
          <h2 class="page-h2">Six signals <em>your WordPress site needs a redesign.</em></h2>
        </div>
        <div class="rds-when-grid">
          {whenRedesign.map((w) => (
            <article class="rds-when-card">
              <span class="rds-when-num">{w.num}</span>
              <h3 class="rds-when-signal">{w.signal}</h3>
              <p class="rds-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="rds-faq">
      <div class="container">
        <div class="rds-faq-head">
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line"></span><span class="page-eyebrow-text">WordPress redesign FAQ</span><span class="page-eyebrow-line"></span></div>
          <h2 class="page-h2 rds-faq-h2">Six questions <em>before you book.</em></h2>
        </div>
        <div class="rds-faq-list">
          {faqs.map((f, i) => (
            <details class="rds-faq-item">
              <summary class="rds-faq-q">
                <span class="rds-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="rds-faq-q-text">{f.q}</span>
                <span class="rds-faq-icon" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </summary>
              <p class="rds-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="page-cta">
      <div class="container">
        <div class="page-cta-inner">
          <div class="page-eyebrow-strip"><span class="page-eyebrow-line page-eyebrow-line-amber"></span><span class="page-eyebrow-text page-eyebrow-text-light">Book a redesign</span><span class="page-eyebrow-line page-eyebrow-line-amber"></span></div>
          <h2 class="page-h2 page-cta-h2">WordPress redesign without ranking loss.<br><em>$2,500 refresh. $5,000 standard.</em></h2>
          <p class="page-cta-lead">A free 15-minute call to confirm scope. We send the SOW within 24 hours and start on signature.</p>
          <div class="page-cta-buttons">
            <a href="/contact/" class="lp-btn-primary page-cta-primary">Book a redesign <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="/services/wordpress-migration/" class="page-cta-ghost-light">See migration if changing platform <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <BottomFormCTA formName="wp-redesign-cta"
    formSteps={[
      { title: 'Tell us who you are', subtitle: 'Just your name and email. 30 seconds.', fields: [
        { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
        { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
      ]},
      { title: 'About your site', subtitle: 'What we will redesign.', fields: [
        { type: 'url',  name: 'site_url', label: 'Current WordPress site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
        { type: 'select', name: 'current_builder', label: 'Current page builder / theme', required: true,
          options: ['Native Gutenberg blocks', 'Elementor', 'Divi', 'Beaver Builder', 'Custom theme', 'Theme from ThemeForest', 'Not sure'] },
      ]},
      { title: 'Redesign scope', subtitle: 'Page count and what changes.', fields: [
        { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
          options: ['Under 10 pages', '10 to 30 pages', '30 to 100 pages', '100+ pages', 'Not sure'] },
        { type: 'select', name: 'redesign_type', label: 'Redesign type', required: true,
          options: ['Visual refresh only', 'Full redesign with new design system', 'Architecture + content restructure', 'WooCommerce overhaul', 'Not sure, recommend'] },
      ]},
      { title: 'Engagement scope', subtitle: 'Which package fits.', fields: [
        { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
          options: ['Refresh ($2,500)', 'Standard ($5,000)', 'Custom ($10,000+)', 'Not sure yet'] },
        { type: 'textarea', name: 'message', label: 'What does the redesign need to accomplish?', placeholder: 'Conversion goals, brand changes, performance issues.', required: true, rows: 2 },
      ]},
    ]}
  />
  <Footer />
</BaseLayout>

<style>
  .page-h2 { font-family: var(--f-display); font-weight: 400; font-size: clamp(26px, 3.2vw, 42px); line-height: 1.15; letter-spacing: -0.025em; color: var(--ink); margin: 12px 0 0; }
  .page-h2 em { font-style: italic; font-weight: 300; color: var(--amber-deep); }
  .page-section-lead { font-size: 16px; line-height: 1.6; color: var(--ink-soft); max-width: 60ch; margin: 16px auto 0; }
  .page-eyebrow-strip { display: inline-flex; align-items: center; gap: 14px; flex-wrap: nowrap; justify-content: center; }
  .page-eyebrow-line { display: inline-block; width: 48px; height: 1px; background: var(--amber); flex-shrink: 0; }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; white-space: nowrap; }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }
  .lp-btn-primary { display: inline-flex; align-items: center; gap: 9px; font-family: var(--f-body); font-size: 15px; font-weight: 500; padding: 14px 26px; border-radius: var(--radius-pill); text-decoration: none; white-space: nowrap; transition: all 0.22s ease; cursor: pointer; background: var(--ink); color: var(--cream); border: 1.5px solid var(--ink); }
  .lp-btn-primary:hover { background: var(--amber-deep); border-color: var(--amber-deep); transform: translateY(-2px); }
  .lp-btn-primary svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }
  .rds-section-eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); margin: 0; font-weight: 500; }
  .rds-section-eyebrow-line { display: inline-block; width: 32px; height: 1px; background: var(--amber); }

  .rds-define { background: var(--paper); padding: clamp(48px, 6vh, 80px) 0; border-bottom: 1px solid var(--line); }
  .rds-define-card { max-width: 880px; margin: 0 auto; background: var(--cream); border: 1.5px solid rgba(212,147,46,0.3); border-radius: var(--radius-lg); padding: 36px 40px; position: relative; box-shadow: var(--shadow-sm); overflow: hidden; }
  .rds-define-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--amber); }
  .rds-define-head { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .rds-define-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--amber); box-shadow: 0 0 0 4px rgba(212,147,46,0.18); animation: rds-pulse 2s ease-in-out infinite; }
  @keyframes rds-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .rds-define-label { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; }
  .rds-define-h2 { margin: 0 0 16px; font-size: clamp(22px, 3vw, 32px); }
  .rds-define-answer { font-size: 16.5px; line-height: 1.6; color: var(--ink); margin: 0 0 20px; }
  .rds-define-answer strong { font-weight: 600; color: var(--ink); }
  .rds-define-meta { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; padding-top: 18px; border-top: 1px dashed var(--line); }
  .rds-define-meta-item { display: flex; flex-direction: column; gap: 4px; }
  .rds-define-meta-label { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; }
  .rds-define-meta-val { font-size: 13px; line-height: 1.5; color: var(--ink-soft); }

  .rds-tiers { background: var(--cream); padding: clamp(56px, 8vh, 96px) 0; border-bottom: 1px solid var(--line); scroll-margin-top: 24px; }
  .rds-tiers-head { text-align: center; max-width: 720px; margin: 0 auto 48px; display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .rds-tiers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 1100px; margin: 0 auto; align-items: stretch; }
  .rds-tier { display: flex; flex-direction: column; gap: 10px; padding: 32px 28px 28px; background: var(--paper); border: 1.5px solid var(--line); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: all 0.3s ease; position: relative; overflow: hidden; }
  .rds-tier:hover { border-color: var(--amber); transform: translateY(-4px); box-shadow: 0 14px 36px rgba(212,147,46,0.12); }
  .rds-tier-highlight { background: var(--ink); color: var(--cream); border-color: var(--amber); transform: translateY(-6px); overflow: hidden; }
  .rds-tier-highlight::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--amber), var(--amber-deep), var(--amber)); }
  .rds-tier-highlight:hover { transform: translateY(-10px); }
  .rds-tier-flag { position: absolute; top: 14px; right: 14px; display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px 5px 11px; background: var(--amber); color: var(--ink); border-radius: var(--radius-pill); font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; white-space: nowrap; box-shadow: 0 2px 10px rgba(212, 147, 46, 0.4); z-index: 3; }
  .rds-tier-name { font-family: var(--f-display); font-size: 32px; line-height: 1; color: var(--ink); font-weight: 500; letter-spacing: -0.025em; margin-top: 4px; }
  .rds-tier-highlight .rds-tier-name { color: var(--cream); }
  .rds-tier-price { font-family: var(--f-display); font-size: 24px; line-height: 1; color: var(--amber-deep); font-weight: 500; margin-top: 8px; }
  .rds-tier-highlight .rds-tier-price { color: var(--amber); }
  .rds-tier-duration { font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); }
  .rds-tier-highlight .rds-tier-duration { color: rgba(244,239,230,0.5); }
  .rds-tier-summary { font-size: 13px; line-height: 1.55; color: var(--ink-muted); margin: 12px 0 0; padding-top: 12px; border-top: 1px dashed var(--line); }
