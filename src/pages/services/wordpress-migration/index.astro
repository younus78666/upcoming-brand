---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';

import BottomFormCTA from '../../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/services/wordpress-migration/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Migration Service | Wix, Squarespace, GoDaddy to WordPress | Upcoming Brand",
      "description": "WordPress migration service from a senior WordPress migration expert. Wix, Squarespace, GoDaddy, Shopify, or outdated WordPress to custom WordPress. Zero-downtime DNS, complete redirect maps, no ranking loss. Fixed-scope from $750.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",            "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Migration", "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Migration Services",
      "description": "Senior WordPress migration services from Wix, Squarespace, GoDaddy, Shopify, or outdated WordPress to custom WordPress builds. Complete redirect maps, zero-downtime DNS cutover, 30-day Search Console monitoring.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress migration",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "750",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress migration",
        "WordPress migration service",
        "WordPress migration services",
        "WordPress migration expert",
        "WordPress site migration",
        "Wix to WordPress migration",
        "Squarespace to WordPress migration",
        "GoDaddy to WordPress migration",
        "Shopify to WordPress migration",
        "Migrate website to WordPress",
        "WordPress migration company"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to migrate a website to WordPress",
      "description": "The five-phase WordPress migration process for moving from Wix, Squarespace, GoDaddy, Shopify, or outdated WordPress without losing rankings.",
      "totalTime": "P3W",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Audit current site",       "text": "URL inventory, content extraction plan, current ranking baseline (positions 1-50 captured), and integration / redirect dependencies mapped." },
        { "@type": "HowToStep", "position": 2, "name": "Build new WordPress site",  "text": "Custom WordPress build on the new platform with schema, performance, and content architecture matched to or improved from the original." },
        { "@type": "HowToStep", "position": 3, "name": "Map redirects",              "text": "Every old URL redirected to its new equivalent via 301 redirects. Lost or merged pages routed to the closest topical match." },
        { "@type": "HowToStep", "position": 4, "name": "DNS cutover",                "text": "Zero-downtime DNS cutover scheduled in your timezone during low-traffic window. New site verified live before old site is decommissioned." },
        { "@type": "HowToStep", "position": 5, "name": "30-day monitoring",          "text": "Daily Search Console + ranking monitoring for first 7 days, then weekly. Day-30 written report with full migration outcome." }
      ]
    }
  ]
});

const sources = [
  { num: "01", platform: "Wix",         detail: "Wix-locked content extraction, custom redirect mapping, and full WordPress rebuild with schema and Core Web Vitals." },
  { num: "02", platform: "Squarespace", detail: "Catalog and content export, redirect map, and custom WordPress design that retains the brand without the platform lock-in." },
  { num: "03", platform: "GoDaddy",      detail: "GoDaddy Website Builder or Managed WordPress to custom WordPress on better hosting. Most common migration we run." },
  { num: "04", platform: "Shopify",      detail: "Shopify to WooCommerce migration with product import, customer/order import, and SEO-preserving redirect map." },
  { num: "05", platform: "Outdated WP",  detail: "Old WordPress theme + plugin bloat to a clean custom build. Often paired with a redesign sprint." },
  { num: "06", platform: "Webflow",       detail: "Webflow to WordPress for clients hitting CMS limitations or wanting open-platform ownership. Content + design re-platformed." },
];

const tiers = [
  {
    name: "Basic",
    price: "From $750",
    duration: "1-2 weeks",
    summary: "Simple WordPress-to-WordPress migration or small site (under 20 pages) from Wix / Squarespace / GoDaddy with redirect map.",
    fits: ["Under 20 pages", "WordPress-to-WordPress", "Hosting move only"],
    href: "/contact/?plan=migration-basic",
  },
  {
    name: "Standard",
    price: "From $1,500",
    duration: "2-4 weeks",
    summary: "Full WordPress migration from any platform: content, schema, performance, redirect map, DNS cutover, 30-day monitoring.",
    fits: ["20-100 pages", "Wix / Squarespace / GoDaddy", "Includes redesign light-touch"],
    href: "/contact/?plan=migration-standard",
    highlight: true,
  },
  {
    name: "Custom",
    price: "From $3,500",
    duration: "4-8 weeks",
    summary: "Complex migrations: WooCommerce / Shopify with product imports, multi-language, multi-site, or 100+ page catalogs.",
    fits: ["WooCommerce / Shopify", "Multi-language", "100+ pages or complex"],
    href: "/contact/?plan=migration-custom",
  },
];

const whyMigrate = [
  { num: "01", signal: "Wix monthly fees keep climbing",      detail: "$30-$60/month for a feature-limited site you can replace with WordPress + $20/month hosting. The migration pays for itself in 12-24 months." },
  { num: "02", signal: "Squarespace can't add the schema you need", detail: "Squarespace has limited schema control. Custom WordPress with vertical-specific schema is what gets you into the Local Pack." },
  { num: "03", signal: "GoDaddy hosting is destroying your speed", detail: "GoDaddy shared hosting routinely lands sites at 30-40 Lighthouse. Migrating to Cloudways or Kinsta puts you back at 90+." },
  { num: "04", signal: "Shopify monthly + transaction fees eat margin", detail: "Past 12-18 months of operation, WooCommerce on your own hosting is almost always cheaper than Shopify Plus." },
  { num: "05", signal: "Old WordPress theme is unmaintainable", detail: "If your current WP theme has 40+ active plugins, page builder lock-in, or hasn't been updated in 2 years, a migration to a custom build is the fix." },
  { num: "06", signal: "You don't own the platform",            detail: "Wix, Squarespace, GoDaddy, and Shopify can deplatform a site. WordPress on your own hosting is yours forever." },
];

const faqs = [
  {
    q: "What is WordPress migration?",
    a: "WordPress migration is the process of moving a website from another platform (Wix, Squarespace, GoDaddy, Shopify, or older WordPress) to a new WordPress installation. The migration includes content extraction, design rebuild or recreation, schema architecture, redirect mapping for SEO preservation, DNS cutover, and post-migration monitoring. Quality WordPress migration services preserve all rankings and traffic; cheap migrations frequently lose 30-50% of organic visibility because the redirect map is incomplete.",
  },
  {
    q: "How much does WordPress migration cost?",
    a: "Quality WordPress migration costs $750 to $5,000+ depending on source platform and complexity. WordPress-to-WordPress migrations or small Wix / Squarespace / GoDaddy moves start at $750. Standard migrations with redirect map, DNS cutover, and 30-day monitoring run $1,500-$2,500. Complex Shopify-to-WooCommerce or multi-language migrations start at $3,500. Hourly WordPress migration expert rates run $80-$200/hr; fixed-scope is the better structure for clients who don't want surprises.",
  },
  {
    q: "Will I lose Google rankings during a WordPress migration?",
    a: "Not if it's done correctly. Properly migrated WordPress sites recover all top-10 rankings within 4 weeks. The keys are: a complete 301 redirect map (every old URL routes to the right new one), a zero-downtime DNS cutover during a low-traffic window, schema preservation or improvement, and 30-day Search Console monitoring post-launch. Cheap migrations skip the redirect map and lose rankings; quality migrations don't.",
  },
  {
    q: "How long does a WordPress migration take?",
    a: "Typical timelines: simple WordPress-to-WordPress migrations in 1-2 weeks. Wix / Squarespace / GoDaddy migrations in 2-4 weeks. Complex Shopify-to-WooCommerce or multi-language migrations in 4-8 weeks. The biggest variables are content volume (50 pages vs 5,000), integration complexity (single CMS vs multiple connected systems), and whether the migration includes a design refresh.",
  },
  {
    q: "Should I migrate from Wix or Squarespace to WordPress?",
    a: "If you have under 5 simple pages, no schema needs, and the platform fee is comfortable: stay on Wix or Squarespace. Migrate to WordPress if you need vertical-specific schema (legal, medical, dental, real estate), Local Pack ranking, custom integrations (CRM, IDX, booking), faster page speed, or simply want to own the platform. The break-even point is roughly 12-24 months of platform fees vs. one-time WordPress build.",
  },
  {
    q: "Can you migrate without taking the site offline?",
    a: "Yes. Every migration we run is zero-downtime. We build the new WordPress site on a staging URL while your existing site stays live and serving traffic. On launch day, we do a DNS cutover during a low-traffic window (typically 2-4 AM Eastern). Visitors hitting the old IP during the propagation window get the old site; visitors hitting the new IP get the new site. Both render correctly. No 'this site is down for maintenance' page.",
  },
  {
    q: "What's included in the redirect map?",
    a: "Every old URL on the source site is paired with its new equivalent on the WordPress site. URLs that move (e.g., /blog/post-name to /articles/post-name) get a 301 redirect. URLs that are removed entirely (e.g., outdated landing pages) get redirected to the closest topical match or the parent category. We document the entire map in a spreadsheet you keep, so any future developer can see exactly what was redirected and why.",
  },
];
---
<BaseLayout
  title="WordPress Migration Service | Wix, Squarespace, GoDaddy to WordPress | Upcoming Brand"
  description="WordPress migration service from a senior expert. Wix, Squarespace, GoDaddy, Shopify, or outdated WordPress to custom WordPress. Zero-downtime DNS, complete redirect maps, no ranking loss. Fixed-scope from $750."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='WordPress migration service'
      pillText='WordPress Migration · Maryland'
      h1Lines={[
        { text: 'WordPress migration' },
        { text: 'from any platform,', type: 'accent' },
        { text: 'with zero ranking loss.', type: 'italic' },
      ]}
      lead='<strong>WordPress migration services</strong> from Wix, Squarespace, <strong>GoDaddy to WordPress</strong>, Shopify, or outdated WordPress. Complete redirect maps. Zero-downtime DNS cutover. 30-day Search Console monitoring. <strong>Fixed-scope from $750.</strong> Recover all rankings within 4 weeks of launch.'
      formName='wp-migration-inquiry'
      trustLines={['From $750 fixed-scope', 'Zero-downtime DNS', 'No ranking loss']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'Source platform',
          subtitle: 'Where the site lives now.',
          fields: [
            { type: 'select', name: 'source_platform', label: 'Migrating from', required: true,
              options: ['Wix', 'Squarespace', 'GoDaddy Builder', 'Webflow', 'Shopify', 'Old WordPress site', 'Custom HTML', 'Joomla / Drupal', 'Other'] },
            { type: 'url', name: 'current_site', label: 'Current site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
          ],
        },
        {
          title: 'Site size',
          subtitle: 'Page count and access.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
              options: ['Under 10 pages', '10 to 30 pages', '30 to 100 pages', '100 to 500 pages', '500+ pages', 'Not sure yet'] },
            { type: 'select', name: 'admin_access', label: 'Do you have admin access?', required: true,
              options: ['Yes, full admin', 'Partial access only', 'No, need to recover', 'Not sure'] },
          ],
        },
        {
          title: 'Timeline + goal',
          subtitle: 'When you need it migrated.',
          fields: [
            { type: 'select', name: 'timeline', label: 'Timeline', required: true,
              options: ['ASAP, within 2 weeks', 'Standard, 3 to 5 weeks', 'Flexible, 2+ months', 'Just exploring'] },
            { type: 'textarea', name: 'message', label: 'Migration concerns', placeholder: 'Rankings, downtime, design changes you want.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <!-- DEFINITION -->
    <section class="mig-define">
      <div class="container">
        <div class="mig-define-card">
          <div class="mig-define-head">
            <span class="mig-define-pulse" aria-hidden="true"></span>
            <span class="mig-define-label">Executive Summary</span>
          </div>
          <h2 class="page-h2 mig-define-h2">
            What is WordPress migration?
          </h2>
          <p class="mig-define-answer">
            <strong>WordPress migration is the process of moving a website from another platform (Wix, Squarespace, GoDaddy, Shopify, or older WordPress) to a new WordPress installation.</strong> Quality migration includes content extraction, schema preservation or improvement, complete 301 redirect mapping, zero-downtime DNS cutover, and 30-day post-launch monitoring. The biggest difference between cheap and quality migrations: cheap migrations skip the redirect map and lose 30-50% of organic visibility. Done right, you keep every ranking.
          </p>
          <div class="mig-define-meta">
            <div class="mig-define-meta-item">
              <span class="mig-define-meta-label">Investment</span>
              <span class="mig-define-meta-val">$750 (basic) to $5,000+ (Shopify, multi-language)</span>
            </div>
            <div class="mig-define-meta-item">
              <span class="mig-define-meta-label">Timeline</span>
              <span class="mig-define-meta-val">1-2 weeks (small) to 4-8 weeks (complex)</span>
            </div>
            <div class="mig-define-meta-item">
              <span class="mig-define-meta-label">Ranking impact</span>
              <span class="mig-define-meta-val">Full recovery within 4 weeks (when done right)</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOURCES -->
    <section class="mig-sources">
      <div class="container">
        <div class="mig-sources-head">
          <p class="mig-section-eyebrow">
            <span class="mig-section-eyebrow-line"></span>
            What we migrate from
          </p>
          <h2 class="page-h2">
            Six platforms <em>migrated to WordPress.</em>
          </h2>
          <p class="page-section-lead">If your platform isn't listed, ask. We've handled custom CMSes, ASP.NET sites, Drupal, Joomla, and a few platforms even Google has forgotten about.</p>
        </div>

        <div class="mig-sources-grid">
          {sources.map((s) => (
            <article class="mig-source-card">
              <span class="mig-source-num">{s.num}</span>
              <h3 class="mig-source-platform">{s.platform}</h3>
              <p class="mig-source-detail">{s.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- TIERS -->
    <section class="mig-tiers" id="tiers">
      <div class="container">
        <div class="mig-tiers-head">
          <p class="mig-section-eyebrow">
            <span class="mig-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress migration packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope, documented in a PDF, and held at the stated price for 30 days after the discovery call.</p>
        </div>

        <div class="mig-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`mig-tier ${t.highlight ? 'mig-tier-highlight' : ''}`}>
              {t.highlight && <span class="mig-tier-flag">Most chosen</span>}
              <span class="mig-tier-name">{t.name}</span>
              <span class="mig-tier-price">{t.price}</span>
              <span class="mig-tier-duration">{t.duration}</span>
              <p class="mig-tier-summary">{t.summary}</p>
              <div class="mig-tier-fits">
                <span class="mig-tier-fits-label">Fits</span>
                <ul class="mig-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="mig-tier-cta">
                Start {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY MIGRATE (Causation) -->
    <section class="mig-why">
      <div class="container">
        <div class="mig-why-head">
          <p class="mig-section-eyebrow">
            <span class="mig-section-eyebrow-line"></span>
            When to migrate
          </p>
          <h2 class="page-h2">
            Six signals <em>your site needs migrating.</em>
          </h2>
        </div>

        <div class="mig-why-grid">
          {whyMigrate.map((w) => (
            <article class="mig-why-card">
              <span class="mig-why-num">{w.num}</span>
              <h3 class="mig-why-signal">{w.signal}</h3>
              <p class="mig-why-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mig-faq">
      <div class="container">
        <div class="mig-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Migration FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 mig-faq-h2">
            Seven questions <em>before you migrate.</em>
          </h2>
        </div>
        <div class="mig-faq-list">
          {faqs.map((f, i) => (
            <details class="mig-faq-item">
              <summary class="mig-faq-q">
                <span class="mig-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="mig-faq-q-text">{f.q}</span>
                <span class="mig-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="mig-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
</main>
  <BottomFormCTA formName="wordpress-migration-cta" 
    formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'Source platform',
          subtitle: 'Where the site lives now.',
          fields: [
            { type: 'select', name: 'source_platform', label: 'Migrating from', required: true,
              options: ['Wix', 'Squarespace', 'GoDaddy Builder', 'Webflow', 'Shopify', 'Old WordPress site', 'Custom HTML', 'Joomla / Drupal', 'Other'] },
            { type: 'url', name: 'current_site', label: 'Current site URL', placeholder: 'https://yoursite.com', required: true, autocomplete: 'url' },
          ],
        },
        {
          title: 'Site size',
          subtitle: 'Page count and access.',
          fields: [
            { type: 'select', name: 'page_count', label: 'Approximate page count', required: true,
              options: ['Under 10 pages', '10 to 30 pages', '30 to 100 pages', '100 to 500 pages', '500+ pages', 'Not sure yet'] },
            { type: 'select', name: 'admin_access', label: 'Do you have admin access?', required: true,
              options: ['Yes, full admin', 'Partial access only', 'No, need to recover', 'Not sure'] },
          ],
        },
        {
          title: 'Timeline + goal',
          subtitle: 'When you need it migrated.',
          fields: [
            { type: 'select', name: 'timeline', label: 'Timeline', required: true,
              options: ['ASAP, within 2 weeks', 'Standard, 3 to 5 weeks', 'Flexible, 2+ months', 'Just exploring'] },
            { type: 'textarea', name: 'message', label: 'Migration concerns', placeholder: 'Rankings, downtime, design changes you want.', required: true, rows: 2 },
          ],
        },
      ]}
  />

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(48px, 7vh, 80px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before { content: ""; position: absolute; top: -300px; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%); pointer-events: none; }
  .page-hero-inner { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 28px; }
  .page-eyebrow-strip { display: inline-flex; align-items: center; gap: 14px; flex-wrap: nowrap; justify-content: center; }
  .page-eyebrow-line { display: inline-block; width: 48px; height: 1px; background: var(--amber); flex-shrink: 0; }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber-deep); font-weight: 500; white-space: nowrap; }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }
  .page-h1 { font-family: var(--f-display); font-weight: 400; font-size: clamp(32px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.035em; display: flex; flex-direction: column; gap: 4px; margin: 0; text-align: center; }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent { font-style: inherit; position: relative; color: var(--ink); display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none; }
  .page-h1-accent::after { display: none; }
  .page-h1-italic { font-style: italic; font-weight: 300; color: var(--amber-deep); }
  .page-lead { font-size: clamp(15px, 1.2vw, 18px); line-height: 1.6; color: var(--ink-soft); max-width: 64ch; margin: 0 auto; }
  .page-lead strong { font-weight: 600; color: var(--ink); }
  .page-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 4px; }
  .lp-btn-primary, .lp-btn-ghost { display: inline-flex; align-items: center; gap: 9px; font-family: var(--f-body); font-size: 15px; font-weight: 500; padding: 14px 26px; border-radius: var(--radius-pill); text-decoration: none; white-space: nowrap; transition: all 0.22s ease; cursor: pointer; }
  .lp-btn-primary { background: var(--ink); color: var(--cream); border: 1.5px solid var(--ink); }
  .lp-btn-primary:hover { background: var(--amber-deep); border-color: var(--amber-deep); transform: translateY(-2px); }
  .lp-btn-ghost { background: transparent; color: var(--ink); border: 1.5px solid var(--line-strong); }
