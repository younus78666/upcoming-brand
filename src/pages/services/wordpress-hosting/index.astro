---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../../components/AnnouncementBar.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import Marquee from '../../../components/Marquee.astro';
import BottomFormCTA from '../../../components/BottomFormCTA.astro';

const canonical = "https://upcomingbrand.com/services/wordpress-hosting/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "WordPress Hosting Service | Managed Hosting Setup & Migration | Upcoming Brand",
      "description": "WordPress hosting service from a senior hosting expert. Managed WordPress hosting setup, migration to Kinsta / WP Engine / Cloudways, server tuning, and ongoing management. Independent advice, not a reseller. Fixed-scope from $750.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://upcomingbrand.com/#logo" },
      "dateModified": "2026-05-03",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2", ".page-lead"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                 "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services",             "item": "https://upcomingbrand.com/services/" },
          { "@type": "ListItem", "position": 3, "name": "WordPress Hosting",    "item": canonical }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": "WordPress Hosting Service",
      "description": "Senior WordPress hosting service: managed WordPress hosting setup, migration between hosts, server tuning for Core Web Vitals, and ongoing managed hosting on Kinsta, WP Engine, Cloudways, or SiteGround. Independent advice, not a reseller. Fixed-scope from $750.",
      "provider": { "@id": "https://upcomingbrand.com/#organization" },
      "serviceType": "WordPress hosting consultancy",
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "Offer",
        "price": "750",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5"
      },
      "knowsAbout": [
        "WordPress hosting",
        "WordPress hosting service",
        "Managed WordPress hosting",
        "Best WordPress hosting",
        "Fast WordPress hosting",
        "Secure WordPress hosting",
        "WordPress hosting setup",
        "WordPress hosting migration",
        "Kinsta hosting",
        "WP Engine hosting",
        "Cloudways WordPress",
        "SiteGround WordPress",
        "WordPress hosting expert"
      ]
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How to set up WordPress hosting",
      "description": "The five-phase WordPress hosting methodology covering host evaluation, setup, migration, tuning, and verification.",
      "totalTime": "P5D",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Host evaluation",     "text": "Site requirements assessment, traffic projection, budget alignment, geography review, and host shortlist (Kinsta, WP Engine, Cloudways, SiteGround) matched to your specific needs." },
        { "@type": "HowToStep", "position": 2, "name": "Account + DNS setup", "text": "Hosting account created with optimal plan tier, staging environment configured, DNS records prepared, SSL provisioning verified, and email routing planned." },
        { "@type": "HowToStep", "position": 3, "name": "Migration",            "text": "Full WordPress site copy with database, media, and plugin state. Tested on staging URL. Search Console properties updated. 30-day rollback plan documented." },
        { "@type": "HowToStep", "position": 4, "name": "Performance tuning",   "text": "Object cache configuration (Redis or Memcached), OPcache verification, PHP version check, CDN setup, and Core Web Vitals baseline tested on top 10 pages." },
        { "@type": "HowToStep", "position": 5, "name": "DNS cutover + monitoring", "text": "Zero-downtime DNS cutover during low-traffic window. Search Console + uptime monitoring set up for 30 days post-cutover. Written report on host configuration." }
      ]
    }
  ]
});

const covered = [
  "Independent host evaluation across Kinsta, WP Engine, Cloudways, SiteGround",
  "Account setup with optimal plan tier matched to traffic and storage needs",
  "Staging environment configuration for safe deployments",
  "Full WordPress migration: database, media, plugin state, theme files",
  "DNS preparation and zero-downtime cutover scheduling",
  "SSL / TLS provisioning verification and HSTS configuration",
  "Object cache setup (Redis or Memcached) where the host supports it",
  "OPcache and PHP version tuning for maximum throughput",
  "CDN setup (Cloudflare, BunnyCDN, or host-native CDN)",
  "Email routing planning so transactional email keeps working",
  "Search Console property migration and Bing Webmaster sync",
  "30-day post-cutover monitoring with uptime + Search Console alerts",
];

const tiers = [
  {
    name: "Setup",
    price: "$750",
    duration: "3-5 business days",
    summary: "WordPress hosting setup on a fresh account. Host evaluation, account creation, staging configuration, baseline performance tuning. New sites only (no migration).",
    fits: ["New WordPress installs", "Pre-launch sites", "Hosting account creation only"],
    href: "/contact/?plan=hosting-setup",
  },
  {
    name: "Migration",
    price: "$1,500",
    duration: "5-7 business days",
    summary: "Full hosting migration to Kinsta, WP Engine, Cloudways, or SiteGround. Includes setup, migration, performance tuning, DNS cutover, and 30-day monitoring.",
    fits: ["Sites under 200 pages", "Switching from slow hosts", "Full SEO-safe migration"],
    href: "/contact/?plan=hosting-migration",
    highlight: true,
  },
  {
    name: "Managed",
    price: "From $300/mo",
    duration: "Month-to-month",
    summary: "Ongoing managed WordPress hosting: host management, performance tuning, plugin updates, daily backups, security monitoring, and 4-hour SLA. Pairs with care plans.",
    fits: ["Sites under management", "Bundled with care plans", "Hands-off hosting + ops"],
    href: "/contact/?plan=hosting-managed",
  },
];

const whenHosting = [
  { num: "01", signal: "Currently on shared hosting (GoDaddy, Bluehost, Hostinger)", detail: "Shared WordPress hosting is the most common cause of slow site speed. Migrating to managed WordPress hosting (Kinsta, WP Engine, Cloudways) typically halves TTFB and lifts Lighthouse by 20+ points without any code changes." },
  { num: "02", signal: "TTFB above 1.5 seconds despite caching",                    detail: "If your Time to First Byte is consistently above 1.5s with caching enabled, the host is the bottleneck. No amount of plugin caching fixes a slow upstream server. A migration is the answer." },
  { num: "03", signal: "Site outgrew its hosting plan",                              detail: "Traffic doubled, you added WooCommerce, or you launched a content marketing strategy. Plans that worked at 5,000 visits/mo break at 50,000. Right-sizing the host prevents the next outage." },
  { num: "04", signal: "Hosting renewal sticker shock",                              detail: "Bluehost and SiteGround renewals routinely 2-4x the introductory price. By month 13 you are paying $400+/year for shared hosting that performs worse than $20/month Cloudways. Migration usually pays back in 6-12 months." },
  { num: "05", signal: "No staging environment",                                      detail: "If your hosting plan does not include a staging environment, you are deploying changes directly to production. Every plugin update is a risk. Managed hosts include staging on all plans for a reason." },
  { num: "06", signal: "Frequent downtime or maintenance windows",                    detail: "If your host emails you about maintenance windows or your site goes down for 30+ minutes per month, the SLA is not what was sold. Tier-1 managed hosts maintain 99.99% uptime which is 52 minutes of downtime per year, not per month." },
];

const hostingMatrix = [
  { factor: "Best for",           kinsta: "Performance-first marketing sites",           wpe: "Agencies + multisite networks",                cloudways: "Flexible budgets, control freaks",         siteground: "Budget-conscious starters" },
  { factor: "Starting price",     kinsta: "$35/mo (10k visits)",                          wpe: "$25/mo (10k visits)",                            cloudways: "$14/mo (DigitalOcean 1GB)",                 siteground: "$3/mo intro, $20/mo renewal" },
  { factor: "Performance",        kinsta: "Top tier, Google Cloud + LiteSpeed",            wpe: "Top tier, AWS + Genesis",                        cloudways: "Configurable, depends on chosen stack",     siteground: "Mid tier, shared infrastructure" },
  { factor: "Support quality",    kinsta: "Excellent, WordPress-native engineers",         wpe: "Excellent, WordPress-native",                     cloudways: "Good, more general LAMP-stack",            siteground: "Mixed; outsourced for shared plans" },
  { factor: "Daily backups",      kinsta: "Yes, included",                                 wpe: "Yes, included",                                  cloudways: "Yes, with restore",                         siteground: "Yes on higher plans only" },
  { factor: "Staging",             kinsta: "Yes, one-click",                                wpe: "Yes, one-click",                                 cloudways: "Yes, manual setup",                         siteground: "Yes on GrowBig+" },
];

const faqs = [
  {
    q: "What is WordPress hosting?",
    a: "WordPress hosting is the server infrastructure that runs your WordPress site. WordPress hosting comes in three tiers: shared hosting (Bluehost, GoDaddy, Hostinger) where hundreds of sites share one server, managed WordPress hosting (Kinsta, WP Engine, Cloudways, SiteGround) where the host handles WordPress-specific optimization, and self-hosted (DigitalOcean, AWS, Linode) where you manage the server yourself. Most growing businesses outgrow shared hosting between 5,000 and 50,000 monthly visits and benefit from managed WordPress hosting.",
  },
  {
    q: "What is the best WordPress hosting?",
    a: "There is no single best WordPress hosting; the right choice depends on traffic, budget, and how much control you want. For performance-first marketing sites, Kinsta is excellent. For agency multisite networks, WP Engine is the standard. For flexible-budget setups with full control, Cloudways on DigitalOcean or Vultr is hard to beat. For budget-conscious starter sites with growth potential, SiteGround is reasonable until renewal pricing kicks in. Our hosting setup engagement includes a host recommendation matched to your specific needs.",
  },
  {
    q: "How much does WordPress hosting cost?",
    a: "Quality managed WordPress hosting runs $14 to $200/mo depending on traffic and storage. Cloudways starts at $14/mo on DigitalOcean 1GB, suitable for sites under 25,000 monthly visits. WP Engine and Kinsta start at $25 to $35/mo for 10,000 visits and scale up. Enterprise-grade managed WordPress hosting (Pantheon, WP Engine Premium) runs $300 to $1,000+/mo for high-traffic sites. Shared WordPress hosting is cheaper ($3 to $20/mo) but performance and support quality drop accordingly.",
  },
  {
    q: "Do you sell WordPress hosting?",
    a: "No. We are not a hosting reseller. We do not earn affiliate commissions on the hosts we recommend, which means our advice stays independent. We charge a fixed engagement fee for hosting setup, migration, or ongoing management. The host invoices you directly. This avoids the conflict of interest where agencies push you to expensive hosts for kickbacks.",
  },
  {
    q: "How long does WordPress hosting migration take?",
    a: "Standard WordPress hosting migration takes 5 to 7 business days. Day 1 to 2 covers host setup and staging configuration. Day 3 to 4 covers full site migration and testing. Day 5 covers DNS preparation and cutover scheduling. The DNS cutover itself takes minutes during a low-traffic window. We then monitor uptime and Search Console for 30 days post-cutover. Larger sites (WooCommerce stores, multilingual setups) can take 7 to 14 days.",
  },
  {
    q: "Will switching WordPress hosting affect my SEO rankings?",
    a: "Done correctly, switching WordPress hosting will not affect SEO rankings. The site remains at the same URL with the same content, only the upstream server changes. Done badly (no redirect verification, broken canonical tags, lost robots.txt configuration) it can drop rankings temporarily. Our migration includes Search Console property verification, robots.txt and sitemap re-confirmation, redirect map validation, and 30-day post-cutover ranking monitoring.",
  },
  {
    q: "Can you set up WordPress hosting on AWS or DigitalOcean directly?",
    a: "Yes. For clients who want full control and lower long-term cost, we set up WordPress on AWS Lightsail, DigitalOcean droplets, Linode, or Vultr instances directly. This avoids the managed-host markup and gives you root access. The tradeoff is you (or we, on a managed engagement) handle server updates, security patches, and scaling manually. Pricing for self-managed hosting setups starts at $1,500 for the initial configuration plus optional $300/mo ongoing management.",
  },
];
---
<BaseLayout
  title="WordPress Hosting Service | Managed Hosting Setup & Migration from $750 | Upcoming Brand"
  description="Senior WordPress hosting service: managed hosting setup, migration to Kinsta / WP Engine / Cloudways, server tuning, ongoing management. Independent advice, not a reseller. Fixed-scope from $750."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <ServiceHero
      eyebrow='WordPress hosting service'
      pillText='WordPress Hosting · Independent Advice'
      h1Lines={[
        { text: 'WordPress hosting service' },
        { text: 'from a senior hosting expert', type: 'accent' },
        { text: 'who does not resell hosting.', type: 'italic' },
      ]}
      lead='<strong>WordPress hosting service</strong> covering host evaluation, account setup, full migration, performance tuning, and ongoing managed WordPress hosting on <strong>Kinsta, WP Engine, Cloudways, and SiteGround</strong>. We do not earn affiliate commissions, so the advice stays independent. <strong>Fixed-scope from $750. Migration in 5-7 days.</strong>'
      formName='wp-hosting-inquiry'
      trustLines={['From $750 fixed-scope', 'Independent advice, no kickbacks', 'Zero-downtime DNS cutover']}
      formSteps={[
        {
          title: 'Tell us who you are',
          subtitle: 'Just your name and email. 30 seconds.',
          fields: [
            { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
            { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
          ],
        },
        {
          title: 'About your site',
          subtitle: 'Where it lives now and where it should go.',
          fields: [
            { type: 'url',  name: 'site_url', label: 'WordPress site URL', placeholder: 'https://yoursite.com', required: false, autocomplete: 'url' },
            { type: 'select', name: 'current_host', label: 'Current host', required: true,
              options: ['No host yet (new site)', 'Bluehost', 'GoDaddy', 'Hostinger', 'SiteGround', 'Kinsta', 'WP Engine', 'Cloudways', 'Other / Not sure'] },
          ],
        },
        {
          title: 'Site profile',
          subtitle: 'Traffic and store status.',
          fields: [
            { type: 'select', name: 'monthly_traffic', label: 'Monthly visitors', required: true,
              options: ['Under 1,000', '1,000 to 10,000', '10,000 to 50,000', '50,000 to 250,000', '250,000+', 'Not sure'] },
            { type: 'select', name: 'site_type', label: 'Site type', required: true,
              options: ['Marketing site', 'Blog / content site', 'WooCommerce store', 'Multisite network', 'Membership / SaaS', 'Other'] },
          ],
        },
        {
          title: 'Engagement scope',
          subtitle: 'Which package fits and what success looks like.',
          fields: [
            { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
              options: ['Hosting setup ($750)', 'Migration ($1,500)', 'Managed hosting ($300+/mo)', 'Not sure, recommend a host'] },
            { type: 'textarea', name: 'message', label: 'What is the problem?', placeholder: 'Slow site, renewal pricing, outage, planning a launch.', required: true, rows: 2 },
          ],
        },
      ]}
    />
    <Marquee />

    <section class="hst-define">
      <div class="container">
        <div class="hst-define-card">
          <div class="hst-define-head">
            <span class="hst-define-pulse" aria-hidden="true"></span>
            <span class="hst-define-label">In plain English</span>
          </div>
          <h2 class="page-h2 hst-define-h2">
            What is WordPress hosting?
          </h2>
          <p class="hst-define-answer">
            <strong>WordPress hosting is the server infrastructure that runs your WordPress site.</strong> WordPress hosting comes in three tiers: shared hosting (Bluehost, GoDaddy, Hostinger) where hundreds of sites share one server, managed WordPress hosting (Kinsta, WP Engine, Cloudways, SiteGround) where the host handles WordPress-specific optimization, and self-hosted (DigitalOcean, AWS, Linode) where you control the server yourself. Most growing businesses outgrow shared hosting between 5,000 and 50,000 monthly visits and benefit from managed WordPress hosting.
          </p>
          <div class="hst-define-meta">
            <div class="hst-define-meta-item">
              <span class="hst-define-meta-label">Investment</span>
              <span class="hst-define-meta-val">$750 (Setup) to $300+/mo (Managed)</span>
            </div>
            <div class="hst-define-meta-item">
              <span class="hst-define-meta-label">Delivery</span>
              <span class="hst-define-meta-val">5-7 business days for migration</span>
            </div>
            <div class="hst-define-meta-item">
              <span class="hst-define-meta-label">Outcome</span>
              <span class="hst-define-meta-val">Right host, optimized config, monitored</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="hst-includes">
      <div class="container">
        <div class="hst-includes-head">
          <p class="hst-section-eyebrow">
            <span class="hst-section-eyebrow-line"></span>
            What we cover
          </p>
          <h2 class="page-h2">
            Twelve checks <em>across setup, migration, and tuning.</em>
          </h2>
          <p class="page-section-lead">From host evaluation to DNS cutover to 30-day monitoring. Every engagement ships with a written hosting configuration document so future developers know exactly what was changed.</p>
        </div>

        <div class="hst-includes-grid">
          {covered.map((item, i) => (
            <div class="hst-include">
              <span class="hst-include-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="hst-include-check" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="hst-include-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="hst-tiers" id="tiers">
      <div class="container">
        <div class="hst-tiers-head">
          <p class="hst-section-eyebrow">
            <span class="hst-section-eyebrow-line"></span>
            Three tiers
          </p>
          <h2 class="page-h2">
            Three <em>WordPress hosting packages.</em>
          </h2>
          <p class="page-section-lead">Each tier is fixed-scope. The host invoices you directly; we do not mark up hosting fees or earn affiliate commissions on placements.</p>
        </div>

        <div class="hst-tiers-grid">
          {tiers.map((t) => (
            <a href={t.href} class={`hst-tier ${t.highlight ? 'hst-tier-highlight' : ''}`}>
              {t.highlight && <span class="hst-tier-flag">Most chosen</span>}
              <span class="hst-tier-name">{t.name}</span>
              <span class="hst-tier-price">{t.price}</span>
              <span class="hst-tier-duration">{t.duration}</span>
              <p class="hst-tier-summary">{t.summary}</p>
              <div class="hst-tier-fits">
                <span class="hst-tier-fits-label">Fits</span>
                <ul class="hst-tier-fits-list">
                  {t.fits.map((f) => (<li>{f}</li>))}
                </ul>
              </div>
              <span class="hst-tier-cta">
                Book {t.name}
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="hst-when">
      <div class="container">
        <div class="hst-when-head">
          <p class="hst-section-eyebrow">
            <span class="hst-section-eyebrow-line"></span>
            When you need it
          </p>
          <h2 class="page-h2">
            Six signals <em>your WordPress hosting needs to change.</em>
          </h2>
        </div>

        <div class="hst-when-grid">
          {whenHosting.map((w) => (
            <article class="hst-when-card">
              <span class="hst-when-num">{w.num}</span>
              <h3 class="hst-when-signal">{w.signal}</h3>
              <p class="hst-when-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="hst-compare">
      <div class="container">
        <div class="hst-compare-head">
          <p class="hst-section-eyebrow">
            <span class="hst-section-eyebrow-line"></span>
            Host comparison
          </p>
          <h2 class="page-h2">
            How four managed WordPress hosts <em>actually compare.</em>
          </h2>
          <p class="page-section-lead">Honest comparison from someone who has migrated sites onto and off all four. Pricing accurate as of May 2026; verify on the host website before committing.</p>
        </div>

        <div class="hst-compare-table-wrap">
          <table class="hst-compare-table">
            <thead>
              <tr>
                <th class="hst-compare-th-factor">Factor</th>
                <th class="hst-compare-th-host">Kinsta</th>
                <th class="hst-compare-th-host">WP Engine</th>
                <th class="hst-compare-th-host">Cloudways</th>
                <th class="hst-compare-th-host">SiteGround</th>
              </tr>
            </thead>
            <tbody>
              {hostingMatrix.map((c) => (
                <tr>
                  <td class="hst-compare-factor">{c.factor}</td>
                  <td class="hst-compare-cell">{c.kinsta}</td>
                  <td class="hst-compare-cell">{c.wpe}</td>
                  <td class="hst-compare-cell">{c.cloudways}</td>
                  <td class="hst-compare-cell">{c.siteground}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="hst-faq">
      <div class="container">
        <div class="hst-faq-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">WordPress hosting FAQ</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 hst-faq-h2">
            Seven questions <em>before you book.</em>
          </h2>
        </div>

        <div class="hst-faq-list">
          {faqs.map((f, i) => (
            <details class="hst-faq-item">
              <summary class="hst-faq-q">
                <span class="hst-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="hst-faq-q-text">{f.q}</span>
                <span class="hst-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="hst-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

</main>
  <BottomFormCTA formName="wp-hosting-cta"
    formSteps={[
      {
        title: 'Tell us who you are',
        subtitle: 'Just your name and email. 30 seconds.',
        fields: [
          { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
          { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
        ],
      },
      {
        title: 'About your site',
        subtitle: 'Where it lives now and where it should go.',
        fields: [
          { type: 'url',  name: 'site_url', label: 'WordPress site URL', placeholder: 'https://yoursite.com', required: false, autocomplete: 'url' },
          { type: 'select', name: 'current_host', label: 'Current host', required: true,
            options: ['No host yet (new site)', 'Bluehost', 'GoDaddy', 'Hostinger', 'SiteGround', 'Kinsta', 'WP Engine', 'Cloudways', 'Other / Not sure'] },
        ],
      },
      {
        title: 'Site profile',
        subtitle: 'Traffic and store status.',
        fields: [
          { type: 'select', name: 'monthly_traffic', label: 'Monthly visitors', required: true,
            options: ['Under 1,000', '1,000 to 10,000', '10,000 to 50,000', '50,000 to 250,000', '250,000+', 'Not sure'] },
          { type: 'select', name: 'site_type', label: 'Site type', required: true,
            options: ['Marketing site', 'Blog / content site', 'WooCommerce store', 'Multisite network', 'Membership / SaaS', 'Other'] },
        ],
      },
      {
        title: 'Engagement scope',
        subtitle: 'Which package fits and what success looks like.',
        fields: [
          { type: 'select', name: 'engagement_tier', label: 'Engagement type', required: true,
            options: ['Hosting setup ($750)', 'Migration ($1,500)', 'Managed hosting ($300+/mo)', 'Not sure, recommend a host'] },
          { type: 'textarea', name: 'message', label: 'What is the problem?', placeholder: 'Slow site, renewal pricing, outage, planning a launch.', required: true, rows: 2 },
        ],
      },
    ]}
  />

  <Footer />
