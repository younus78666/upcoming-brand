---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import BottomFormCTA from '../../components/BottomFormCTA.astro';
const canonical = "https://upcomingbrand.com/team/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "The Team | Upcoming Brand WordPress Studio",
      "description": "Meet the team behind Upcoming Brand. A small remote-first WordPress studio led by founder Younus, with a trusted network of designers, developers, and SEO specialists across 12 countries.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".page-lead"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": "https://upcomingbrand.com/about/" },
          { "@type": "ListItem", "position": 3, "name": "Team",  "item": canonical }
        ]
      }
    },
    {
      "@type": "Person",
      "@id": `${canonical}#younus`,
      "name": "Younus",
      "jobTitle": "Founder & WordPress Lead",
      "worksFor": { "@id": "https://upcomingbrand.com/#organization" },
      "description": "Founder of Upcoming Brand. WordPress web design, schema architecture, and Core Web Vitals specialist with 400+ projects shipped across 12 countries."
    }
  ]
});

const stats = [
  { num: "5+",   label: "Years building WordPress" },
  { num: "400+", label: "Projects shipped" },
  { num: "12",   label: "Countries served" },
  { num: "9",    label: "Industry verticals" },
];

const expertise = [
  { area: "WordPress development",  detail: "Custom blocks, ACF Pro, Elementor, theme dev, plugin engineering" },
  { area: "Core Web Vitals",        detail: "90+ Lighthouse scores as a deliverable on every project" },
  { area: "Schema architecture",    detail: "LocalBusiness, FAQ, Service, vertical-specific schema types" },
  { area: "WooCommerce",            detail: "Subscriptions, configurators, multi-vendor, payment integrations" },
  { area: "Local SEO",              detail: "Local Pack ranking, GBP optimisation, citation strategy" },
  { area: "Migrations",             detail: "Wix / Squarespace / GoDaddy → custom WordPress, zero ranking loss" },
];

const network = [
  {
    role: "Visual designers",
    detail: "Brand-aligned UI / UX collaborators who handle bespoke design rounds when projects need a dedicated design partner.",
    count: "3-5",
    icon: "design",
  },
  {
    role: "Front-end developers",
    detail: "Senior WP developers we bring in for sprints when a project has tight timelines or specialty integrations.",
    count: "2-4",
    icon: "code",
  },
  {
    role: "SEO + content specialists",
    detail: "Long-form content writers and on-page SEO consultants for verticals that need deep editorial work.",
    count: "2",
    icon: "search",
  },
  {
    role: "Photography + production",
    detail: "Maryland-based photographers we partner with when a project needs original imagery instead of stock.",
    count: "On call",
    icon: "camera",
  },
];

const principles = [
  {
    num: "01",
    title: "One channel of accountability",
    body: "The person you book a discovery call with is the person who writes your schema, builds your blocks, and ships your launch. No relays. No telephone game.",
  },
  {
    num: "02",
    title: "Specialists, not generalists",
    body: "When a project needs a dedicated visual designer or a senior front-end engineer, we bring in a partner who's built that exact thing 20+ times. Niche specialists beat agency generalists every time.",
  },
  {
    num: "03",
    title: "Async by default",
    body: "Most communication happens in writing on a private staging URL. Faster decisions, written record, no calendar Tetris. Sync calls only when the conversation needs voice.",
  },
  {
    num: "04",
    title: "Small on purpose",
    body: "We've turned down acquisition offers and growth-team pitches. A small studio with vetted partners outperforms a 50-person agency on every metric we care about: depth, speed, and care.",
  },
];
---
<BaseLayout
  title="The Team | Upcoming Brand WordPress Studio Maryland"
  description="Meet the team behind Upcoming Brand. A small remote-first WordPress studio led by founder Younus, with a trusted network of designers, developers, and SEO specialists across 12 countries."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">The team</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">Small studio.</span>
          <span class="page-h1-line"><em class="page-h1-accent">Vetted network.</em></span>
          <span class="page-h1-line page-h1-italic">No account managers.</span>
        </h1>

        <p class="page-lead">
          Upcoming Brand is run by <strong>one founder and a vetted network of specialists</strong> across design, development, SEO, and photography. The result: a 50-person agency's depth without the 50-person agency's overhead, hand-offs, or quality drift.
        </p>

        <div class="page-hero-ctas">
          <a href="/contact/" class="lp-btn-primary">
            Book a call with the founder
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/about/" class="lp-btn-ghost">
            About the studio
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Top Rated &middot; Upwork
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">5+ years &middot; 400+ projects</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">12 countries &middot; 9 verticals</span>
        </div>
      </div>
    </section>

    <!-- ====== FOUNDER ====== -->
    <section class="team-founder">
      <div class="container">
        <div class="team-founder-head">
          <div class="page-eyebrow-strip page-eyebrow-strip-left">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">The founder</span>
          </div>
          <h2 class="page-h2">
            Every project, <em>personally led.</em>
          </h2>
        </div>

        <div class="team-founder-card">
          <!-- Portrait column -->
          <div class="team-founder-portrait">
            <div class="team-founder-photo">
              <!-- Placeholder portrait — replace src with /team/younus.jpg once added -->
              <img src="/team-placeholder.svg" alt="Younus, Founder of Upcoming Brand" width="320" height="400" onerror="this.style.display='none'; this.parentElement.classList.add('no-img');" />
              <div class="team-founder-photo-fallback" aria-hidden="true">
                <span class="team-founder-photo-initials">Y</span>
                <span class="team-founder-photo-glow"></span>
              </div>
            </div>
            <div class="team-founder-meta">
              <span class="team-founder-meta-label">Based in</span>
              <span class="team-founder-meta-val">Maryland, USA</span>
              <div class="team-founder-meta-divider" aria-hidden="true"></div>
              <span class="team-founder-meta-label">Working since</span>
              <span class="team-founder-meta-val">2019</span>
              <div class="team-founder-meta-divider" aria-hidden="true"></div>
              <span class="team-founder-meta-label">Stack</span>
              <span class="team-founder-meta-val">WordPress · WooCommerce · Schema</span>
            </div>
          </div>

          <!-- Bio column -->
          <div class="team-founder-bio">
            <span class="team-founder-tag">Founder &middot; WordPress Lead</span>
            <h3 class="team-founder-name">Younus</h3>
            <p class="team-founder-role">Founder &amp; WordPress lead</p>

            <div class="team-founder-text">
              <p>
                Five years and 400+ WordPress projects in. Started Upcoming Brand after watching too many businesses spend five figures with traditional agencies and still not crack page one. The pattern was always the same: beautiful sites, missing schema, Lighthouse scores in the forties, and zero Local Pack visibility.
              </p>
              <p>
                Today the studio runs on a simple promise: the person you book your discovery call with is the same person who maps your schema, writes your blocks, audits your Core Web Vitals, and ships your site. One channel, one chain of accountability, one person responsible for the launch landing in the green.
              </p>
              <p>
                Outside of client work: building open-source schema generators, contributing to WordPress core ticket discussions, and keeping a long-running spreadsheet of every Maryland Local Pack composition for the verticals we serve most.
              </p>
            </div>

            <div class="team-founder-stack">
              <span class="team-founder-stack-label">Specialty stack</span>
              <div class="team-founder-stack-pills">
                <span class="team-stack-pill">WordPress core</span>
                <span class="team-stack-pill">Custom blocks</span>
                <span class="team-stack-pill">ACF Pro</span>
                <span class="team-stack-pill">WooCommerce</span>
                <span class="team-stack-pill">Schema.org</span>
                <span class="team-stack-pill">Core Web Vitals</span>
                <span class="team-stack-pill">RankMath</span>
                <span class="team-stack-pill">LocalBusiness SEO</span>
              </div>
            </div>

            <div class="team-founder-social">
              <a href="#" class="team-social-link" aria-label="Upwork profile">
                <span class="team-social-text">Upwork profile</span>
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a href="#" class="team-social-link" aria-label="LinkedIn profile">
                <span class="team-social-text">LinkedIn</span>
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a href="/work/" class="team-social-link" aria-label="Portfolio">
                <span class="team-social-text">Portfolio</span>
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Stats strip -->
        <div class="team-stats-strip">
          {stats.map((s) => (
            <div class="team-stat-card">
              <span class="team-stat-num">{s.num}</span>
              <span class="team-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== EXPERTISE ====== -->
    <section class="team-expertise">
      <div class="container">
        <div class="team-expertise-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Specialty areas</span>
            <span class="page-eyebrow-line"></span>
          </div>
          <h2 class="page-h2 team-expertise-h2">
            What the founder <em>actually builds.</em>
          </h2>
          <p class="page-section-lead team-expertise-lead">Six things shipped on every project, regardless of vertical or budget tier. The deliverables under each are the same whether you're at the Starter or Custom tier.</p>
        </div>

        <div class="team-expertise-grid">
          {expertise.map((e, i) => (
            <article class="team-expertise-card">
              <span class="team-expertise-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="team-expertise-area">{e.area}</h3>
              <p class="team-expertise-detail">{e.detail}</p>
              <div class="team-expertise-line" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== EXTENDED NETWORK ====== -->
    <section class="team-network">
      <div class="container">
        <div class="team-network-head">
          <div class="page-eyebrow-strip page-eyebrow-strip-left">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">The extended network</span>
          </div>
          <h2 class="page-h2">
            Who else is <em>in the room.</em>
          </h2>
          <p class="page-section-lead">
            For projects that need a dedicated designer, a sprint with a senior front-end engineer, or original photography, we bring in vetted specialists from a long-standing network. You meet them at the kickoff. They're paid through us. The accountability stays with the founder.
          </p>
        </div>

        <div class="team-network-grid">
          {network.map((n) => (
            <div class="team-network-card">
              <div class="team-network-card-top">
                <span class="team-network-icon" aria-hidden="true">
                  {n.icon === "design" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
                  )}
                  {n.icon === "code" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  )}
                  {n.icon === "search" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  )}
                  {n.icon === "camera" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                  )}
                </span>
                <span class="team-network-count">{n.count}</span>
              </div>
              <h3 class="team-network-role">{n.role}</h3>
              <p class="team-network-detail">{n.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== HOW WE OPERATE ====== -->
    <section class="team-principles">
      <div class="container">
        <div class="team-principles-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">How we operate</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 team-principles-h2">
            Four operating <em>principles.</em>
          </h2>
        </div>

        <div class="team-principles-grid">
          {principles.map((p) => (
            <article class="team-principle-card">
              <span class="team-principle-num">{p.num}</span>
              <h3 class="team-principle-title">{p.title}</h3>
              <p class="team-principle-body">{p.body}</p>
            </article>
          ))}
        </div>

        <div class="team-principles-careers">
          <div class="team-careers-text">
            <p class="team-careers-eyebrow">Want to join the network?</p>
            <p class="team-careers-body">
              We work with a tight roster of senior designers, front-end developers, and SEO specialists on a project-by-project basis. If you're WordPress-deep and care about Core Web Vitals as much as we do, we'd like to know you.
            </p>
          </div>
          <a href="/careers/" class="team-careers-cta">
            See open collaborations
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 6.5h11M7 1l5.5 5.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
</main>

  <BottomFormCTA formName="team-cta" />

  <Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM (mirrored from About)
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(56px, 8vh, 96px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }

  .page-eyebrow-strip-left {
    justify-content: flex-start;
  }

  .page-eyebrow-line {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .page-eyebrow-line-light {
    background: rgba(212,147,46,0.5);
  }

  .page-eyebrow-line-amber {
    background: var(--amber);
  }

  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }

  .page-eyebrow-text-light {
    color: rgba(244,239,230,0.7);
  }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }

  .page-h1-line { display: block; color: var(--ink); }

  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }

  .page-h1-accent::after { display: none; }

  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }

  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .lp-btn-primary,
  .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lp-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg,
  .lp-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }
  .lp-btn-ghost:hover svg { transform: translate(2px, -2px); }

  .page-hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .page-trust-line {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .page-trust-dot {
    width: 3px; height: 3px;
    background: var(--ink-muted);
    border-radius: 50%;
    opacity: 0.4;
  }

  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 16px 0 0;
  }

  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-section-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 16px 0 0;
  }

  /* ===========================================
     FOUNDER SECTION
     =========================================== */
  .team-founder {
    background: var(--paper);
    padding: clamp(56px, 8vh, 96px) 0;
