---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const pageUrl   = "https://upcomingbrand.com/industries/";
const pageTitle = "Industry Web Design Maryland | 12 Verticals | Upcoming Brand";
const pageDesc  = "Maryland web design for law firms, dental, medical, restaurants, contractors, real estate, nonprofits, and ecommerce. Schema-first. Fixed scope from $1,500.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": pageDesc,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "dateModified": "2026-05-01",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Industries", "item": pageUrl }
        ]
      }
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#itemlist`,
      "name": "Industries served by Upcoming Brand",
      "description": "Vertical-specific WordPress web design for 12 Maryland business industries",
      "numberOfItems": 12,
      "itemListElement": [
        { "@type": "ListItem", "position": 1,  "url": "https://upcomingbrand.com/industries/law-firm-website-design/",       "name": "Law Firm Website Design Maryland" },
        { "@type": "ListItem", "position": 2,  "url": "https://upcomingbrand.com/industries/dental-website-design/",         "name": "Dental Website Design Maryland" },
        { "@type": "ListItem", "position": 3,  "url": "https://upcomingbrand.com/industries/medical-website-design/",        "name": "Medical Website Design Maryland" },
        { "@type": "ListItem", "position": 4,  "url": "https://upcomingbrand.com/industries/accountant-website-design/",     "name": "Accountant Website Design Maryland" },
        { "@type": "ListItem", "position": 5,  "url": "https://upcomingbrand.com/industries/contractor-website-design/",     "name": "Contractor Website Design Maryland" },
        { "@type": "ListItem", "position": 6,  "url": "https://upcomingbrand.com/industries/restaurant-website-design/",     "name": "Restaurant Website Design Maryland" },
        { "@type": "ListItem", "position": 7,  "url": "https://upcomingbrand.com/industries/real-estate-website-design/",    "name": "Real Estate Website Design Maryland" },
        { "@type": "ListItem", "position": 8,  "url": "https://upcomingbrand.com/industries/nonprofit-website-design/",      "name": "Nonprofit Website Design Maryland" },
        { "@type": "ListItem", "position": 9,  "url": "https://upcomingbrand.com/industries/small-business-website-design/", "name": "Small Business Website Design Maryland" },
        { "@type": "ListItem", "position": 10, "url": "https://upcomingbrand.com/industries/ecommerce-website-design/",      "name": "Ecommerce Website Design Maryland" },
        { "@type": "ListItem", "position": 11, "url": "https://upcomingbrand.com/industries/church-website-design/",         "name": "Church Website Design Maryland" },
        { "@type": "ListItem", "position": 12, "url": "https://upcomingbrand.com/industries/gym-website-design/",            "name": "Gym Website Design Maryland" }
      ]
    }
  ]
};

const pillars = [
  {
    num: "01",
    title: "Schema type determines discoverability",
    body: "A dental practice needs Dentist and MedicalOrganization schema. A law firm needs LegalService and Attorney markup. A restaurant needs FoodEstablishment. Generic agencies skip all of it, leaving your Local Pack slot empty for a competitor to fill.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    num: "02",
    title: "Compliance rules vary by industry",
    body: "Maryland attorneys operate under MRPC 7.1-7.5. Medical and dental sites must handle HIPAA-aware form boundaries. Nonprofits need FEC-compliant donation flows. Agencies that build sites for everyone specialise in none of these constraints.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    num: "03",
    title: "Conversion architecture follows your buyer",
    body: "A patient books an appointment. A homeowner requests an estimate. A donor gives once, then monthly. An attorney prospect submits a multi-step intake. The form, the funnel, and the page hierarchy each need to match exactly how your customer decides to act.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>`,
  },
];

const groups = [
  {
    label: "Professional Services",
    slug: "professional-services",
    bg: "light",
    desc: "Regulated industries where schema compliance, professional trust signals, and multi-step intake forms drive the conversion. Generic agencies routinely leave bar licenses exposed and Local Pack slots empty.",
    industries: [
      {
        num: "01",
        name: "Law Firms & Attorneys",
        href: "/industries/law-firm-website-design/",
        hook: "Most attorney sites load in 6-9 seconds on mobile. Your prospect has already called the next firm before your phone number appears.",
        schema: "LegalService + Attorney schema",
        note: "MRPC 7.1-7.5 compliant copy",
        stat: "+312% organic intake leads",
        tags: ["Multi-step intake forms", "Practice area pages", "Local Pack setup"],
        cta: "Law firm web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M8 7l-4 9h8L8 7zM16 7l-4 9h8L16 7z"/><path d="M4 20h16"/></svg>`,
      },
      {
        num: "02",
        name: "Dental Practices",
        href: "/industries/dental-website-design/",
        hook: "67% of patients prefer to book appointments online. 42% of dental bookings happen outside business hours. A contact form is not a booking system.",
        schema: "Dentist + MedicalOrganization schema",
        note: "HIPAA-aware form structure",
        stat: "4x Local Pack appointment rate",
        tags: ["Online appointment booking", "Before/after gallery", "Insurance info pages"],
        cta: "Dental web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C9 2 6 4.5 6 7.5c0 1.5.5 3 1 4.5L8 18c.5 2 1.5 4 4 4s3.5-2 4-4l1-6c.5-1.5 1-3 1-4.5C18 4.5 15 2 12 2z"/></svg>`,
      },
      {
        num: "03",
        name: "Medical Clinics",
        href: "/industries/medical-website-design/",
        hook: "62% of medical sites fail Core Web Vitals. Patients searching 'internist near me Annapolis' leave sites that load in 7-10 seconds on mobile.",
        schema: "Physician + MedicalOrganization schema",
        note: "HIPAA-aware contact forms",
        stat: "+284% organic patient inquiries",
        tags: ["Patient portal integration", "Provider bio pages", "Healthgrades/Vitals sync"],
        cta: "Medical web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
      },
      {
        num: "04",
        name: "Accountants & CPAs",
        href: "/industries/accountant-website-design/",
        hook: "82% of accounting clients search online first, but most CPA websites rank only for their firm name. One generic 'services' page ranks for nothing.",
        schema: "AccountingService + ProfessionalService schema",
        note: "Niche client segment landing pages",
        stat: "60-90 day ranking movement",
        tags: ["Service-specific pages", "Client portal integration", "Tax season lead capture"],
        cta: "Accountant web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
      },
    ],
  },
  {
    label: "Local & Trade",
    slug: "local-trade",
    bg: "cream",
    desc: "Service-area businesses where city-level search visibility, review authority, and multi-step quote forms determine whether the phone rings. Speed and Local Pack presence are table stakes.",
    industries: [
      {
        num: "05",
        name: "Contractors & Trades",
        href: "/industries/contractor-website-design/",
        hook: "The average contractor site we audit loads in 7 seconds on mobile. Every second above 1.5 seconds costs you booked jobs to whoever is ranking below you.",
        schema: "HomeAndConstructionBusiness + LocalBusiness schema",
        note: "City landing pages per service area",
        stat: "3-6 month first-page timeline",
        tags: ["Multi-step estimate forms", "Service area pages", "HomeAdvisor/Angi sync"],
        cta: "Contractor web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
      },
      {
        num: "06",
        name: "Restaurants & Hospitality",
        href: "/industries/restaurant-website-design/",
        hook: "89% of diners research restaurants online before visiting. Without Restaurant schema, your price range, hours, and cuisine type never appear in rich results.",
        schema: "Restaurant + FoodEstablishment schema",
        note: "OpenTable/Resy/Tock integration",
        stat: "30-day Local Pack improvement",
        tags: ["Interactive menus", "Reservation widget", "TripAdvisor/Yelp sync"],
        cta: "Restaurant web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><path d="M6 1v3M10 1v3M14 1v3"/></svg>`,
      },
      {
        num: "07",
        name: "Real Estate Brokerages",
        href: "/industries/real-estate-website-design/",
        hook: "93% of buyers start their home search online (NAR 2024). Without neighborhood pages, that traffic goes to Zillow instead of you.",
        schema: "RealEstateAgent + LocalBusiness schema",
        note: "IDX integration with Bright MLS",
        stat: "60-90 day neighborhood page ranking",
        tags: ["IDX/MLS live listings", "Neighborhood pages", "Seller valuation forms"],
        cta: "Real estate web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>`,
      },
      {
        num: "08",
        name: "Nonprofits",
        href: "/industries/nonprofit-website-design/",
        hook: "If your giving page redirects to a third-party site with no branding, you are losing recurring donors at the moment of commitment.",
        schema: "NonprofitOrganization + LocalBusiness schema",
        note: "Google Ad Grants setup included",
        stat: "GiveWP / Stripe recurring giving",
        tags: ["Donation integration", "Volunteer signup forms", "Impact pages"],
        cta: "Nonprofit web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
      },
    ],
  },
  {
    label: "Growth & Ecommerce",
    slug: "growth-ecommerce",
    bg: "light",
    desc: "Scale-first builds where product schema, class schedules, online giving, and conversion rate optimization determine revenue. Speed and checkout flow are not cosmetic choices.",
    industries: [
      {
        num: "09",
        name: "Small Business & Startups",
        href: "/industries/small-business-website-design/",
        hook: "A site without LocalBusiness schema, city landing pages, and a Google Business Profile optimized for your trade cannot compete for 'near me' searches.",
        schema: "LocalBusiness + ProfessionalService schema",
        note: "City landing pages for every market",
        stat: "4-6 week Starter delivery",
        tags: ["Lead generation forms", "GBP optimization", "Calendly scheduling"],
        cta: "Small business web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><path d="M12 12v4M10 14h4"/></svg>`,
      },
      {
        num: "10",
        name: "Ecommerce & DTC Brands",
        href: "/industries/ecommerce-website-design/",
        hook: "WooCommerce stores with Product and Offer schema appear as rich results with pricing and availability. Stores without it are competing blind.",
        schema: "Product + Offer schema · WooCommerce",
        note: "Google Merchant Center feed setup",
        stat: "Stripe/PayPal checkout built-in",
        tags: ["Product pages", "Abandoned cart recovery", "ShipStation integration"],
        cta: "Ecommerce web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.97-1.67l1.38-7.33H6"/></svg>`,
      },
      {
        num: "11",
        name: "Churches & Ministries",
        href: "/industries/church-website-design/",
        hook: "When someone searches 'Baptist church near me Columbia MD,' Google shows churches with complete local schema, not the church whose service times are buried in a PDF.",
        schema: "Church + PlaceOfWorship + Event schema",
        note: "Tithe.ly/Pushpay giving integration",
        stat: "Sermon archive with filter/search",
        tags: ["Online giving", "Event calendar", "Ministry directory pages"],
        cta: "Church web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="10" y1="4" x2="14" y2="4"/><path d="M5 10h14l1 10H4z"/><path d="M9 20v-5h6v5"/></svg>`,
      },
      {
        num: "12",
        name: "Gyms & Fitness Studios",
        href: "/industries/gym-website-design/",
        hook: "Multi-step trial signup forms with a progress indicator outperform single-page forms for fitness audiences by 40-60%. A generic contact form is losing you members daily.",
        schema: "FitnessCenter + SportsActivityLocation schema",
        note: "Mindbody/Glofox class schedule integration",
        stat: "3-5x trial signup rate increase",
        tags: ["Live class schedule", "Free trial CTA", "Transformation gallery"],
        cta: "Gym web design guide",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M5 8H4a4 4 0 000 8h1"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="8" y1="8" x2="8" y2="16"/><line x1="16" y1="8" x2="16" y2="16"/></svg>`,
      },
    ],
  },
];

const capabilities = [
  {
    num: "90+",
    label: "PageSpeed on delivery",
    sub: "Every site ships with green Core Web Vitals across LCP, INP, and CLS, or we fix it before launch at no cost.",
  },
  {
    num: "$0",
    label: "Hourly billing, ever",
    sub: "Every project is fixed-scope. You know the full price before signing. No surprise invoices mid-build.",
  },
  {
    num: "6-10",
    label: "Week delivery window",
    sub: "Discovery, design, build, and launch in a single fixed-scope engagement. No retainers required.",
  },
  {
    num: "12",
    label: "Industries, one studio",
    sub: "Seven years full-time WordPress work across Maryland and 12 countries. No agency overhead, no handoffs.",
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl={pageUrl}
  ogImage="https://upcomingbrand.com/og-image.jpg"
  ogImageAlt="Upcoming Brand - vertical-specific WordPress web design across 12 Maryland industries"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navigation />

  <!-- ── HERO ── -->
  <section class="ih-hero section-pad">
    <div class="container">
      <div class="ih-hero-inner">
        <p class="eyebrow" style="justify-content:center">Who we build for</p>
        <h1 class="ih-h1">
          WordPress web design built for<br>
          <em class="ih-h1-accent">your industry</em>, not adapted to it
        </h1>
        <p class="ih-lead">
          We've audited enough generic-agency sites to know the pattern: missing schema, wrong conversion architecture, compliance problems nobody caught. Every industry on this page gets a build that starts from vertical-specific requirements, not from a theme.
        </p>
        <div class="ih-ctas">
          <a href="#contact" class="cta-btn">Book a discovery call</a>
          <a href="#professional-services" class="ih-btn-ghost">
            Browse industries
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 2v10M2 8l5 5 5-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="ih-trust mono-xs">
          <span>Top Rated &middot; Upwork</span>
          <span class="ih-trust-dot" aria-hidden="true"></span>
          <span>400+ projects &middot; 12 countries</span>
          <span class="ih-trust-dot" aria-hidden="true"></span>
          <span>7 yrs full-time WordPress</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHY VERTICAL MATTERS ── -->
  <section class="ih-pillars section-pad">
    <div class="container">
      <div class="ih-pillars-intro">
        <p class="eyebrow" style="justify-content:center">Why vertical expertise matters</p>
        <h2 class="h2-section ih-pillars-h2">
          Three things that change completely by industry
        </h2>
      </div>
      <div class="ih-pillars-grid">
        {pillars.map((p) => (
          <div class="ih-pillar">
            <div class="ih-pillar-icon" aria-hidden="true" set:html={p.icon} />
            <span class="ih-pillar-num mono-xs">{p.num}</span>
            <h3 class="ih-pillar-title">{p.title}</h3>
            <p class="ih-pillar-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INDUSTRY GROUPS ── -->
  {groups.map((group) => (
    <section
      id={group.slug}
      class={`ih-group section-pad ih-group--${group.bg}`}
    >
      <div class="container">

        <div class="ih-group-header">
          <div class="ih-group-title-block">
            <h2 class="ih-group-label">{group.label}</h2>
            <p class="ih-group-desc">{group.desc}</p>
          </div>
        </div>

        <div class="ih-cards" role="list">
          {group.industries.map((ind) => (
            <article class="ih-card" role="listitem">
              <div class="ih-card-top">
                <div class="ih-card-meta">
                  <div class="ih-icon" aria-hidden="true" set:html={ind.icon} />
                  <span class="ih-num mono-xs">{ind.num}</span>
                </div>
                <span class="ih-stat-badge mono-xs">{ind.stat}</span>
              </div>

              <h3 class="ih-card-name">
                <a href={ind.href} class="ih-card-link">{ind.name}</a>
              </h3>

              <p class="ih-card-hook">{ind.hook}</p>

              <div class="ih-schema-row">
                <span class="ih-schema-badge">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <polyline points="1 6 4 9 11 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {ind.schema}
                </span>
              </div>

              <p class="ih-card-note mono-xs">{ind.note}</p>

              <div class="ih-card-tags" aria-hidden="true">
                {ind.tags.map((t) => <span class="ih-tag">{t}</span>)}
              </div>

              <a href={ind.href} class="ih-card-cta" aria-label={`Read the ${ind.name.toLowerCase()} web design guide`}>
                {ind.cta}
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </div>

      </div>
    </section>
  ))}

  <!-- ── CAPABILITIES ── -->
  <section class="ih-cap section-pad">
    <div class="container">
      <div class="ih-cap-intro">
        <p class="eyebrow ih-cap-eyebrow">What every build includes</p>
        <h2 class="ih-cap-h2">The same foundation under every vertical</h2>
        <p class="ih-cap-lead">Schema, speed, and fixed pricing don't change by industry. Here's what every project ships with.</p>
      </div>
      <div class="ih-cap-grid" role="list">
        {capabilities.map((c) => (
          <div class="ih-cap-card" role="listitem">
            <div class="ih-cap-num-wrap">
              <span class="ih-cap-num">{c.num}</span>
              <span class="ih-cap-rule" aria-hidden="true"></span>
            </div>
            <span class="ih-cap-label">{c.label}</span>
            <p class="ih-cap-sub mono-xs">{c.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="ih-cta section-pad" id="contact">
    <div class="container">
      <div class="ih-cta-inner">

        <div class="ih-cta-copy">
          <p class="eyebrow ih-cta-eyebrow">Ready to start?</p>
          <h2 class="ih-cta-h2">Tell us what you do. We'll build the site that fits.</h2>
          <div class="ih-trust-rows">
            <div class="ih-trust-row">
              <span class="ih-trust-icon" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </span>
              <span>Fixed-scope pricing, one price, no surprises</span>
            </div>
            <div class="ih-trust-row">
              <span class="ih-trust-icon" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <span>Reply within 4 business hours</span>
            </div>
            <div class="ih-trust-row">
              <span class="ih-trust-icon" aria-hidden="true">
