---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import FinalCTA from '../../components/FinalCTA.astro';
const pageUrl   = "https://upcomingbrand.com/industries/";
const pageTitle = "Industry Web Design Maryland | 12 Verticals | Upcoming Brand";
const pageDesc  = "Maryland web design for law firms, dental, medical, restaurants, contractors, real estate, nonprofits, and ecommerce. Schema-first. Fixed scope from $1,500.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": pageDesc,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Industries", "item": pageUrl }
        ]
      }
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#itemlist`,
      "name": "Industries served by Upcoming Brand",
      "numberOfItems": 12,
      "itemListElement": [
        { "@type": "ListItem", "position": 1,  "url": "https://upcomingbrand.com/industries/law-firm-website-design/",       "name": "Law Firm Website Design Maryland" },
        { "@type": "ListItem", "position": 2,  "url": "https://upcomingbrand.com/industries/dental-website-design/",         "name": "Dental Website Design Maryland" },
        { "@type": "ListItem", "position": 3,  "url": "https://upcomingbrand.com/industries/medical-website-design/",        "name": "Medical Website Design Maryland" },
        { "@type": "ListItem", "position": 4,  "url": "https://upcomingbrand.com/industries/accountant-website-design/",     "name": "Accountant Website Design Maryland" },
        { "@type": "ListItem", "position": 5,  "url": "https://upcomingbrand.com/industries/contractor-website-design/",     "name": "Contractor Website Design Maryland" },
        { "@type": "ListItem", "position": 6,  "url": "https://upcomingbrand.com/industries/restaurant-website-design/",     "name": "Restaurant Website Design Maryland" },
        { "@type": "ListItem", "position": 7,  "url": "https://upcomingbrand.com/industries/real-estate-website-design/",    "name": "Real Estate Website Design Maryland" },
        { "@type": "ListItem", "position": 8,  "url": "https://upcomingbrand.com/industries/nonprofit-website-design/",      "name": "Nonprofit Website Design Maryland" },
        { "@type": "ListItem", "position": 9,  "url": "https://upcomingbrand.com/industries/small-business-website-design/", "name": "Small Business Website Design Maryland" },
        { "@type": "ListItem", "position": 10, "url": "https://upcomingbrand.com/industries/ecommerce-website-design/",      "name": "Ecommerce Website Design Maryland" },
        { "@type": "ListItem", "position": 11, "url": "https://upcomingbrand.com/industries/church-website-design/",         "name": "Church Website Design Maryland" },
        { "@type": "ListItem", "position": 12, "url": "https://upcomingbrand.com/industries/gym-website-design/",            "name": "Gym Website Design Maryland" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faqpage`,
      "mainEntity": [
        { "@type": "Question", "name": "Do you specialise in one industry or work across all 12?", "acceptedAnswer": { "@type": "Answer", "text": "We work across all 12 verticals listed on this page, but vertical-specific experience is the point. Each industry has distinct schema requirements, compliance constraints, and conversion patterns. We have built enough sites in each vertical to know the pitfalls before your project hits them." } },
        { "@type": "Question", "name": "What does 'vertical-specific' web design actually mean?", "acceptedAnswer": { "@type": "Answer", "text": "It means three things change by industry: the schema type Google needs to classify your business correctly, the compliance rules that govern what you can say, and the conversion architecture that matches how your customer decides to act. A dental site needs Dentist schema and online booking. A law firm site needs LegalService schema and MRPC-compliant copy. A contractor site needs HomeAndConstructionBusiness schema and multi-step estimate forms." } },
        { "@type": "Question", "name": "How long does it take to rank for industry-specific searches in Maryland?", "acceptedAnswer": { "@type": "Answer", "text": "For less competitive Maryland markets like Frederick or Annapolis, most industries see meaningful ranking movement in 60 to 90 days. Baltimore, Bethesda, and Columbia take 3 to 6 months for consistent first-page presence. Google Business Profile and Local Pack optimisation typically produce the fastest early results, with improvements appearing within 30 to 45 days of launch." } },
        { "@type": "Question", "name": "Do you write the website copy for every industry?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Copy is included in every project tier. You provide raw material via a structured questionnaire and we draft everything: service pages, team bios, FAQs, and location pages. For regulated industries like law and healthcare, we handle the compliance framing. You review one draft for factual accuracy." } },
        { "@type": "Question", "name": "Can you handle HIPAA, MRPC, and other compliance requirements?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Medical and dental sites receive HIPAA-aware form structures that collect only scheduling-necessary information without requesting protected health information. Law firm copy is written under Maryland Rules of Professional Conduct 7.1 through 7.5. Nonprofit donation flows are structured to avoid FEC gray areas. We flag compliance considerations at Discovery before a line of code is written." } },
        { "@type": "Question", "name": "What is the starting price for an industry-specific site?", "acceptedAnswer": { "@type": "Answer", "text": "Starter builds begin at $1,500 for a 5 to 8 page site with custom design, vertical-specific schema, and Core Web Vitals green on delivery. Growth tier builds with 14 or more pages, city landing pages, and full Local Pack optimization run $3,500 to $6,000. Custom builds with IDX integration, WooCommerce, or multi-location schema start at $6,000. All pricing is fixed-scope. You know the full number before signing." } }
      ]
    }
  ]
};

const pillars = [
  {
    num: "01",
    title: "Schema type determines discoverability",
    body: "A dental practice needs Dentist and MedicalOrganization schema. A law firm needs LegalService and Attorney markup. A restaurant needs FoodEstablishment. Generic agencies skip all of it, leaving your Local Pack slot empty for a competitor to fill.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    num: "02",
    title: "Compliance rules vary by industry",
    body: "Maryland attorneys operate under MRPC 7.1-7.5. Medical and dental sites must handle HIPAA-aware form boundaries. Nonprofits need compliant donation flows. Agencies that build sites for everyone specialise in none of these constraints.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    num: "03",
    title: "Conversion architecture follows your buyer",
    body: "A patient books an appointment. A homeowner requests an estimate. A donor gives once, then monthly. An attorney prospect submits a multi-step intake. The form, funnel, and page hierarchy each need to match how your customer decides to act.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>`,
  },
];

const groups = [
