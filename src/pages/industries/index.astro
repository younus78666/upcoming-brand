const capabilities = [
  { num: "90+",  label: "PageSpeed on delivery",      sub: "Core Web Vitals green across LCP, INP, and CLS, guaranteed before launch." },
  { num: "$0",   label: "Hourly billing, ever",        sub: "Every project is fixed-scope. Full price agreed before you sign anything." },
  { num: "6-10", label: "Week delivery window",        sub: "Discovery, design, build, and launch in one fixed-scope engagement." },
  { num: "7 yrs",label: "Full-time WordPress",         sub: "No agency overhead, no handoffs. One studio, one point of contact." },
];

const faqs = [
