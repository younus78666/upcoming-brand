        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M8 7l-4 9h8L8 7zM16 7l-4 9h8L16 7z"/><path d="M4 20h16"/></svg>`,
      },
