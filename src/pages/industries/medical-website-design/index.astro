---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const stats = [
  { val: "62%", label: "of medical sites fail Core Web Vitals" },
  { val: "4.2x", label: "More appointments from Local Pack" },
  { val: "+284%", label: "Organic patient inquiries" },
];

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow sites lose patients before they call",
    body: "53% of mobile visitors leave a site that takes more than 3 seconds to load. Most medical practice websites we audit load in 7–10 seconds on mobile, which means a patient searching 'internist near me Annapolis' bounces before your phone number appears.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "Generic agencies skip MedicalOrganization schema",
    body: "Without Physician and MedicalOrganization JSON-LD schema, Google cannot confidently surface your practice in local searches or Knowledge Panels. Agencies that build sites for restaurants don't know these schema types exist, let alone how to implement them correctly.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Broken booking forms cost appointments",
    body: "A contact form is not a booking system. Patients expect online scheduling. Studies show 43% of appointments are now booked outside of business hours. If your site can't handle that, you're sending new patients to a practice that can.",
  },
];

const features = [
  {
    num: "01",
    title: "Physician and MedicalOrganization schema",
    body: "Every physician bio page and service page receives Physician and MedicalOrganization JSON-LD markup, including medical specialties, accepted insurance networks, hospital affiliations, and service areas. This tells Google exactly who you are, what you treat, and where: the prerequisite for appearing in local health searches and voice results.",
    tags: ["Physician schema", "MedicalOrganization", "Insurance networks"],
  },
  {
    num: "02",
    title: "Online appointment booking integration",
    body: "We integrate your preferred booking platform (Zocdoc, NexHealth, Phreesia, or Calendly) directly into your site. Patients can request appointments without calling during office hours. We build the scheduling flow to qualify patients by reason for visit and insurance before they book, reducing administrative burden on your front desk.",
    tags: ["Zocdoc / NexHealth", "Insurance pre-qualification", "After-hours booking"],
  },
  {
    num: "03",
    title: "Physician bio pages that build trust",
    body: "Patients research their doctor before booking. We design bio pages that lead with board certifications, medical school, residency, and hospital affiliations, formatted as structured data. A well-built physician bio page ranks independently for doctor-name searches and appears in Google's Knowledge Panel for the practice.",
    tags: ["Physician credentials", "Knowledge Panel", "Board certifications"],
  },
  {
    num: "04",
    title: "HIPAA-aware contact and inquiry forms",
    body: "We build appointment request forms that collect only what's necessary for scheduling (name, contact, reason for visit, insurance carrier) without requesting protected health information. Forms are labeled and structured to avoid HIPAA gray areas on the public-facing site, keeping your practice protected while still converting inquiries.",
    tags: ["HIPAA-aware forms", "PHI boundaries", "Secure submissions"],
  },
  {
    num: "05",
    title: "Google Business Profile and Local Pack setup",
    body: "Appearing in the Google Maps 3-pack for 'family doctor near me' or 'internist Baltimore' is frequently more valuable than any organic ranking. We audit and optimize your GBP: primary medical category, services, accepted insurance, Q&A, and photo metadata. We also ensure citation consistency across Healthgrades, Vitals, and WebMD.",
    tags: ["Google Business Profile", "Local Pack", "Healthgrades / Vitals"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your site ships with green Core Web Vitals across LCP, INP, and CLS, or we fix it before launch at no cost. Medical sites with poor performance are deprioritized in search rankings regardless of content quality. Our builds use a performance-first WordPress stack: CDN-delivered assets, server-side rendering, and LCP under 2.5 seconds on mobile.",
    tags: ["Core Web Vitals", "LCP < 2.5s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + patient journey mapping",
    body: "We audit your current site for technical SEO, Core Web Vitals, schema gaps, and booking friction. We map your target patient searches by specialty and city: Baltimore, Annapolis, Frederick, Bethesda. You receive a written strategy document covering keyword targets, GBP gaps, and the specific pages we'll build.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-assisted design + copy draft",
    body: "We generate your homepage and key service pages using AI-assisted design, desktop and mobile, built around your practice's positioning and patient demographics. We draft all copy including physician bios, service descriptions, and FAQs. One consolidated feedback round keeps the project moving.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "WordPress build + schema + booking integration",
    body: "Approved designs move into WordPress on our performance stack. Every physician bio, service page, and location page receives Physician and MedicalOrganization schema. Your booking platform is integrated and tested across mobile and desktop. You get a staging link to review weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Launch, GBP + Healthgrades optimization",
    body: "We handle DNS cutover, 301 redirect mapping, and sitemap submission to Search Console. Your Google Business Profile and Healthgrades listing are audited and optimized in the same window. You receive a plain-English handoff video and a 30-day post-launch monitoring window.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long before a new medical practice website ranks on Google?",
    a: "For local searches in smaller Maryland markets like Annapolis or Frederick, practices typically see meaningful ranking movement in 60–90 days. Competitive markets like Baltimore or Bethesda take 3–6 months for consistent first-page presence. GBP and Local Pack optimization often produce the fastest early results, with improvement typically appearing within 30–45 days of launch.",
  },
  {
    num: "02",
    category: "Platform",
    q: "Will the website integrate with our EHR or practice management system?",
    a: "The public-facing website integrates with your patient-facing booking tools (Zocdoc, NexHealth, Phreesia, or similar), not with your EHR directly. This keeps the public site outside your HIPAA compliance boundary. We do not connect websites to Epic, athenahealth, or eClinicalWorks directly. Appointment requests flow through the booking platform of your choice.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you write physician bios and service page copy?",
    a: "Yes, we write all copy as part of every project tier. You provide raw material via a structured questionnaire: physician credentials, medical school, residency, hospital affiliations, specialties, and any content focus areas. We draft copy that is factually accurate, credential-forward, and written for both patients and search engines. One review round included.",
  },
  {
    num: "04",
    category: "Migration",
    q: "Will we lose our search rankings when switching from our current site?",
    a: "Not with proper migration planning. We map every existing URL to its new equivalent, implement 301 redirects before DNS cutover, and monitor crawl errors in the 30-day post-launch window. Clean migrations with full redirect maps recover quickly, usually within 4–6 weeks. We have never shipped a build without one.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you provide after launch?",
    a: "Care plans start at $150/month and cover WordPress core and plugin updates, weekly backups, uptime monitoring, and priority support with a 4-business-hour response window. We also offer a content add-on for one new service page or location page per month, which builds your SEO footprint over time. Month-to-month with no annual contract.",
  },
  {
    num: "06",
    category: "SEO",
    q: "Can you help us rank for multiple physician specialties in multiple cities?",
    a: "Yes, this is exactly what the Growth and Custom tiers are built for. We create dedicated service pages for each specialty and location landing pages for each Maryland city you serve. Each page targets specific search queries like 'pediatrician Annapolis' or 'cardiologist Baltimore' with proper schema, copy, and internal linking to build topical authority across your full market area.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
