    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow donation pages cost you gifts at the moment of intent",
    body: "73% of donors research nonprofits online before making a gift, and a one-second delay in donation page load time reduces conversions by 7%. Most nonprofit websites we audit load in 6–9 seconds on mobile, which means a donor arriving from an email campaign abandons before they see your Give button. Every second of friction is a gift that doesn't happen.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "No NonprofitOrganization schema means no Google for Nonprofits visibility",
    body: "Without NonprofitOrganization and Organization JSON-LD schema, Google cannot confidently surface your organization in Local Search, Knowledge Panels, or Google for Nonprofits discovery paths. Generic web agencies don't implement this markup, leaving your organization invisible to donors who are specifically searching for nonprofits in your cause area.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Broken or inconvenient donation flows lose recurring givers",
    body: "A PayPal button is not a donation system. Donors expect online giving with credit cards, ACH, and recurring gift options, including a tax receipt confirmation. If your donation process requires more than three clicks or redirects to a third-party site with no branding, you're losing first-time donors before they become recurring supporters.",
  },
];

const features = [
