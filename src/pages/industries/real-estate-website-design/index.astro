<script>
  // Specialty custom dropdown
  document.querySelectorAll('.lf-cs-wrap').forEach((wrap) => {
    const trigger = wrap.querySelector('.lf-cs-trigger');
    const list    = wrap.querySelector('.lf-cs-list');
    const valSpan = wrap.querySelector('.lf-cs-val');
    const hidden  = wrap.querySelector('.lf-cs-hidden');
    const opts    = wrap.querySelectorAll('.lf-cs-opt');
    const open  = () => wrap.setAttribute('aria-expanded', 'true');
    const close = () => wrap.setAttribute('aria-expanded', 'false');
    const isOpen = () => wrap.getAttribute('aria-expanded') === 'true';
    trigger.addEventListener('click', (e) => { e.stopPropagation(); isOpen() ? close() : open(); });
    opts.forEach((opt) => {
      opt.addEventListener('click', () => {
        valSpan.textContent = opt.textContent.trim();
        hidden.value = opt.dataset.value;
        opts.forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        wrap.classList.add('has-value');
        close();
        trigger.focus();
      });
      opt.setAttribute('tabindex', '0');
      opt.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); } });
    });
    document.addEventListener('click', (e) => { if (!wrap.contains(e.target)) close(); });
    wrap.addEventListener('keydown', (e) => { if (e.key === 'Escape') { close(); trigger.focus(); } });
  });

  // FAQ accordion
  const items = document.querySelectorAll('[data-faq-item]');
  items.forEach((item) => {
    const btn  = item.querySelector('.lf-faq-trigger');
    const ans  = item.querySelector('.lf-faq-answer');
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      items.forEach((o) => {
        o.querySelector('.lf-faq-trigger').setAttribute('aria-expanded', 'false');
        o.querySelector('.lf-faq-answer').hidden = true;
      });
      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        ans.hidden = false;
      }
    });
  });
</script>
