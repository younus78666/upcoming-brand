  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you offer after launch?",
    a: "Our <a href=\"/services/wordpress-care-plans/\">WordPress care plan</a> starts at $150/month: WordPress updates, weekly backups, uptime monitoring, and priority support within 4 business hours. Neighborhood page content add-ons (one new page per month) are available separately, compounding your SEO footprint. Month-to-month, no annual contract.",
  },
  {
    num: "06",
    category: "SEO",
    q: "Can you help me rank for luxury real estate searches?",
    a: "Yes. Luxury real estate SEO requires dedicated market pages targeting high-intent searches like 'waterfront homes Annapolis over $1M' or 'luxury condos Baltimore Harbor.' We build property-type and price-tier landing pages that capture these searches with proper RealEstateAgent schema and locally-specific market content.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
