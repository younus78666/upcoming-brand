  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "WordPress build + IDX + schema",
    body: "Approved designs go into WordPress. IDX integration connects to Bright MLS and is tested across mobile and desktop. Every neighborhood and market page gets RealEstateAgent schema. Seller valuation pages and lead capture forms are built and tested.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Launch, GBP + portal profile audit",
    body: "We handle DNS cutover, 301 redirects, and sitemap submission. Your GBP and key portal profiles are audited simultaneously. You receive a handoff video and 30-day post-launch monitoring window.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long before an agent website ranks for neighborhood searches?",
    a: "For specific neighborhood searches in smaller Maryland markets, agents often see first-page movement in 60–90 days. Baltimore and broader county-level searches take 3–6 months. Neighborhood landing pages with proper schema and local content tend to rank faster than generic agent pages, as they target less competitive, more specific queries.",
  },
  {
    num: "02",
    category: "Platform",
    q: "What IDX providers do you work with?",
    a: "We work with IDX Broker, Showcase IDX, iHomeFinder, and Flexmls. We connect whichever platform your brokerage supports or help you select one. We handle the Bright MLS data feed setup and test all search widgets across mobile and desktop. IDX integration is included in the Growth and Custom tiers.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you write neighborhood page copy or do we provide it?",
    a: "We write initial neighborhood page frameworks as part of every tier. You provide local knowledge (school district info, market trends, community highlights, lifestyle selling points) via a questionnaire. We draft the copy that ranks and converts. One review round included. You can add more neighborhoods over time with our content add-on.",
  },
  {
    num: "04",
    category: "Migration",
    q: "Will we lose rankings when we move from our brokerage site?",
