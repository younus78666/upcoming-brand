---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Potential members can't find your gym in local search.",
    body: "When someone searches 'CrossFit gym near me in Columbia MD' or 'yoga studio Annapolis,' Google surfaces gyms with complete SportsActivityLocation schema and optimized Google Business Profiles. If your location, hours, class types, and membership options aren't structured for Google to read, you're invisible to people with a credit card ready and a fitness goal in mind — your most valuable prospective members.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "No online class schedule means fewer bookings.",
    body: "Fitness members plan their week around class schedules. If your schedule lives in a PDF, a separate app that doesn't match your site, or a static page that the front desk forgets to update — you're losing bookings to gyms that show live availability. We build class schedule integrations with Mindbody, Glofox, or custom WordPress solutions that stay current without requiring staff intervention.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Membership trial forms that lose signups at the last step.",
    body: "A free trial offer is the highest-converting fitness CTA — and most gym websites bury it behind a generic contact form, four clicks deep. When your trial form is mobile-optimized, above the fold, and asks for only the essential information (name, email, goal, preferred time), trial signup rates increase 3–5x. We build trial intake forms that connect directly to your CRM or email system and notify your front desk instantly.",
  },
];

const features = [
  {
    num: "01",
    title: "SportsActivityLocation and FitnessCenter schema on every page",
    body: "Every page receives SportsActivityLocation, FitnessCenter, and LocalBusiness JSON-LD schema — your gym's disciplines (HIIT, yoga, CrossFit, etc.), hours, location, and membership options. This is what enables Google to show your facility in the local 3-pack for searches like 'personal training studio Frederick MD' and in the fitness-specific results Google shows for workout-related queries. Without this structured data, Google is guessing what kind of business you are.",
    tags: ["FitnessCenter schema", "SportsActivityLocation", "Local Pack"],
  },
  {
    num: "02",
    title: "Class schedule integration with Mindbody, Glofox, or custom",
    body: "We integrate your class management system — Mindbody, Glofox, Pike13, or a custom WordPress solution — directly into your site. Members see live availability, instructors, and duration without leaving your branded environment. The schedule is filterable by class type, instructor, and time slot, and works correctly on every device. When classes fill up, the schedule updates automatically.",
    tags: ["Mindbody integration", "Glofox", "Live class schedule"],
  },
  {
    num: "03",
    title: "Membership and free trial signup pages that convert",
    body: "We design your membership page around one goal: converting a visitor into a trial booking or membership signup. The page hierarchy leads with your strongest offer (free trial, founding member rate, or challenge), surfaces pricing clearly, and places the signup form where mobile visitors see it without scrolling. Multi-step forms with a progress indicator consistently outperform single-page forms for fitness audiences by 40–60%.",
    tags: ["Membership conversion", "Free trial CTA", "Multi-step forms"],
  },
  {
    num: "04",
    title: "Trainer and coach bio pages that build trust and rank",
    body: "Prospective members read trainer bios to decide if your facility is for them. We build trainer pages that lead with credentials, certifications, specialties, and real photography direction — with structured data for each trainer's qualifications. A strong trainer page also ranks independently for trainer-name and specialty searches, capturing referral traffic from former clients who search for their coach at a new location.",
    tags: ["Coach profiles", "Person schema", "Trust signals"],
  },
  {
    num: "05",
    title: "Transformation gallery and results pages",
    body: "Social proof is the strongest conversion driver in the fitness industry. We build transformation galleries and results pages that load fast (optimized images, lazy loading), are filterable by program or goal type, and include proper testimonial schema so Google can display star ratings in search results. Every results page is independently SEO-targeted for searches like 'weight loss program Baltimore' or 'CrossFit results Maryland.'",
    tags: ["Results gallery", "Testimonial schema", "Before/after SEO"],
  },
  {
    num: "06",
    title: "Core Web Vitals green on delivery — guaranteed",
    body: "We guarantee your site launches with green Core Web Vitals scores across LCP, INP, and CLS — or we fix it at no cost before launch. Fitness sites frequently fail these metrics because of large video backgrounds, unoptimized transformation photos, and class schedule embed scripts. Our builds use server-side rendering, WebP images, CDN-delivered assets, and LCP under 2.5 seconds on mobile — including on class schedule pages.",
    tags: ["Core Web Vitals", "LCP < 2.5s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + membership funnel mapping",
    body: "We audit your current site for Core Web Vitals, schema gaps, and local SEO issues. We map your membership structure — class types, pricing tiers, trial offer — and identify the queries your target members use to find a gym in your area. You receive a written strategy document covering page architecture, class schedule integration options, and conversion funnel priorities.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-assisted designs + content plan",
    body: "We use AI-assisted design to generate and refine your homepage, membership page, and class schedule — built around your gym's brand identity and the local competitive landscape. Simultaneously, we map your trainer bio structure, results gallery, and trial signup flow. You review both in one consolidated feedback round.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "Full WordPress build + booking integration",
    body: "Approved designs go into WordPress on our performance stack. We build your class schedule integration, membership and trial signup pages, trainer bios, and results gallery. FitnessCenter and SportsActivityLocation schema is implemented on every relevant page. Your front desk receives a staff training doc as part of the handoff.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–9",
    title: "Launch, GBP optimization + handoff",
    body: "We handle DNS cutover, 301 redirect mapping from your old URLs, and sitemap submission to Google Search Console. Your Google Business Profile is audited and fully optimized — gym category, class types, hours, photo metadata. You receive a video walkthrough and a 30-day post-launch monitoring window where we resolve anything that surfaces.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How do we get our gym to show up in Google Maps for local searches?",
    a: "The primary lever is FitnessCenter and SportsActivityLocation JSON-LD schema on your homepage combined with a fully optimized Google Business Profile. Your GBP needs the correct primary category (Gym or the specific type — 'Yoga Studio,' 'CrossFit Gym,' etc.), complete hours, consistent NAP matching your website, and photos of your actual facility with descriptive file names. We handle all of this as part of every project. In competitive Maryland markets like Baltimore or Bethesda, expect 3–5 months for consistent Local Pack presence. Smaller markets like Frederick or Salisbury often move in 60–90 days.",
  },
  {
    num: "02",
    category: "Booking",
    q: "Which class booking system do you recommend for a gym our size?",
    a: "For studios under 200 members, Glofox or Pike13 offer the best balance of features and cost — clean WordPress integrations, reasonable monthly fees, and solid mobile apps for members. For larger facilities or multi-location operations, Mindbody is the industry standard despite its complexity and higher cost. If you're an independent personal trainer or small studio and cost is the primary concern, we can build a booking flow using Calendly or Acuity integrated into your WordPress site at no platform fee beyond your subscription. We assess your situation during Discovery.",
  },
  {
    num: "03",
    category: "Platform",
    q: "Can our staff update membership pricing, class schedules, and promotions without touching code?",
    a: "Yes — that is a core design requirement for every gym site we build. Pricing tables, class schedules (if using a custom WordPress solution), promotional banners, and blog posts are all editable through the WordPress admin with no code required. If you're using Mindbody or Glofox, schedule updates happen in your booking system and sync to the site automatically. We provide a plain-English admin manual, a recorded walkthrough video, and a 30-minute live training call with your key staff members.",
  },
  {
    num: "04",
    category: "Conversion",
    q: "What's the best way to structure a free trial or intro offer on the website?",
    a: "The offer should appear on your homepage above the fold, on a dedicated trial landing page, and as a sticky banner or CTA on class schedule and pricing pages. The trial form should ask for 3–5 fields maximum: name, email, fitness goal, and preferred class time. Multi-step forms — where you split the form across two screens — consistently outperform single-page forms for fitness audiences. We build the form with instant email notification to your front desk and optional integration with your CRM or email marketing platform.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What happens after the site launches — do you offer ongoing support?",
    a: "Yes. Our care plans start at $150/month and cover WordPress core and plugin updates, weekly backups, uptime monitoring, and priority support with a 4-business-hour response window. For gyms, we also offer a content add-on that includes one new class landing page, trainer bio, or transformation results page per month — compounding your SEO footprint over time as your program offerings expand. Plans are month-to-month — no annual contract required.",
  },
  {
    num: "06",
    category: "Migration",
    q: "We're on Squarespace, Wix, or a fitness-specific site builder — how disruptive is moving to WordPress?",
    a: "Typically 8–9 weeks from first call to live site, with minimal disruption if the migration is handled correctly. We map your current URL structure, implement 301 redirects for every existing page, and migrate your blog content and testimonials. Class schedule data from your booking system is not migrated (that lives in Mindbody or Glofox), but the integration configuration is set up fresh. The most common concern is losing existing Google rankings — with a proper redirect map, any ranking dip from a clean migration recovers within 4–6 weeks.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Booking":    { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Conversion": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Migration":  { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500–$3,500",
    timeline: "4–6 weeks",
    popular: false,
    dark: false,
    features: [
      "Up to 6 pages: Home, Classes, Membership, Trainers, About, Contact",
      "FitnessCenter + SportsActivityLocation JSON-LD schema",
      "Class schedule integration (Mindbody, Glofox, or custom)",
      "Mobile-first build · Core Web Vitals green on delivery",
      "Free trial signup form with CRM/email integration",
      "Google Search Console + Analytics 4 setup",
      "30 days post-launch support window",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500–$6,000",
    timeline: "6–8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 16 pages · trainer bios + results gallery + class library",
      "FitnessCenter + Person JSON-LD schema, specialty-mapped",
      "Multi-step trial signup flow with conditional logic",
      "Transformation results gallery with testimonial schema",
      "Google Business Profile audit + Local Pack optimization",
      "City landing pages for up to 3 Maryland markets",
      "60 days post-launch monitoring with monthly performance report",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000–$10,000+",
    timeline: "8–10 weeks",
    popular: false,
    dark: true,
    features: [
      "Multi-location schema + GBP for up to 4 locations",
      "Advanced Mindbody or Glofox integration with member portal",
      "Custom membership funnel with upsell and retention flows",
      "Woocommerce store for merchandise and supplements",
      "Full content migration from existing site or builder",
      "Staff training for multiple roles (front desk, trainers, admin)",
      "90 days post-launch support + first month of care plan included",
    ],
    cta: "Start a conversation",
  },
];
---
<BaseLayout
  title="Gym & Fitness Studio Website Design Maryland | Upcoming Brand"
  description="WordPress website design for Maryland gyms, fitness studios, and personal trainers. Class booking, membership signup, trainer bios, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore, Annapolis, Frederick."
  canonicalUrl="https://upcomingbrand.com/industries/gym-website-design/"
>
  <Navigation />

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="lfh-hero">

    <div class="container">
      <nav class="lfh-breadcrumb mono-xs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#industries">Industries</a>
        <span aria-hidden="true">/</span>
        <span>Gym &amp; Fitness Website Design</span>
      </nav>
    </div>

    <div class="container lfh-wrap">

      <!-- LEFT COLUMN -->
      <div class="lfh-left">

        <div class="lfh-tags">
          <span class="lfh-pill">
            <span class="lfh-dot" aria-hidden="true"></span>
            Gym &amp; Fitness Web Design &middot; Maryland
          </span>
          <span class="lfh-hero-sep" aria-hidden="true">&mdash;</span>
          <span class="lfh-hero-eyebrow">A specialist studio, not a template shop</span>
        </div>

        <h1 class="lfh-h1">
          <span class="lfh-h1-line">Maryland gym websites</span>
          <span class="lfh-h1-line lfh-h1-accent-line"><em class="lfh-h1-accent">built to book classes,</em></span>
          <span class="lfh-h1-line lfh-h1-italic">fill memberships, and grow.</span>
        </h1>

        <p class="lfh-lede">
          Most gym and fitness studio websites lose signups before anyone reads the membership page — slow load times, no class schedule, and a booking form that breaks on phones. We build WordPress sites for Maryland fitness businesses that rank in local search, convert visitors into trial memberships, and give your front desk one less thing to manage. Fixed-scope from <strong>$1,500</strong>.
        </p>

        <div class="lfh-ctas">
          <a href="#contact" class="lfh-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#pricing" class="lfh-btn-ghost">
            See pricing
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="lfh-trust">
          <span class="lfh-trust-item">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Maryland-based studio
          </span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">SportsActivityLocation schema</span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">Fixed-scope pricing &middot; no surprises</span>
        </div>

      </div>

      <!-- RIGHT COLUMN — FORM -->
      <div class="lfh-right">
        <div class="lfh-form-card">
          <div class="lfh-form-header">
            <p class="lfh-form-eyebrow">Free site audit</p>
            <h2 class="lfh-form-title">Is your gym website losing you members?</h2>
            <p class="lfh-form-sub">We review your current site and send a plain-English audit within 2 business days — no sales call required.</p>
          </div>

          <form class="lfh-form" name="gym-inquiry" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value="gym-inquiry" />
            <div style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
              <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="gym-name">Your name</label>
              <input class="lfh-form-input" type="text" id="gym-name" name="name" placeholder="Marcus Webb" required autocomplete="name" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="gym-email">Email address</label>
              <input class="lfh-form-input" type="email" id="gym-email" name="email" placeholder="marcus@ironoakgym.com" required autocomplete="email" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="gym-org">Gym or studio name</label>
              <input class="lfh-form-input" type="text" id="gym-org" name="gym_name" placeholder="Iron + Oak Strength" autocomplete="organization" />
            </div>

            <div class="lfh-form-row">
              <span class="lfh-form-label" id="lbl-facility">Type of fitness facility</span>
              <div class="lf-cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-facility" data-name="facility_type">
                <button type="button" class="lf-cs-trigger" aria-haspopup="listbox">
                  <span class="lf-cs-val">Select facility type</span>
                  <svg class="lf-cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="lf-cs-list" role="listbox" aria-label="Facility type">
                  <li class="lf-cs-opt" role="option" data-value="Gym / Fitness Center">Gym / Fitness Center</li>
                  <li class="lf-cs-opt" role="option" data-value="CrossFit / Functional Fitness">CrossFit / Functional Fitness</li>
                  <li class="lf-cs-opt" role="option" data-value="Yoga Studio">Yoga Studio</li>
                  <li class="lf-cs-opt" role="option" data-value="Pilates Studio">Pilates Studio</li>
                  <li class="lf-cs-opt" role="option" data-value="Personal Training Studio">Personal Training Studio</li>
                  <li class="lf-cs-opt" role="option" data-value="Martial Arts / Boxing">Martial Arts / Boxing</li>
                  <li class="lf-cs-opt" role="option" data-value="Dance or Barre Studio">Dance or Barre Studio</li>
                  <li class="lf-cs-opt" role="option" data-value="Other / Multiple">Other / Multiple</li>
                </ul>
                <input type="hidden" name="facility_type" class="lf-cs-hidden" />
              </div>
            </div>

            <button type="submit" class="lfh-submit">
              Get a free audit
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="lfh-form-note">No commitment required &middot; Fixed-scope quotes only</p>
          </form>
        </div>
      </div>

    </div>

    <!-- STATS STRIP -->
    <div class="container">
      <div class="lfh-stats" role="list" aria-label="Key results">
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">73<span class="lfh-amb">%</span></div>
          <div class="lfh-stat-lbl">of fitness searches happen on mobile<br>&mdash; where most gym sites fail</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">4<span class="lfh-amb">x</span></div>
          <div class="lfh-stat-lbl">More membership inquiries from sites<br>with online trial signup</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">7<span class="lfh-amb">sec</span></div>
          <div class="lfh-stat-lbl">Avg load time on gym sites<br>we audit</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">8<span class="lfh-amb">wks</span></div>
          <div class="lfh-stat-lbl">From first call to a live,<br>optimized gym website</div>
        </div>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════════════
       PAIN POINTS
  ══════════════════════════════════════════════ -->
  <section class="lf-pain section-pad-sm">
    <div class="container">
      <div class="lf-pain-intro">
        <p class="eyebrow lf-eyebrow-dark">Why members leave before signing up</p>
        <h2 class="h2-section">Why most gym websites fail Maryland fitness businesses</h2>
      </div>
      <div class="lf-pain-grid">
        {painPoints.map((p) => (
          <div class="lf-pain-card">
            <span class="lf-pain-icon" aria-hidden="true" set:html={p.icon} />
            <h3 class="lf-pain-title">{p.title}</h3>
            <p class="lf-pain-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FEATURES
  ══════════════════════════════════════════════ -->
  <section class="lf-features section-pad-sm">
    <div class="container">
      <div class="lf-features-intro">
        <p class="eyebrow lf-eyebrow-dark">What we build into every site</p>
        <h2 class="h2-section">Six things every Maryland gym website needs</h2>
        <p class="lead">A fitness website is not a brochure. It is a membership acquisition engine. Every element we build — from schema to booking integrations to trial forms — is designed to do one job: turn a searching stranger into a paying member.</p>
      </div>
      <div class="lf-features-grid">
        {features.map((f) => (
          <div class="lf-feature-card">
            <div class="lf-fc-top">
              <span class="lf-fc-num mono-xs">{f.num}</span>
            </div>
            <h3 class="lf-fc-title">{f.title}</h3>
            <p class="lf-fc-body">{f.body}</p>
            <div class="lf-fc-tags">
              {f.tags.map((t) => <span class="lf-tag mono-xs">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CASE STUDY
  ══════════════════════════════════════════════ -->
  <section class="lf-case section-pad-sm">
    <div class="container">
      <div class="lf-case-inner">

        <div class="lf-case-content">
          <p class="eyebrow lf-eyebrow-dark">Client result &middot; Annapolis, MD</p>
          <h2 class="h2-section lf-case-h2">How Iron + Oak Strength doubled membership trials in 90 days</h2>
          <p class="lf-case-desc">
            Iron + Oak Strength, a functional fitness gym in Annapolis, came to us after their Squarespace site was generating almost no online trial requests — the form was four clicks deep, broke on Android, and the class schedule was a static PDF. We rebuilt their site in 7 weeks on WordPress.
          </p>

          <div class="lf-case-results">
            <div class="lf-cr-item">
              <span class="lf-cr-val">+280%</span>
              <span class="lf-cr-label mono-xs">Increase in organic search traffic</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">#1</span>
              <span class="lf-cr-label mono-xs">Local Pack &middot; "functional fitness gym Annapolis"</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">1.6s</span>
              <span class="lf-cr-label mono-xs">Mobile load time (was 7.3s)</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">2x</span>
              <span class="lf-cr-label mono-xs">Online trial signups in first 90 days</span>
            </div>
          </div>

          <blockquote class="lf-case-quote">
