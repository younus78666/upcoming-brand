---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const PAGE_URL = "https://upcomingbrand.com/industries/small-business-website-design/";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      "url": PAGE_URL,
      "name": "Small Business Website Design Maryland | Upcoming Brand",
      "description": "WordPress website design for Maryland small businesses. LocalBusiness schema, lead generation forms, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "dateModified": "2026-05-01",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "@id": `${PAGE_URL}#breadcrumb`,
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://upcomingbrand.com/industries/" },
          { "@type": "ListItem", "position": 3, "name": "Small Business Website Design", "item": PAGE_URL }
        ]
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": `${PAGE_URL}#service`,
      "name": "Small Business Website Design Maryland",
      "url": PAGE_URL,
      "description": "WordPress website design for Maryland small businesses. LocalBusiness schema, lead generation forms, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore.",
      "priceRange": "$1,500-$10,000+",
      "areaServed": [
        { "@type": "City", "name": "Baltimore", "sameAs": "https://en.wikipedia.org/wiki/Baltimore", "geo": { "@type": "GeoCoordinates", "latitude": 39.2904, "longitude": -76.6122 } },
        { "@type": "City", "name": "Annapolis", "sameAs": "https://en.wikipedia.org/wiki/Annapolis,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9784, "longitude": -76.4922 } },
        { "@type": "City", "name": "Frederick", "sameAs": "https://en.wikipedia.org/wiki/Frederick,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.4143, "longitude": -77.4105 } },
        { "@type": "City", "name": "Bethesda", "sameAs": "https://en.wikipedia.org/wiki/Bethesda,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9807, "longitude": -77.1006 } },
        { "@type": "City", "name": "Columbia", "sameAs": "https://en.wikipedia.org/wiki/Columbia,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.2037, "longitude": -76.8610 } },
        { "@type": "City", "name": "Silver Spring", "sameAs": "https://en.wikipedia.org/wiki/Silver_Spring,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9907, "longitude": -77.0261 } },
        { "@type": "City", "name": "Rockville", "sameAs": "https://en.wikipedia.org/wiki/Rockville,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.0840, "longitude": -77.1528 } },
        { "@type": "State", "name": "Maryland", "sameAs": "https://en.wikipedia.org/wiki/Maryland" }
      ],
      "knowsAbout": [
        "LocalBusiness schema",
        "small business website design Maryland",
        "Google Business Profile optimization",
        "lead generation form WordPress",
        "Calendly scheduling",
        "local SEO Maryland",
        "service area business",
        "BBB listing",
        "Yelp profile",
        "online appointment scheduling",
        "small business WordPress theme",
        "city landing pages Maryland"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Small Business Website Design Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Small Business Website Design - Starter",
              "description": "5-8 page WordPress site with custom design, LocalBusiness schema, contact form, and Core Web Vitals green on delivery."
            },
            "priceRange": "$1,500-$3,500"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Small Business Website Design - Growth",
              "description": "Up to 15 pages including city landing pages, Calendly or WPForms booking, Google Reviews integration, and lead qualification forms."
            },
            "priceRange": "$3,500-$6,000"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Small Business Website Design - Custom",
              "description": "Full-scope build with unlimited city pages, content migration, 301 redirect mapping, and 12-month quarterly SEO reviews."
            },
            "priceRange": "$6,000-$10,000+"
          }
        ]
      },
      "provider": { "@id": "https://upcomingbrand.com/#organization" }
    },
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faqpage`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How long before a small business website ranks in local search?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For specific service and city searches in smaller Maryland markets, businesses typically see meaningful movement in 45-90 days. Baltimore and Bethesda take 3-6 months for consistent first-page presence. GBP and Local Pack optimization often produce the fastest early results, with improvements appearing within 30 days."
          }
        },
        {
          "@type": "Question",
          "name": "Do you write all the website copy or do we provide it?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We write all copy as part of every tier. You fill out a questionnaire covering your services, service area, years in business, credentials, and differentiators. We draft service descriptions, city page frameworks, and trust copy. One review round is included. We don't outsource copywriting."
          }
        },
        {
          "@type": "Question",
          "name": "Can you add online booking or appointment scheduling?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We integrate Calendly, Acuity Scheduling, or a custom WPForms booking system on Growth and Custom tiers. Customers can request appointments or services without calling during business hours. We configure the booking flow to capture the information your team needs before responding."
          }
        },
        {
          "@type": "Question",
          "name": "We're on Wix or Squarespace. Will we lose anything by switching?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wix and Squarespace sites rarely have strong organic rankings, because the platforms limit how effectively Google can crawl and index them. There's typically little organic traffic to protect. We still map all existing URLs and implement 301 redirects before DNS cutover, then monitor Search Console for 30 days post-launch."
          }
        },
        {
          "@type": "Question",
          "name": "What ongoing support do you provide after the site is live?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Care plans start at $150/month and include WordPress core and plugin updates, weekly backups, uptime monitoring, and priority support within 4 business hours. City landing page content add-ons (one page per month) are available separately to expand your geographic SEO footprint. Month-to-month, no annual contract."
          }
        },
        {
          "@type": "Question",
          "name": "My competitor has a massive website. How can I compete with more pages?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "More pages don't win. More targeted pages do. A competitor with 200 generic service pages often ranks below a competitor with 20 well-structured, schema-marked, internally-linked pages targeting the exact queries their customers use. We focus on building the pages that rank for the specific searches that bring you customers: quality over volume."
          }
        }
      ]
    }
  ]
};

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Small business sites that aren't found aren't earning",
    body: "88% of consumers research a local business online before visiting or calling. If your site loads in 7 seconds on mobile, lacks LocalBusiness schema, and ranks for nothing except your business name, your website is a digital business card, not a marketing tool. Every day it stays that way is revenue going to a competitor whose site actually shows up.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "Generic templates look like every other business in your category",
    body: "Free WordPress themes and Wix templates produce sites that look identical to your competitors. There's no reason for a customer searching 'HVAC Frederick MD' to choose your site over the next one in search results unless your site loads faster, communicates value more clearly, and has the trust signals (reviews, credentials, service areas) that they're looking for.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "No contact or booking system means leads slip away",
    body: "A phone number at the bottom of the page is not a lead capture system. A properly built contact or booking form, asking for the right information at the right moment, captures inquiries at 8-10pm when your office is closed. Without one, you're losing every after-hours customer to whoever picks up a live chat or has an online booking widget.",
  },
];

const features = [
  {
    num: "01",
    title: "LocalBusiness schema on every page",
    body: "Every page receives LocalBusiness JSON-LD markup: business type, geographic service areas, operating hours, price range, and service categories. This is the technical foundation that enables Local Pack visibility for searches like 'HVAC repair Frederick' or 'plumber near me Annapolis.' Without this markup, Google treats your business as a generic listing rather than the specific local service you provide.",
    tags: ["LocalBusiness schema", "Service area markup", "Google Local visibility"],
  },
  {
    num: "02",
    title: "Lead capture forms that qualify prospects",
    body: "A contact form that asks only for a name and email produces unqualified inquiries. We build forms that capture service type, location, timeline, and project scope before submission, so your team can respond with context and your calendar stays filled with the right jobs. WPForms and Calendly integrations included in Growth and Custom tiers.",
    tags: ["WPForms / Calendly", "Lead qualification", "After-hours capture"],
  },
  {
    num: "03",
    title: "Service area pages for every city you serve",
    body: "If your site doesn't have dedicated pages for each city and county you serve, you don't rank for those city-specific searches. We build targeted landing pages for your full service territory. Every city page uses unique copy, proper LocalBusiness schema with that city's coordinates, and is internally linked to build authority across your market.",
    tags: ["City landing pages", "Service area SEO", "Multi-city targeting"],
  },
  {
    num: "04",
    title: "Reviews integration and trust signals",
    body: "Trust is the conversion variable most small business sites ignore. We integrate your Google Reviews feed, display testimonials with ReviewRating schema, and structure your homepage to lead with credentials, years in business, and local market proof. These trust signals are often the deciding factor when a customer is choosing between two businesses in the same category.",
    tags: ["Google Reviews feed", "ReviewRating schema", "Trust conversion"],
  },
  {
    num: "05",
    title: "Google Business Profile and Local Pack setup",
    body: "The Google Maps 3-pack is the highest-ROI marketing channel for most Maryland small businesses, providing free visibility for every 'near me' search in your category. We audit and optimize your GBP: correct business category, service areas, products and services, Q&A, and photo uploads. We also ensure citation consistency across Yelp, BBB, and industry-specific directories.",
    tags: ["Google Business Profile", "Local Pack", "Citation consistency"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your site ships with green Core Web Vitals, or we fix it before launch at no cost. Small business sites built on shared hosting with unoptimized images routinely fail these benchmarks and are deprioritized in search rankings. Our builds use a performance-first WordPress stack with CDN delivery and sub-2-second mobile load times.",
    tags: ["Core Web Vitals", "LCP < 2s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + local competitor map",
    body: "We audit your current site for technical SEO, Core Web Vitals, and schema gaps. We analyze your top 5 local competitors' online presence and identify the gaps you can exploit. You receive a written strategy document: keyword targets, GBP gaps, page list, and service territory map.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1-2",
    title: "AI-assisted design + copy draft",
    body: "We generate your homepage and key service pages using AI-assisted design built around your business type and target customer. We draft all copy: service descriptions, service area frameworks, and trust copy. One consolidated feedback round.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2-6",
    title: "WordPress build + schema + lead capture",
    body: "Approved designs go into WordPress. Every service and city page gets LocalBusiness schema. Lead capture forms with conditional logic are built and tested. Google Reviews integration is configured. You get a staging link to review weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 6-8",
    title: "Launch, GBP + directory cleanup",
    body: "We handle DNS cutover, 301 redirects, and sitemap submission. Your GBP and key directory listings are audited and made consistent. You receive a handoff video and 30-day post-launch monitoring window.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long before a small business website ranks in local search?",
    a: "For specific service + city searches in smaller Maryland markets, businesses typically see meaningful movement in 45-90 days. Baltimore and Bethesda take 3-6 months for consistent first-page presence. GBP and Local Pack optimization often produce the fastest early results, with improvements appearing within 30 days.",
  },
  {
    num: "02",
    category: "Services",
    q: "Do you write all the website copy or do we provide it?",
    a: "We write all copy as part of every tier. You fill out a questionnaire covering your services, service area, years in business, credentials, and differentiators. We draft service descriptions, city page frameworks, and trust copy. One review round is included. We don't outsource copywriting.",
  },
  {
    num: "03",
    category: "Platform",
    q: "Can you add online booking or appointment scheduling?",
    a: "Yes. We integrate Calendly, Acuity Scheduling, or a custom WPForms booking system on Growth and Custom tiers. Customers can request appointments or services without calling during business hours. We configure the booking flow to capture the information your team needs before responding.",
  },
  {
    num: "04",
    category: "Migration",
    q: "We're on Wix or Squarespace. Will we lose anything by switching?",
    a: "Wix and Squarespace sites rarely have strong organic rankings, because the platforms limit how effectively Google can crawl and index them. There's typically little organic traffic to protect. We still map all existing URLs and implement 301 redirects before DNS cutover, then monitor Search Console for 30 days post-launch.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you provide after the site is live?",
    a: "Care plans start at $150/month and include WordPress core and plugin updates, weekly backups, uptime monitoring, and priority support within 4 business hours. City landing page content add-ons (one page per month) are available separately to expand your geographic SEO footprint. Month-to-month, no annual contract.",
  },
  {
    num: "06",
    category: "SEO",
    q: "My competitor has a massive website. How can I compete with more pages?",
    a: "More pages don't win. More targeted pages do. A competitor with 200 generic service pages often ranks below a competitor with 20 well-structured, schema-marked, internally-linked pages targeting the exact queries their customers use. We focus on building the pages that rank for the specific searches that bring you customers: quality over volume.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500-$3,500",
    timeline: "4-6 weeks",
    popular: false,
    dark: false,
    features: [
      "Up to 6 pages: Home, About, Services, Service Areas, Contact, Thank You",
      "LocalBusiness JSON-LD schema on all pages",
      "Lead capture form with service type and timeline fields",
      "Mobile-first build · Core Web Vitals green on delivery",
      "Google Business Profile audit and optimization",
      "Google Search Console + Analytics 4 setup",
      "30 days post-launch support",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500-$6,000",
    timeline: "6-8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 16 pages · 4 service pages + 8 city landing pages",
      "LocalBusiness schema with service territory mapping",
      "Calendly or WPForms booking integration",
      "Google Reviews feed with ReviewRating schema",
      "Yelp, BBB, and industry directory citation consistency audit",
      "60 days post-launch monitoring with monthly report",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000-$10,000+",
    timeline: "8-10 weeks",
    popular: false,
    dark: true,
    features: [
      "Unlimited service and city pages across full territory",
      "Multi-location schema for businesses with multiple offices",
      "Custom quote or estimate workflow with conditional form logic",
      "Full content migration with 301 redirect mapping from old site",
      "Quarterly SEO reviews for 12 months post-launch",
      "90 days post-launch support + first month care plan included",
