    border-radius: var(--radius-md);
    border-left: 3px solid var(--amber);
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .lf-case-quote p {
    font-size: 14px;
    color: rgba(244,239,230,0.7);
    line-height: 1.7;
    font-style: italic;
  }

  .lf-case-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .lf-cite-name {
    font-style: normal;
    font-weight: 600;
    font-size: 14px;
    color: var(--cream);
  }

  .lf-cite-role {
    font-size: 10px;
    color: rgba(244,239,230,0.4);
    letter-spacing: 0.06em;
  }

  .lf-case-visual {
    position: relative;
  }

  .lf-case-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 60px rgba(15,20,25,0.15);
    border: 1.5px solid rgba(15,20,25,0.08);
  }

  .lf-case-badge {
    position: absolute;
    bottom: -12px;
    left: 20px;
    background: var(--ink);
    color: rgba(244,239,230,0.6);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(244,239,230,0.1);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  /* ══════════════════════
     PROCESS
  ══════════════════════ */
  .lf-process {
    background: var(--cream-soft);
  }

  .lf-process-intro {
    max-width: 600px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .lf-process-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 48px;
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .lf-process-step {
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    position: relative;
    transition: background var(--transition);
  }

  .lf-process-step:nth-child(2n) { border-right: none; }
  .lf-process-step:nth-child(3),
  .lf-process-step:nth-child(4) { border-bottom: none; }

  .lf-process-step:hover { background: var(--cream-soft); }

  .lf-phase-marker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .lf-phase-num {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 50%;
    color: var(--amber);
    font-family: var(--f-display);
    font-size: 14px;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .lf-phase-line {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .lf-phase-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }

  .lf-phase-name {
    font-family: var(--f-display);
    font-size: clamp(15px, 1.6vw, 19px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .lf-phase-timing {
    color: var(--amber);
    white-space: nowrap;
    letter-spacing: 0.06em;
    text-align: right;
    flex-shrink: 0;
  }

  .lf-deliverables-label {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 4px;
    opacity: 0.8;
  }

  .lf-phase-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .lf-process-cta {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .lf-process-cta-note {
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  /* ══════════════════════
     PRICING
  ══════════════════════ */
  .lf-pricing {
    background: var(--paper);
  }

  .lf-pricing-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .lf-pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 24px;
  }

  .lf-tier {
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }

  .lf-tier:hover { box-shadow: var(--shadow-md); }

  .lf-tier-popular {
    border-color: var(--amber);
    box-shadow: 0 0 0 2px var(--amber), 0 12px 40px rgba(212,147,46,0.15);
  }

  .lf-tier-dark {
    background: var(--ink);
    color: var(--cream);
    border-color: rgba(244,239,230,0.1);
  }

  .lf-popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--amber);
    color: var(--ink);
    padding: 4px 16px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
  }

  .lf-tier-header {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .lf-tier-dark .lf-tier-header { border-color: rgba(244,239,230,0.1); }

  .lf-tier-name {
    font-family: var(--f-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .lf-tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .lf-tier-price {
    font-family: var(--f-display);
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .lf-tier-period {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .lf-tier-dark .lf-tier-period { color: rgba(244,239,230,0.5); }

  .lf-tier-timeline {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: var(--cream-soft);
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .lf-tier-dark .lf-tier-timeline { background: rgba(244,239,230,0.08); }

  .lf-tl-label { color: var(--ink-muted); font-size: 10px; letter-spacing: 0.06em; }
  .lf-tl-val   { color: var(--ink); font-size: 10px; font-weight: 500; letter-spacing: 0.06em; }
  .lf-tier-dark .lf-tl-val { color: var(--amber); }

  .lf-tier-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .lf-tier-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.5;
  }

  .lf-check {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--green);
  }

  .lf-tier-dark .lf-tier-feature { color: rgba(244,239,230,0.8); }
  .lf-tier-dark .lf-check { color: #8ab86a; }

  .lf-tier-cta {
    width: 100%;
    justify-content: center;
  }

  .lf-pricing-note {
    text-align: center;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    padding: 14px 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--cream-soft);
  }

  /* ══════════════════════
     FAQ
  ══════════════════════ */
  .lf-faq {
    background: var(--cream-soft);
  }

  .lf-faq-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 72px;
    align-items: start;
  }

  /* Sidebar */
  .lf-faq-sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .lf-faq-h2 {
    font-size: clamp(22px, 2.2vw, 30px);
    line-height: 1.2;
  }

  .lf-faq-sidebar-text {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.65;
    margin-top: -4px;
  }

  .lf-faq-stats {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    border: 1.5px solid rgba(15,20,25,0.07);
    border-radius: var(--radius-sm);
    background: var(--paper);
  }

  .lf-faq-stat { display: flex; flex-direction: column; gap: 3px; }

  .lf-faq-stat-num {
    font-family: var(--f-display);
    font-size: 28px;
    font-weight: 300;
    letter-spacing: -0.04em;
    color: var(--amber);
    line-height: 1;
  }

  .lf-faq-stat-label {
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lf-faq-stat-divider {
    width: 1px;
    height: 36px;
    background: var(--line);
  }

  .lf-faq-sidebar-cta {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  .lf-faq-cta-note {
    text-align: center;
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.07em;
    margin-top: -8px;
    opacity: 0.7;
  }

  /* Accordion */
  .lf-faq-list {
    display: flex;
    flex-direction: column;
    border: 1.5px solid rgba(15,20,25,0.07);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(15,20,25,0.05);
    background: var(--paper);
  }

  .lf-faq-item {
    border-bottom: 1px solid rgba(15,20,25,0.07);
    border-left: 3px solid transparent;
    transition: border-left-color var(--transition), background var(--transition);
  }

  .lf-faq-item:last-child { border-bottom: none; }

  .lf-faq-item:has(.lf-faq-trigger[aria-expanded="true"]) {
    border-left-color: var(--amber);
    background: var(--cream-soft);
  }

  .lf-faq-trigger {
    display: grid;
    grid-template-columns: 36px 1fr auto auto;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 20px 22px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: color var(--transition);
  }

  .lf-faq-trigger:hover .lf-faq-q { color: var(--amber-deep); }

  .lf-faq-num {
    font-size: 11px;
    color: var(--amber);
    letter-spacing: 0.08em;
    font-weight: 500;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .lf-faq-q {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
    transition: color var(--transition);
  }

  .lf-faq-cat {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 800px) {
    .lf-faq-cat { display: inline-block; }
  }

  .lf-faq-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--ink-muted);
    transition: transform var(--transition), color var(--transition);
  }

  .lf-faq-trigger[aria-expanded="true"] .lf-faq-icon {
    transform: rotate(45deg);
    color: var(--amber);
  }

  .lf-plus-v { transition: opacity var(--transition); }
  .lf-faq-trigger[aria-expanded="true"] .lf-plus-v { opacity: 0; }

  .lf-faq-answer { overflow: hidden; }

  .lf-faq-answer:not([hidden]) {
    display: block;
    animation: lf-faq-open 200ms ease forwards;
  }

  @keyframes lf-faq-open {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lf-faq-a {
    padding: 0 22px 22px 72px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--ink-muted);
  }

  /* ══════════════════════
     FINAL CTA
  ══════════════════════ */
  .lf-cta {
    background: var(--ink);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .lf-cta-watermark {
    position: absolute;
    bottom: -32px;
    right: -16px;
    font-family: var(--f-display);
    font-size: clamp(60px, 12vw, 160px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.04em;
    color: var(--cream);
    opacity: 0.03;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
  }

  .lf-cta-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 72px;
    align-items: center;
  }

  .lf-cta-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .lf-cta-h2 { color: var(--cream); max-width: 18ch; margin: 0; }

  .lf-cta-trust { display: flex; flex-direction: column; gap: 12px; }

  .lf-trust-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: rgba(244,239,230,0.65);
  }

  .lf-trust-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212,147,46,0.1);
    border: 1px solid rgba(212,147,46,0.2);
    border-radius: var(--radius-sm);
    color: var(--amber);
  }

  .lf-cta-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(244,239,230,0.4);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  .lf-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }

  /* CTA card */
  .lf-cta-card {
    background: rgba(244,239,230,0.04);
    border: 1px solid rgba(244,239,230,0.1);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 32px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.25);
  }

  .lf-cta-card-header { display: flex; flex-direction: column; gap: 10px; }

  .lf-avail-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 4px 10px;
    border: 1px solid rgba(92,128,64,0.35);
    border-radius: var(--radius-pill);
    background: rgba(92,128,64,0.1);
    color: #8ab86a;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lf-avail-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #8ab86a;
    flex-shrink: 0;
    animation: lf-pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;
  }

  @keyframes lf-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .lf-cta-card-title {
    font-family: var(--f-display);
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--cream);
  }

  .lf-cta-card-sub {
    font-size: 12px;
    color: rgba(244,239,230,0.4);
    font-family: var(--f-mono);
    letter-spacing: 0.03em;
    line-height: 1.5;
  }

  /* Form */
  .lf-form { display: flex; flex-direction: column; gap: 14px; }

  .lf-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .lf-form-group { display: flex; flex-direction: column; gap: 6px; }

  .lf-form-label {
    color: rgba(244,239,230,0.4);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .lf-form-input {
    background: rgba(244,239,230,0.05);
    border: 1px solid rgba(244,239,230,0.12);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--cream);
    width: 100%;
    transition: border-color var(--transition), background var(--transition);
    outline: none;
    -webkit-appearance: none;
  }

  .lf-form-input::placeholder { color: rgba(244,239,230,0.25); }
  .lf-form-input:focus {
    border-color: rgba(212,147,46,0.5);
    background: rgba(212,147,46,0.04);
  }

  .lf-form-textarea { resize: vertical; min-height: 80px; line-height: 1.5; }

  .lf-form-submit { width: 100%; justify-content: center; }

  /* ══════════════════════
     RESPONSIVE
  ══════════════════════ */
  @media (max-width: 1100px) {
    .lf-cta-inner  { grid-template-columns: 1fr 420px; gap: 48px; }
  }

  @media (max-width: 1000px) {
    .lf-faq-layout   { grid-template-columns: 1fr; gap: 40px; }
    .lf-faq-sidebar  { position: static; }
  }

  @media (max-width: 900px) {
    .lf-pain-grid    { grid-template-columns: 1fr; }
    .lf-features-grid{ grid-template-columns: repeat(2, 1fr); }
    .lf-case-inner   { grid-template-columns: 1fr; }
    .lf-pricing-grid { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; }
    .lf-cta-inner    { grid-template-columns: 1fr; gap: 48px; }
    .lf-cta-h2       { max-width: 100%; }
  }

  @media (max-width: 600px) {
    .lf-features-grid{ grid-template-columns: 1fr; }
    .lf-case-results { grid-template-columns: 1fr 1fr; }
    .lf-process-grid { grid-template-columns: 1fr; }
    .lf-process-step { border-right: none; border-bottom: 1px solid var(--line); }
    .lf-process-step:last-child { border-bottom: none; }
    .lf-pricing-grid { max-width: 100%; }
    .lf-faq-trigger  { grid-template-columns: 28px 1fr auto; gap: 10px; padding: 16px; }
    .lf-faq-a        { padding: 0 16px 18px 54px; }
    .lf-form-row     { grid-template-columns: 1fr; }
    .lf-cta-card     { padding: 24px 20px 20px; }
  }

/* ══════════════════════
   GUIDE
══════════════════════ */
.lf-guide { background: var(--cream-soft); }
.lf-guide-intro { max-width: 700px; margin-bottom: 56px; }
.lf-guide-layout { display: grid; grid-template-columns: 280px 1fr; gap: 40px; align-items: start; }
.lf-guide-body { display: flex; flex-direction: column; gap: 48px; }
.lf-guide-section { display: flex; flex-direction: column; gap: 14px; }
.lf-guide-h3 { font-family: var(--f-display); font-size: clamp(20px,2vw,26px); font-weight: 400; letter-spacing: -0.02em; line-height: 1.2; color: var(--ink); }
.lf-guide-p { font-size: 15px; line-height: 1.75; color: var(--ink-soft); }
.lf-guide-p strong { color: var(--ink); font-weight: 600; }
.lf-guide-p em { color: var(--amber-deep); font-style: italic; }
.lf-guide-li strong { color: var(--ink); font-weight: 600; }
.lf-guide-li em { color: var(--amber-deep); font-style: italic; }
.lf-guide-ul { display: flex; flex-direction: column; gap: 8px; margin: 4px 0; padding: 0; list-style: none; }
.lf-guide-li { display: flex; gap: 10px; font-size: 15px; line-height: 1.6; color: var(--ink-soft); }
.lf-guide-li::before { content: "→"; color: var(--amber); flex-shrink: 0; font-family: var(--f-mono); font-size: 13px; margin-top: 3px; }
.lf-guide-sidebar { position: sticky; top: 96px; display: flex; flex-direction: column; gap: 16px; }
.lf-gsb-block { background: var(--paper); border: 1px solid var(--line); border-top: 3px solid var(--amber); border-radius: var(--radius-md); padding: 20px; display: flex; flex-direction: column; gap: 10px; box-shadow: var(--shadow-sm); }
.lf-gsb-dark { background: var(--ink); border-color: rgba(244,239,230,0.08); }
.lf-gsb-newsletter { background: var(--cream-soft); }
.lf-gsb-eyebrow { font-family: var(--f-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--amber); }
.lf-gsb-h4 { font-family: var(--f-display); font-size: 17px; font-weight: 400; letter-spacing: -0.02em; line-height: 1.25; color: var(--ink); }
.lf-gsb-dark .lf-gsb-h4 { color: var(--cream); }
.lf-gsb-desc { font-size: 13px; line-height: 1.6; color: var(--ink-muted); }
.lf-gsb-dark .lf-gsb-desc { color: rgba(244,239,230,0.55); }
.lf-gsb-form { display: flex; flex-direction: column; gap: 8px; }
.lf-gsb-input { padding: 9px 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); font-size: 13px; font-family: var(--f-body); background: var(--cream-soft); color: var(--ink); outline: none; width: 100%; transition: border-color var(--transition); box-sizing: border-box; }
.lf-gsb-input:focus { border-color: var(--amber); }
.lf-gsb-submit { padding: 9px 14px; background: var(--amber); color: var(--ink); border: none; border-radius: var(--radius-sm); font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; transition: opacity var(--transition); width: 100%; }
.lf-gsb-submit:hover { opacity: 0.85; }
.lf-gsb-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.lf-gsb-link { font-size: 13px; line-height: 1.45; color: var(--ink); text-decoration: none; padding-left: 16px; position: relative; display: block; transition: color var(--transition); }
.lf-gsb-link::before { content: "→"; position: absolute; left: 0; color: var(--amber); font-family: var(--f-mono); font-size: 11px; top: 2px; }
.lf-gsb-link:hover { color: var(--amber-deep); }
@media (max-width: 1100px) { .lf-guide-layout { grid-template-columns: 240px 1fr; gap: 28px; } }
@media (max-width: 900px) { .lf-guide-layout { grid-template-columns: 1fr; } .lf-guide-sidebar { position: static; display: grid; grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .lf-guide-body { gap: 36px; } .lf-guide-h3 { font-size: 20px; } .lf-guide-p { font-size: 14px; } .lf-guide-sidebar { grid-template-columns: 1fr; } }

</style>

<script>
  // Business type custom dropdown
  document.querySelectorAll('.lf-cs-wrap').forEach((wrap) => {
    const trigger = wrap.querySelector('.lf-cs-trigger');
    const list    = wrap.querySelector('.lf-cs-list');
    const valSpan = wrap.querySelector('.lf-cs-val');
    const hidden  = wrap.querySelector('.lf-cs-hidden');
    const opts    = wrap.querySelectorAll('.lf-cs-opt');
    const open  = () => wrap.setAttribute('aria-expanded', 'true');
    const close = () => wrap.setAttribute('aria-expanded', 'false');
    const isOpen = () => wrap.getAttribute('aria-expanded') === 'true';
    trigger.addEventListener('click', (e) => { e.stopPropagation(); isOpen() ? close() : open(); });
    opts.forEach((opt) => {
      opt.addEventListener('click', () => {
        valSpan.textContent = opt.textContent.trim();
        hidden.value = opt.dataset.value;
        opts.forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        wrap.classList.add('has-value');
        close();
        trigger.focus();
      });
      opt.setAttribute('tabindex', '0');
      opt.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); } });
    });
    document.addEventListener('click', (e) => { if (!wrap.contains(e.target)) close(); });
    wrap.addEventListener('keydown', (e) => { if (e.key === 'Escape') { close(); trigger.focus(); } });
  });

  // FAQ accordion
  const items = document.querySelectorAll('[data-faq-item]');
  items.forEach((item) => {
    const btn  = item.querySelector('.lf-faq-trigger');
    const ans  = item.querySelector('.lf-faq-answer');
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      items.forEach((o) => {
        o.querySelector('.lf-faq-trigger').setAttribute('aria-expanded', 'false');
        o.querySelector('.lf-faq-answer').hidden = true;
      });
      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        ans.hidden = false;
      }
    });
  });
</script>
