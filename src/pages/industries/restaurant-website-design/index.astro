---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow sites lose diners to the restaurant down the street",
    body: "89% of diners research restaurants online before visiting (as of 2025), and 53% leave a site that takes more than 3 seconds to load. Most restaurant websites we audit load in 7–10 seconds on mobile. A diner searching 'seafood restaurant Annapolis' will book the first restaurant whose site loads and shows a menu, and that's rarely a site on shared hosting.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "No Restaurant schema means no rich results",
    body: "Without Restaurant and FoodEstablishment JSON-LD schema, Google cannot display your menu items, price range, cuisine type, or hours in rich results or the Local Pack. Generalist web agencies building restaurant sites without this markup leave you competing with full schema-enabled competitors on uneven ground.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "PDF menus and no online reservations drive diners away",
    body: "A PDF menu is a dead end on mobile. Online reservation systems (OpenTable, Resy, or Tock) are now table stakes for Maryland restaurants competing for weekend bookings. If your site can't show an interactive menu and let diners book in under 60 seconds, you're losing covers to restaurants that can.",
  },
];

const features = [
  {
    num: "01",
    title: "Restaurant and FoodEstablishment schema",
    body: "Every page receives Restaurant and FoodEstablishment JSON-LD markup: cuisine type, price range, menu URL, accepted payment types, operating hours, and reservation links. This is what enables rich results with your star rating, hours, and price range appearing directly in Google search. That's the difference between being clicked and being scrolled past.",
    tags: ["Restaurant schema", "FoodEstablishment", "Rich results"],
  },
  {
    num: "02",
    title: "OpenTable, Resy, and Tock integration",
    body: "We integrate your preferred reservation platform directly into your site: OpenTable, Resy, Tock, or a custom form. Diners can book a table without calling or leaving your site. We configure the widget to match your brand, embed it on the homepage and contact page, and ensure it works correctly on mobile, where most restaurant reservations are made.",
    tags: ["OpenTable / Resy / Tock", "Reservation widget", "Mobile booking"],
  },
  {
    num: "03",
    title: "Interactive menu pages with structured markup",
    body: "We build interactive menu pages with your full menu organized by category (appetizers, mains, drinks, desserts) with prices, descriptions, and dietary flags (GF, V, vegan). Each menu item can receive MenuItem schema for potential rich results. Menu pages also rank for food-specific searches like 'oysters Annapolis' or 'crab cake Baltimore.'",
    tags: ["Interactive menus", "MenuItem schema", "Food search SEO"],
  },
  {
    num: "04",
    title: "High-converting food photography display",
    body: "Restaurant websites live and die by food photography. We build image-first layouts that showcase your best dishes with proper lazy loading, WebP compression, and retina display support, without slowing your site down. We also provide photo direction guidelines so your team knows exactly what shots will convert best on each page.",
    tags: ["Food photography layout", "WebP optimization", "Image performance"],
  },
  {
    num: "05",
    title: "Google Business Profile and Local Pack setup",
    body: "Appearing in the Google Maps 3-pack for 'restaurant near me' or 'seafood Annapolis' drives more covers than most paid advertising. We audit and optimize your GBP: correct cuisine categories, menu link, reservation link, hours, Q&A, and photo uploads. We also ensure consistency across Yelp, TripAdvisor, and OpenTable profile listings.",
    tags: ["Google Business Profile", "Local Pack", "Yelp / TripAdvisor"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your site ships with green Core Web Vitals scores. If it doesn't pass, we fix it before launch at no cost. Restaurant sites crammed with unoptimized food photos and embedded social feeds routinely fail these benchmarks. Our builds use CDN-delivered, WebP-converted images and a performance stack that keeps mobile load times under 2 seconds.",
    tags: ["Core Web Vitals", "LCP < 2s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + competitor map",
    body: "We audit your current site for Core Web Vitals, schema gaps, and reservation friction. We research your top 5 local competitors' online presence and identify the gaps we can exploit. You receive a written strategy document covering keyword targets, GBP gaps, and exactly what pages we'll build.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-assisted design + menu structure",
    body: "We generate your homepage, menu pages, and reservation experience using AI-assisted design for desktop and mobile, built around your cuisine and brand. We structure your menu content and draft page copy simultaneously. One consolidated feedback round keeps the project moving.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–6",
    title: "WordPress build + schema + reservation integration",
    body: "Approved designs go into WordPress. Every page gets Restaurant and FoodEstablishment schema. Your reservation platform is integrated and tested across mobile and desktop. Interactive menus are built with proper markup. You get a staging link to review weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 6–8",
    title: "Launch, GBP + directory optimization",
    body: "We handle DNS cutover, 301 redirects, and sitemap submission. Your GBP, Yelp, TripAdvisor, and OpenTable profiles are audited simultaneously. You receive a handoff video and 30-day post-launch monitoring window.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long before a restaurant website ranks for local food searches?",
    a: "For local searches in smaller Maryland markets, restaurants typically see movement in 45–75 days. Baltimore and Annapolis take 2–4 months for consistent first-page presence. GBP optimization tends to produce the fastest results. Local Pack improvements often appear within 30 days of launch.",
  },
  {
    num: "02",
    category: "Platform",
    q: "Can you integrate with our existing reservation platform?",
    a: "Yes, we integrate with OpenTable, Resy, Tock, SevenRooms, and custom booking forms. We connect whichever platform you already use. If you're not on a reservation system yet, we help you choose the right one based on your volume and budget. We also integrate with online ordering platforms like Toast or Square Online if you offer takeout.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you build and update our menu pages?",
    a: "We build your initial menu pages with full markup and all current items. For ongoing menu updates after launch, we provide a simple WordPress admin interface your team can update without touching code. On our care plan, we include menu updates as part of the monthly support scope.",
  },
  {
    num: "04",
    category: "Migration",
    q: "Will we lose rankings when we move from our current website?",
    a: "Not with proper migration planning. We map every existing URL, implement 301 redirects before DNS cutover, and monitor Search Console for 30 days post-launch. Clean migrations recover within 4–6 weeks. We've never shipped a restaurant site migration without a complete redirect map.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you offer after the site launches?",
    a: "Care plans start at $150/month: WordPress updates, weekly backups, uptime monitoring, and priority support within 4 business hours. Menu update support and seasonal content refreshes are available as add-ons. Month-to-month, no annual contract required.",
  },
  {
    num: "06",
    category: "SEO",
    q: "Can you help us rank for multiple cuisine types and neighborhoods?",
    a: "Yes, this is what the Growth and Custom tiers are built for. We create dedicated pages for each cuisine category, event type (private dining, happy hour), and neighborhood or city landing pages for your delivery or catering reach. Each page targets specific search queries with proper Restaurant schema and unique copy.",
  },
  {
    num: "07",
    category: "Platform",
    q: "Should I build my restaurant website on WordPress or a platform like Squarespace?",
    a: "WordPress gives Maryland restaurants full control over speed, schema, and reservation integrations. Squarespace and Wix cap your PageSpeed and limit the Restaurant and MenuItem schema you can implement - both reduce your Local Pack visibility. For restaurants where a guest decision takes seconds, load speed is a direct revenue line. A custom WordPress build hits 90+ PageSpeed, passes Core Web Vitals, and integrates OpenTable, Resy, or Tock without the performance tax of a widget loaded from a third-party platform.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
