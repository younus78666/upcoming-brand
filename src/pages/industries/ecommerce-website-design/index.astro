---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const PAGE_URL = "https://upcomingbrand.com/industries/ecommerce-website-design/";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      "url": PAGE_URL,
      "name": "Ecommerce Website Design Maryland | WooCommerce Experts",
      "description": "Ecommerce website design for Maryland businesses. WooCommerce with product schema, Stripe/PayPal checkout, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "dateModified": "2026-05-01",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "@id": `${PAGE_URL}#breadcrumb`,
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://upcomingbrand.com/industries/" },
          { "@type": "ListItem", "position": 3, "name": "Ecommerce Website Design", "item": PAGE_URL }
        ]
      }
    },
    {
      "@type": ["OnlineBusiness", "LocalBusiness"],
      "@id": `${PAGE_URL}#service`,
      "name": "Ecommerce Website Design Maryland",
      "url": PAGE_URL,
      "description": "Ecommerce website design for Maryland businesses. WooCommerce with product schema, Stripe/PayPal checkout, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore.",
      "priceRange": "$1,500-$10,000+",
      "areaServed": [
        { "@type": "City", "name": "Baltimore", "sameAs": "https://en.wikipedia.org/wiki/Baltimore", "geo": { "@type": "GeoCoordinates", "latitude": 39.2904, "longitude": -76.6122 } },
        { "@type": "City", "name": "Annapolis", "sameAs": "https://en.wikipedia.org/wiki/Annapolis,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9784, "longitude": -76.4922 } },
        { "@type": "City", "name": "Frederick", "sameAs": "https://en.wikipedia.org/wiki/Frederick,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.4143, "longitude": -77.4105 } },
        { "@type": "City", "name": "Bethesda", "sameAs": "https://en.wikipedia.org/wiki/Bethesda,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9807, "longitude": -77.1006 } },
        { "@type": "City", "name": "Columbia", "sameAs": "https://en.wikipedia.org/wiki/Columbia,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.2037, "longitude": -76.8610 } },
        { "@type": "City", "name": "Silver Spring", "sameAs": "https://en.wikipedia.org/wiki/Silver_Spring,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 38.9907, "longitude": -77.0261 } },
        { "@type": "City", "name": "Rockville", "sameAs": "https://en.wikipedia.org/wiki/Rockville,_Maryland", "geo": { "@type": "GeoCoordinates", "latitude": 39.0840, "longitude": -77.1528 } },
        { "@type": "State", "name": "Maryland", "sameAs": "https://en.wikipedia.org/wiki/Maryland" }
      ],
      "knowsAbout": [
        "WooCommerce design Maryland",
        "ecommerce website design Maryland",
        "Product schema",
        "Offer schema",
        "Stripe WooCommerce",
        "PayPal checkout",
        "Google Merchant Center",
        "abandoned cart recovery",
        "ShipStation integration",
        "WooCommerce Subscriptions",
        "online store design Maryland",
        "product page SEO"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Ecommerce Website Design Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "WooCommerce Store Design - Starter",
              "description": "WooCommerce store up to 50 products with custom design, Product schema, Stripe/PayPal checkout, and Core Web Vitals green on delivery."
            },
            "priceRange": "$1,500-$3,500"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "WooCommerce Store Design - Growth",
              "description": "Up to 200 products, catalog migration, category SEO pages, abandoned cart recovery, and ShipStation integration."
            },
            "priceRange": "$3,500-$6,000"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "WooCommerce Store Design - Custom",
              "description": "Unlimited products, WooCommerce Subscriptions, custom configurator, inventory sync, and 12-month SEO reviews."
            },
            "priceRange": "$6,000-$10,000+"
          }
        ]
      },
      "provider": { "@id": "https://upcomingbrand.com/#organization" }
    },
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faqpage`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why WooCommerce instead of Shopify or BigCommerce?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "WooCommerce gives you full ownership of your store, your customer data, and your SEO infrastructure: no platform fees on transactions, no forced URL structures, and no limitations on schema implementation. For clients asking about Shopify SEO vs WooCommerce SEO, we recommend WooCommerce for Maryland businesses that also have a physical presence or service component, since WordPress and WooCommerce handles the full business website better than Shopify, which is optimized for pure retail."
          }
        },
        {
          "@type": "Question",
          "name": "How long before a WooCommerce store ranks for product searches?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Category and collection pages with proper Product schema typically see movement in 60-90 days for specific product searches. Broad category searches like 'handmade gifts Maryland' take 3-6 months. Product-level schema and Google Merchant Center submission can drive Shopping results faster, often within 30-45 days of launch."
          }
        },
        {
          "@type": "Question",
          "name": "Do you migrate our existing products and content?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. On Growth and Custom tiers we migrate your existing product catalog, customer data, and order history. We map all existing product URLs to their new equivalents and implement 301 redirects. We test the complete store: checkout, payment, and email confirmations before DNS cutover."
          }
        },
        {
          "@type": "Question",
          "name": "What shipping and inventory integrations do you support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We integrate with ShipStation, EasyPost, WooCommerce Shipping (for USPS/UPS/FedEx label printing), and local pickup/delivery options. For inventory management, we work with WooCommerce's native system or sync with third-party tools like Linnworks or Veeqo. We scope specific integrations during Discovery."
          }
        },
        {
          "@type": "Question",
          "name": "What ongoing support do you provide after the store launches?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Care plans start at $150/month: WordPress and WooCommerce updates, weekly backups, uptime monitoring, and priority support within 4 business hours. WooCommerce requires more frequent plugin updates than a standard WordPress site. Our care plan handles this so payment processing and checkout never break unexpectedly."
          }
        },
        {
          "@type": "Question",
          "name": "Can you set up subscriptions or recurring billing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We configure WooCommerce Subscriptions with Stripe for recurring billing, including free trial periods, pause and cancel flows, and renewal reminder emails. Subscription products can be standalone or mixed with one-time purchase products in the same catalog. This is included in the Growth and Custom tiers."
          }
        }
      ]
    }
  ]
};

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow product pages cost you sales before checkout",
    body: "A 1-second delay in page load time reduces ecommerce conversions by 7%. Most WooCommerce stores we audit load in 6–9 seconds on mobile, the channel where 65% of shopping sessions now happen. Every unoptimized product image and unnecessary plugin is a sale that doesn't complete.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "No Product schema means invisible product pages in Google",
    body: "Without Product and Offer JSON-LD schema, Google cannot show your products in Shopping results, price rich snippets, or product carousels. You're competing in organic search without the rich results that grab clicks, while competitors with proper schema get the star ratings, price range, and availability displayed before a click happens.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>`,
    title: "Mobile checkout abandonment kills your conversion rate",
    body: "69% of shopping carts are abandoned, and most of that abandonment is friction: too many form fields, broken payment buttons on iOS Safari, forced account creation before checkout. A properly built WooCommerce store with a streamlined checkout, Apple Pay and Google Pay, and guest checkout converts at 2–4x the rate of a default WooCommerce installation.",
  },
];

const features = [
  {
    num: "01",
    title: "Product and Offer schema on every listing",
    body: "Every product page receives Product, Offer, and AggregateRating JSON-LD markup: price, availability, condition, brand, and SKU. This is what enables your products to appear in Google Shopping results, price rich snippets, and product carousels with star ratings. Without this markup, your product pages compete in organic search without the visual advantage that drives clicks.",
    tags: ["Product schema", "Offer markup", "Google Shopping"],
  },
  {
    num: "02",
    title: "Stripe, PayPal, and Apple/Google Pay",
    body: "We configure WooCommerce with Stripe as primary payment gateway, supporting credit cards, Apple Pay, Google Pay, and ACH bank transfers, with PayPal as a backup. One-click checkout for returning customers, guest checkout enabled by default, and Stripe's fraud detection configured to protect your store. Authorize.net integration available for existing merchant accounts.",
    tags: ["Stripe / PayPal", "Apple Pay / Google Pay", "ACH payments"],
  },
  {
    num: "03",
    title: "Conversion-optimized product and category pages",
    body: "Default WooCommerce product pages are designed for functionality, not conversion. We redesign product pages to lead with your best product photography, position reviews prominently, add urgency signals (stock levels, shipping cutoffs), and structure the add-to-cart path to reduce decision friction. Category pages are rebuilt with filtering and sorting that helps customers find products fast.",
    tags: ["Product page optimization", "Category page UX", "Conversion design"],
  },
  {
    num: "04",
    title: "Streamlined checkout with abandon recovery",
    body: "We strip default WooCommerce checkout to the minimum fields, add real-time field validation, and configure abandoned cart recovery via Klaviyo or WooCommerce's native system. Abandoned cart emails recover 10–15% of abandoned sessions on average. Combined with a streamlined checkout, this is the highest-ROI optimization for most stores.",
    tags: ["Streamlined checkout", "Abandoned cart recovery", "Klaviyo integration"],
  },
  {
    num: "05",
    title: "Category and collection SEO pages",
    body: "Product-level SEO alone isn't enough. We build keyword-targeted category pages for your product collections, each with unique copy, proper Product schema in aggregate, and internal links to your best sellers. A 'handmade Maryland gifts' category page captures mid-funnel searchers who don't know your product names yet but are ready to buy.",
    tags: ["Category SEO", "Collection pages", "Mid-funnel search"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your store ships with green Core Web Vitals, or we fix it before launch at no cost. WooCommerce stores with unoptimized product images, conflicting plugins, and slow hosting routinely fail these benchmarks. Our builds use a performance stack with CDN delivery, WebP image conversion, and sub-2-second product page load times.",
    tags: ["Core Web Vitals", "LCP < 2s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Store audit + conversion map",
    body: "We audit your current store for Core Web Vitals, schema gaps, checkout friction, and catalog structure. We map your top-selling products and highest-intent search queries. You receive a written strategy document: page list, schema plan, payment gateway recommendation, and checkout optimization targets.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-assisted design + product page framework",
    body: "We generate your homepage, product pages, and checkout experience using AI-assisted design, built around your product catalog and brand. We structure category and collection page frameworks simultaneously. One consolidated feedback round.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "WooCommerce build + schema + payment setup",
    body: "Approved designs go into WooCommerce. Every product page gets Product and Offer schema. Stripe and PayPal are configured and tested across mobile, desktop, and Safari. Abandoned cart recovery is set up. You get a staging store to review weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Launch, product feed + Google Shopping setup",
    body: "We handle DNS cutover, 301 redirects, and Google Merchant Center setup for Shopping ads eligibility. Search Console and GA4 e-commerce tracking are configured. You receive a handoff video and 30-day post-launch monitoring window.",
  },
];

const faqs = [
  {
    num: "01",
    category: "Platform",
    q: "Why WooCommerce instead of Shopify or BigCommerce?",
    a: "WooCommerce gives you full ownership of your store, your customer data, and your SEO infrastructure: no platform fees on transactions, no forced URL structures, and no limitations on schema implementation. For clients asking about Shopify SEO vs WooCommerce SEO, we recommend WooCommerce for Maryland businesses that also have a physical presence or service component, since WordPress + WooCommerce handles the full business website better than Shopify, which is optimized for pure retail.",
  },
  {
    num: "02",
    category: "SEO",
    q: "How long before a WooCommerce store ranks for product searches?",
    a: "Category and collection pages with proper Product schema typically see movement in 60–90 days for specific product searches. Broad category searches like 'handmade gifts Maryland' take 3–6 months. Product-level schema and Google Merchant Center submission can drive Shopping results faster, often within 30–45 days of launch.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you migrate our existing products and content?",
    a: "Yes. On Growth and Custom tiers we migrate your existing product catalog, customer data, and order history. We map all existing product URLs to their new equivalents and implement 301 redirects. We test the complete store: checkout, payment, and email confirmations before DNS cutover.",
  },
  {
    num: "04",
    category: "Platform",
    q: "What shipping and inventory integrations do you support?",
    a: "We integrate with ShipStation, EasyPost, WooCommerce Shipping (for USPS/UPS/FedEx label printing), and local pickup/delivery options. For inventory management, we work with WooCommerce's native system or sync with third-party tools like Linnworks or Veeqo. We scope specific integrations during Discovery.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you provide after the store launches?",
    a: "Care plans start at $150/month: WordPress and WooCommerce updates, weekly backups, uptime monitoring, and priority support within 4 business hours. WooCommerce requires more frequent plugin updates than a standard WordPress site. Our care plan handles this so payment processing and checkout never break unexpectedly.",
  },
  {
    num: "06",
    category: "Platform",
    q: "Can you set up subscriptions or recurring billing?",
    a: "Yes. We configure WooCommerce Subscriptions with Stripe for recurring billing, including free trial periods, pause and cancel flows, and renewal reminder emails. Subscription products can be standalone or mixed with one-time purchase products in the same catalog. This is included in the Growth and Custom tiers.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500–$3,500",
    timeline: "4–6 weeks",
    popular: false,
    dark: false,
    features: [
      "WooCommerce store up to 50 products with custom design",
      "Product + Offer JSON-LD schema on all product pages",
      "Stripe and PayPal checkout with Apple Pay and Google Pay",
      "Mobile-first build · Core Web Vitals green on delivery",
      "Google Merchant Center setup for Shopping eligibility",
      "Google Search Console + GA4 e-commerce tracking",
      "30 days post-launch support",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500–$6,000",
    timeline: "6–8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 200 products · full catalog migration from existing store",
      "Category and collection SEO pages with Product schema",
      "Streamlined checkout with abandoned cart recovery (Klaviyo or native)",
      "Product page conversion optimization with reviews and trust signals",
      "ShipStation or WooCommerce Shipping integration",
      "60 days post-launch monitoring with monthly performance report",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000–$10,000+",
    timeline: "8–10 weeks",
    popular: false,
    dark: true,
    features: [
      "Unlimited products · WooCommerce Subscriptions or B2B wholesale",
      "Custom product configurator or variation builder",
      "Third-party inventory management sync (Linnworks, Veeqo, or similar)",
