---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow sites get passed over for the next contractor",
    body: "Homeowners searching 'roofing contractor Annapolis' or 'HVAC repair Baltimore' make a decision in seconds. A site that loads in 7 seconds on mobile (the average for contractor sites we audit) loses the lead before the prospect sees your phone number. Every second of load time above 1.5 seconds costs you booked jobs.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "No service area pages means no city-level rankings",
    body: "If your website has one 'service area' paragraph buried on your About page, Google cannot rank you for 'contractor Bethesda' or 'roofer Frederick.' You need dedicated, keyword-targeted pages for every city you serve, each with HomeAndConstructionBusiness schema telling Google exactly what you do and where.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Generic quote forms don't qualify leads",
    body: "A contact form that asks for a name and email produces unqualified inquiries. A properly built estimate form (asking for project type, timeline, location, and scope) produces leads your team can act on. We build multi-step forms that qualify prospects before they hit submit, so your office handles fewer tire-kickers.",
  },
];

const features = [
  {
    num: "01",
    title: "HomeAndConstructionBusiness schema on every page",
    body: "Every page receives HomeAndConstructionBusiness and LocalBusiness JSON-LD markup covering trade categories, service areas, license numbers, and operating hours. This tells Google exactly what you build and where, enabling Local Pack visibility for searches like 'general contractor Annapolis' and 'roofer Baltimore.' Without this markup, Google cannot confidently surface you for trade-specific searches.",
    tags: ["HomeAndConstructionBusiness", "LocalBusiness schema", "License markup"],
  },
  {
    num: "02",
    title: "Service area pages for every Maryland city",
    body: "We build dedicated, keyword-targeted landing pages for every city and county you serve: Annapolis, Baltimore, Frederick, Bethesda, Columbia, Silver Spring, and beyond. Each page targets city-specific search queries, uses unique copy, and is internally linked to build topical authority across your service territory. This is how you dominate local search across a multi-city market.",
    tags: ["City landing pages", "Service area SEO", "Multi-market targeting"],
  },
  {
    num: "03",
    title: "Project gallery with before/after photos",
    body: "Homeowners want proof before they call. We build project galleries that showcase your best work, organized by project type and location, with proper image compression, lazy loading, and structured markup. A gallery page targeting 'kitchen remodel Annapolis before after' captures mid-funnel prospects who are ready to commit but need to see real work first.",
    tags: ["Project gallery", "Before/after photos", "Portfolio SEO"],
  },
  {
    num: "04",
    title: "Multi-step estimate request forms",
    body: "Single-page quote forms produce low-quality leads. We build multi-step estimate forms that ask for project type, location, approximate timeline, and project scope before the prospect submits. This pre-qualifies every lead before your team responds, and typically doubles form conversion rates compared to a generic 'contact us' form.",
    tags: ["Multi-step forms", "Lead qualification", "Estimate requests"],
  },
  {
    num: "05",
    title: "Google Business Profile and Local Pack setup",
    body: "Appearing in the Google Maps 3-pack for your trade and city is often the highest-ROI marketing you can do. We audit and optimize your GBP: trade categories, service areas, services, Q&A, and photo uploads. We also build citation consistency across HomeAdvisor, Angi, Houzz, and the BBB to strengthen your local ranking signal.",
    tags: ["Google Business Profile", "Local Pack", "HomeAdvisor / Angi"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your site ships with green Core Web Vitals (LCP, INP, and CLS) or we fix it before launch at no cost. Contractor sites built on cheap WordPress themes with unoptimized images routinely fail these benchmarks. Our builds use a performance stack with CDN delivery, server-side rendering, and sub-2-second load times on mobile.",
    tags: ["Core Web Vitals", "LCP < 2s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + territory map",
    body: "We audit your current site for technical SEO, Core Web Vitals, and schema gaps. We map keyword targets by trade and city across your service territory. You receive a written strategy document: gaps, opportunities, page list, and the exact cities we'll target with landing pages.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-assisted design + copy draft",
    body: "We generate your homepage and key service pages using AI-assisted design for desktop and mobile. We draft all copy: service descriptions, city landing page frameworks, and estimate form language. One consolidated feedback round keeps the project moving.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "WordPress build + schema + city pages",
    body: "Approved designs go into WordPress on our performance stack. Every service and city page gets HomeAndConstructionBusiness schema. Multi-step estimate forms are built and tested. You get a staging link to review weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Launch, GBP + directory optimization",
    body: "We handle DNS cutover, 301 redirects, and sitemap submission. Your GBP and key directory listings are audited and optimized simultaneously. You receive a handoff video and 30-day post-launch monitoring.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long before a contractor website ranks for city searches?",
    a: "For less competitive Maryland markets like Frederick or Annapolis, contractors typically see meaningful movement in 60–90 days. Baltimore and Bethesda take 3–6 months for consistent first-page presence. Local Pack and GBP optimization often produce the fastest early results, with improvements appearing within 30–45 days.",
  },
  {
    num: "02",
    category: "Services",
    q: "Do you build individual pages for every city we serve?",
    a: "Yes, this is the core of our contractor SEO approach. We build dedicated, keyword-targeted landing pages for every city and county in your service territory. Each page has unique copy targeting city-specific search queries, proper HomeAndConstructionBusiness schema, and is internally linked to build authority. The number of city pages depends on your tier.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you write all the website copy or do we provide it?",
    a: "We write all copy as part of every tier. You fill out a questionnaire covering your trade specialties, service area, notable projects, license numbers, and any differentiators. We draft service descriptions, city page copy, and form language. One review round included. We do not outsource copywriting.",
  },
  {
    num: "04",
    category: "Migration",
    q: "Will we lose Google rankings when we switch from our old site?",
    a: "Not if the migration is handled correctly. We map every existing URL to its new equivalent and implement 301 redirects before DNS cutover. We monitor Search Console for 30 days post-launch and resolve any crawl errors. Clean migrations with full redirect maps recover within 4–6 weeks.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What ongoing support do you provide after launch?",
    a: "Care plans start at $150/month covering WordPress updates, weekly backups, uptime monitoring, and priority support within 4 business hours. We also offer a content add-on: one new city landing page or service page per month, compounding your geographic SEO footprint over time. Month-to-month, no annual contract.",
  },
  {
    num: "06",
    category: "Platform",
    q: "Can the site handle online payments or deposit collection?",
    a: "Yes. On Growth and Custom tiers we can integrate Stripe or PayPal for deposit collection at estimate confirmation. We also integrate with Jobber, ServiceTitan, or Housecall Pro if you use field service management software and want the web form to sync directly. We scope these integrations during Discovery.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500–$3,500",
    timeline: "4–6 weeks",
    popular: false,
    dark: false,
    features: [
      "Up to 6 pages: Home, About, 3 service pages, Contact",
      "HomeAndConstructionBusiness JSON-LD schema on all pages",
      "Multi-step estimate request form with project type fields",
      "Mobile-first build · Core Web Vitals green on delivery",
      "Google Business Profile audit and optimization",
      "Google Search Console + Analytics 4 setup",
      "30 days post-launch support",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500–$6,000",
    timeline: "6–8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 18 pages · 6 service pages + 8 city landing pages",
      "HomeAndConstructionBusiness schema, trade and territory mapped",
      "Project gallery with before/after photos and ImageObject markup",
      "Multi-step estimate form with lead qualification and email routing",
      "Google Business Profile full optimization + HomeAdvisor/Angi citations",
      "60 days post-launch monitoring with monthly report",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000–$10,000+",
    timeline: "8–10 weeks",
    popular: false,
    dark: true,
    features: [
      "Unlimited service and city pages across full territory",
      "Multi-location schema for multiple offices or yards",
      "Jobber / ServiceTitan / Housecall Pro integration",
      "Custom project portfolio with filter by trade and city",
      "Full content migration with 301 redirect mapping",
      "Quarterly SEO reviews for 12 months post-launch",
      "90 days post-launch support + first month care plan included",
    ],
    cta: "Start a conversation",
  },
];
---
<BaseLayout
  title="Contractor Website Design Maryland | Upcoming Brand"
  description="WordPress website design for Maryland contractors. HomeAndConstructionBusiness schema, service area pages, 90+ PageSpeed. Fixed-scope from $1,500. Baltimore."
  canonicalUrl="https://upcomingbrand.com/industries/contractor-website-design/"
>
  <Navigation />

  <!-- Schema: HomeAndConstructionBusiness + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["HomeAndConstructionBusiness", "LocalBusiness"],
        "@id": "https://upcomingbrand.com/industries/contractor-website-design/",
        "name": "Upcoming Brand — Contractor Website Design Maryland",
        "description": "WordPress website design for Maryland contractors. HomeAndConstructionBusiness schema, service area pages, 90+ PageSpeed. Fixed-scope from $1,500.",
        "url": "https://upcomingbrand.com/industries/contractor-website-design/",
        "areaServed": [
          { "@type": "State", "name": "Maryland" },
          { "@type": "City", "name": "Baltimore" },
          { "@type": "City", "name": "Annapolis" },
          { "@type": "City", "name": "Frederick" },
          { "@type": "City", "name": "Bethesda" },
          { "@type": "City", "name": "Columbia" },
          { "@type": "City", "name": "Silver Spring" }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Contractor Website Design Services",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Contractor WordPress Website Design" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HomeAndConstructionBusiness Schema Implementation" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Service Area Landing Pages" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Google Business Profile Optimization" } }
          ]
        }
      }
    ]
  })} />

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="lfh-hero">

    <div class="container">
      <nav class="lfh-breadcrumb mono-xs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#industries">Industries</a>
        <span aria-hidden="true">/</span>
        <span>Contractor Website Design</span>
      </nav>
    </div>

    <div class="container lfh-wrap">

      <!-- LEFT COLUMN -->
      <div class="lfh-left">

        <div class="lfh-tags">
          <span class="lfh-pill">
            <span class="lfh-dot" aria-hidden="true"></span>
            Contractor Web Design &middot; Maryland
          </span>
          <span class="lfh-hero-sep" aria-hidden="true">/</span>
          <span class="lfh-hero-eyebrow">A specialist studio, not a template shop</span>
        </div>

        <h1 class="lfh-h1">
          <span class="lfh-h1-line">Maryland contractor websites</span>
          <span class="lfh-h1-line lfh-h1-accent-line"><em class="lfh-h1-accent">built to generate leads</em></span>
          <span class="lfh-h1-line lfh-h1-italic">not just look good.</span>
        </h1>

        <p class="lfh-lede">
          Most contractor websites lose leads before the first call: slow load times, no service area pages, and quote forms that break on mobile. We build WordPress sites for Maryland contractors that rank across every city you serve, load fast, and turn visitors into booked estimates. Fixed-scope from <strong>$1,500</strong>.
        </p>

        <div class="lfh-ctas">
          <a href="#contact" class="lfh-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#pricing" class="lfh-btn-ghost">
            See pricing
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="lfh-trust">
          <span class="lfh-trust-item">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Maryland-based studio
          </span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">HomeAndConstructionBusiness schema</span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">Fixed-scope &middot; no surprises</span>
        </div>

      </div>

      <!-- RIGHT COLUMN: FORM -->
      <div class="lfh-right">
        <div class="lfh-form-card">
          <div class="lfh-form-header">
            <p class="lfh-form-eyebrow">Free site audit</p>
            <h2 class="lfh-form-title">Is your website costing you jobs?</h2>
            <p class="lfh-form-sub">We review your current site and send a plain-English audit within 2 business days. No sales call required.</p>
          </div>

          <form class="lfh-form" name="contractor-inquiry" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value="contractor-inquiry" />
            <div style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
              <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="ct-name">Your name</label>
              <input class="lfh-form-input" type="text" id="ct-name" name="name" placeholder="David Caruso" required autocomplete="name" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="ct-email">Email address</label>
              <input class="lfh-form-input" type="email" id="ct-email" name="email" placeholder="david@chesapeakehome.com" required autocomplete="email" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="ct-company">Company name</label>
              <input class="lfh-form-input" type="text" id="ct-company" name="company" placeholder="Chesapeake Home Services" autocomplete="organization" />
            </div>

            <div class="lfh-form-row">
              <span class="lfh-form-label" id="lbl-trade">Trade / service type</span>
              <div class="lf-cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-trade" data-name="trade_type">
                <button type="button" class="lf-cs-trigger" aria-haspopup="listbox">
                  <span class="lf-cs-val">Select trade / service type</span>
                  <svg class="lf-cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="lf-cs-list" role="listbox" aria-label="Trade type">
                  <li class="lf-cs-opt" role="option" data-value="General Contractor">General Contractor</li>
                  <li class="lf-cs-opt" role="option" data-value="Roofing">Roofing</li>
                  <li class="lf-cs-opt" role="option" data-value="HVAC">HVAC</li>
                  <li class="lf-cs-opt" role="option" data-value="Plumbing">Plumbing</li>
                  <li class="lf-cs-opt" role="option" data-value="Electrical">Electrical</li>
                  <li class="lf-cs-opt" role="option" data-value="Painting">Painting</li>
                  <li class="lf-cs-opt" role="option" data-value="Landscaping">Landscaping</li>
                  <li class="lf-cs-opt" role="option" data-value="Home Remodeling">Home Remodeling</li>
                  <li class="lf-cs-opt" role="option" data-value="Other">Other</li>
                </ul>
                <input type="hidden" name="trade_type" class="lf-cs-hidden" />
              </div>
            </div>

            <button type="submit" class="lfh-submit">
              Get a free audit
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="lfh-form-note">No commitment required &middot; Fixed-scope quotes only</p>
          </form>
        </div>
      </div>

    </div>

    <!-- STATS STRIP -->
    <div class="container">
      <div class="lfh-stats" role="list" aria-label="Key results">
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">71<span class="lfh-amb">%</span></div>
          <div class="lfh-stat-lbl">of contractor sites fail<br>Core Web Vitals</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">5.1<span class="lfh-amb">x</span></div>
          <div class="lfh-stat-lbl">More leads from sites<br>ranking in local search</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">78<span class="lfh-amb">%</span></div>
          <div class="lfh-stat-lbl">Of homeowners research<br>contractors online before calling</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">10<span class="lfh-amb">wks</span></div>
          <div class="lfh-stat-lbl">From first call<br>to live, lead-generating site</div>
        </div>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════════════
       PAIN POINTS
  ══════════════════════════════════════════════ -->
  <section class="lf-pain section-pad-sm">
    <div class="container">
      <div class="lf-pain-intro">
        <p class="eyebrow lf-eyebrow-dark">Why leads walk before calling</p>
        <h2 class="h2-section">Why most contractor websites fail Maryland tradespeople</h2>
      </div>
      <div class="lf-pain-grid">
        {painPoints.map((p) => (
          <div class="lf-pain-card">
            <span class="lf-pain-icon" aria-hidden="true" set:html={p.icon} />
            <h3 class="lf-pain-title">{p.title}</h3>
            <p class="lf-pain-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FEATURES
  ══════════════════════════════════════════════ -->
  <section class="lf-features section-pad-sm">
    <div class="container">
      <div class="lf-features-intro">
        <p class="eyebrow lf-eyebrow-dark">What we build into every site</p>
        <h2 class="h2-section">Six things every Maryland contractor website needs</h2>
        <p class="lead">A contractor site is not a digital business card. It is a lead generation system. Every element we build, from schema to city pages to estimate forms, is designed to do one job: turn a searching homeowner into a booked estimate.</p>
      </div>
      <div class="lf-features-grid">
        {features.map((f) => (
          <div class="lf-feature-card">
            <div class="lf-fc-top">
              <span class="lf-fc-num mono-xs">{f.num}</span>
            </div>
            <h3 class="lf-fc-title">{f.title}</h3>
            <p class="lf-fc-body">{f.body}</p>
            <div class="lf-fc-tags">
              {f.tags.map((t) => <span class="lf-tag mono-xs">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CASE STUDY
  ══════════════════════════════════════════════ -->
  <section class="lf-case section-pad-sm">
    <div class="container">
      <div class="lf-case-inner">

        <div class="lf-case-content">
          <p class="eyebrow lf-eyebrow-dark">Client result &middot; Annapolis, MD</p>
          <h2 class="h2-section lf-case-h2">How Chesapeake Home Services doubled their monthly leads in 4 months</h2>
          <p class="lf-case-desc">
            Chesapeake Home Services, a general contractor in Annapolis serving Anne Arundel and Howard counties, came to us with a seven-year-old WordPress site with no schema, a 4.8-second mobile load time, and zero city-specific landing pages. Within 4 months of launch, the difference was clear.
          </p>

          <div class="lf-case-results">
            <div class="lf-cr-item">
              <span class="lf-cr-val">+214%</span>
              <span class="lf-cr-label mono-xs">Qualified estimate requests</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">Pg 1</span>
              <span class="lf-cr-label mono-xs">For 14 city + service combinations</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">1.8s</span>
              <span class="lf-cr-label mono-xs">Mobile load time (was 4.8s)</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">9</span>
              <span class="lf-cr-label mono-xs">City landing pages live and ranking</span>
            </div>
          </div>

          <blockquote class="lf-case-quote">
            <p>"We were spending $2,000 a month on ads because our organic visibility was essentially zero. Upcoming Brand built us city pages for every area we serve, fixed our site speed, and set up our GBP correctly. Within four months we cut our ad budget in half and were still getting more leads than before. The estimate form, where we can actually see what the job is before we call back, changed how our office operates."</p>
            <footer>
              <cite class="lf-cite-name">David Caruso</cite>
              <span class="lf-cite-role mono-xs">Owner &middot; Chesapeake Home Services &middot; Annapolis, MD</span>
            </footer>
          </blockquote>
        </div>

        <div class="lf-case-visual">
          <img
