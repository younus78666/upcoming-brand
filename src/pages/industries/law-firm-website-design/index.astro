  .lfh-submit svg { transition: transform 0.22s; flex-shrink: 0; }
  .lfh-submit:hover svg { transform: translateX(3px); }
  .lfh-form-note {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(244,239,230,0.3);
    text-align: center;
    margin-top: -4px;
  }

  /* stats strip */
  .lfh-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    padding-block: 28px;
