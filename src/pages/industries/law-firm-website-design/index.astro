    .lfh-stats { padding-block: 16px; }
    .lfh-stat-num { font-size: clamp(22px, 2vh, 32px); }
    .lfh-form-title { font-size: 17px; }
  }
  @media (max-width: 768px) {
    .lfh-hero { padding-top: clamp(20px, 5vw, 44px); }
    .lfh-wrap { grid-template-columns: 1fr; gap: 28px; padding-bottom: 32px; }
    .lfh-h1 { font-size: clamp(30px, 8vw, 48px); }
