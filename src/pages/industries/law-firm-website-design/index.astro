---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const stats = [
  { val: "Pg 1", label: "Rankings for 11 attorney keywords" },
  { val: "94",   label: "PageSpeed score on mobile" },
  { val: "+312%", label: "Organic intake leads" },
];

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow sites lose clients before they call",
    body: "The average Maryland law firm site scores 38 on mobile PageSpeed. Every second of load time costs you 7% of conversions — and courts in competitive practice areas are relentless.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "Template shops don't know attorney ethics rules",
    body: "Testimonials, case results, guarantees — Maryland bar rules restrict what your site can say. Generic agencies get this wrong constantly, leaving you exposed to bar complaints.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Missing schema = missing the Local Pack",
    body: "Google's Local Pack (the 3-map results) relies on LegalService schema markup. Without it, competitors with worse sites outrank you for searches like 'divorce attorney Baltimore'.",
  },
];

const features = [
  {
    num: "01",
    title: "Practice area pages that rank",
    body: "One dedicated, schema-marked page per practice area — Personal Injury, Family Law, Criminal Defense, Estate Planning, Business Law, Real Estate. Each targets 3–5 high-intent local keywords.",
    tags: ["LegalService schema", "Local SEO", "Internal linking"],
  },
  {
    num: "02",
    title: "Intake forms that actually convert",
    body: "Multi-step intake forms with conditional logic route leads to the right attorney or paralegal instantly. Spam-protected, WCAG 2.1 accessible, tested on iOS Safari and Android Chrome.",
    tags: ["Conditional logic", "Spam protection", "Accessibility"],
  },
  {
    num: "03",
    title: "Attorney profile pages",
    body: "Individual bios with education, bar admissions, case results (bar-compliant), headshots, and direct contact. Each profile is a standalone SEO landing page for the attorney's name.",
    tags: ["Attorney schema", "Direct contact", "Name rankings"],
  },
  {
    num: "04",
    title: "Ethics-compliant copy guidance",
    body: "We flag anything that violates Maryland bar advertising rules during the design phase — before it goes live. Results-based claims, testimonials, and guarantees reviewed against MRPC 7.1–7.5.",
    tags: ["MRPC review", "Testimonial rules", "Results claims"],
  },
  {
    num: "05",
    title: "Google Business Profile sync",
    body: "NAP consistency across your site, GBP, and local citations. We set up Organization + LegalService JSON-LD that feeds directly into Google's knowledge graph and Local Pack triggers.",
    tags: ["NAP consistency", "JSON-LD", "Local Pack"],
  },
  {
    num: "06",
    title: "Core Web Vitals in the green",
    body: "Every build ships with a PageSpeed score of 90+ on mobile and desktop, LCP under 2.5s, INP under 200ms. Written into the scope — if we miss it at launch, we fix it at no cost.",
    tags: ["90+ PageSpeed", "LCP < 2.5s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Practice area audit & keyword research",
    body: "We map your 6–8 practice areas against actual search volume in your target cities. You'll see exactly which keywords are worth targeting and which competitors are ranking for them.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "Figma mockups reviewed with you",
    body: "Full desktop and mobile mockups for every key page. We handle the layout — you focus on confirming the content hierarchy and that the messaging matches how you present in person.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "WordPress build with schema & SEO",
    body: "Built on Elementor Pro + Astra with RankMath Pro. Every page gets JSON-LD schema, meta title, meta description, and is cross-tested across Chrome, Safari, Firefox, and Edge.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Search Console setup & 30-day monitoring",
    body: "We submit your sitemap, verify ownership, and monitor Search Console for the first 30 days post-launch. Any indexing issues are resolved the same day they surface.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long does a law firm website take to rank on Google?",
    a: "Practice area pages for mid-competition keywords (e.g. 'estate planning attorney Frederick MD') typically reach page 1 within 4–6 months on a new site with proper on-page SEO and schema. Highly competitive terms like 'personal injury attorney Baltimore' take 9–18 months and require an ongoing content strategy.",
  },
  {
    num: "02",
    category: "Migration",
    q: "Can you build a site while keeping our current domain and email?",
    a: "Yes. We build on a staging subdomain, run a pre-launch crawl to map all existing URLs, set up 301 redirects, and then cut over DNS. Your email runs on a separate MX record and is never touched. Most migrations see zero ranking disruption within 30 days.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you handle the copywriting for practice area pages?",
    a: "Yes — copywriting is included in Growth and Custom builds. We draft SEO-optimised copy for every practice area page and attorney bio, send for your review, and revise based on your feedback. Copy is written to comply with Maryland bar advertising rules and never makes guarantees or results-based promises.",
  },
  {
    num: "04",
    category: "Platform",
    q: "What makes a law firm site different from a regular business site?",
    a: "Three things: schema markup (LegalService, Attorney, LegalAid types that generic builders don't implement), ethics compliance (MRPC 7.1–7.5 governs every headline and CTA), and conversion architecture (intake forms routed by practice area, click-to-call prominence, trust signals like bar memberships above the fold).",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "Do you offer care plans for law firm sites?",
    a: "Yes, starting at $150/month. Care plans include weekly WordPress core and plugin updates, off-site backups, uptime monitoring, and a 4-hour SLA on support tickets. You communicate directly with the founder — not a help desk. Law firm clients can add monthly content updates and local citation management.",
  },
  {
    num: "06",
    category: "SEO",
    q: "Will you guarantee specific keyword rankings?",
    a: "No ethical agency can guarantee rankings — and you should be suspicious of any that do. We guarantee clean LegalService schema, Core Web Vitals in the green, and a properly structured topical map. Clients on our SEO care plan typically see top-10 positions for 15–25 targeted attorney keywords within 9 months.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500–$3,500",
    timeline: "4–6 weeks",
    popular: false,
    dark: false,
    features: [
      "Up to 8 pages (Home, About, 4 practice areas, Contact, Blog)",
      "Mobile-responsive, accessibility-aware",
      "RankMath Pro SEO + LegalService schema",
      "Contact form with spam protection",
      "Attorney bio page",
      "PageSpeed 90+ at launch",
      "30 days free post-launch support",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500–$6,000",
    timeline: "6–8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 20 pages with custom Figma design",
      "6+ practice area pages, attorney profiles",
      "Multi-step intake form with conditional logic",
      "Service area pages for 3–5 Maryland cities",
      "Full JSON-LD schema (LegalService, Attorney, FAQ)",
      "Google Search Console + Analytics setup",
      "60 days free post-launch support",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000–$10,000+",
    timeline: "8–10 weeks",
    popular: false,
    dark: true,
    features: [
      "Unlimited pages — large multi-attorney firms",
      "ACF Pro attorney roster with filter/search",
      "Custom intake routing by practice area",
      "MRPC compliance review built into process",
      "Dedicated project manager",
      "First 3 months of care plan included",
      "90 days free post-launch support",
    ],
    cta: "Start a conversation",
  },
];
---
<BaseLayout
  title="Law Firm Website Design Maryland | Upcoming Brand"
  description="WordPress website design for Maryland law firms. Practice area pages, intake forms, LegalService schema, 90+ PageSpeed. Fixed-scope pricing from $1,500. Baltimore, Annapolis, Frederick."
  canonicalUrl="https://upcomingbrand.com/industries/law-firm-website-design/"
>
  <Navigation />

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="lfh-hero">

    <div class="container">
      <nav class="lfh-breadcrumb mono-xs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#industries">Industries</a>
        <span aria-hidden="true">/</span>
        <span>Law Firm Website Design</span>
      </nav>
    </div>

    <div class="container lfh-wrap">

      <!-- LEFT COLUMN -->
      <div class="lfh-left">

        <div class="lfh-tags">
          <span class="lfh-pill">
            <span class="lfh-dot" aria-hidden="true"></span>
            Law Firm Web Design &middot; Maryland
          </span>
          <span class="lfh-hero-sep" aria-hidden="true">&mdash;</span>
          <span class="lfh-hero-eyebrow">A specialist studio, not a template shop</span>
        </div>

        <h1 class="lfh-h1">
          <span class="lfh-h1-line">WordPress sites built</span>
          <span class="lfh-h1-line lfh-h1-accent-line"><em class="lfh-h1-accent">for Maryland law firms</em></span>
          <span class="lfh-h1-line lfh-h1-italic">that rank &amp; convert.</span>
        </h1>

        <p class="lfh-lede">
          Fixed-scope builds from <strong>$1,500</strong> — LegalService schema, multi-step intake forms, ethics-compliant copy, and a written <strong>90+ PageSpeed guarantee</strong> — delivered in 4–10 weeks.
        </p>

        <div class="lfh-ctas">
          <a href="#contact" class="lfh-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#pricing" class="lfh-btn-ghost">
            See pricing
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="lfh-trust">
          <span class="lfh-trust-item">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            LegalService schema included
          </span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">MRPC-compliant copy</span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">Fixed-scope &middot; no surprises</span>
        </div>

      </div>

      <!-- RIGHT COLUMN — FORM -->
      <div class="lfh-right">
        <div class="lfh-form-card">
          <div class="lfh-form-header">
            <p class="lfh-form-eyebrow">Free discovery call</p>
            <h2 class="lfh-form-title">Tell us about your firm</h2>
            <p class="lfh-form-sub">We reply within 4 business hours. No sales pitch — just an honest conversation about what your firm needs.</p>
          </div>

          <form class="lfh-form" name="lf-inquiry" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value="lf-inquiry" />
            <div style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
              <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-name">Your name</label>
              <input class="lfh-form-input" type="text" id="lf-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-email">Email address</label>
              <input class="lfh-form-input" type="email" id="lf-email" name="email" placeholder="jane@smithlaw.com" required autocomplete="email" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-firm">Law firm name</label>
              <input class="lfh-form-input" type="text" id="lf-firm" name="firm" placeholder="Smith &amp; Associates" autocomplete="organization" />
            </div>

            <div class="lfh-form-row">
              <span class="lfh-form-label" id="lbl-practice">Primary practice area</span>
              <div class="lf-cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-practice" data-name="practice_area">
                <button type="button" class="lf-cs-trigger" aria-haspopup="listbox">
                  <span class="lf-cs-val">Select practice area</span>
                  <svg class="lf-cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="lf-cs-list" role="listbox" aria-label="Practice area">
                  <li class="lf-cs-opt" role="option" data-value="Personal Injury">Personal Injury</li>
                  <li class="lf-cs-opt" role="option" data-value="Family Law">Family Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Criminal Defense">Criminal Defense</li>
                  <li class="lf-cs-opt" role="option" data-value="Estate Planning">Estate Planning</li>
                  <li class="lf-cs-opt" role="option" data-value="Business Law">Business Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Real Estate Law">Real Estate Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Immigration">Immigration</li>
                  <li class="lf-cs-opt" role="option" data-value="Other / Multiple">Other / Multiple</li>
                </ul>
                <input type="hidden" name="practice_area" class="lf-cs-hidden" />
              </div>
            </div>

            <button type="submit" class="lfh-submit">
              Get a free quote
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="lfh-form-note">No commitment required &middot; Fixed-scope quotes only</p>
          </form>
        </div>
      </div>

    </div>

    <!-- STATS STRIP -->
    <div class="container">
      <div class="lfh-stats" role="list" aria-label="Key results">
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">Pg&nbsp;1</div>
          <div class="lfh-stat-lbl">Rankings for 11<br>attorney keywords</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">94<span class="lfh-amb">+</span></div>
          <div class="lfh-stat-lbl">PageSpeed score<br>on mobile</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">+312<span class="lfh-amb">%</span></div>
          <div class="lfh-stat-lbl">Organic intake<br>leads generated</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">4<span class="lfh-amb">hr</span></div>
          <div class="lfh-stat-lbl">Average<br>response time</div>
        </div>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════════════
       PAIN POINTS
  ══════════════════════════════════════════════ -->
  <section class="lf-pain section-pad-sm">
    <div class="container">
      <div class="lf-pain-intro">
        <p class="eyebrow lf-eyebrow-dark">Why most law firm sites fail</p>
        <h2 class="h2-section">Three problems we fix before any Maryland attorney goes live</h2>
      </div>
      <div class="lf-pain-grid">
        {painPoints.map((p) => (
          <div class="lf-pain-card">
            <span class="lf-pain-icon" aria-hidden="true" set:html={p.icon} />
            <h3 class="lf-pain-title">{p.title}</h3>
            <p class="lf-pain-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FEATURES
  ══════════════════════════════════════════════ -->
  <section class="lf-features section-pad-sm">
    <div class="container">
      <div class="lf-features-intro">
        <p class="eyebrow lf-eyebrow-dark">What we build</p>
        <h2 class="h2-section">Every law firm WordPress site from Upcoming Brand includes</h2>
        <p class="lead">Six things every Maryland attorney's website needs to compete in local search and convert visitors into consultations.</p>
      </div>
      <div class="lf-features-grid">
        {features.map((f) => (
          <div class="lf-feature-card">
            <div class="lf-fc-top">
              <span class="lf-fc-num mono-xs">{f.num}</span>
            </div>
            <h3 class="lf-fc-title">{f.title}</h3>
            <p class="lf-fc-body">{f.body}</p>
            <div class="lf-fc-tags">
              {f.tags.map((t) => <span class="lf-tag mono-xs">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CASE STUDY
  ══════════════════════════════════════════════ -->
  <section class="lf-case section-pad-sm">
    <div class="container">
      <div class="lf-case-inner">

        <div class="lf-case-content">
          <p class="eyebrow lf-eyebrow-dark">Case study</p>
          <h2 class="h2-section lf-case-h2">Meridian Law Group, Baltimore</h2>
          <p class="lf-case-desc">
            A 40-year Baltimore firm with six practice areas came to us with a 12-second mobile load time, page-3 Google rankings, and an intake form that broke on iOS Safari. We rebuilt the entire site in 7 weeks.
          </p>

          <div class="lf-case-results">
            <div class="lf-cr-item">
              <span class="lf-cr-val">+312%</span>
              <span class="lf-cr-label mono-xs">Organic leads within 6 months</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">94</span>
              <span class="lf-cr-label mono-xs">PageSpeed score on mobile</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">Pg 1</span>
              <span class="lf-cr-label mono-xs">Rankings for 11 attorney keywords</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">7 wks</span>
              <span class="lf-cr-label mono-xs">From kickoff to live</span>
            </div>
          </div>

          <blockquote class="lf-case-quote">
            <p>"We'd tried two other agencies before Upcoming Brand. Both disappeared after launch and left us with a site that took 12 seconds to load on mobile. Upcoming Brand delivered in 7 weeks, hit 91 on PageSpeed, and we've been ranking page one for three practice area keywords ever since."</p>
            <footer>
              <cite class="lf-cite-name">Maya Rodriguez</cite>
              <span class="lf-cite-role mono-xs">Managing Partner · Meridian Law Group · Baltimore, MD</span>
            </footer>
          </blockquote>
        </div>

        <div class="lf-case-visual">
          <img
            src="/work/meridian-law-group.png"
            alt="Meridian Law Group website redesign — Baltimore law firm"
            class="lf-case-img"
            width="600"
            height="420"
            loading="lazy"
            decoding="async"
          />
          <div class="lf-case-badge mono-xs">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Live site · Google verified results
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       PROCESS
  ══════════════════════════════════════════════ -->
  <section class="lf-process section-pad-sm">
    <div class="container">
      <div class="lf-process-intro">
        <p class="eyebrow lf-eyebrow-dark" style="justify-content:center">How it works</p>
        <h2 class="h2-section">From first call to ranked law firm website in 4–10 weeks</h2>
        <p class="lead">A fixed-scope process means you know the price, scope, and deadline before you sign anything.</p>
      </div>
      <div class="lf-process-grid" role="list" aria-label="Project phases">
        {process.map((step) => (
          <div class="lf-process-step" role="listitem">
            <div class="lf-phase-marker" aria-hidden="true">
              <span class="lf-phase-num">{step.num}</span>
              <div class="lf-phase-line"></div>
            </div>
            <div class="lf-phase-header">
              <h3 class="lf-phase-name">{step.phase}: {step.title}</h3>
              <span class="lf-phase-timing mono-xs">{step.timing}</span>
            </div>
            <p class="lf-deliverables-label">DELIVERABLES</p>
            <p class="lf-phase-desc">{step.body}</p>
          </div>
        ))}
      </div>
      <div class="lf-process-cta">
        <a href="#contact" class="cta-btn">Book a discovery call &rarr;</a>
        <p class="lf-process-cta-note mono-xs">No sales pitch on the first call. Just a working conversation.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       PRICING
  ══════════════════════════════════════════════ -->
  <section class="lf-pricing section-pad-sm" id="pricing">
    <div class="container">
      <div class="lf-pricing-intro">
        <p class="eyebrow lf-eyebrow-dark">Transparent pricing</p>
        <h2 class="h2-section">Fixed-scope law firm website pricing</h2>
        <p class="lead">One price, one scope, one timeline. No hourly billing, no retainer creep. Every project starts with a written proposal.</p>
      </div>
      <div class="lf-pricing-grid">
        {tiers.map((tier) => (
          <div class={`lf-tier ${tier.popular ? 'lf-tier-popular' : ''} ${tier.dark ? 'lf-tier-dark' : ''}`}>
