    text-align: center;
  }
  .lfh-stat:last-child { border-right: none; }
  .lfh-stat-num {
    font-family: var(--f-display);
    font-size: clamp(26px, 2.5vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
  }
  .lfh-amb { color: var(--amber-deep); font-style: italic; font-weight: 300; }
  .lfh-stat-lbl {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  /* responsive */
  @media (max-width: 1100px) {
    .lfh-wrap { grid-template-columns: 1fr 360px; gap: 32px; }
