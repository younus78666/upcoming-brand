    color: var(--ink-muted);
    transition: color var(--transition);
  }
  .lfh-breadcrumb a:hover { color: var(--amber); }

  /* two-column layout */
  .lfh-wrap {
    display: grid;
    grid-template-columns: 1fr 400px;
