  }
  .lfh-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lfh-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lfh-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lfh-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lfh-btn-primary svg, .lfh-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lfh-btn-primary:hover svg { transform: translateX(3px); }
  .lfh-btn-ghost:hover svg  { transform: translate(2px, -2px); }

  /* trust bar */
  .lfh-trust { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .lfh-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .lfh-trust-item svg { color: var(--amber); flex-shrink: 0; }
  .lfh-trust-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--line-strong);
    flex-shrink: 0;
  }

  /* form card */
  .lfh-right { align-self: start; }
  .lfh-form-card {
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--radius-lg);
    padding: clamp(20px, 2.5vh, 32px) clamp(20px, 2.5vw, 32px);
    box-shadow: var(--shadow-lg);
  }
  .lfh-form-header { margin-bottom: clamp(14px, 2vh, 22px); }
  .lfh-form-eyebrow {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 8px;
  }
  .lfh-form-title {
    font-family: var(--f-display);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 8px;
    color: var(--cream);
  }
  .lfh-form-sub {
    font-size: 13px;
    line-height: 1.55;
    color: rgba(244,239,230,0.5);
  }
  .lfh-form { display: flex; flex-direction: column; gap: clamp(10px, 1.5vh, 14px); }
  .lfh-form-row { display: flex; flex-direction: column; gap: 5px; position: relative; }
  .lfh-form-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.45);
  }
  .lfh-form-input {
    background: rgba(244,239,230,0.07);
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    padding: clamp(8px, 1.2vh, 11px) 14px;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--cream);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .lfh-form-input::placeholder { color: rgba(244,239,230,0.28); }
  .lfh-form-input:focus { border-color: var(--amber); }

  /* custom dropdown */
  .lf-cs-wrap { position: relative; }
  .lf-cs-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: rgba(244,239,230,0.07);
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    padding: clamp(8px, 1.2vh, 11px) 14px;
    font-family: var(--f-body);
    font-size: 14px;
    color: rgba(244,239,230,0.4);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s;
  }
  .lf-cs-trigger:focus { outline: none; border-color: var(--amber); }
  .lf-cs-wrap[aria-expanded="true"] .lf-cs-trigger { border-color: var(--amber); color: var(--cream); }
  .lf-cs-wrap.has-value .lf-cs-trigger { color: var(--cream); }
  .lf-cs-chevron {
    flex-shrink: 0;
    color: rgba(244,239,230,0.35);
    transition: transform 0.2s;
  }
  .lf-cs-wrap[aria-expanded="true"] .lf-cs-chevron { transform: rotate(180deg); }
  .lf-cs-list {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0; right: 0;
    background: #1C232B;
    border: 1px solid rgba(244,239,230,0.15);
    border-radius: var(--radius-sm);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    z-index: 100;
    list-style: none;
    margin: 0; padding: 4px;
    max-height: 220px;
    overflow-y: auto;
  }
  .lf-cs-wrap[aria-expanded="true"] .lf-cs-list { display: block; }
  .lf-cs-opt {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    font-size: 14px;
    color: rgba(244,239,230,0.7);
    border-radius: 6px;
