  .lfh-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
  }
  .lfh-h1-accent::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.05em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }
  .lfh-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  /* lede */
  .lfh-lede {
    font-size: clamp(14px, min(1.2vw, 2vh), 17px);
    line-height: 1.6;
    color: var(--ink-soft);
