  .lf-cs-hidden { display: none; }

  /* submit */
  .lfh-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    width: 100%;
    background: var(--amber);
    color: var(--ink);
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 600;
    padding: clamp(11px, 1.5vh, 15px) 24px;
