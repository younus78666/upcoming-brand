    .lfh-stats { grid-template-columns: repeat(2, 1fr); padding-block: 20px; }
    .lfh-stat:nth-child(2) { border-right: none; }
    .lfh-stat:nth-child(3) { border-right: 1px solid var(--line); border-top: 1px solid var(--line); padding-top: 20px; }
    .lfh-stat:nth-child(4) { border-top: 1px solid var(--line); padding-top: 20px; }
    .lfh-trust { gap: 8px; }
    .lfh-trust-dot { display: none; }
    .lfh-trust-item { display: block; }
  }
  @media (max-width: 480px) {
    .lfh-ctas { flex-direction: column; width: 100%; }
    .lfh-btn-primary, .lfh-btn-ghost { justify-content: center; width: 100%; }
  }

  /* ══════════════════════
     PAIN POINTS
  ══════════════════════ */
  .lf-pain {
    background: var(--paper);
  }

  .lf-pain-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .lf-pain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .lf-pain-card {
    background: var(--cream-soft);
    border: 1.5px solid rgba(15,20,25,0.07);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: box-shadow var(--transition);
  }

  .lf-pain-card:hover {
    box-shadow: 0 8px 28px rgba(15,20,25,0.09);
  }

  .lf-pain-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(176,74,62,0.08);
    border: 1px solid rgba(176,74,62,0.15);
    border-radius: var(--radius-sm);
    color: var(--red);
    flex-shrink: 0;
  }

  .lf-pain-title {
    font-family: var(--f-display);
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
  }

  .lf-pain-body {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.65;
  }

  /* ══════════════════════
     FEATURES
  ══════════════════════ */
  .lf-features {
    background: var(--cream-soft);
  }

  .lf-features-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .lf-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .lf-feature-card {
    background: var(--paper);
    border: 1.5px solid rgba(15,20,25,0.07);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 28px 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow var(--transition), transform var(--transition);
    box-shadow: 0 2px 10px rgba(15,20,25,0.05);
  }

  .lf-feature-card:hover {
    box-shadow: 0 10px 30px rgba(15,20,25,0.1);
    transform: translateY(-3px);
  }

  .lf-fc-top {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .lf-fc-num {
    color: var(--amber);
    font-size: 10px;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  .lf-fc-title {
    font-family: var(--f-display);
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
  }

  .lf-fc-body {
    font-size: 13.5px;
    color: var(--ink-muted);
    line-height: 1.65;
    flex: 1;
  }

  .lf-fc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  .lf-tag {
    font-size: 10px;
    padding: 3px 8px;
    background: var(--amber-glow);
    border: 1px solid rgba(212,147,46,0.2);
    border-radius: var(--radius-pill);
    color: var(--amber-deep);
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  /* ══════════════════════
     CASE STUDY
  ══════════════════════ */
  .lf-case {
    background: var(--paper);
  }

  .lf-case-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .lf-case-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .lf-case-h2 {
    font-size: clamp(26px, 3vw, 40px);
  }

  .lf-case-desc {
    font-size: 15px;
    color: var(--ink-muted);
    line-height: 1.7;
  }

  .lf-case-results {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .lf-cr-item {
    background: var(--cream-soft);
    border: 1.5px solid rgba(15,20,25,0.07);
    border-left: 3px solid var(--amber);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .lf-cr-val {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--amber);
    line-height: 1;
  }

  .lf-cr-label {
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  .lf-case-quote {
    background: var(--ink);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--amber);
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .lf-case-quote p {
    font-size: 14px;
    color: rgba(244,239,230,0.7);
    line-height: 1.7;
    font-style: italic;
  }

  .lf-case-quote footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .lf-cite-name {
    font-style: normal;
    font-weight: 600;
    font-size: 14px;
    color: var(--cream);
  }

  .lf-cite-role {
    font-size: 10px;
    color: rgba(244,239,230,0.4);
    letter-spacing: 0.06em;
  }

  .lf-case-visual {
    position: relative;
  }

  .lf-case-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 60px rgba(15,20,25,0.15);
    border: 1.5px solid rgba(15,20,25,0.08);
  }

  .lf-case-badge {
    position: absolute;
    bottom: -12px;
    left: 20px;
    background: var(--ink);
    color: rgba(244,239,230,0.6);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(244,239,230,0.1);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  /* ══════════════════════
     PROCESS
  ══════════════════════ */
  .lf-process {
    background: var(--cream-soft);
  }

  .lf-process-intro {
    max-width: 600px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .lf-process-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 48px;
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .lf-process-step {
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    position: relative;
    transition: background var(--transition);
  }

  .lf-process-step:nth-child(2n) { border-right: none; }
  .lf-process-step:nth-child(3),
  .lf-process-step:nth-child(4) { border-bottom: none; }

  .lf-process-step:hover { background: var(--cream-soft); }

  .lf-phase-marker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .lf-phase-num {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 50%;
    color: var(--amber);
    font-family: var(--f-display);
    font-size: 14px;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .lf-phase-line {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .lf-phase-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }

  .lf-phase-name {
    font-family: var(--f-display);
    font-size: clamp(15px, 1.6vw, 19px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .lf-phase-timing {
    color: var(--amber);
    white-space: nowrap;
    letter-spacing: 0.06em;
    text-align: right;
    flex-shrink: 0;
  }

  .lf-deliverables-label {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 4px;
    opacity: 0.8;
  }

  .lf-phase-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .lf-process-cta {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .lf-process-cta-note {
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  /* ══════════════════════
     PRICING
  ══════════════════════ */
  .lf-pricing {
    background: var(--paper);
  }

  .lf-pricing-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .lf-pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 24px;
  }

  .lf-tier {
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }

  .lf-tier:hover { box-shadow: var(--shadow-md); }

  .lf-tier-popular {
    border-color: var(--amber);
    box-shadow: 0 0 0 2px var(--amber), 0 12px 40px rgba(212,147,46,0.15);
  }

  .lf-tier-dark {
    background: var(--ink);
    color: var(--cream);
    border-color: rgba(244,239,230,0.1);
  }

  .lf-popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--amber);
    color: var(--ink);
    padding: 4px 16px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
  }

  .lf-tier-header {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .lf-tier-dark .lf-tier-header { border-color: rgba(244,239,230,0.1); }

  .lf-tier-name {
    font-family: var(--f-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .lf-tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .lf-tier-price {
    font-family: var(--f-display);
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .lf-tier-period {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .lf-tier-dark .lf-tier-period { color: rgba(244,239,230,0.5); }

  .lf-tier-timeline {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: var(--cream-soft);
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .lf-tier-dark .lf-tier-timeline { background: rgba(244,239,230,0.08); }

  .lf-tl-label { color: var(--ink-muted); font-size: 10px; letter-spacing: 0.06em; }
  .lf-tl-val   { color: var(--ink); font-size: 10px; font-weight: 500; letter-spacing: 0.06em; }
  .lf-tier-dark .lf-tl-val { color: var(--amber); }

  .lf-tier-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .lf-tier-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.5;
  }

  .lf-check {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--green);
  }

  .lf-tier-dark .lf-tier-feature { color: rgba(244,239,230,0.8); }
  .lf-tier-dark .lf-check { color: #8ab86a; }

  .lf-tier-cta {
    width: 100%;
    justify-content: center;
  }

  .lf-pricing-note {
    text-align: center;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    padding: 14px 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--cream-soft);
  }

  /* ══════════════════════
     FAQ
  ══════════════════════ */
  .lf-faq {
    background: var(--cream-soft);
  }

  .lf-faq-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 72px;
    align-items: start;
  }

  /* Sidebar */
  .lf-faq-sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .lf-faq-h2 {
    font-size: clamp(22px, 2.2vw, 30px);
    line-height: 1.2;
  }

  .lf-faq-sidebar-text {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.65;
    margin-top: -4px;
  }

  .lf-faq-stats {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    border: 1.5px solid rgba(15,20,25,0.07);
    border-radius: var(--radius-sm);
    background: var(--paper);
  }

  .lf-faq-stat { display: flex; flex-direction: column; gap: 3px; }

  .lf-faq-stat-num {
    font-family: var(--f-display);
    font-size: 28px;
    font-weight: 300;
    letter-spacing: -0.04em;
    color: var(--amber);
    line-height: 1;
  }

  .lf-faq-stat-label {
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lf-faq-stat-divider {
    width: 1px;
    height: 36px;
    background: var(--line);
  }

  .lf-faq-sidebar-cta {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  .lf-faq-cta-note {
    text-align: center;
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.07em;
    margin-top: -8px;
    opacity: 0.7;
  }

  /* Accordion */
  .lf-faq-list {
    display: flex;
    flex-direction: column;
    border: 1.5px solid rgba(15,20,25,0.07);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(15,20,25,0.05);
    background: var(--paper);
  }

  .lf-faq-item {
    border-bottom: 1px solid rgba(15,20,25,0.07);
    border-left: 3px solid transparent;
    transition: border-left-color var(--transition), background var(--transition);
  }

  .lf-faq-item:last-child { border-bottom: none; }

  .lf-faq-item:has(.lf-faq-trigger[aria-expanded="true"]) {
    border-left-color: var(--amber);
    background: var(--cream-soft);
  }

  .lf-faq-trigger {
    display: grid;
    grid-template-columns: 36px 1fr auto auto;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 20px 22px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: color var(--transition);
  }

  .lf-faq-trigger:hover .lf-faq-q { color: var(--amber-deep); }

  .lf-faq-num {
    font-size: 11px;
    color: var(--amber);
    letter-spacing: 0.08em;
    font-weight: 500;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .lf-faq-q {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
    transition: color var(--transition);
  }

  .lf-faq-cat {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 800px) {
    .lf-faq-cat { display: inline-block; }
  }

  .lf-faq-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--ink-muted);
    transition: transform var(--transition), color var(--transition);
  }

  .lf-faq-trigger[aria-expanded="true"] .lf-faq-icon {
    transform: rotate(45deg);
    color: var(--amber);
  }

  .lf-plus-v { transition: opacity var(--transition); }
  .lf-faq-trigger[aria-expanded="true"] .lf-plus-v { opacity: 0; }

  .lf-faq-answer { overflow: hidden; }

  .lf-faq-answer:not([hidden]) {
    display: block;
    animation: lf-faq-open 200ms ease forwards;
  }

  @keyframes lf-faq-open {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lf-faq-a {
    padding: 0 22px 22px 72px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--ink-muted);
  }

  /* ══════════════════════
     FINAL CTA
  ══════════════════════ */
  .lf-cta {
    background: var(--ink);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .lf-cta-watermark {
    position: absolute;
    bottom: -32px;
    right: -16px;
    font-family: var(--f-display);
    font-size: clamp(60px, 12vw, 160px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.04em;
    color: var(--cream);
    opacity: 0.03;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
  }

  .lf-cta-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 72px;
    align-items: center;
  }

  .lf-cta-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .lf-cta-h2 { color: var(--cream); max-width: 18ch; margin: 0; }

  .lf-cta-trust { display: flex; flex-direction: column; gap: 12px; }

  .lf-trust-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: rgba(244,239,230,0.65);
  }

  .lf-trust-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212,147,46,0.1);
    border: 1px solid rgba(212,147,46,0.2);
    border-radius: var(--radius-sm);
    color: var(--amber);
  }

  .lf-cta-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(244,239,230,0.4);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  .lf-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }

  /* CTA card */
  .lf-cta-card {
    background: rgba(244,239,230,0.04);
    border: 1px solid rgba(244,239,230,0.1);
    border-top: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 32px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.25);
  }

  .lf-cta-card-header { display: flex; flex-direction: column; gap: 10px; }

  .lf-avail-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 4px 10px;
    border: 1px solid rgba(92,128,64,0.35);
    border-radius: var(--radius-pill);
    background: rgba(92,128,64,0.1);
    color: #8ab86a;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lf-avail-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #8ab86a;
    flex-shrink: 0;
    animation: lf-pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;
  }

  @keyframes lf-pulse {
    0%, 100% { opacity: 1; }
