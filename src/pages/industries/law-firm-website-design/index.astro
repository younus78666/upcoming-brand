  }
  @media (max-height: 780px) and (min-width: 769px) {
    .lfh-hero { padding-top: clamp(12px, 2vh, 28px); }
    .lfh-wrap { padding-bottom: clamp(12px, 2vh, 28px); }
    .lfh-h1 { font-size: clamp(24px, min(3.5vw, 5vh), 52px); }
