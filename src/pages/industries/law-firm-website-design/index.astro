---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const stats = [
  { val: "Pg 1", label: "Rankings for 11 attorney keywords" },
  { val: "94",   label: "PageSpeed score on mobile" },
  { val: "+312%", label: "Organic intake leads" },
];

const painPoints = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Slow sites bleed leads at every second",
    body: "Google's data shows a 1-second delay in page load reduces conversions by 7%. Most attorney sites we audit load in 6–9 seconds on mobile — which means a prospect searching \"Baltimore personal injury lawyer\" bounces before your phone number even appears.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: "Generic agencies don't know MRPC",
    body: "Maryland's Rules of Professional Conduct govern exactly what attorney advertising can and cannot say — no unqualified superlatives, no misleading case outcome claims. Agencies that build sites for dentists and restaurants don't know these rules exist, leaving your bar license exposed.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "No schema means no Local Pack visibility",
    body: "Generic web agencies skip LegalService and Attorney schema markup entirely. Without it, Google can't confidently surface your firm in the local 3-pack for searches like \"Annapolis divorce attorney near me\" — searches that convert at 4x the rate of organic clicks.",
  },
];

const features = [
  {
    num: "01",
    title: "Practice area pages with LegalService schema",
    body: "Each practice area gets its own dedicated page: structured, keyword-targeted, and marked up with LegalService JSON-LD schema. This tells Google exactly what your firm does and in which jurisdictions — so pages appear for searches like \"Frederick MD estate planning attorney\" rather than just your firm name. We don't drop every service onto one cluttered page; that approach splits authority and ranks for nothing.",
    tags: ["LegalService Schema", "Jurisdiction targeting", "Practice area SEO"],
  },
  {
    num: "02",
    title: "Multi-step legal intake forms",
    body: "Single-page contact forms convert at roughly 2–3%. A properly built multi-step intake form — asking qualifying questions in the right order — routinely converts at 8–12% for legal audiences. We build conditional-logic forms that qualify case type, urgency, and location before the prospect hits submit, so your team spends time on viable cases, not tire-kickers. Forms connect directly to your CRM or email system.",
    tags: ["Conditional logic", "CRM integration", "Legal intake"],
  },
  {
    num: "03",
    title: "Attorney bio pages that build trust fast",
    body: "Prospective clients read attorney bios before they read anything else on your site. We design bio pages that lead with credentials, feature real photography direction, and include structured data for each attorney's bar admissions, practice areas, and education. A strong bio page also ranks independently for attorney-name searches — important for referral traffic from other counsel.",
    tags: ["Attorney schema", "Personal branding", "Trust signals"],
  },
  {
    num: "04",
    title: "Ethics-compliant copy, written in-house",
    body: "We write all website copy under Maryland Rules of Professional Conduct (MRPC) 7.1–7.5. No \"best lawyer in Baltimore\" headlines, no implied outcome guarantees, proper disclaimer placement on every page. You review for factual accuracy — we handle the compliance framing. No separate copywriter invoice, no back-and-forth with a writer who has never read a bar rule.",
    tags: ["MRPC 7.1–7.5", "Legal copywriting", "Attorney advertising rules"],
  },
  {
    num: "05",
    title: "Google Business Profile and Local Pack setup",
    body: "Ranking in the Google Maps 3-pack is often worth more than ranking #1 organically. We audit and optimize your GBP — primary category, service areas, Q&A, photo metadata, and citation consistency across Yelp, Avvo, FindLaw, and Justia. For firms in Baltimore, Bethesda, Annapolis, and Columbia, Local Pack visibility is frequently the difference between a dead and a thriving marketing channel.",
    tags: ["Google Business Profile", "Local Pack", "Citation building"],
  },
  {
    num: "06",
    title: "Core Web Vitals performance guarantee",
    body: "We guarantee your site ships with green Core Web Vitals scores across LCP, INP, and CLS — or we fix it at no cost before launch. Our builds use a purpose-built WordPress stack: server-side rendering, no pagebuilder bloat, CDN-delivered assets, and LCP under 2.5 seconds on mobile. 44% of attorney sites currently fail these benchmarks and are being deprioritized in search rankings as a result.",
    tags: ["Core Web Vitals", "LCP < 2.5s", "Written guarantee"],
  },
];

const process = [
  {
    num: "01",
    phase: "Discovery",
    timing: "Week 0",
    title: "Site audit + strategy document",
    body: "We audit your current site for technical SEO, Core Web Vitals, schema gaps, and MRPC compliance issues. Then we map your keyword targets by practice area and city — Baltimore, Annapolis, Frederick, Silver Spring, wherever your clients come from. You receive a written strategy document that becomes the blueprint for everything built in Phase 3.",
  },
  {
    num: "02",
    phase: "Design",
    timing: "Weeks 1–2",
    title: "AI-generated designs + copy draft",
    body: "We use AI-assisted design to generate and refine your homepage and key practice area pages — desktop and mobile — based on your firm's positioning and the competitive landscape in your market. Simultaneously, we draft all page copy following MRPC guidelines and your brand voice. You review both in one consolidated feedback round to keep the project moving.",
  },
  {
    num: "03",
    phase: "Build",
    timing: "Weeks 2–7",
    title: "Full WordPress build + schema implementation",
    body: "Approved designs go into WordPress on our performance stack. We build every practice area page, attorney bio page, and intake form with conditional logic — and implement LegalService + Attorney schema markup on every relevant page. Internal linking is structured from day one, not retrofitted. You get a staging link to review progress weekly.",
  },
  {
    num: "04",
    phase: "Launch",
    timing: "Week 7–10",
    title: "Launch, GBP optimization + handoff",
    body: "We handle DNS cutover, 301 redirect mapping from your old URLs, and sitemap submission to Google Search Console. Your Google Business Profile is audited and fully optimized in the same window. You receive a plain-English handoff document, a video walkthrough, and a 30-day post-launch monitoring window where we resolve anything that surfaces.",
  },
];

const faqs = [
  {
    num: "01",
    category: "SEO",
    q: "How long does it take to rank on Google after the new site launches?",
    a: "For local searches in smaller Maryland markets like Frederick or Annapolis, firms typically see meaningful movement in 60–90 days post-launch. Competitive markets like Baltimore or Bethesda generally take 3–6 months for consistent first-page presence. Schema implementation and GBP optimization tend to produce the fastest early gains — Local Pack improvements often appear within 30–45 days. We set these expectations in writing during Discovery so there is no ambiguity.",
  },
  {
    num: "02",
    category: "Migration",
    q: "Will I lose my current Google rankings when the site migrates?",
    a: "Not if the migration is handled correctly. We map every existing URL to its new equivalent and implement 301 redirects before the DNS cutover. We submit updated sitemaps to Google Search Console immediately post-launch and monitor crawl errors during the 30-day post-launch window. Ranking dips during a clean migration are temporary and typically recover within 4–6 weeks. Migrations that lose rankings permanently are almost always missing redirect maps — we have never shipped a build without one.",
  },
  {
    num: "03",
    category: "Services",
    q: "Do you write the website copy or do I have to provide it?",
    a: "We write all copy as part of every project tier. You provide the raw material — your practice areas, notable case results you can ethically reference, attorney bios — via a structured questionnaire. We draft copy that is MRPC-compliant, keyword-targeted, and written in a voice that sounds like your firm rather than a legal directory listing. You review one draft and provide factual corrections. We handle the rest.",
  },
  {
    num: "04",
    category: "Platform",
    q: "What makes a law firm website different from a standard business site?",
    a: "Three things: schema requirements, compliance constraints, and conversion architecture. Law firm pages require LegalService and Attorney structured data that general business sites don't need. Attorney advertising in Maryland is governed by MRPC Rules 7.1 through 7.5 — rules most generalist agencies are unaware of. And the conversion goal is a qualified intake submission, not a generic form fill, which requires a different form structure and page hierarchy than a retail or service business site.",
  },
  {
    num: "05",
    category: "Care Plans",
    q: "What happens after the site launches — do you offer ongoing support?",
    a: "Yes. Our care plans start at $150/month and cover WordPress core and plugin updates, weekly backups, uptime monitoring, and priority support with a 4-business-hour response window. We also offer a content add-on that includes one new practice area page or city landing page per month, which compounds your SEO footprint over time. Care plans are month-to-month — no annual contract required.",
  },
  {
    num: "06",
    category: "SEO",
    q: "Can you guarantee we will rank #1 on Google?",
    a: "No, and any agency that makes that guarantee is lying to you. What we do guarantee is that your site launches with green Core Web Vitals scores, fully implemented LegalService schema, a properly optimized Google Business Profile, and a sound on-page SEO foundation — the controllable inputs that give you the best chance to rank. We also provide a 90-day keyword tracking report so you can see exactly where movement is happening.",
  },
];

const faqCategoryColors = {
  "SEO":        { bg: "rgba(92,128,64,0.09)",   text: "#4a7a28",           border: "rgba(92,128,64,0.2)" },
  "Migration":  { bg: "rgba(160,100,200,0.08)", text: "#7a40b0",           border: "rgba(160,100,200,0.2)" },
  "Services":   { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
  "Platform":   { bg: "rgba(15,20,25,0.06)",    text: "var(--ink-muted)",  border: "rgba(15,20,25,0.12)" },
  "Care Plans": { bg: "rgba(212,147,46,0.1)",   text: "var(--amber-deep)", border: "rgba(212,147,46,0.25)" },
};

const tiers = [
  {
    name: "Starter",
    price: "$1,500–$3,500",
    timeline: "4–6 weeks",
    popular: false,
    dark: false,
    features: [
      "Up to 6 pages: Home, About, 2 practice areas, Contact, Thank You",
      "LegalService JSON-LD schema on all pages",
      "MRPC-compliant copy written by our team",
      "Mobile-first build · Core Web Vitals green on delivery",
      "Multi-step intake form with email notifications",
      "Google Search Console + Analytics 4 setup and verified",
      "30 days post-launch support window",
    ],
    cta: "Get a quote",
  },
  {
    name: "Growth",
    price: "$3,500–$6,000",
    timeline: "6–8 weeks",
    popular: true,
    dark: false,
    features: [
      "Up to 14 pages · 6 targeted practice area pages + attorney bios",
      "LegalService + Attorney JSON-LD schema, jurisdiction-mapped",
      "MRPC-compliant copy for all pages with one revision round",
      "Multi-step conditional intake form with CRM or email integration",
      "Google Business Profile audit + full Local Pack optimization",
      "City landing pages for up to 3 Maryland markets",
      "60 days post-launch monitoring with monthly performance report",
    ],
    cta: "Book discovery call",
  },
  {
    name: "Custom",
    price: "$6,000–$10,000+",
    timeline: "8–10 weeks",
    popular: false,
    dark: true,
    features: [
      "Unlimited pages · full practice area library + attorney roster",
      "Multi-location schema + GBP optimization for up to 5 offices",
      "Custom intake routing with case-type and urgency logic",
      "ACF Pro attorney directory with search and filter",
      "Full content migration with 301 redirect mapping from old site",
      "Quarterly SEO performance reviews for 12 months post-launch",
      "90 days post-launch support + first month of care plan included",
    ],
    cta: "Start a conversation",
  },
];
---
<BaseLayout
  title="Law Firm Website Design Maryland | Upcoming Brand"
  description="WordPress website design for Maryland law firms. Practice area pages, intake forms, LegalService schema, 90+ PageSpeed. Fixed-scope pricing from $1,500. Baltimore, Annapolis, Frederick."
  canonicalUrl="https://upcomingbrand.com/industries/law-firm-website-design/"
>
  <Navigation />

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="lfh-hero">

    <div class="container">
      <nav class="lfh-breadcrumb mono-xs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#industries">Industries</a>
        <span aria-hidden="true">/</span>
        <span>Law Firm Website Design</span>
      </nav>
    </div>

    <div class="container lfh-wrap">

      <!-- LEFT COLUMN -->
      <div class="lfh-left">

        <div class="lfh-tags">
          <span class="lfh-pill">
            <span class="lfh-dot" aria-hidden="true"></span>
            Law Firm Web Design &middot; Maryland
          </span>
          <span class="lfh-hero-sep" aria-hidden="true">&mdash;</span>
          <span class="lfh-hero-eyebrow">A specialist studio, not a template shop</span>
        </div>

        <h1 class="lfh-h1">
          <span class="lfh-h1-line">Maryland law firm websites</span>
          <span class="lfh-h1-line lfh-h1-accent-line"><em class="lfh-h1-accent">built to rank, convert,</em></span>
          <span class="lfh-h1-line lfh-h1-italic">and win cases.</span>
        </h1>

        <p class="lfh-lede">
          Most law firm websites lose clients before the first phone call — slow load times, missing schema, and copy that violates bar rules. We build WordPress sites for Maryland attorneys that pass Core Web Vitals, rank in the Local Pack, and turn visitors into signed clients. Fixed-scope from <strong>$1,500</strong>.
        </p>

        <div class="lfh-ctas">
          <a href="#contact" class="lfh-btn-primary">
            Book a discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#pricing" class="lfh-btn-ghost">
            See pricing
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="lfh-trust">
          <span class="lfh-trust-item">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Maryland-based studio
          </span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">LegalService schema on every build</span>
          <span class="lfh-trust-dot" aria-hidden="true"></span>
          <span class="lfh-trust-item">Fixed-scope pricing &middot; no surprises</span>
        </div>

      </div>

      <!-- RIGHT COLUMN — FORM -->
      <div class="lfh-right">
        <div class="lfh-form-card">
          <div class="lfh-form-header">
            <p class="lfh-form-eyebrow">Free site audit</p>
            <h2 class="lfh-form-title">Is your website costing you clients?</h2>
            <p class="lfh-form-sub">We review your current site and send a plain-English audit within 2 business days — no sales call required.</p>
          </div>

          <form class="lfh-form" name="lf-inquiry" netlify-honeypot="bot-field" data-netlify="true" action="/thank-you/">
            <input type="hidden" name="form-name" value="lf-inquiry" />
            <div style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
              <label>Leave blank: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-name">Your name</label>
              <input class="lfh-form-input" type="text" id="lf-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-email">Email address</label>
              <input class="lfh-form-input" type="email" id="lf-email" name="email" placeholder="jane@smithlaw.com" required autocomplete="email" />
            </div>

            <div class="lfh-form-row">
              <label class="lfh-form-label" for="lf-firm">Law firm name</label>
              <input class="lfh-form-input" type="text" id="lf-firm" name="firm" placeholder="Smith &amp; Associates" autocomplete="organization" />
            </div>

            <div class="lfh-form-row">
              <span class="lfh-form-label" id="lbl-practice">Primary practice area</span>
              <div class="lf-cs-wrap" role="combobox" aria-expanded="false" aria-labelledby="lbl-practice" data-name="practice_area">
                <button type="button" class="lf-cs-trigger" aria-haspopup="listbox">
                  <span class="lf-cs-val">Select practice area</span>
                  <svg class="lf-cs-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <ul class="lf-cs-list" role="listbox" aria-label="Practice area">
                  <li class="lf-cs-opt" role="option" data-value="Personal Injury">Personal Injury</li>
                  <li class="lf-cs-opt" role="option" data-value="Family Law">Family Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Criminal Defense">Criminal Defense</li>
                  <li class="lf-cs-opt" role="option" data-value="Estate Planning">Estate Planning</li>
                  <li class="lf-cs-opt" role="option" data-value="Business Law">Business Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Real Estate Law">Real Estate Law</li>
                  <li class="lf-cs-opt" role="option" data-value="Immigration">Immigration</li>
                  <li class="lf-cs-opt" role="option" data-value="Other / Multiple">Other / Multiple</li>
                </ul>
                <input type="hidden" name="practice_area" class="lf-cs-hidden" />
              </div>
            </div>

            <button type="submit" class="lfh-submit">
              Get a free quote
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="lfh-form-note">No commitment required &middot; Fixed-scope quotes only</p>
          </form>
        </div>
      </div>

    </div>

    <!-- STATS STRIP -->
    <div class="container">
      <div class="lfh-stats" role="list" aria-label="Key results">
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">44<span class="lfh-amb">%</span></div>
          <div class="lfh-stat-lbl">of attorney sites fail<br>Core Web Vitals</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">3.2<span class="lfh-amb">x</span></div>
          <div class="lfh-stat-lbl">More leads from sites<br>in the Local Pack</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">8<span class="lfh-amb">sec</span></div>
          <div class="lfh-stat-lbl">Avg load time we find<br>on attorney sites audited</div>
        </div>
        <div class="lfh-stat" role="listitem">
          <div class="lfh-stat-num">10<span class="lfh-amb">wks</span></div>
          <div class="lfh-stat-lbl">From first call<br>to ranked, live site</div>
        </div>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════════════
       PAIN POINTS
  ══════════════════════════════════════════════ -->
  <section class="lf-pain section-pad-sm">
    <div class="container">
      <div class="lf-pain-intro">
        <p class="eyebrow lf-eyebrow-dark">Why clients leave before calling</p>
        <h2 class="h2-section">Why most law firm websites fail Maryland attorneys</h2>
      </div>
      <div class="lf-pain-grid">
        {painPoints.map((p) => (
          <div class="lf-pain-card">
            <span class="lf-pain-icon" aria-hidden="true" set:html={p.icon} />
            <h3 class="lf-pain-title">{p.title}</h3>
            <p class="lf-pain-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FEATURES
  ══════════════════════════════════════════════ -->
  <section class="lf-features section-pad-sm">
    <div class="container">
      <div class="lf-features-intro">
        <p class="eyebrow lf-eyebrow-dark">What we build into every site</p>
        <h2 class="h2-section">Six things every Maryland law firm website needs</h2>
        <p class="lead">A law firm site is not a brochure. It is intake infrastructure. Every element we build — from schema to forms to copy — is designed to do one job: turn a searching stranger into a signed client.</p>
      </div>
      <div class="lf-features-grid">
        {features.map((f) => (
          <div class="lf-feature-card">
            <div class="lf-fc-top">
              <span class="lf-fc-num mono-xs">{f.num}</span>
            </div>
            <h3 class="lf-fc-title">{f.title}</h3>
            <p class="lf-fc-body">{f.body}</p>
            <div class="lf-fc-tags">
              {f.tags.map((t) => <span class="lf-tag mono-xs">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CASE STUDY
  ══════════════════════════════════════════════ -->
  <section class="lf-case section-pad-sm">
    <div class="container">
      <div class="lf-case-inner">

        <div class="lf-case-content">
          <p class="eyebrow lf-eyebrow-dark">Client result &middot; Baltimore, MD</p>
          <h2 class="h2-section lf-case-h2">How Meridian Law Group went from page 3 to the Local Pack in 90 days</h2>
          <p class="lf-case-desc">
            Meridian Law Group, a three-attorney family law firm in Baltimore, came to us after spending 14 months and $18,000 with a national legal marketing agency that delivered a slow, generic site with no local schema and a contact form that broke on mobile. Within 90 days of launch, their numbers told a different story.
          </p>

          <div class="lf-case-results">
            <div class="lf-cr-item">
              <span class="lf-cr-val">+340%</span>
              <span class="lf-cr-label mono-xs">Increase in organic traffic</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">#1</span>
              <span class="lf-cr-label mono-xs">Local Pack &middot; "Baltimore divorce attorney"</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">1.3s</span>
              <span class="lf-cr-label mono-xs">Mobile load time (was 4.1s)</span>
            </div>
            <div class="lf-cr-item">
              <span class="lf-cr-val">22</span>
              <span class="lf-cr-label mono-xs">New consultations in first 60 days</span>
            </div>
          </div>

          <blockquote class="lf-case-quote">
            <p>"Before Upcoming Brand, we were invisible in search — our old site didn't even load correctly on my own phone. They rebuilt everything, wrote copy that actually sounds like us, and explained every decision without burying us in technical talk. Within three months we had more inbound consultation requests than we'd ever handled in a quarter. The intake form alone changed how our front desk operates."</p>
            <footer>
              <cite class="lf-cite-name">Maya Rodriguez</cite>
              <span class="lf-cite-role mono-xs">Managing Partner &middot; Meridian Law Group &middot; Baltimore, MD</span>
            </footer>
          </blockquote>
        </div>

        <div class="lf-case-visual">
          <img
            src="/work/meridian-law-group.png"
            alt="Meridian Law Group website redesign — Baltimore law firm"
            class="lf-case-img"
            width="600"
            height="420"
            loading="lazy"
            decoding="async"
          />
          <div class="lf-case-badge mono-xs">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
