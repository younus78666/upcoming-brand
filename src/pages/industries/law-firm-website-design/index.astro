  }

  /* ══════════════════════
     HERO (homepage-style)
  ══════════════════════ */
  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  .lfh-hero {
    padding-top: clamp(16px, 3vh, 40px);
    padding-bottom: 0;
    background: var(--cream-soft);
    overflow: hidden;
  }

  /* breadcrumb */
  .lfh-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-muted);
    font-size: 11px;
    padding-bottom: 16px;
  }
  .lfh-breadcrumb a {
    color: var(--ink-muted);
    transition: color var(--transition);
  }
  .lfh-breadcrumb a:hover { color: var(--amber); }

  /* two-column layout */
  .lfh-wrap {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: clamp(24px, 4vw, 64px);
    align-items: center;
    padding-bottom: clamp(28px, 4vh, 64px);
  }

  .lfh-left {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2.5vh, 28px);
  }

  /* pill badge */
  .lfh-tags { display: flex; align-items: center; gap: 12px; }
  .lfh-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .lfh-dot {
    width: 6px;
    height: 6px;
    background: var(--amber);
    border-radius: 50%;
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }
  .lfh-hero-sep {
    color: var(--line-strong);
    font-size: 13px;
  }
  .lfh-hero-eyebrow {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* h1 */
  .lfh-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, min(4.5vw, 6vh), 64px);
    line-height: 1.0;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
  }
  .lfh-h1-line { display: block; color: var(--ink); }
  .lfh-h1-accent-line { display: block; }
  .lfh-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
  }
  .lfh-h1-accent::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.05em;
    height: 0.1em;
    background: var(--amber);
    opacity: 0.5;
    border-radius: 2px;
  }
  .lfh-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  /* lede */
  .lfh-lede {
    font-size: clamp(14px, min(1.2vw, 2vh), 17px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0;
  }
  .lfh-lede strong { font-weight: 600; color: var(--ink); }

  /* cta buttons */
  .lfh-ctas { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .lfh-btn-primary,
  .lfh-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
