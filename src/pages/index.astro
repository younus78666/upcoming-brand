---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Navigation from '../components/Navigation.astro';
import ServiceHero from '../components/ServiceHero.astro';
import Marquee from '../components/Marquee.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Services from '../components/Services.astro';
import Metrics from '../components/Metrics.astro';
import TechStack from '../components/TechStack.astro';
import Work from '../components/Work.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Process from '../components/Process.astro';
import Industries from '../components/Industries.astro';
import Pricing from '../components/Pricing.astro';
import Locations from '../components/Locations.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import BlogPreview from '../components/BlogPreview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.upcomingbrand.com/#webpage",
      "url": "https://www.upcomingbrand.com/",
      "name": "WordPress Web Design Agency Maryland | Upcoming Brand",
      "description": "WordPress web design agency in Maryland. Fixed-scope WordPress sites built to rank in Google, win Local Pack placement, and convert. 90+ PageSpeed, 6-10 week delivery - web design near you across Baltimore, Annapolis, Frederick, Bethesda, and the DMV metro.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://www.upcomingbrand.com/#website" },
      "about": { "@id": "https://www.upcomingbrand.com/#organization" },
      "primaryImageOfPage": { "@id": "https://www.upcomingbrand.com/#logo" },
      "dateModified": "2026-05-30",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".svc-hero-lead"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.upcomingbrand.com/" }
        ]
      }
    },
    {
      "@type": ["ProfessionalService", "LocalBusiness"],
      "@id": "https://www.upcomingbrand.com/#service",
      "name": "Upcoming Brand - WordPress Web Design Maryland",
      "url": "https://www.upcomingbrand.com/",
      "description": "WordPress web design studio based in Maryland. Fixed-scope builds, 90+ PageSpeed, 6-10 week delivery. Serving Baltimore, Annapolis, Frederick, and all of Maryland.",
      "image": { "@id": "https://www.upcomingbrand.com/#logo" },
      "logo": { "@id": "https://www.upcomingbrand.com/#logo" },
      "priceRange": "$1,500-$15,000",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Credit Card, Bank Transfer",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "State", "name": "Maryland", "sameAs": "https://en.wikipedia.org/wiki/Maryland" },
        { "@type": "City", "name": "Baltimore", "sameAs": "https://en.wikipedia.org/wiki/Baltimore" },
        { "@type": "City", "name": "Annapolis", "sameAs": "https://en.wikipedia.org/wiki/Annapolis,_Maryland" },
        { "@type": "City", "name": "Frederick", "sameAs": "https://en.wikipedia.org/wiki/Frederick,_Maryland" },
        { "@type": "City", "name": "Bethesda", "sameAs": "https://en.wikipedia.org/wiki/Bethesda,_Maryland" },
        { "@type": "City", "name": "Rockville", "sameAs": "https://en.wikipedia.org/wiki/Rockville,_Maryland" },
        { "@type": "City", "name": "Silver Spring", "sameAs": "https://en.wikipedia.org/wiki/Silver_Spring,_Maryland" },
        { "@type": "City", "name": "Columbia", "sameAs": "https://en.wikipedia.org/wiki/Columbia,_Maryland" },
        { "@type": "City", "name": "Towson", "sameAs": "https://en.wikipedia.org/wiki/Towson,_Maryland" }
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "12",
        "bestRating": "5",
        "worstRating": "1"
      },
      "knowsAbout": [
        "Custom WordPress design with Elementor Pro",
        "WooCommerce development",
        "WordPress SEO and schema markup",
        "WordPress speed optimization and Core Web Vitals",
        "LCP INP CLS performance metrics",
        "WordPress migration from Wix Squarespace GoDaddy",
        "WordPress security hardening and malware recovery",
        "WordPress website maintenance and care plans",
        "Local Pack ranking and Google Business Profile optimisation",
        "LocalBusiness schema LegalService schema MedicalOrganization schema",
        "Mobile-first responsive web design",
        "Fixed-scope WordPress web design Maryland"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "WordPress Web Design Agency Services Maryland",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Starter WordPress Website", "serviceType": "WordPress Web Design" },
            "name": "Starter Tier",
            "description": "8-page custom WordPress build with LocalBusiness schema, custom design, and Core Web Vitals green on delivery.",
            "price": "1500",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Growth WordPress Website", "serviceType": "WordPress Web Design + Local SEO" },
            "name": "Growth Tier",
            "description": "15-20 page site with city landing pages, custom design, and full Local Pack optimization.",
            "price": "3500",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Custom WordPress Build", "serviceType": "WordPress + WooCommerce Development" },
            "name": "Custom Tier",
            "description": "WooCommerce, IDX integration, multi-location schema, or complex booking systems for established businesses.",
            "price": "6000",
            "priceCurrency": "USD"
          }
        ]
      },
      "provider": { "@id": "https://www.upcomingbrand.com/#organization" },
      "parentOrganization": { "@id": "https://www.upcomingbrand.com/#organization" }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.upcomingbrand.com/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "How much does a WordPress website cost in Maryland?", "acceptedAnswer": { "@type": "Answer", "text": "Most Maryland small business WordPress websites fall between $1,500 and $10,000. A straightforward 8-page site for a contractor or solo practitioner starts at $1,500 to $3,500. A 15 to 20 page site with custom design, SEO setup, and blog runs $3,500 to $6,000. Complex WooCommerce, booking, or IDX builds start at $6,000. Every quote is fixed-scope: one price, no hourly surprises." } },
        { "@type": "Question", "name": "How long does a WordPress project take from start to launch?", "acceptedAnswer": { "@type": "Answer", "text": "Starter sites (up to 8 pages) take 4 to 6 weeks. Growth sites (up to 20 pages with custom design) take 6 to 8 weeks. Custom builds take 8 to 10 weeks. Timeline depends most on how quickly you can review and provide feedback." } },
        { "@type": "Question", "name": "Will my site score 90+ on Google PageSpeed?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We commit to it in writing. Every site we launch targets a PageSpeed score of 90+ on both mobile and desktop, with LCP under 2.5s, INP under 200ms, and all three Core Web Vitals passing in Search Console." } },
        { "@type": "Question", "name": "Can you migrate my existing Wix or Squarespace site to WordPress?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, without losing your Google rankings. We build a complete 301 redirect map before any DNS changes, run a pre-launch ranking benchmark, and monitor Search Console for 30 days post-launch. Most migrations see no ranking loss and often see improvement within 60 days." } },
        { "@type": "Question", "name": "Do you work with law firms, dental practices, and regulated industries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Law firm, dental, and medical websites make up a significant part of our Maryland client base. We understand compliance considerations and the schema types (LegalService, Dentist, MedicalOrganization) that help these sites rank in competitive local searches and Google Maps results." } },
        { "@type": "Question", "name": "What is included in your monthly care plans?", "acceptedAnswer": { "@type": "Answer", "text": "Care plans start at $150/month and include weekly WordPress core and plugin updates, off-site backups to S3 or Google Drive, uptime monitoring, and a 4-hour SLA for support tickets. Higher-tier plans include content updates, SEO reporting, and quarterly strategy reviews." } },
        { "@type": "Question", "name": "Why WordPress instead of Webflow, Squarespace, or Wix?", "acceptedAnswer": { "@type": "Answer", "text": "WordPress is open source: you own your data, there is no platform lock-in, and no monthly SaaS fee. 43% of all websites run on WordPress. On Wix or Squarespace, you cannot add custom LocalBusiness, LegalService, or MedicalOrganization schema, which drives Local Pack rankings." } },
        { "@type": "Question", "name": "Why does a custom WordPress site rank better than a Wix or template site?", "acceptedAnswer": { "@type": "Answer", "text": "Three technical reasons. First, page builder templates and Wix sites average 3.8 to 4.2s LCP on mobile, above Google's 2.5s threshold. Second, template platforms do not support custom JSON-LD schema at the page-type level. Third, Wix and Squarespace use JavaScript-rendered content that Googlebot must render before indexing; server-rendered WordPress HTML is indexed immediately." } },
        { "@type": "Question", "name": "Do you guarantee specific Google rankings?", "acceptedAnswer": { "@type": "Answer", "text": "No ethical agency can guarantee rankings. We guarantee clean schema markup, Core Web Vitals in the green, proper internal linking, and a topical map built for your market. Clients on our SEO care plan see top-10 positions for 20 to 40 targeted keywords within 6 to 9 months." } },
        { "@type": "Question", "name": "What happens if I need changes after launch?", "acceptedAnswer": { "@type": "Answer", "text": "The first 30 days post-launch are covered at no extra cost. After that, care plan clients get unlimited small changes included. Larger additions are quoted as fixed-scope additions, the same as the original project." } },
        { "@type": "Question", "name": "Is there a payment plan or deposit structure?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All projects are split 50% upfront and 50% before launch. We do not charge hourly at any point in the project. Care plans are billed monthly with a 30-day cancel notice: no contracts, no minimum commitment." } }
      ]
    }
  ]
});
---
<BaseLayout
  title="WordPress Web Design Agency Maryland | Upcoming Brand"
  description="WordPress web design agency Maryland. 90+ PageSpeed, Core Web Vitals green, fixed-scope builds. Serving Baltimore, Annapolis, Frederick, and the DMV metro."
  canonicalUrl="https://www.upcomingbrand.com/"
  ogImageAlt="WordPress Web Design Agency Maryland — Upcoming Brand"
>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />
  <!-- Section 1: Announcement Bar -->
  <AnnouncementBar />

  <!-- Section 2: Navigation (sticky) -->
  <Navigation />

  <!-- Section 3: Hero -->
  <ServiceHero
    eyebrow='A studio, not a factory'
    pillText='WordPress Agency · Maryland'
    h1Lines={[
      { text: 'WordPress web design' },
      { text: 'agency services that rank,', type: 'accent' },
      { text: 'convert & keep working.', type: 'italic' },
    ]}
    lead={`Upcoming Brand is a <a href="/wordpress-agency/" style="color:inherit;text-decoration:underline;text-underline-offset:0.16em;text-decoration-color:rgba(212,147,46,0.55);"><strong>WordPress web design agency</strong></a> based in Maryland. We design and build custom WordPress websites for <strong>law firms, dental practices, real estate brokerages,</strong> and small businesses across Baltimore, Annapolis, Frederick, Bethesda, and the broader DMV metro. Sites that rank in Google, win Local Pack placement with Google Business Profile optimisation, and keep working long after launch. AI-assisted design workflow delivers custom Elementor layouts in days, client-reviewed on a live staging link throughout.`}
    formName='hero-inquiry'
    trustLines={['Top Rated · Upwork', '400+ projects · 90+ PageSpeed guaranteed', 'RankMath Pro · Elementor Pro · WooCommerce']}
    formSteps={[
      {
        title: 'Tell us who you are',
        subtitle: 'Just your name and email. 30 seconds.',
        fields: [
          { type: 'text',  name: 'name',  label: 'Your name',     placeholder: 'Jane Smith',       required: true, autocomplete: 'name' },
          { type: 'email', name: 'email', label: 'Email address', placeholder: 'jane@company.com', required: true, autocomplete: 'email' },
        ],
      },
      {
        title: 'About your business',
        subtitle: 'Company and what you do.',
        fields: [
          { type: 'text', name: 'company', label: 'Company or brand', placeholder: 'Smith & Co.', autocomplete: 'organization' },
          { type: 'select', name: 'business_type', label: 'Business type', required: true,
            options: ['Law Firm / Attorney', 'Dental / Medical', 'Real Estate', 'Restaurant / Hospitality', 'Contractor / Trades', 'Nonprofit / Church', 'Ecommerce / Retail', 'Small Business / Startup', 'Other'] },
        ],
      },
      {
        title: 'What you need',
        subtitle: 'Which service and your budget.',
        fields: [
          { type: 'select', name: 'service_interest', label: 'Service interested in', required: true,
            options: ['New WordPress site build', 'Redesign existing site', 'WooCommerce store', 'WordPress SEO services', 'Migration to WordPress', 'Care plan / maintenance', 'SEO audit', 'Not sure yet'] },
          { type: 'select', name: 'budget', label: 'Budget range', required: true,
            options: ['Under $1,500', '$1,500 to $3,500', '$3,500 to $6,000', '$6,000 to $15,000', '$15,000+', 'Not sure yet'] },
        ],
      },
      {
        title: 'Timeline + goal',
        subtitle: 'When you need it and what success looks like.',
        fields: [
          { type: 'select', name: 'timeline', label: 'Timeline', required: true,
            options: ['ASAP, within 4 weeks', 'Standard, 6 to 10 weeks', 'Flexible, 3+ months', 'Just exploring'] },
          { type: 'textarea', name: 'message', label: 'Project goal', placeholder: 'Three sentences. We will ask the rest in the reply.', required: true, rows: 2 },
        ],
      },
    ]}
  />

  <!-- Section 4: Marquee -->
  <Marquee />

  <!-- Section 5: Key Takeaways (AEO.1 — AI Overview citation block) -->
  <section class="kt-section" aria-label="Quick facts about Upcoming Brand">
    <div class="container">
      <div class="kt-layout">
        <div class="kt-image-col">
          <img
            src="/Portfolio/imgi_33_default.webp"
            alt="Real client WordPress website design by Upcoming Brand"
            loading="lazy"
            width="640"
            height="480"
            class="kt-img"
          />
        </div>
        <div class="kt-content-col">
          <p class="eyebrow kt-eyebrow">Quick facts</p>
          <h2 class="kt-heading">What does a custom WordPress website from a Maryland web design agency include?</h2>
          <ul class="kt-list" role="list">
            <li class="kt-item">
              <span class="kt-label">Cost</span>
              <span class="kt-value">$1,500 to $15,000, fixed-scope quotes, no hourly billing</span>
            </li>
            <li class="kt-item">
              <span class="kt-label">Timeline</span>
              <span class="kt-value">4 to 10 weeks from discovery call to live launch</span>
            </li>
            <li class="kt-item">
              <span class="kt-label">Performance</span>
              <span class="kt-value">Core Web Vitals green on delivery, LCP under 2.5s, INP under 200ms</span>
            </li>
            <li class="kt-item">
              <span class="kt-label">Coverage</span>
              <span class="kt-value">20+ Maryland cities: Baltimore, Annapolis, Frederick, Bethesda, Rockville, Silver Spring</span>
            </li>
            <li class="kt-item">
              <span class="kt-label">Care plans</span>
              <span class="kt-value">From $150/month — weekly updates, off-site backups, security monitoring, 4-hour SLA</span>
            </li>
          </ul>
          <p class="kt-footer-links">
            See full <a href="/pricing/" class="kt-link">WordPress web design pricing</a> or learn about our <a href="/services/local-seo-maryland/" class="kt-link">local SEO Maryland services</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: Before / After -->
  <BeforeAfter />

  <!-- Section 7: Services -->
  <Services />

  <!-- Section 8: Proof Metrics -->
  <Metrics />

  <!-- Section 9: Tech Stack -->
  <TechStack />

  <!-- Section 10: Featured Work -->
  <Work />

  <!-- Section 10.5: Portfolio Preview (real client projects) -->
  <PortfolioPreview />

  <!-- Section 11: Process -->
  <Process />

  <!-- Section 12: Industries -->
  <Industries />

  <!-- Section 13: Pricing -->
  <Pricing />

  <!-- Section 14: Locations -->
  <Locations />

  <!-- Section 15: Testimonials -->
  <Testimonials />

  <!-- Section 16: FAQ -->
  <FAQ />

  <!-- Section 17: Blog Preview -->
  <BlogPreview />

  <!-- Section 18: Final CTA -->
  <FinalCTA />

  <Footer />
</BaseLayout>

<style>
  /* ── KEY TAKEAWAYS — left / right layout ── */
  .kt-section {
    background: var(--ink);
    padding: clamp(56px, 8vw, 96px) 0;
  }

  .kt-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .kt-image-col {
    position: relative;
  }

  .kt-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    display: block;
    box-shadow: 0 24px 64px rgba(0,0,0,0.45);
  }

  .kt-content-col {
    display: flex;
    flex-direction: column;
  }

  .kt-eyebrow {
    color: var(--amber);
    margin-bottom: 12px;
  }

  .kt-heading {
    font-family: var(--f-display);
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin-bottom: 28px;
    line-height: 1.25;
  }

  .kt-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    overflow: hidden;
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
  }

  .kt-item {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-size: 14px;
    line-height: 1.5;
  }

  .kt-item:last-child {
    border-bottom: none;
  }

  .kt-label {
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
    min-width: 88px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .kt-value {
    color: rgba(244,239,230,0.82);
    line-height: 1.55;
  }

  .kt-footer-links {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .kt-link {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-color: rgba(212,147,46,0.4);
    transition: text-decoration-color 0.2s ease;
  }

  .kt-link:hover {
    text-decoration-color: var(--amber);
  }

  @media (max-width: 960px) {
    .kt-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .kt-image-col { order: 2; }
    .kt-content-col { order: 1; }
  }

  @media (max-width: 600px) {
    .kt-item {
      flex-direction: column;
      gap: 4px;
    }
    .kt-label {
      min-width: unset;
    }
  }
</style>
