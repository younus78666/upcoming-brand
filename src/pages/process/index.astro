---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import FinalCTA from '../../components/FinalCTA.astro';
const canonical = "https://upcomingbrand.com/process/";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Our Process | Upcoming Brand WordPress Studio",
      "description": "How Upcoming Brand runs WordPress projects. Six phases from discovery to post-launch monitoring. Fixed-scope, async-first, schema-led, with 90+ Lighthouse scores as a contractual deliverable.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-01",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".page-lead"]
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",    "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "About",   "item": "https://upcomingbrand.com/about/" },
          { "@type": "ListItem", "position": 3, "name": "Process", "item": canonical }
        ]
      }
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": "How a WordPress project moves through Upcoming Brand",
      "description": "The six-phase Upcoming Brand process from discovery to post-launch monitoring.",
      "totalTime": "P10W",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Discovery",                "text": "45-minute Zoom call to map your competitive set, schema needs, Local Pack gaps, and conversion architecture." },
        { "@type": "HowToStep", "position": 2, "name": "Fixed-scope quote",        "text": "Within 48 hours we send a PDF quote with the full scope, milestones, deliverables, and one fixed price." },
        { "@type": "HowToStep", "position": 3, "name": "Design rounds",            "text": "Async design reviews on a private staging URL. Two structured rounds, comment-thread feedback, no surprise check-ins." },
        { "@type": "HowToStep", "position": 4, "name": "Build and schema",         "text": "Custom WordPress build with vertical-specific schema mapped first, then blocks, integrations, and content imported." },
        { "@type": "HowToStep", "position": 5, "name": "Launch",                   "text": "Pre-launch performance audit, 301 redirect map, zero-downtime DNS cutover, and post-launch verification." },
        { "@type": "HowToStep", "position": 6, "name": "30-day monitoring",        "text": "Search Console watch, ranking baseline, Core Web Vitals checks, and a written launch report at day 30." }
      ]
    }
  ]
});

const phases = [
  {
    num: "01",
    title: "Discovery",
    duration: "45 min",
    cost: "Free",
    summary: "A focused conversation about what you actually need — not a sales call disguised as one.",
    deliverables: [
      "Competitive set audit (top 5 SERP results)",
      "Schema map for your vertical (LocalBusiness, FAQ, Service, vertical-specific types)",
      "Local Pack gap analysis (city + service combinations)",
      "Conversion architecture review of your current site",
    ],
    you: "Show up. Talk about the business honestly.",
    us: "Listen. Document. Send a written summary within 24 hours.",
  },
  {
    num: "02",
    title: "Fixed-scope quote",
    duration: "48 hours",
    cost: "Quote attached",
    summary: "One PDF. One price. Every milestone, deliverable, and dependency mapped before we start.",
    deliverables: [
      "Full project scope document with deliverables per milestone",
      "One fixed price — no hourly billing, no scope-creep retainers",
      "Timeline with explicit review windows",
      "Care plan options scoped from day one",
    ],
    you: "Read the quote. Ask anything. Sign or walk away.",
    us: "Hold the price for 30 days. No upsells.",
  },
  {
    num: "03",
    title: "Design rounds",
    duration: "1-2 weeks",
    cost: "Two rounds included",
    summary: "Async design reviews on a private staging URL. Comment threads beat conference calls every time.",
    deliverables: [
      "Wireframe and design system on staging URL within 5 days",
      "Two structured review rounds with comment-thread feedback",
      "Mobile + desktop reviews per page",
      "Final approval gate before development begins",
    ],
    you: "Click around. Leave comments. Approve or request specific changes.",
    us: "Reply within 4 business hours. Iterate visibly on staging.",
  },
  {
    num: "04",
    title: "Build &amp; schema",
    duration: "3-6 weeks",
    cost: "Tier-dependent",
    summary: "Schema goes in first, then blocks, integrations, and content. Performance is monitored from week one.",
    deliverables: [
      "Vertical-specific schema (LocalBusiness, LegalService, Dentist, etc.) mapped to every page",
      "Custom WordPress blocks built for your specific content patterns",
      "WooCommerce / IDX / booking integrations as scoped",
      "Weekly written status update with staging URL preview",
    ],
    you: "Review weekly progress. Provide content as the build map directs.",
    us: "Build. Test. Audit performance every week of the build.",
  },
  {
    num: "05",
    title: "Launch",
    duration: "1 week",
    cost: "Included",
    summary: "Performance audit, redirect map, DNS cutover, post-launch verification. No surprises on launch day.",
    deliverables: [
      "Pre-launch performance audit with 90+ Lighthouse on every page",
      "Complete 301 redirect map from old URLs",
      "Zero-downtime DNS cutover scheduled in your timezone",
      "Post-launch verification report (forms, schema, tracking, sitemap)",
    ],
    you: "Approve the cutover window. Test the live site.",
    us: "Watch the cutover live. Fix any anomaly within hours.",
  },
  {
    num: "06",
    title: "30-day monitoring",
    duration: "30 days",
    cost: "Included on every project",
    summary: "Search Console watch, ranking baseline, Core Web Vitals checks. A written report at day 30.",
    deliverables: [
      "Daily Search Console index status checks for first 7 days",
      "Weekly ranking + impression baselines for target keywords",
      "Core Web Vitals field data tracking",
      "Day-30 launch report with next-90-day recommendations",
    ],
    you: "Read the report. Ask about anything you don't understand.",
    us: "Catch any post-launch issue before it costs you traffic.",
  },
];

const guarantees = [
  { num: "90+", label: "Lighthouse score on every page", note: "Or we don't invoice the final milestone" },
  { num: "48h", label: "Quote turnaround after discovery", note: "Held at quoted price for 30 days" },
  { num: "4h",  label: "Reply SLA on care-plan tickets",  note: "Direct to the founder, not a queue" },
  { num: "0",   label: "Hourly billing on any project",   note: "Fixed-scope or we don't take it" },
];

const faqs = [
  {
    q: "What happens before discovery?",
    a: "You fill out a short intake form on the contact page or send a brief email. We respond within 4 business hours and either propose a discovery time or, if your project isn't a fit, point you toward a studio that's better suited. We turn down about 1 in 4 inquiries — usually because the timeline is unrealistic for the scope or the brief asks us to violate one of our four operating principles."
  },
  {
    q: "How do design rounds actually work without meetings?",
    a: "We post a private staging URL. You click around, leave comments directly on the design (we use a tool that lets you comment on specific elements), and submit your feedback whenever it's convenient. We respond within 4 business hours during business days. Most clients tell us this is faster than the typical 'schedule a 60-minute call to walk through changes' dance — and it leaves a written record neither side has to remember."
  },
  {
    q: "What if I want changes after design approval?",
    a: "Small content tweaks during build are part of the project. Larger design changes after final approval are scoped as a change order with a fixed price you approve before work resumes. We don't quietly absorb scope changes and then surface a 'we ran over' surprise at the end. Every change is visible, scoped, and signed off in writing."
  },
  {
    q: "Do you handle hosting and DNS?",
    a: "We don't host, but we have three hosts we recommend (one budget, one mid-tier, one enterprise) and we handle the entire setup, migration, and DNS cutover for you. You own the hosting account so you keep control. Care plans cover server-level monitoring and backups regardless of which host you choose."
  },
  {
    q: "What if the site doesn't perform after launch?",
    a: "If the site ships below 90 Lighthouse, we don't invoice the final launch milestone until it's green. If rankings drop in the 30-day window because of a technical issue we caused, we fix it under the original scope. If rankings move because Google's algorithm shifted, we send a written analysis with recommendations — that's separate work but we explain it before billing for it."
  },
  {
    q: "Can we hire you for an audit only?",
    a: "Yes. Audit-only engagements are scoped at $1,500 and include a full Lighthouse + schema + Core Web Vitals + Local Pack analysis, with a prioritised action list you can take to any developer. We'll quote a build separately if you decide to come back, with the audit fee credited toward the build."
  },
];
---
<BaseLayout
  title="Our Process | Upcoming Brand WordPress Studio Maryland"
  description="How Upcoming Brand runs WordPress projects. Six phases from discovery to post-launch monitoring. Fixed-scope, schema-led, async-first, 90+ Lighthouse."
  canonicalUrl={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">Our process</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1">
          <span class="page-h1-line">Six phases.</span>
          <span class="page-h1-line"><em class="page-h1-accent">One fixed price.</em></span>
          <span class="page-h1-line page-h1-italic">Zero scope-creep surprises.</span>
        </h1>

        <p class="page-lead">
          Every Upcoming Brand WordPress project moves through the same six phases — <strong>Discovery, Quote, Design, Build, Launch, and 30-day Monitoring</strong>. Async by default. Schema-led. Lighthouse 90+ on every page or we don't invoice the final milestone.
        </p>

        <div class="page-hero-ctas">
          <a href="/contact/" class="lp-btn-primary">
            Book the discovery call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="lp-btn-ghost">
            View pricing
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="page-hero-trust">
          <span class="page-trust-line">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5.5" stroke="currentColor" stroke-opacity="0.35"/><path d="M3.5 6l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            6-10 week delivery
          </span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">90+ Lighthouse guarantee</span>
          <span class="page-trust-dot" aria-hidden="true"></span>
          <span class="page-trust-line">Async &middot; Zoom + staging URL</span>
        </div>
      </div>
    </section>

    <!-- ====== TIMELINE STRIP ====== -->
    <section class="proc-timeline">
      <div class="container">
        <div class="proc-timeline-head">
          <span class="proc-timeline-label">Project timeline</span>
          <span class="proc-timeline-total">6-10 weeks total</span>
        </div>
        <div class="proc-timeline-bar">
          {phases.map((p, i) => (
            <a href={`#phase-${p.num}`} class="proc-timeline-step" style={`--step-i: ${i}`}>
              <span class="proc-timeline-dot" aria-hidden="true"></span>
              <span class="proc-timeline-step-num">{p.num}</span>
              <span class="proc-timeline-step-name">{p.title}</span>
              <span class="proc-timeline-step-dur">{p.duration}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== PHASES ====== -->
    {phases.map((p, idx) => (
      <section class={`proc-phase ${idx % 2 === 0 ? 'proc-phase-light' : 'proc-phase-dim'}`} id={`phase-${p.num}`}>
        <div class="container">
          <div class="proc-phase-grid">

            <!-- Left: meta column -->
            <div class="proc-phase-meta">
              <div class="proc-phase-num-block">
                <span class="proc-phase-num">{p.num}</span>
                <span class="proc-phase-of">/ 06</span>
              </div>
              <div class="proc-phase-meta-card">
                <div class="proc-phase-meta-row">
                  <span class="proc-phase-meta-label">Duration</span>
                  <span class="proc-phase-meta-val">{p.duration}</span>
                </div>
                <div class="proc-phase-meta-divider" aria-hidden="true"></div>
                <div class="proc-phase-meta-row">
                  <span class="proc-phase-meta-label">Cost</span>
                  <span class="proc-phase-meta-val">{p.cost}</span>
                </div>
                <div class="proc-phase-meta-divider" aria-hidden="true"></div>
                <div class="proc-phase-meta-row">
                  <span class="proc-phase-meta-label">Phase</span>
                  <span class="proc-phase-meta-val">{p.num} of 06</span>
                </div>
              </div>
            </div>

            <!-- Right: content column -->
            <div class="proc-phase-content">
              <div class="proc-phase-eyebrow-row">
                <span class="proc-phase-eyebrow">Phase {p.num}</span>
                <span class="proc-phase-pill">{p.duration}</span>
              </div>
              <h2 class="page-h2 proc-phase-h2">
                {p.title}
              </h2>
              <p class="proc-phase-summary">{p.summary}</p>

              <div class="proc-phase-deliverables">
                <span class="proc-phase-deliverables-label">Deliverables</span>
                <ul class="proc-phase-deliverables-list">
                  {p.deliverables.map((d) => (
                    <li>
                      <span class="proc-phase-check" aria-hidden="true">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2.5 5.5l2 2 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                      <span set:html={d}></span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="proc-phase-roles">
                <div class="proc-phase-role">
                  <span class="proc-phase-role-label">You</span>
                  <p class="proc-phase-role-text">{p.you}</p>
                </div>
                <div class="proc-phase-role-divider" aria-hidden="true"></div>
                <div class="proc-phase-role proc-phase-role-us">
                  <span class="proc-phase-role-label">Us</span>
                  <p class="proc-phase-role-text">{p.us}</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    ))}

    <!-- ====== GUARANTEES BAND ====== -->
    <section class="proc-guarantees">
      <div class="container">
        <div class="proc-guarantees-head">
          <div class="page-eyebrow-strip">
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
            <span class="page-eyebrow-text page-eyebrow-text-light">Guaranteed in writing</span>
            <span class="page-eyebrow-line page-eyebrow-line-light"></span>
          </div>
          <h2 class="page-h2 proc-guarantees-h2">
            Four numbers <em>we put on every contract.</em>
          </h2>
        </div>

        <div class="proc-guarantees-grid">
          {guarantees.map((g) => (
            <div class="proc-guarantee-card">
              <span class="proc-guarantee-num">{g.num}</span>
              <span class="proc-guarantee-label">{g.label}</span>
              <span class="proc-guarantee-note">{g.note}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FAQ ====== -->
    <section class="proc-faq">
      <div class="container">
        <div class="proc-faq-head">
          <div class="page-eyebrow-strip page-eyebrow-strip-left">
            <span class="page-eyebrow-line"></span>
            <span class="page-eyebrow-text">Process FAQ</span>
          </div>
          <h2 class="page-h2">
            What clients <em>actually ask.</em>
          </h2>
          <p class="page-section-lead">Six questions that come up in nearly every discovery call. If yours isn't here, mention it on the call — we'll add it to the list.</p>
        </div>

        <div class="proc-faq-list">
          {faqs.map((f, i) => (
            <details class="proc-faq-item">
              <summary class="proc-faq-q">
                <span class="proc-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="proc-faq-q-text">{f.q}</span>
                <span class="proc-faq-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <p class="proc-faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
</main>

<FinalCTA />
<Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE SYSTEM
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(56px, 8vh, 96px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }

  .page-eyebrow-strip-left { justify-content: flex-start; }

  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .page-eyebrow-line-light { background: rgba(212,147,46,0.5); }
  .page-eyebrow-line-amber { background: var(--amber); }

  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }

  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }

  .page-h1-line { display: block; color: var(--ink); }

  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }

  .page-h1-accent::after { display: none; }

  .page-h1-italic {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }

  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .lp-btn-primary,
  .lp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
  }
  .lp-btn-primary {
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--line-strong);
  }
  .lp-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg,
  .lp-btn-ghost svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }
  .lp-btn-ghost:hover svg { transform: translate(2px, -2px); }

  .page-hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .page-trust-line {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .page-trust-dot {
    width: 3px; height: 3px;
    background: var(--ink-muted);
    border-radius: 50%;
    opacity: 0.4;
  }

  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 16px 0 0;
  }

  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .page-section-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 16px 0 0;
  }

  /* ===========================================
     TIMELINE STRIP
     =========================================== */
  .proc-timeline {
    background: var(--ink);
    color: var(--cream);
    padding: 28px 0;
    position: relative;
    overflow: hidden;
  }

  .proc-timeline::before {
    content: "";
    position: absolute;
    top: 0; left: 50%;
    width: 80%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,147,46,0.5), transparent);
    transform: translateX(-50%);
  }

  .proc-timeline-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .proc-timeline-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244,239,230,0.55);
  }

  .proc-timeline-total {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
