---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

import FinalCTA from '../../components/FinalCTA.astro';
const canonical = "https://upcomingbrand.com/accessibility/";
const lastUpdated = "May 2, 2026";
const lastAudited = "April 2026";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": "Accessibility Statement | Upcoming Brand",
      "description": "Upcoming Brand's accessibility commitment, conformance status, what we've done on this site, known limitations, and how to report accessibility issues. WCAG 2.1 AA target.",
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://upcomingbrand.com/#website" },
      "about": { "@id": "https://upcomingbrand.com/#organization" },
      "dateModified": "2026-05-02",
      "datePublished": "2024-01-01",
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "h2"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",          "item": "https://upcomingbrand.com/" },
          { "@type": "ListItem", "position": 2, "name": "Accessibility", "item": canonical }
        ]
      }
    }
  ]
});

const sections = [
  { id: "summary",       title: "Plain-language summary" },
  { id: "commitment",    title: "Our commitment" },
  { id: "conformance",   title: "Conformance status" },
  { id: "implemented",   title: "What we've implemented" },
  { id: "compatibility", title: "Browser & assistive tech" },
  { id: "limitations",   title: "Known limitations" },
  { id: "client-sites",  title: "Accessibility on client projects" },
  { id: "feedback",      title: "Feedback & reporting" },
  { id: "alternatives",  title: "Alternative formats" },
  { id: "review",        title: "Review schedule" },
  { id: "contact",       title: "Contact us" },
];

const implemented = [
  { area: "Semantic HTML",         detail: "Header, nav, main, section, article, footer landmarks on every page" },
  { area: "Heading hierarchy",     detail: "Single H1 per page, logical H2-H6 structure, no skipped levels" },
  { area: "Keyboard navigation",   detail: "Every interactive element reachable and operable via keyboard alone" },
  { area: "Focus indicators",      detail: "Visible 2px amber focus ring on all focusable elements, WCAG 2.4.7 compliant" },
  { area: "Skip-to-content link",  detail: "First focusable element on every page jumps to <main id=\"main-content\">" },
  { area: "Color contrast",        detail: "All text meets WCAG AA (4.5:1 body, 3:1 large text) measured against background" },
  { area: "Image alt text",        detail: "Descriptive alt on every meaningful image, empty alt on decorative images" },
  { area: "Form labels",           detail: "Every input has a visible label or aria-label, errors announced to screen readers" },
  { area: "ARIA where needed",     detail: "aria-label, aria-expanded, aria-current, role attributes used sparingly and correctly" },
  { area: "Reduced motion",        detail: "prefers-reduced-motion respected; animations disabled when user prefers" },
  { area: "Responsive zoom",       detail: "Layout works at 200% zoom without horizontal scroll or content loss" },
  { area: "Touch targets",         detail: "Minimum 44x44px on mobile per WCAG 2.5.5 Target Size" },
];

const compatibility = [
  { name: "Chrome",        version: "120+",  status: "Fully tested" },
  { name: "Firefox",       version: "118+",  status: "Fully tested" },
  { name: "Safari",        version: "17+",   status: "Fully tested" },
  { name: "Edge",          version: "120+",  status: "Fully tested" },
  { name: "Mobile Safari", version: "iOS 16+", status: "Fully tested" },
  { name: "Chrome Mobile", version: "120+",  status: "Fully tested" },
  { name: "VoiceOver",     version: "macOS / iOS", status: "Tested April 2026" },
  { name: "NVDA",          version: "2024.x", status: "Tested April 2026" },
  { name: "JAWS",          version: "2024",  status: "Spot-tested" },
];

const limitations = [
  {
    item: "Third-party embeds",
    detail: "Embedded forms, calendars, or video players from third-party services may not meet WCAG AA. We replace them with accessible alternatives where possible."
  },
  {
    item: "PDF downloads",
    detail: "Older PDF case studies and documents may not be fully tagged. We're remediating in priority order."
  },
  {
    item: "Decorative animations",
    detail: "Hero motion accents and pulse animations are decorative. We respect prefers-reduced-motion, but a few subtle effects continue to render and are kept at low intensity."
  },
];
---
<BaseLayout
  title="Accessibility Statement | Upcoming Brand WordPress Studio"
  description="Upcoming Brand's accessibility commitment, conformance status, what we've done on this site, known limitations, and how to report accessibility issues. WCAG 2.1 AA target."
  canonicalUrl={canonical}
  noindex
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <AnnouncementBar />
  <Navigation />

  <main id="main-content">

    <!-- ====== HERO ====== -->
    <section class="page-hero legal-hero">
      <div class="container page-hero-inner">
        <div class="page-eyebrow-strip">
          <span class="page-eyebrow-line"></span>
          <span class="page-eyebrow-text">Accessibility statement</span>
          <span class="page-eyebrow-line"></span>
        </div>

        <h1 class="page-h1 legal-h1">
          <span class="page-h1-line">Built to be used</span>
          <span class="page-h1-line"><em class="page-h1-accent">by everyone.</em></span>
        </h1>

        <p class="page-lead">
          Our commitment to accessibility, what we've implemented, what we haven't, and how to tell us when something doesn't work for you. Targeted at <strong>WCAG 2.1 AA</strong> with a path toward AAA on the parts that matter most.
        </p>

        <div class="legal-meta a11y-meta">
          <div class="legal-meta-item">
            <span class="legal-meta-label">Standard</span>
            <span class="legal-meta-val">WCAG 2.1 AA</span>
          </div>
          <div class="legal-meta-divider" aria-hidden="true"></div>
          <div class="legal-meta-item">
            <span class="legal-meta-label">Last audited</span>
            <span class="legal-meta-val">{lastAudited}</span>
          </div>
          <div class="legal-meta-divider" aria-hidden="true"></div>
          <div class="legal-meta-item">
            <span class="legal-meta-label">Conformance</span>
            <span class="legal-meta-val a11y-meta-conformance">
              <span class="a11y-conformance-dot" aria-hidden="true"></span>
              Partially conformant
            </span>
          </div>
          <div class="legal-meta-divider" aria-hidden="true"></div>
          <div class="legal-meta-item">
            <span class="legal-meta-label">Last updated</span>
            <span class="legal-meta-val">{lastUpdated}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== BODY ====== -->
    <section class="legal-body">
      <div class="container legal-body-grid">

        <aside class="legal-toc">
          <div class="legal-toc-inner">
            <span class="legal-toc-label">On this page</span>
            <nav aria-label="Accessibility statement sections">
              <ol class="legal-toc-list">
                {sections.map((s, i) => (
                  <li class="legal-toc-item">
                    <a href={`#${s.id}`} class="legal-toc-link">
                      <span class="legal-toc-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="legal-toc-text">{s.title}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
            <div class="legal-toc-footer">
              <a href="#feedback" class="legal-toc-cta">
                Report an issue
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1 5.5h9M6 1l4.5 4.5L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </aside>

        <article class="legal-content">

          <section id="summary" class="legal-section legal-section-callout">
            <span class="legal-section-num">01</span>
            <h2 class="legal-section-h2">Plain-language summary</h2>
            <div class="legal-section-body">
              <p>
                We design and build websites that work for everyone — including people who use screen readers, keyboards instead of mice, voice control, or assistive technology. <strong>This site targets WCAG 2.1 AA.</strong> If something isn't working for you, email us and we'll fix it within 5 business days. We never charge for accessibility fixes on our own work.
              </p>
            </div>
          </section>

          <section id="commitment" class="legal-section">
            <span class="legal-section-num">02</span>
            <h2 class="legal-section-h2">Our commitment</h2>
            <div class="legal-section-body">
              <p>
                Accessibility isn't a launch-day checklist for us. It's part of how we design and build, on every project. We commit to the following on this site and any work we deliver:
              </p>
              <ul class="legal-list">
                <li>Target WCAG 2.1 AA on every page we publish</li>
                <li>Test with keyboard navigation and screen readers before any launch</li>
                <li>Respond to accessibility issues within 5 business days</li>
                <li>Never charge for accessibility fixes on our own work</li>
                <li>Remediate older content (PDFs, embedded media) in priority order</li>
                <li>Re-audit the site once a year and after major redesigns</li>
              </ul>
            </div>
          </section>

          <section id="conformance" class="legal-section">
            <span class="legal-section-num">03</span>
            <h2 class="legal-section-h2">Conformance status</h2>
            <div class="legal-section-body">
              <p>
                The Web Content Accessibility Guidelines (WCAG) define requirements for designers and developers to improve accessibility for people with disabilities. WCAG defines three levels of conformance: A, AA, and AAA.
              </p>
              <p>
                <strong>upcomingbrand.com is partially conformant with WCAG 2.1 level AA.</strong> "Partially conformant" means that some parts of the content do not yet fully conform — see Known Limitations below for the specific items we're working on.
              </p>

              <div class="a11y-status-card">
                <div class="a11y-status-row">
                  <span class="a11y-status-label">Standard</span>
                  <span class="a11y-status-val">WCAG 2.1 AA</span>
                </div>
                <div class="a11y-status-row">
                  <span class="a11y-status-label">Status</span>
                  <span class="a11y-status-val a11y-status-partial">
                    <span class="a11y-conformance-dot" aria-hidden="true"></span>
                    Partially conformant
                  </span>
                </div>
                <div class="a11y-status-row">
                  <span class="a11y-status-label">Audit method</span>
                  <span class="a11y-status-val">Automated (axe DevTools, Lighthouse) + manual screen reader testing</span>
                </div>
                <div class="a11y-status-row">
                  <span class="a11y-status-label">Audited by</span>
                  <span class="a11y-status-val">Internal team, with external review every 12 months</span>
                </div>
              </div>
            </div>
          </section>

          <section id="implemented" class="legal-section">
            <span class="legal-section-num">04</span>
            <h2 class="legal-section-h2">What we've implemented</h2>
            <div class="legal-section-body">
              <p>The site is built on the following accessibility foundations:</p>

              <div class="a11y-implemented-grid">
                {implemented.map((item, i) => (
                  <div class="a11y-implemented-card">
                    <span class="a11y-implemented-num">{String(i + 1).padStart(2, '0')}</span>
                    <div class="a11y-implemented-content">
                      <h3 class="a11y-implemented-area">{item.area}</h3>
                      <p class="a11y-implemented-detail">{item.detail}</p>
                    </div>
                    <span class="a11y-implemented-check" aria-hidden="true">
                      <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M3 6.5l2.5 2.5L10 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="compatibility" class="legal-section">
            <span class="legal-section-num">05</span>
            <h2 class="legal-section-h2">Browser &amp; assistive technology</h2>
            <div class="legal-section-body">
              <p>The site is designed and tested with the following combinations:</p>

              <div class="legal-table-wrap">
                <table class="legal-table">
                  <thead>
                    <tr>
                      <th>Software</th>
                      <th>Version</th>
                      <th>Test status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {compatibility.map((c) => (
                      <tr>
                        <td>{c.name}</td>
                        <td>{c.version}</td>
                        <td>{c.status}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <p>
                If you use a different browser or assistive technology and run into problems, please report it — we'll add it to our test matrix.
              </p>
            </div>
          </section>

          <section id="limitations" class="legal-section">
            <span class="legal-section-num">06</span>
            <h2 class="legal-section-h2">Known limitations</h2>
            <div class="legal-section-body">
              <p>
                We're transparent about the parts of the site that don't yet meet our target. Here's what we're aware of and working on:
              </p>

              <div class="a11y-limitations-list">
                {limitations.map((l, i) => (
                  <div class="a11y-limitation">
                    <span class="a11y-limitation-num">{String(i + 1).padStart(2, '0')}</span>
                    <div class="a11y-limitation-content">
                      <h3 class="a11y-limitation-title">{l.item}</h3>
                      <p class="a11y-limitation-detail">{l.detail}</p>
                    </div>
                    <span class="a11y-limitation-badge">In progress</span>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="client-sites" class="legal-section">
            <span class="legal-section-num">07</span>
            <h2 class="legal-section-h2">Accessibility on client projects</h2>
            <div class="legal-section-body">
              <p>
                Every site we build for clients ships with the same accessibility baseline as upcomingbrand.com:
              </p>
              <ul class="legal-list">
                <li>Semantic HTML, landmark structure, logical heading hierarchy</li>
                <li>Keyboard navigation tested before launch</li>
                <li>Screen reader testing on at least one assistive technology</li>
                <li>Color contrast verified against the brand palette</li>
                <li>Focus indicators on every interactive element</li>
                <li>Form labels, error messaging, and ARIA where it actually helps</li>
                <li>Lighthouse Accessibility score of 95+ as a launch deliverable</li>
              </ul>
              <p>
                We don't sell "accessibility overlay" plugins or third-party widgets. Those products often <strong>create more problems than they solve</strong> and have been the subject of multiple lawsuits. Real accessibility is built into the markup, not bolted onto it.
              </p>
            </div>
          </section>

          <section id="feedback" class="legal-section legal-section-callout">
            <span class="legal-section-num">08</span>
            <h2 class="legal-section-h2">Feedback &amp; reporting</h2>
            <div class="legal-section-body">
              <p>
                If you experience an accessibility barrier on this site, or on any site we built, please tell us. We take every report seriously and respond within 5 business days.
              </p>

              <div class="a11y-feedback-card">
                <div class="a11y-feedback-row">
                  <span class="a11y-feedback-label">Email</span>
                  <a class="a11y-feedback-val" href="mailto:hello@upcomingbrand.com?subject=Accessibility%20Feedback">hello@upcomingbrand.com</a>
                </div>
                <div class="a11y-feedback-divider" aria-hidden="true"></div>
                <div class="a11y-feedback-row">
                  <span class="a11y-feedback-label">Subject line</span>
                  <span class="a11y-feedback-val">Accessibility: [page or feature]</span>
                </div>
                <div class="a11y-feedback-divider" aria-hidden="true"></div>
                <div class="a11y-feedback-row">
                  <span class="a11y-feedback-label">Response window</span>
                  <span class="a11y-feedback-val">Within 5 business days</span>
                </div>
                <div class="a11y-feedback-divider" aria-hidden="true"></div>
                <div class="a11y-feedback-row">
                  <span class="a11y-feedback-label">Helpful to include</span>
                  <span class="a11y-feedback-val">Page URL, browser/AT used, what didn't work</span>
                </div>
              </div>
            </div>
          </section>

          <section id="alternatives" class="legal-section">
            <span class="legal-section-num">09</span>
            <h2 class="legal-section-h2">Alternative formats</h2>
            <div class="legal-section-body">
              <p>
                If you need information from this site in a different format — large print, plain text, audio description, or any other accommodation — email <a href="mailto:hello@upcomingbrand.com">hello@upcomingbrand.com</a> and we'll provide it within 5 business days at no charge.
              </p>
            </div>
          </section>

          <section id="review" class="legal-section">
            <span class="legal-section-num">10</span>
            <h2 class="legal-section-h2">Review schedule</h2>
            <div class="legal-section-body">
              <p>
                This statement is reviewed and updated:
              </p>
              <ul class="legal-list">
                <li><strong>After every major redesign</strong> or significant content overhaul</li>
                <li><strong>At least once per year</strong>, regardless of changes</li>
                <li><strong>When new WCAG guidance is published</strong>, to align with the latest standards</li>
                <li><strong>When a reported issue surfaces a pattern</strong> that affects multiple parts of the site</li>
              </ul>
              <p>
                The "Last audited" and "Last updated" dates at the top of this page reflect the most recent review.
              </p>
            </div>
          </section>

          <section id="contact" class="legal-section legal-section-contact">
            <span class="legal-section-num">11</span>
            <h2 class="legal-section-h2">Contact us</h2>
            <div class="legal-section-body">
              <p>
                Beyond accessibility-specific feedback, you can reach us about anything related to this site or our work. We respond within 4 business hours during business days.
              </p>

              <div class="legal-contact-card">
                <div class="legal-contact-row">
                  <span class="legal-contact-label">Email</span>
                  <a class="legal-contact-val" href="mailto:hello@upcomingbrand.com">hello@upcomingbrand.com</a>
                </div>
                <div class="legal-contact-divider" aria-hidden="true"></div>
                <div class="legal-contact-row">
                  <span class="legal-contact-label">Response window</span>
                  <span class="legal-contact-val">4 business hours, weekdays</span>
                </div>
                <div class="legal-contact-divider" aria-hidden="true"></div>
                <div class="legal-contact-row">
                  <span class="legal-contact-label">Mailing</span>
                  <span class="legal-contact-val">Available on request via email</span>
                </div>
              </div>
            </div>
          </section>

        </article>
      </div>
    </section>

    <!-- ====== FINAL CTA ====== -->
</main>

<FinalCTA />
<Footer />
</BaseLayout>

<style>
  /* ===========================================
     SHARED PAGE / LEGAL SYSTEM (mirrored from privacy-policy)
     =========================================== */
  .page-hero {
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vh, 128px) 0 clamp(56px, 8vh, 96px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .page-hero::before {
    content: "";
    position: absolute;
    top: -300px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(212,147,46,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .page-eyebrow-strip {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  .page-eyebrow-line {
    display: inline-block;
    width: 48px; height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  .page-eyebrow-line-amber { background: var(--amber); }
  .page-eyebrow-text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    font-weight: 500;
    white-space: nowrap;
  }
  .page-eyebrow-text-light { color: rgba(244,239,230,0.7); }

  .page-h1 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(34px, 5.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    text-align: center;
  }
  .page-h1-line { display: block; color: var(--ink); }
  .page-h1-accent {
    font-style: inherit;
    position: relative;
    color: var(--ink);
    display: inline;
    text-decoration: underline;
    text-decoration-color: rgba(212, 147, 46, 0.55);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-skip-ink: none;
  }
  .page-h1-accent::after { display: none; }

  .page-lead {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 auto;
  }
  .page-lead strong { font-weight: 600; color: var(--ink); }

  .page-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 16px 0 0;
  }
  .page-h2 em {
    font-style: italic;
    font-weight: 300;
    color: var(--amber-deep);
  }

  .lp-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.22s ease;
    cursor: pointer;
    background: var(--ink);
    color: var(--cream);
    border: 1.5px solid var(--ink);
  }
  .lp-btn-primary:hover {
    background: var(--amber-deep);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }
  .lp-btn-primary svg { transition: transform 0.22s ease; flex-shrink: 0; }
  .lp-btn-primary:hover svg { transform: translateX(3px); }

  /* Legal hero meta */
  .legal-h1 { margin-bottom: 4px; }
  .legal-meta {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 14px 24px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    margin-top: 8px;
  }
  .legal-meta-item { display: flex; flex-direction: column; gap: 3px; }
  .legal-meta-label {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
  }
  .legal-meta-val {
    font-size: 13px;
    color: var(--ink);
    font-weight: 500;
  }
  .legal-meta-divider {
    width: 1px; height: 28px;
    background: var(--line);
  }

  /* A11y-specific: conformance pulse dot */
  .a11y-meta-conformance {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--amber-deep);
  }
  .a11y-conformance-dot {
    width: 7px;
    height: 7px;
