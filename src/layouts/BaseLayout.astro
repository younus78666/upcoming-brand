---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
}

const {
  title = "WordPress Web Design Services Maryland | Upcoming Brand",
  description = "WordPress web design services in Maryland. Fixed-scope builds, 6-10 week delivery, 90+ PageSpeed. Baltimore, Annapolis, Frederick. Book a 45-min discovery call.",
  ogImage = "https://upcomingbrand.com/og-image.jpg",
  ogImageAlt = "Upcoming Brand — WordPress Web Design Maryland",
  canonicalUrl = "https://upcomingbrand.com/",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FBF8F2" />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Upcoming Brand" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!-- Favicon — all devices -->
  <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
  <link rel="shortcut icon" type="image/jpeg" href="/favicon.jpg" />
  <link rel="apple-touch-icon" href="/favicon.jpg" />
  <meta name="msapplication-TileImage" content="/favicon.jpg" />
  <meta name="msapplication-TileColor" content="#0F1419" />

  <!-- reCAPTCHA v3 — replace YOUR_SITE_KEY once obtained from https://www.google.com/recaptcha/admin -->
  <!-- <script src="https://www.google.com/recaptcha/api.js?render=YOUR_SITE_KEY" async defer></script> -->

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,500&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Schema.org Root: Organization + WebSite (referenced by @id on every page) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://upcomingbrand.com/#organization",
        "name": "Upcoming Brand",
        "alternateName": "Upcoming Brand WordPress Web Design",
        "url": "https://upcomingbrand.com/",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://upcomingbrand.com/#logo",
          "url": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "contentUrl": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "width": 200,
          "height": 52,
          "caption": "Upcoming Brand"
        },
        "image": { "@id": "https://upcomingbrand.com/#logo" },
        "description": "WordPress web design studio based in Maryland. Fixed-scope builds, 90+ PageSpeed, 6-10 week delivery serving Baltimore, Annapolis, Frederick, and the DMV metro.",
        "foundingDate": "2024",
        "areaServed": {
          "@type": "State",
          "name": "Maryland",
          "sameAs": "https://en.wikipedia.org/wiki/Maryland"
        },
        "knowsAbout": [
          "WordPress web design",
          "WooCommerce development",
          "WordPress SEO",
          "Core Web Vitals optimization",
          "LocalBusiness schema",
          "WordPress care plans",
          "WordPress migration",
          "WordPress security"
        ],
        "slogan": "WordPress web design Maryland businesses trust for real Google rankings.",
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "MD",
          "addressCountry": "US"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "availableLanguage": "English",
          "areaServed": "US"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://upcomingbrand.com/#website",
        "url": "https://upcomingbrand.com/",
        "name": "Upcoming Brand",
        "description": "WordPress web design services Maryland - fixed-scope, 90+ PageSpeed, 6-10 week delivery.",
        "publisher": { "@id": "https://upcomingbrand.com/#organization" },
        "inLanguage": "en-US",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://upcomingbrand.com/?s={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  })} />
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
