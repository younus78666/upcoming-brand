---
import '../styles/global.css';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title = "WordPress Web Design Services Maryland | Upcoming Brand",
  description = "WordPress web design services in Maryland. Fixed-scope builds, 6-10 week delivery, 90+ PageSpeed. Baltimore, Annapolis, Frederick. Book a 45-min discovery call.",
  ogImage = "https://upcomingbrand.com/og-image.jpg",
  ogImageAlt = "Upcoming Brand — WordPress Web Design Maryland",
  canonicalUrl = "https://upcomingbrand.com/",
  noindex = false,
} = Astro.props;
const robotsContent = noindex ? "noindex, follow" : "index, follow";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q794J9JFE1"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-Q794J9JFE1');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FBF8F2" />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Upcoming Brand" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- Robots -->
  <meta name="robots" content={robotsContent} />

  <!-- Pinterest domain verification -->
  <meta name="p:domain_verify" content="1b73ae448872c7b7cb4f7292a66f0918" />

  <!-- Favicon — all devices -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="shortcut icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon.png" />
  <meta name="msapplication-TileImage" content="/favicon.png" />
  <meta name="msapplication-TileColor" content="#0F1419" />

  <!-- reCAPTCHA v2 (I'm not a robot) -->
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,500&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Schema.org Root: Organization + WebSite (referenced by @id on every page) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://upcomingbrand.com/#organization",
        "name": "Upcoming Brand",
        "alternateName": "Upcoming Brand WordPress Web Design",
        "url": "https://upcomingbrand.com/",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://upcomingbrand.com/#logo",
          "url": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "contentUrl": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "width": 200,
          "height": 52,
          "caption": "Upcoming Brand"
        },
        "image": { "@id": "https://upcomingbrand.com/#logo" },
        "description": "WordPress web design studio based in Maryland. Fixed-scope builds, 90+ PageSpeed, 6-10 week delivery serving Baltimore, Annapolis, Frederick, and the DMV metro.",
        "foundingDate": "2024",
        "areaServed": {
          "@type": "State",
          "name": "Maryland",
          "sameAs": "https://en.wikipedia.org/wiki/Maryland"
        },
        "knowsAbout": [
          "WordPress web design",
          "WooCommerce development",
          "WordPress SEO",
          "Core Web Vitals optimization",
          "LocalBusiness schema",
          "WordPress care plans",
          "WordPress migration",
          "WordPress security"
        ],
        "slogan": "WordPress web design Maryland businesses trust for real Google rankings.",
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "MD",
          "addressCountry": "US"
        },
        "telephone": "+1-240-209-2757",
        "email": "hello@upcomingbrand.com",
        "contactPoint": [
          {
            "@type": "ContactPoint",
            "@id": "https://upcomingbrand.com/#contactpoint-sales",
            "contactType": "sales",
            "telephone": "+1-240-209-2757",
            "email": "hello@upcomingbrand.com",
            "contactOption": ["TollFree"],
            "availableLanguage": "English",
            "areaServed": "US",
            "hoursAvailable": {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
              "opens": "09:00",
              "closes": "18:00"
            }
          },
          {
            "@type": "ContactPoint",
            "@id": "https://upcomingbrand.com/#contactpoint-support",
            "contactType": "customer support",
            "telephone": "+1-240-209-2757",
            "email": "hello@upcomingbrand.com",
            "availableLanguage": "English",
            "areaServed": "US"
          }
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://upcomingbrand.com/#website",
        "url": "https://upcomingbrand.com/",
        "name": "Upcoming Brand",
        "description": "WordPress web design services Maryland - fixed-scope, 90+ PageSpeed, 6-10 week delivery.",
        "publisher": { "@id": "https://upcomingbrand.com/#organization" },
        "inLanguage": "en-US",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://upcomingbrand.com/?s={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  })} />
  <slot name="head" />
</head>
<body>
  <slot />

  <!-- Exit-intent popup (sitewide, suppressed on /thank-you/ /contact/ /book-a-discovery-call/) -->
  <ExitIntentPopup />

  <!-- WhatsApp floating contact (left side) -->
  <a
    href="https://wa.me/12402092757?text=Hi%20Upcoming%20Brand%2C%20I%20have%20a%20project%20I%27d%20like%20to%20discuss."
    class="wa-fab"
    target="_blank"
    rel="noopener"
    aria-label="Chat with us on WhatsApp"
    title="Chat on WhatsApp · +1 (240) 209 2757"
  >
    <span class="wa-fab-icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M17.6 6.32A8 8 0 0 0 4.3 14.97L4 19.7l4.84-1.27A8 8 0 0 0 19.7 8.42a7.94 7.94 0 0 0-2.1-2.1Zm-5.6 12.18a6.65 6.65 0 0 1-3.4-.94l-.24-.14-2.87.75.77-2.8-.16-.25a6.66 6.66 0 1 1 5.9 3.38Zm3.65-4.99c-.2-.1-1.18-.58-1.36-.65-.18-.07-.32-.1-.45.1-.13.2-.51.65-.63.78-.12.13-.23.15-.43.05a5.46 5.46 0 0 1-1.61-1 6 6 0 0 1-1.11-1.38c-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.61-1.48-.16-.39-.32-.34-.45-.34h-.39c-.13 0-.34.05-.52.25s-.69.67-.69 1.64.71 1.91.81 2.04c.1.13 1.4 2.13 3.39 2.99.47.2.84.32 1.13.42.48.15.91.13 1.25.08.38-.06 1.18-.48 1.34-.94.17-.46.17-.86.12-.94-.05-.08-.18-.13-.38-.23Z" fill="currentColor"/>
      </svg>
    </span>
    <span class="wa-fab-tooltip">Chat on WhatsApp</span>
  </a>
  <style is:global>
    .wa-fab {
      position: fixed;
      left: clamp(16px, 3vw, 32px);
      bottom: clamp(16px, 3vw, 32px);
      width: 56px;
      height: 56px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--ink, #0F1419);
      color: var(--cream, #F4EFE6);
      border: 2px solid var(--amber, #D4932E);
      border-radius: 50%;
      box-shadow: 0 10px 30px rgba(15, 20, 25, 0.22), 0 0 0 0 rgba(212, 147, 46, 0.5);
      cursor: pointer;
      text-decoration: none;
      z-index: 60;
      transition: transform .25s ease, box-shadow .25s ease, background .25s ease, color .25s ease;
      animation: wa-pulse 2.4s infinite;
    }
    .wa-fab:hover {
      background: var(--amber, #D4932E);
      color: var(--ink, #0F1419);
      transform: scale(1.06);
      box-shadow: 0 14px 40px rgba(212, 147, 46, 0.32);
    }
    .wa-fab:focus-visible {
      outline: 2px solid var(--amber, #D4932E);
      outline-offset: 4px;
    }
    .wa-fab-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .wa-fab-tooltip {
      position: absolute;
      left: calc(100% + 12px);
      top: 50%;
      transform: translateY(-50%) translateX(-6px);
      background: var(--ink, #0F1419);
      color: var(--cream, #F4EFE6);
      font-family: var(--f-mono, 'JetBrains Mono', monospace);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 600;
      padding: 8px 12px;
      border-radius: 6px;
      border: 1px solid var(--amber, #D4932E);
      white-space: nowrap;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity .2s ease, transform .2s ease, visibility .2s ease;
    }
    .wa-fab-tooltip::before {
      content: "";
      position: absolute;
      left: -5px;
      top: 50%;
      transform: translateY(-50%) rotate(45deg);
      width: 8px;
      height: 8px;
      background: var(--ink, #0F1419);
      border-left: 1px solid var(--amber, #D4932E);
      border-bottom: 1px solid var(--amber, #D4932E);
    }
    .wa-fab:hover .wa-fab-tooltip,
    .wa-fab:focus-visible .wa-fab-tooltip {
      opacity: 1;
      visibility: visible;
      transform: translateY(-50%) translateX(0);
    }
    @keyframes wa-pulse {
      0%   { box-shadow: 0 10px 30px rgba(15,20,25,0.22), 0 0 0 0   rgba(212,147,46,0.45); }
      70%  { box-shadow: 0 10px 30px rgba(15,20,25,0.22), 0 0 0 16px rgba(212,147,46,0); }
      100% { box-shadow: 0 10px 30px rgba(15,20,25,0.22), 0 0 0 0   rgba(212,147,46,0); }
    }
    @media (max-width: 540px) {
      .wa-fab-tooltip { display: none; }
      .wa-fab { width: 52px; height: 52px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .wa-fab { animation: none; }
      .wa-fab:hover { transform: none; }
    }

    /* iOS Safari zoom-on-focus prevention: any input/textarea/select under 16px causes a zoom.
       Force 16px effective rendering on small screens without changing visual sizing on desktop. */
    @media (max-width: 640px) {
      input[type="text"], input[type="email"], input[type="tel"], input[type="url"],
      input[type="search"], input[type="number"], input[type="password"],
      textarea, select {
        font-size: max(16px, 1em) !important;
      }
    }

    /* Prevent horizontal overflow site-wide on mobile — defensive */
    @media (max-width: 640px) {
      html, body { overflow-x: hidden; max-width: 100vw; }
    }

    /* WhatsApp FAB on smallest screens — sit above iOS home indicator */
    .wa-fab { bottom: calc(clamp(16px, 3vw, 32px) + env(safe-area-inset-bottom, 0px)); }
    .back-to-top { bottom: calc(clamp(16px, 3vw, 32px) + env(safe-area-inset-bottom, 0px)); }

    /* reCAPTCHA containment — never let the 304px widget overflow its parent */
    .uc-recaptcha {
      max-width: 100%;
      overflow: hidden;
      display: flex;
      justify-content: center;
    }
    .uc-recaptcha > div,
    .uc-recaptcha iframe { max-width: 100% !important; }
    @media (max-width: 360px) {
      .uc-recaptcha {
        transform: scale(0.85);
        transform-origin: 0 0;
        width: 117.6%;
      }
    }
    /* Hidden by default on multistep — shown when step 3 is active */
    .ms-step .uc-recaptcha { display: none; }
    .ms-step.is-active .uc-recaptcha { display: flex; }
  </style>

  <!-- Back to top button -->
  <button
    type="button"
    id="back-to-top"
    class="back-to-top"
    aria-label="Back to top"
    title="Back to top"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 13V3M8 3L3 8M8 3l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <style is:global>
    .back-to-top {
      position: fixed;
      right: clamp(16px, 3vw, 32px);
      bottom: clamp(16px, 3vw, 32px);
      width: 44px;
      height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--ink, #1a1208);
      color: var(--cream, #fdf8ec);
      border: 1.5px solid var(--ink, #1a1208);
      border-radius: 50%;
      box-shadow: 0 8px 24px rgba(26, 18, 8, 0.18);
      cursor: pointer;
      opacity: 0;
      visibility: hidden;
      transform: translateY(8px);
      transition: opacity .25s ease, transform .25s ease, visibility .25s ease, background .2s ease, color .2s ease, border-color .2s ease;
      z-index: 60;
    }
    .back-to-top.is-visible {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .back-to-top:hover {
      background: var(--amber, #d4932e);
      color: var(--ink, #1a1208);
      border-color: var(--amber, #d4932e);
    }
    .back-to-top:focus-visible {
      outline: 2px solid var(--amber, #d4932e);
      outline-offset: 3px;
    }
    @media (prefers-reduced-motion: reduce) {
      .back-to-top { transition: opacity .15s ease, visibility .15s ease; transform: none; }
    }
  </style>
  <script is:inline>
    (function(){
      var btn = document.getElementById('back-to-top');
      if(!btn) return;
      var threshold = 400;
      function onScroll(){
        if(window.scrollY > threshold){ btn.classList.add('is-visible'); }
        else { btn.classList.remove('is-visible'); }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      btn.addEventListener('click', function(){
        var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
      });
    })();
  </script>

  <!-- Universal form handler: intercepts every <form data-uc-form="..." method="POST" novalidate> on the site -->
  <script is:inline>
  (function(){
    var SITE_KEY = '6LewrNcsAAAAAHUrAokdU5EqgK46ycH4JyFdNxI8';
    var ENDPOINT = '/api/contact';
    var BLOCKED_LANG_RE = /[Ѐ-ӿԀ-ԯ぀-ヿ㐀-䶿一-鿿가-힯豈-﫿]/;

    // Render reCAPTCHA explicitly via grecaptcha.render() so we control timing
    // (auto-render via .g-recaptcha class fires once on page load — no good for hidden / deferred forms).
    function renderCaptchaInto(holder){
      if(!holder || holder.dataset.ucCaptchaId) return; // already rendered
      if(window.grecaptcha && typeof window.grecaptcha.render === 'function'){
        try {
          var id = window.grecaptcha.render(holder, { sitekey: SITE_KEY });
          holder.dataset.ucCaptchaId = String(id);
        } catch(e){ /* already rendered or grecaptcha not ready */ }
      } else {
        // grecaptcha.js still loading — retry shortly
        setTimeout(function(){ renderCaptchaInto(holder); }, 200);
      }
    }

    function ensureRecaptcha(form){
      // If form opted into deferred captcha, the form's own script renders it (e.g. multistep on step 3)
      if(form.dataset.ucRecaptchaDefer === 'true') return;

      var holder = form.querySelector('.uc-recaptcha');
      if(!holder){
        holder = document.createElement('div');
        holder.className = 'uc-recaptcha';
        holder.style.margin = '14px 0 4px';
        var submit = form.querySelector('button[type="submit"], input[type="submit"]');
        if(submit && submit.parentNode){
          submit.parentNode.insertBefore(holder, submit);
        } else {
          form.appendChild(holder);
        }
      }
      // Render after DOM settles so the holder has a real width (prevents widget from rendering at 0px and overflowing)
      setTimeout(function(){ renderCaptchaInto(holder); }, 0);
    }

    // Expose to forms that defer rendering (multistep)
    window.ucRenderRecaptcha = renderCaptchaInto;

    function ensureHoneypot(form){
      if(form.querySelector('input[name="bot-field"]')) return;
      var hp = document.createElement('input');
      hp.type = 'text'; hp.name = 'bot-field'; hp.tabIndex = -1; hp.autocomplete = 'off';
      hp.style.cssText = 'position:absolute;left:-9999px;opacity:0;width:1px;height:1px;';
      form.appendChild(hp);
    }

    function getStatusEl(form){
      var s = form.querySelector('.uc-form-status');
      if(s) return s;
      s = document.createElement('div');
      s.className = 'uc-form-status';
      s.style.cssText = 'margin-top:14px;font:500 13px/1.5 system-ui;display:none;';
      form.appendChild(s);
      return s;
    }

    function setStatus(form, kind, text){
      var s = getStatusEl(form);
      var color = kind === 'ok' ? '#1a6e3a' : kind === 'err' ? '#a8321a' : '#7a6a4a';
      var bg    = kind === 'ok' ? '#e8f5ec' : kind === 'err' ? '#fbe9e3' : '#f6efe1';
      s.style.display = 'block';
      s.style.background = bg;
      s.style.color = color;
      s.style.padding = '10px 14px';
      s.style.borderRadius = '8px';
      s.textContent = text;
    }

    function redirectToThankYou(form){
      var name = (form.querySelector('[name="name"], [name="first-name"], [name="firstName"]') || {}).value || '';
      var firstName = (name.split(/\s+/)[0] || '').trim();
      var formName = form.dataset.ucForm || form.getAttribute('name') || '';
      var qs = new URLSearchParams();
      if(firstName) qs.set('name', firstName);
      if(formName)  qs.set('form', formName);
      var url = '/thank-you/' + (qs.toString() ? '?' + qs.toString() : '');
      window.location.href = url;
    }

    function localLangFilter(payload){
      var keys = ['name','first-name','firstName','email','message','notes','details','project','company'];
      for(var i=0;i<keys.length;i++){
        var v = payload[keys[i]];
        if(v && BLOCKED_LANG_RE.test(v)) return true;
      }
      return false;
    }

    function attach(form){
      if(form.dataset.ucBound) return;
      form.dataset.ucBound = '1';
      ensureHoneypot(form);
      ensureRecaptcha(form);
      // strip old netlify attrs so they don't conflict
      form.removeAttribute('data-netlify');
      form.removeAttribute('netlify');
      form.removeAttribute('netlify-honeypot');
      form.setAttribute('novalidate','');

      form.addEventListener('submit', function(e){
        e.preventDefault();
        var submit = form.querySelector('button[type="submit"], input[type="submit"]');
        var origLabel = submit ? submit.innerHTML : '';

        // collect payload
        var fd = new FormData(form);
        var payload = {};
        fd.forEach(function(v,k){ payload[k] = String(v); });

        // local language pre-check (silent reject)
        if(localLangFilter(payload)){
          redirectToThankYou(form);
          return;
        }

        // recaptcha token
        var token = '';
        try { if(window.grecaptcha){ token = window.grecaptcha.getResponse(); } } catch(_){}
        if(!token){
          setStatus(form, 'err', 'Please confirm you are not a robot.');
          return;
        }
        payload['g-recaptcha-response'] = token;
        payload['form-name'] = form.dataset.ucForm || form.getAttribute('name') || 'unknown';
        payload['page-url'] = location.href;

        if(submit){ submit.disabled = true; submit.innerHTML = 'Sending...'; }
        setStatus(form, 'info', 'Sending your message...');

        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        }).then(function(r){ return r.json().catch(function(){return {ok:false,error:'bad_response'};}); })
        .then(function(j){
          if(j && j.ok){
            redirectToThankYou(form);
          } else {
            var msg = 'Something went wrong. Please try again or email hello@upcomingbrand.com.';
            if(j && j.error === 'recaptcha_failed') msg = 'Captcha failed. Please tick the box again.';
            if(j && j.error === 'rate_limit')      msg = 'Too many submissions. Try again in an hour.';
            setStatus(form, 'err', msg);
            if(submit){ submit.disabled = false; submit.innerHTML = origLabel; }
            try { if(window.grecaptcha) window.grecaptcha.reset(); } catch(_){}
          }
        }).catch(function(){
          setStatus(form, 'err', 'Network error. Please try again.');
          if(submit){ submit.disabled = false; submit.innerHTML = origLabel; }
        });
      });
    }

    function scan(){
      document.querySelectorAll('form[data-uc-form]').forEach(attach);
    }

    if(document.readyState === 'loading'){
      document.addEventListener('DOMContentLoaded', scan);
    } else {
      scan();
    }
    // late-render forms (e.g. inserted by other scripts)
    var mo = new MutationObserver(scan);
    mo.observe(document.documentElement, { childList: true, subtree: true });
  })();
  </script>
</body>
</html>
