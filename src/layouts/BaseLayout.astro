---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
}

const {
  title = "WordPress Web Design Services Maryland | Upcoming Brand",
  description = "WordPress web design services in Maryland. Fixed-scope builds, 6-10 week delivery, 90+ PageSpeed. Baltimore, Annapolis, Frederick. Book a 45-min discovery call.",
  ogImage = "https://upcomingbrand.com/og-image.jpg",
  ogImageAlt = "Upcoming Brand — WordPress Web Design Maryland",
  canonicalUrl = "https://upcomingbrand.com/",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FBF8F2" />

  <!-- Primary Meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Upcoming Brand" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!-- Favicon — all devices -->
  <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
  <link rel="shortcut icon" type="image/jpeg" href="/favicon.jpg" />
  <link rel="apple-touch-icon" href="/favicon.jpg" />
  <meta name="msapplication-TileImage" content="/favicon.jpg" />
  <meta name="msapplication-TileColor" content="#0F1419" />

  <!-- reCAPTCHA v2 (I'm not a robot) -->
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,500&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Schema.org Root: Organization + WebSite (referenced by @id on every page) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://upcomingbrand.com/#organization",
        "name": "Upcoming Brand",
        "alternateName": "Upcoming Brand WordPress Web Design",
        "url": "https://upcomingbrand.com/",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://upcomingbrand.com/#logo",
          "url": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "contentUrl": "https://upcomingbrand.com/02-footer-logo-dark-edited.png",
          "width": 200,
          "height": 52,
          "caption": "Upcoming Brand"
        },
        "image": { "@id": "https://upcomingbrand.com/#logo" },
        "description": "WordPress web design studio based in Maryland. Fixed-scope builds, 90+ PageSpeed, 6-10 week delivery serving Baltimore, Annapolis, Frederick, and the DMV metro.",
        "foundingDate": "2024",
        "areaServed": {
          "@type": "State",
          "name": "Maryland",
          "sameAs": "https://en.wikipedia.org/wiki/Maryland"
        },
        "knowsAbout": [
          "WordPress web design",
          "WooCommerce development",
          "WordPress SEO",
          "Core Web Vitals optimization",
          "LocalBusiness schema",
          "WordPress care plans",
          "WordPress migration",
          "WordPress security"
        ],
        "slogan": "WordPress web design Maryland businesses trust for real Google rankings.",
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "MD",
          "addressCountry": "US"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "availableLanguage": "English",
          "areaServed": "US"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://upcomingbrand.com/#website",
        "url": "https://upcomingbrand.com/",
        "name": "Upcoming Brand",
        "description": "WordPress web design services Maryland - fixed-scope, 90+ PageSpeed, 6-10 week delivery.",
        "publisher": { "@id": "https://upcomingbrand.com/#organization" },
        "inLanguage": "en-US",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://upcomingbrand.com/?s={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  })} />
  <slot name="head" />
</head>
<body>
  <slot />

  <!-- Universal form handler: intercepts every <form data-uc-form="..." method="POST" novalidate> on the site -->
  <script is:inline>
  (function(){
    var SITE_KEY = '6LewrNcsAAAAAHUrAokdU5EqgK46ycH4JyFdNxI8';
    var ENDPOINT = '/api/contact';
    var BLOCKED_LANG_RE = /[Ѐ-ӿԀ-ԯ぀-ヿ㐀-䶿一-鿿가-힯豈-﫿]/;

    function ensureRecaptcha(form){
      var holder = form.querySelector('.uc-recaptcha');
      if(!holder){
        holder = document.createElement('div');
        holder.className = 'uc-recaptcha g-recaptcha';
        holder.setAttribute('data-sitekey', SITE_KEY);
        holder.style.margin = '14px 0 4px';
        var submit = form.querySelector('button[type="submit"], input[type="submit"]');
        if(submit && submit.parentNode){
          submit.parentNode.insertBefore(holder, submit);
        } else {
          form.appendChild(holder);
        }
      } else if(!holder.classList.contains('g-recaptcha')){
        holder.classList.add('g-recaptcha');
        holder.setAttribute('data-sitekey', SITE_KEY);
      }
    }

    function ensureHoneypot(form){
      if(form.querySelector('input[name="bot-field"]')) return;
      var hp = document.createElement('input');
      hp.type = 'text'; hp.name = 'bot-field'; hp.tabIndex = -1; hp.autocomplete = 'off';
      hp.style.cssText = 'position:absolute;left:-9999px;opacity:0;width:1px;height:1px;';
      form.appendChild(hp);
    }

    function getStatusEl(form){
      var s = form.querySelector('.uc-form-status');
      if(s) return s;
      s = document.createElement('div');
      s.className = 'uc-form-status';
      s.style.cssText = 'margin-top:14px;font:500 13px/1.5 system-ui;display:none;';
      form.appendChild(s);
      return s;
    }

    function setStatus(form, kind, text){
      var s = getStatusEl(form);
      var color = kind === 'ok' ? '#1a6e3a' : kind === 'err' ? '#a8321a' : '#7a6a4a';
      var bg    = kind === 'ok' ? '#e8f5ec' : kind === 'err' ? '#fbe9e3' : '#f6efe1';
      s.style.display = 'block';
      s.style.background = bg;
      s.style.color = color;
      s.style.padding = '10px 14px';
      s.style.borderRadius = '8px';
      s.textContent = text;
    }

    function redirectToThankYou(form){
      var name = (form.querySelector('[name="name"], [name="first-name"], [name="firstName"]') || {}).value || '';
      var firstName = (name.split(/\s+/)[0] || '').trim();
      var formName = form.dataset.ucForm || form.getAttribute('name') || '';
      var qs = new URLSearchParams();
      if(firstName) qs.set('name', firstName);
      if(formName)  qs.set('form', formName);
      var url = '/thank-you/' + (qs.toString() ? '?' + qs.toString() : '');
      window.location.href = url;
    }

    function localLangFilter(payload){
      var keys = ['name','first-name','firstName','email','message','notes','details','project','company'];
      for(var i=0;i<keys.length;i++){
        var v = payload[keys[i]];
        if(v && BLOCKED_LANG_RE.test(v)) return true;
      }
      return false;
    }

    function attach(form){
      if(form.dataset.ucBound) return;
      form.dataset.ucBound = '1';
      ensureHoneypot(form);
      ensureRecaptcha(form);
      // strip old netlify attrs so they don't conflict
      form.removeAttribute('data-netlify');
      form.removeAttribute('netlify');
      form.removeAttribute('netlify-honeypot');
      form.setAttribute('novalidate','');

      form.addEventListener('submit', function(e){
        e.preventDefault();
        var submit = form.querySelector('button[type="submit"], input[type="submit"]');
        var origLabel = submit ? submit.innerHTML : '';

        // collect payload
        var fd = new FormData(form);
        var payload = {};
        fd.forEach(function(v,k){ payload[k] = String(v); });

        // local language pre-check (silent reject)
        if(localLangFilter(payload)){
          redirectToThankYou(form);
          return;
        }

        // recaptcha token
        var token = '';
        try { if(window.grecaptcha){ token = window.grecaptcha.getResponse(); } } catch(_){}
        if(!token){
          setStatus(form, 'err', 'Please confirm you are not a robot.');
          return;
        }
        payload['g-recaptcha-response'] = token;
        payload['form-name'] = form.dataset.ucForm || form.getAttribute('name') || 'unknown';
        payload['page-url'] = location.href;

        if(submit){ submit.disabled = true; submit.innerHTML = 'Sending...'; }
        setStatus(form, 'info', 'Sending your message...');

        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        }).then(function(r){ return r.json().catch(function(){return {ok:false,error:'bad_response'};}); })
        .then(function(j){
          if(j && j.ok){
            redirectToThankYou(form);
          } else {
            var msg = 'Something went wrong. Please try again or email hello@upcomingbrand.com.';
            if(j && j.error === 'recaptcha_failed') msg = 'Captcha failed. Please tick the box again.';
            if(j && j.error === 'rate_limit')      msg = 'Too many submissions. Try again in an hour.';
            setStatus(form, 'err', msg);
            if(submit){ submit.disabled = false; submit.innerHTML = origLabel; }
            try { if(window.grecaptcha) window.grecaptcha.reset(); } catch(_){}
          }
        }).catch(function(){
          setStatus(form, 'err', 'Network error. Please try again.');
          if(submit){ submit.disabled = false; submit.innerHTML = origLabel; }
        });
      });
    }

    function scan(){
      document.querySelectorAll('form[data-uc-form]').forEach(attach);
    }

    if(document.readyState === 'loading'){
      document.addEventListener('DOMContentLoaded', scan);
    } else {
      scan();
    }
    // late-render forms (e.g. inserted by other scripts)
    var mo = new MutationObserver(scan);
    mo.observe(document.documentElement, { childList: true, subtree: true });
  })();
  </script>
</body>
</html>
